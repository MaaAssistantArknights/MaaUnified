<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Controls.VerticalSpinNumberBox"
             x:Name="Root">
  <UserControl.Styles>
    <Style Selector="Border.spin-root">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.Background}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.Border}" />
      <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
      <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.SettingsInput}" />
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="MinWidth" Value="72" />
      <Setter Property="Height" Value="{DynamicResource MAA.App.Size.InputHeight}" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="UseLayoutRounding" Value="True" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.16" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.16" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Border.spin-root:pointerover">
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.BorderHover}" />
    </Style>

    <Style Selector="Border.spin-root.focused">
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.BorderFocus}" />
    </Style>

    <Style Selector="Border.spin-root:disabled">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.BackgroundDisabled}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Action.DisabledBorder}" />
    </Style>

    <Style Selector="Border.spin-stepper">
      <Setter Property="Width" Value="{DynamicResource MAA.App.Size.SettingsSpinStepperWidth}" />
      <Setter Property="MinWidth" Value="{DynamicResource MAA.App.Size.SettingsSpinStepperWidth}" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.SettingsInputGroupAction}" />
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="HorizontalAlignment" Value="Right" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="Margin" Value="0,1,1,1" />
      <Setter Property="Opacity" Value="0" />
      <Setter Property="IsHitTestVisible" Value="False" />
      <Setter Property="UseLayoutRounding" Value="True" />
      <Setter Property="RenderTransform">
        <TranslateTransform X="10" />
      </Setter>
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.18" />
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Border.spin-root:pointerover Border.spin-stepper, Border.spin-root.focused Border.spin-stepper">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="IsHitTestVisible" Value="True" />
      <Setter Property="RenderTransform">
        <TranslateTransform X="0" />
      </Setter>
    </Style>

    <Style Selector="Border.spin-stepper:disabled">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Opacity" Value="0" />
      <Setter Property="IsHitTestVisible" Value="False" />
      <Setter Property="RenderTransform">
        <TranslateTransform X="10" />
      </Setter>
    </Style>

    <Style Selector="Border.spin-root:disabled Border.spin-stepper">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Opacity" Value="0" />
      <Setter Property="IsHitTestVisible" Value="False" />
      <Setter Property="RenderTransform">
        <TranslateTransform X="10" />
      </Setter>
    </Style>

    <Style Selector="NumericUpDown.spin-editor">
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.Foreground}" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="MinWidth" Value="34" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>

    <Style Selector="NumericUpDown.spin-editor:disabled">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ForegroundDisabled}" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="NumericUpDown.spin-editor /template/ TextBox#PART_TextBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="14,0,30,0" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.Foreground}" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="TextAlignment" Value="Left" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="FocusAdorner" Value="{x:Null}" />
    </Style>

    <Style Selector="NumericUpDown.spin-editor /template/ TextBox#PART_TextBox:pointerover">
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style Selector="NumericUpDown.spin-editor /template/ TextBox#PART_TextBox:focus">
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style Selector="NumericUpDown.spin-editor /template/ TextBox#PART_TextBox:focus-visible">
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style Selector="NumericUpDown.spin-editor /template/ Border">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style Selector="NumericUpDown.spin-editor:disabled /template/ TextBox#PART_TextBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ForegroundDisabled}" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Button.spin-button">
      <Setter Property="Margin" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.Chevron}" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Focusable" Value="False" />
      <Setter Property="UseLayoutRounding" Value="True" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12" />
        </Transitions>
      </Setter>
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              Margin="{TemplateBinding Padding}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>

    <Style Selector="Button.spin-button /template/ Border">
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style Selector="Button.spin-button-top">
      <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.SettingsSpinButtonTop}" />
    </Style>

    <Style Selector="Button.spin-button-bottom">
      <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.SettingsSpinButtonBottom}" />
    </Style>

    <Style Selector="Button.spin-button:pointerover">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.GroupActionBackgroundHover}" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronHover}" />
    </Style>

    <Style Selector="Button.spin-button:pressed">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.GroupActionBackgroundPressed}" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronHover}" />
    </Style>

    <Style Selector="Button.spin-button:disabled">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ForegroundDisabled}" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="Grid.spin-button-icon">
      <Setter Property="Width" Value="10" />
      <Setter Property="Height" Value="10" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style Selector="Border.spin-button-glyph">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.Chevron}" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="UseLayoutRounding" Value="True" />
    </Style>

    <Style Selector="Border.spin-button-glyph-horizontal">
      <Setter Property="Width" Value="6.8" />
      <Setter Property="Height" Value="1.35" />
    </Style>

    <Style Selector="Border.spin-button-glyph-vertical">
      <Setter Property="Width" Value="1.35" />
      <Setter Property="Height" Value="6.8" />
    </Style>

    <Style Selector="Button.spin-button:pointerover Border.spin-button-glyph">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronHover}" />
    </Style>

    <Style Selector="Button.spin-button:pressed Border.spin-button-glyph">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronHover}" />
    </Style>

    <Style Selector="Button.spin-button:disabled Border.spin-button-glyph">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronDisabled}" />
    </Style>

  </UserControl.Styles>

  <Border x:Name="SpinRootBorder"
          Classes="spin-root"
          IsEnabled="{Binding IsEnabled, ElementName=Root}">
    <Grid x:Name="SpinLayoutGrid"
          ClipToBounds="True">
      <NumericUpDown x:Name="SpinEditor"
                     Classes="spin-editor"
                     Margin="0"
                     ClipValueToMinMax="True"
                     ParsingNumberStyle="Integer"
                     ShowButtonSpinner="False"
                     FormatString="{Binding FormatString, ElementName=Root}"
                     Minimum="{Binding Minimum, ElementName=Root}"
                     Maximum="{Binding Maximum, ElementName=Root}"
                     Increment="{Binding Increment, ElementName=Root}"
                     Value="{Binding Value, ElementName=Root, Mode=TwoWay}"
                     IsEnabled="{Binding IsEnabled, ElementName=Root}" />

      <Border x:Name="SpinButtonsPanel"
              Classes="spin-stepper"
              IsEnabled="{Binding IsEnabled, ElementName=Root}">
        <Grid RowDefinitions="*,*">
          <Button x:Name="SpinIncreaseButton"
                  Grid.Row="0"
                  Classes="spin-button spin-button-top"
                  IsEnabled="{Binding IsEnabled, ElementName=Root}"
                  Click="OnIncreaseClick">
            <Grid Classes="spin-button-icon spin-button-icon-plus"
                  IsHitTestVisible="False">
              <Border Classes="spin-button-glyph spin-button-glyph-horizontal" />
              <Border Classes="spin-button-glyph spin-button-glyph-vertical" />
            </Grid>
          </Button>
          <Button x:Name="SpinDecreaseButton"
                  Grid.Row="1"
                  Classes="spin-button spin-button-bottom"
                  IsEnabled="{Binding IsEnabled, ElementName=Root}"
                  Click="OnDecreaseClick">
            <Grid Classes="spin-button-icon spin-button-icon-minus"
                  IsHitTestVisible="False">
              <Border Classes="spin-button-glyph spin-button-glyph-horizontal" />
            </Grid>
          </Button>
        </Grid>
      </Border>
    </Grid>
  </Border>
</UserControl>
