<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             x:Class="MAAUnified.App.Controls.VerticalSpinNumberBox"
             x:Name="Root">
  <UserControl.Styles>
    <Style Selector="Border.spin-root">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Input.Background}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Input.Border}" />
      <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
      <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.Input}" />
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="MinWidth" Value="72" />
      <Setter Property="Height" Value="{DynamicResource MAA.App.Size.InputHeight}" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="UseLayoutRounding" Value="True" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.16" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.16" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Border.spin-root:pointerover">
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Input.BorderHover}" />
    </Style>

    <Style Selector="Border.spin-root.focused">
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Input.BorderFocus}" />
    </Style>

    <Style Selector="Border.spin-root:disabled">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Input.BackgroundDisabled}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Action.DisabledBorder}" />
    </Style>

    <Style Selector="controls|VerticalSpinNumberBox.settings-spin Border.spin-root">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.Background}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.Border}" />
      <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.SettingsInput}" />
    </Style>

    <Style Selector="controls|VerticalSpinNumberBox.settings-spin Border.spin-root:pointerover">
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.BorderHover}" />
    </Style>

    <Style Selector="controls|VerticalSpinNumberBox.settings-spin Border.spin-root.focused">
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.BorderFocus}" />
    </Style>

    <Style Selector="controls|VerticalSpinNumberBox.settings-spin Border.spin-root:disabled">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.BackgroundDisabled}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Action.DisabledBorder}" />
    </Style>

    <Style Selector="Border.spin-stepper">
      <Setter Property="Width" Value="32" />
      <Setter Property="MinWidth" Value="32" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="HorizontalAlignment" Value="Right" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="Margin" Value="0,1,1,1" />
      <Setter Property="Opacity" Value="0" />
      <Setter Property="IsHitTestVisible" Value="False" />
      <Setter Property="UseLayoutRounding" Value="True" />
      <Setter Property="RenderTransform">
        <TranslateTransform X="10" />
      </Setter>
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.18" />
          <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.18" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="Border.spin-root:pointerover Border.spin-stepper, Border.spin-root.focused Border.spin-stepper">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="IsHitTestVisible" Value="True" />
      <Setter Property="RenderTransform">
        <TranslateTransform X="0" />
      </Setter>
    </Style>

    <Style Selector="Border.spin-stepper:disabled">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Opacity" Value="0" />
      <Setter Property="IsHitTestVisible" Value="False" />
    </Style>

    <Style Selector="controls|VerticalSpinNumberBox.settings-spin Border.spin-stepper">
      <Setter Property="Width" Value="{DynamicResource MAA.App.Size.SettingsSpinStepperWidth}" />
      <Setter Property="MinWidth" Value="{DynamicResource MAA.App.Size.SettingsSpinStepperWidth}" />
    </Style>

    <Style Selector="controls|VerticalSpinNumberBox.settings-spin Border.spin-root:pointerover Border.spin-stepper, controls|VerticalSpinNumberBox.settings-spin Border.spin-root.focused Border.spin-stepper">
      <Setter Property="Opacity" Value="1" />
      <Setter Property="IsHitTestVisible" Value="True" />
      <Setter Property="RenderTransform">
        <TranslateTransform X="0" />
      </Setter>
    </Style>

    <Style Selector="controls|VerticalSpinNumberBox.settings-spin Border.spin-stepper:disabled">
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style Selector="NumericUpDown.spin-editor">
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="MinWidth" Value="34" />
    </Style>

    <Style Selector="NumericUpDown.spin-editor:disabled">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Input.ForegroundDisabled}" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="NumericUpDown.spin-editor /template/ TextBox#PART_TextBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="12,0,34,0" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="TextAlignment" Value="Left" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style Selector="controls|VerticalSpinNumberBox.settings-spin NumericUpDown.spin-editor">
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.Foreground}" />
    </Style>

    <Style Selector="controls|VerticalSpinNumberBox.settings-spin NumericUpDown.spin-editor /template/ TextBox#PART_TextBox">
      <Setter Property="Padding" Value="14,0,26,0" />
    </Style>

    <Style Selector="NumericUpDown.spin-editor /template/ TextBox#PART_TextBox:pointerover">
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style Selector="NumericUpDown.spin-editor /template/ TextBox#PART_TextBox:focus">
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style Selector="NumericUpDown.spin-editor /template/ TextBox#PART_TextBox:focus-visible">
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>

    <Style Selector="NumericUpDown.spin-editor /template/ Border">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="NumericUpDown.spin-editor:disabled /template/ TextBox#PART_TextBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Input.ForegroundDisabled}" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="controls|VerticalSpinNumberBox.settings-spin NumericUpDown.spin-editor:disabled">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ForegroundDisabled}" />
    </Style>

    <Style Selector="controls|VerticalSpinNumberBox.settings-spin NumericUpDown.spin-editor:disabled /template/ TextBox#PART_TextBox">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ForegroundDisabled}" />
    </Style>

    <Style Selector="Button.spin-button">
      <Setter Property="Margin" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Secondary}" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="VerticalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Focusable" Value="False" />
      <Setter Property="UseLayoutRounding" Value="True" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12" />
        </Transitions>
      </Setter>
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              Margin="{TemplateBinding Padding}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>

    <Style Selector="controls|VerticalSpinNumberBox.settings-spin Button.spin-button">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.Background}" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.Chevron}" />
    </Style>

    <Style Selector="Button.spin-button /template/ Border">
      <Setter Property="BorderThickness" Value="0" />
    </Style>

    <Style Selector="Button.spin-button-top">
      <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="Button.spin-button-bottom">
      <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="Button.spin-button:pointerover">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Action.SecondaryBackgroundHover}" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
    </Style>

    <Style Selector="Button.spin-button:pressed">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Action.SubtleBackgroundPressed}" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
    </Style>

    <Style Selector="Button.spin-button:disabled">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Input.ForegroundDisabled}" />
      <Setter Property="Opacity" Value="1" />
    </Style>

    <Style Selector="controls|VerticalSpinNumberBox.settings-spin Button.spin-button:pointerover">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Action.SubtleBackgroundHover}" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronHover}" />
    </Style>

    <Style Selector="controls|VerticalSpinNumberBox.settings-spin Button.spin-button:pressed">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Action.SubtleBackgroundPressed}" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronHover}" />
    </Style>

    <Style Selector="controls|VerticalSpinNumberBox.settings-spin Button.spin-button:disabled">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ForegroundDisabled}" />
    </Style>

    <Style Selector="Path.spin-button-icon">
      <Setter Property="Width" Value="10" />
      <Setter Property="Height" Value="10" />
      <Setter Property="Stroke" Value="{DynamicResource MAA.Brush.App.Text.Secondary}" />
      <Setter Property="StrokeThickness" Value="1.35" />
      <Setter Property="StrokeLineCap" Value="Round" />
      <Setter Property="Stretch" Value="None" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="controls|VerticalSpinNumberBox.settings-spin Path.spin-button-icon">
      <Setter Property="Stroke" Value="{DynamicResource MAA.Brush.App.SettingsInput.Chevron}" />
    </Style>

    <Style Selector="Button.spin-button:pointerover Path.spin-button-icon">
      <Setter Property="Stroke" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
    </Style>

    <Style Selector="Button.spin-button:pressed Path.spin-button-icon">
      <Setter Property="Stroke" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
    </Style>

    <Style Selector="Button.spin-button:disabled Path.spin-button-icon">
      <Setter Property="Stroke" Value="{DynamicResource MAA.Brush.App.Input.ForegroundDisabled}" />
    </Style>

    <Style Selector="controls|VerticalSpinNumberBox.settings-spin Button.spin-button:pointerover Path.spin-button-icon">
      <Setter Property="Stroke" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronHover}" />
    </Style>

    <Style Selector="controls|VerticalSpinNumberBox.settings-spin Button.spin-button:pressed Path.spin-button-icon">
      <Setter Property="Stroke" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronHover}" />
    </Style>

    <Style Selector="controls|VerticalSpinNumberBox.settings-spin Button.spin-button:disabled Path.spin-button-icon">
      <Setter Property="Stroke" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronDisabled}" />
    </Style>
  </UserControl.Styles>

  <Border x:Name="SpinRootBorder"
          Classes="spin-root"
          IsEnabled="{Binding IsEnabled, ElementName=Root}">
    <Grid x:Name="SpinLayoutGrid">
      <NumericUpDown x:Name="SpinEditor"
                     Classes="spin-editor"
                     Margin="0"
                     ClipValueToMinMax="True"
                     ParsingNumberStyle="Integer"
                     ShowButtonSpinner="False"
                     FormatString="{Binding FormatString, ElementName=Root}"
                     Minimum="{Binding Minimum, ElementName=Root}"
                     Maximum="{Binding Maximum, ElementName=Root}"
                     Increment="{Binding Increment, ElementName=Root}"
                     Value="{Binding Value, ElementName=Root, Mode=TwoWay}"
                     IsEnabled="{Binding IsEnabled, ElementName=Root}" />

      <Border x:Name="SpinButtonsPanel"
              Classes="spin-stepper"
              IsEnabled="{Binding IsEnabled, ElementName=Root}">
        <Grid RowDefinitions="*,*">
          <Button x:Name="SpinIncreaseButton"
                  Grid.Row="0"
                  Classes="spin-button spin-button-top"
                  IsEnabled="{Binding IsEnabled, ElementName=Root}"
                  Click="OnIncreaseClick">
            <Path Classes="spin-button-icon spin-button-icon-plus"
                  Data="M 5 1.6 L 5 8.4 M 1.6 5 L 8.4 5" />
          </Button>
          <Button x:Name="SpinDecreaseButton"
                  Grid.Row="1"
                  Classes="spin-button spin-button-bottom"
                  IsEnabled="{Binding IsEnabled, ElementName=Root}"
                  Click="OnDecreaseClick">
            <Path Classes="spin-button-icon spin-button-icon-minus"
                  Data="M 1.6 5 L 8.4 5" />
          </Button>
        </Grid>
      </Border>
    </Grid>
  </Border>
</UserControl>
