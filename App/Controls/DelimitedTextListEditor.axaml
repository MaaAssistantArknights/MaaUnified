<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             x:Class="MAAUnified.App.Controls.DelimitedTextListEditor"
             x:Name="Root">
  <Grid RowDefinitions="Auto,Auto,*">
    <TextBlock Text="{Binding HeaderText, ElementName=Root}"
               Margin="0,0,0,8" />

    <controls:AppTextInput Grid.Row="1"
                           Classes="app-delimited-text-editor-input"
                           Margin="0,0,0,8"
                           Text="{Binding Text, ElementName=Root, Mode=TwoWay}"
                           Watermark="{Binding Watermark, ElementName=Root}"
                           IsReadOnly="{Binding IsReadOnly, ElementName=Root}" />

    <Border Grid.Row="2"
            Classes="app-floating-card app-delimited-text-list-editor-preview">
      <ListBox ItemsSource="{Binding ParsedItems, ElementName=Root}" />
    </Border>
  </Grid>
</UserControl>
