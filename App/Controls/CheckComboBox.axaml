<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Controls.CheckComboBox"
             x:Name="Root">
  <UserControl.Styles>
    <Style Selector="Border.combo-shell">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Input.Background}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Input.Border}" />
      <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
      <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.Input}" />
      <Setter Property="MinHeight" Value="{DynamicResource MAA.App.Size.InputHeight}" />
      <Setter Property="Padding" Value="{DynamicResource MAA.App.Thickness.InputPadding}" />
    </Style>
    <Style Selector="Border.combo-shell:pointerover">
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Input.BorderHover}" />
    </Style>
    <Style Selector="Border.combo-shell.open">
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Input.BorderFocus}" />
    </Style>
    <Style Selector="Border.combo-shell.focused">
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Input.BorderFocus}" />
    </Style>
    <Style Selector="Border.combo-shell.compact-shell">
      <Setter Property="Padding" Value="14,0,8,0" />
    </Style>
    <Style Selector="Border.combo-shell.settings-input">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.Background}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.Border}" />
      <Setter Property="Height" Value="{DynamicResource MAA.App.Size.InputHeight}" />
      <Setter Property="MinHeight" Value="{DynamicResource MAA.App.Size.InputHeight}" />
      <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.SettingsInput}" />
      <Setter Property="Padding" Value="{DynamicResource MAA.App.Thickness.SettingsInputShellPadding}" />
    </Style>
    <Style Selector="Border.combo-shell.settings-input:pointerover">
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.BorderHover}" />
    </Style>
    <Style Selector="Border.combo-shell.settings-input.open">
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.BorderFocus}" />
    </Style>
    <Style Selector="Border.combo-shell.settings-input.focused">
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.BorderFocus}" />
    </Style>
    <Style Selector="Border.combo-shell.settings-input.compact-shell">
      <Setter Property="Padding" Value="{DynamicResource MAA.App.Thickness.SettingsInputShellPadding}" />
    </Style>
    <Style Selector="Border.combo-shell:disabled">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Input.BackgroundDisabled}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Action.DisabledBorder}" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Border.combo-shell.settings-input:disabled">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.BackgroundDisabled}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Action.DisabledBorder}" />
    </Style>
    <Style Selector="TextBlock.combo-display">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.combo-display.settings-input">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.Foreground}" />
    </Style>
    <Style Selector="TextBlock.combo-display.empty">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Secondary}" />
    </Style>
    <Style Selector="TextBlock.combo-display.empty.settings-input">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ItemForeground}" />
    </Style>
    <Style Selector="TextBlock.combo-display:disabled">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Input.ForegroundDisabled}" />
    </Style>
    <Style Selector="TextBlock.combo-display.settings-input:disabled">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ForegroundDisabled}" />
    </Style>
    <Style Selector="TextBox.combo-editor">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="MinHeight" Value="{DynamicResource MAA.App.Size.InputHeight}" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBox.combo-editor:disabled">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Input.ForegroundDisabled}" />
    </Style>
    <Style Selector="TextBox.combo-editor.settings-input">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.Foreground}" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Padding" Value="0,1,0,0" />
    </Style>
    <Style Selector="TextBox.combo-editor.settings-input:disabled">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ForegroundDisabled}" />
    </Style>
    <Style Selector="Popup.combo-popup.settings-input">
      <Setter Property="WindowManagerAddShadowHint" Value="False" />
    </Style>
    <Style Selector="Border.combo-dropdown-panel">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.Surface.SectionStrong}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Input.PopupBorder}" />
      <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
      <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.Card}" />
      <Setter Property="Padding" Value="{DynamicResource MAA.App.Thickness.InputPopupPadding}" />
    </Style>
    <Style Selector="Border.combo-dropdown-panel.settings-input">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.PopupBackground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.PopupBorder}" />
      <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.SettingsInputPopup}" />
      <Setter Property="Padding" Value="{DynamicResource MAA.App.Thickness.SettingsInputPopupPadding}" />
    </Style>
    <Style Selector="Button.combo-arrow">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Secondary}" />
      <Setter Property="MinWidth" Value="36" />
      <Setter Property="MinHeight" Value="{DynamicResource MAA.App.Size.InputHeight}" />
      <Setter Property="Margin" Value="8,0,0,0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Focusable" Value="False" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              Margin="{TemplateBinding Padding}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.combo-arrow:pointerover">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Action.SubtleBackgroundHover}" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
    </Style>
    <Style Selector="Button.combo-arrow:pressed">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Action.SubtleBackgroundPressed}" />
    </Style>
    <Style Selector="Button.combo-arrow:disabled">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Input.ForegroundDisabled}" />
    </Style>
    <Style Selector="Button.combo-arrow.compact-chevron">
      <Setter Property="Width" Value="28" />
      <Setter Property="MinWidth" Value="28" />
      <Setter Property="Height" Value="28" />
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="Margin" Value="4,0,0,0" />
      <Setter Property="CornerRadius" Value="10" />
    </Style>
    <Style Selector="Button.combo-arrow.settings-input">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.Chevron}" />
      <Setter Property="Width" Value="{DynamicResource MAA.App.Size.SettingsInputDropDownButtonWidth}" />
      <Setter Property="MinWidth" Value="{DynamicResource MAA.App.Size.SettingsInputDropDownButtonWidth}" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="Button.combo-arrow.settings-input:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronHover}" />
    </Style>
    <Style Selector="Button.combo-arrow.settings-input:pressed">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.combo-arrow.settings-input:disabled">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronDisabled}" />
    </Style>
    <Style Selector="Button.combo-arrow.settings-input.compact-chevron">
      <Setter Property="Width" Value="{DynamicResource MAA.App.Size.SettingsInputDropDownButtonWidth}" />
      <Setter Property="MinWidth" Value="{DynamicResource MAA.App.Size.SettingsInputDropDownButtonWidth}" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>
    <Style Selector="Path.combo-arrow-icon.compact-chevron">
      <Setter Property="Width" Value="10" />
      <Setter Property="Height" Value="6" />
      <Setter Property="StrokeThickness" Value="1.6" />
    </Style>
    <Style Selector="Path.combo-arrow-icon">
      <Setter Property="Width" Value="14" />
      <Setter Property="Height" Value="14" />
      <Setter Property="StrokeThickness" Value="1.75" />
      <Setter Property="Stretch" Value="Fill" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>
    <Style Selector="Path.combo-arrow-icon.settings-input">
      <Setter Property="Width" Value="{DynamicResource MAA.App.Size.SettingsInputChevronWidth}" />
      <Setter Property="Height" Value="{DynamicResource MAA.App.Size.SettingsInputChevronHeight}" />
      <Setter Property="StrokeThickness" Value="1.4" />
      <Setter Property="Stroke" Value="{DynamicResource MAA.Brush.App.SettingsInput.Chevron}" />
    </Style>
    <Style Selector="Path.combo-arrow-icon.settings-input.compact-chevron">
      <Setter Property="Width" Value="{DynamicResource MAA.App.Size.SettingsInputChevronWidth}" />
      <Setter Property="Height" Value="{DynamicResource MAA.App.Size.SettingsInputChevronHeight}" />
      <Setter Property="StrokeThickness" Value="1.4" />
      <Setter Property="Stroke" Value="{DynamicResource MAA.Brush.App.SettingsInput.Chevron}" />
    </Style>
    <Style Selector="Button.combo-arrow:pointerover Path.combo-arrow-icon">
      <Setter Property="Stroke" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
    </Style>
    <Style Selector="Button.combo-arrow:pressed Path.combo-arrow-icon">
      <Setter Property="Stroke" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
    </Style>
    <Style Selector="Button.combo-arrow:disabled Path.combo-arrow-icon">
      <Setter Property="Stroke" Value="{DynamicResource MAA.Brush.App.Input.ForegroundDisabled}" />
    </Style>
    <Style Selector="Button.combo-arrow.settings-input:pointerover Path.combo-arrow-icon.settings-input">
      <Setter Property="Stroke" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronHover}" />
    </Style>
    <Style Selector="Button.combo-arrow.settings-input:pressed Path.combo-arrow-icon.settings-input">
      <Setter Property="Stroke" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronHover}" />
    </Style>
    <Style Selector="Button.combo-arrow.settings-input:disabled Path.combo-arrow-icon.settings-input">
      <Setter Property="Stroke" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronDisabled}" />
    </Style>
    <Style Selector="TreeView.combo-dropdown">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="TreeView.combo-dropdown TreeViewItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="{DynamicResource MAA.App.Thickness.InputItemPadding}" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Secondary}" />
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="CornerRadius" Value="12" />
    </Style>
    <Style Selector="TreeView.combo-dropdown TreeViewItem:pointerover">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Input.ItemBackgroundHover}" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
    </Style>
    <Style Selector="TreeView.combo-dropdown TreeViewItem:selected">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Input.ItemBackgroundSelected}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Input.ItemBorderSelected}" />
      <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Input.ItemForegroundSelected}" />
    </Style>
    <Style Selector="TreeView.combo-dropdown TreeViewItem:selected:pointerover">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Input.ItemBackgroundSelected}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Input.ItemBorderSelected}" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Input.ItemForegroundSelected}" />
    </Style>
    <Style Selector="TreeView.combo-dropdown.settings-input TreeViewItem">
      <Setter Property="Padding" Value="{DynamicResource MAA.App.Thickness.SettingsInputItemPadding}" />
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.SettingsInput}" />
    </Style>
    <Style Selector="TreeView.combo-dropdown.settings-input TreeViewItem:pointerover">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.ItemBackgroundHover}" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ItemForegroundHover}" />
    </Style>
    <Style Selector="TreeView.combo-dropdown.settings-input TreeViewItem:selected">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.ItemBackgroundSelected}" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ItemForegroundSelected}" />
    </Style>
    <Style Selector="TreeView.combo-dropdown.settings-input TreeViewItem:selected:pointerover">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.ItemBackgroundSelected}" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ItemForegroundSelected}" />
    </Style>
    <Style Selector="TreeView.combo-dropdown ToggleButton">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Secondary}" />
      <Setter Property="MinWidth" Value="24" />
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="Padding" Value="4" />
      <Setter Property="CornerRadius" Value="10" />
    </Style>
    <Style Selector="TreeView.combo-dropdown ToggleButton:pointerover">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Action.SubtleBackgroundHover}" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
    </Style>
    <Style Selector="TreeView.combo-dropdown ToggleButton:pressed">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Action.SubtleBackgroundPressed}" />
    </Style>
    <Style Selector="TreeView.combo-dropdown.settings-input ToggleButton:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
    </Style>
    <Style Selector="TreeView.combo-dropdown.settings-input ToggleButton:pressed">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBox.combo-dropdown">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBox.combo-dropdown ListBoxItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="{DynamicResource MAA.App.Thickness.InputItemPadding}" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Secondary}" />
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="ListBox.combo-dropdown ListBoxItem:pointerover">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Input.ItemBackgroundHover}" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
    </Style>
    <Style Selector="ListBox.combo-dropdown ListBoxItem:selected">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Input.ItemBackgroundSelected}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Input.ItemBorderSelected}" />
      <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Input.ItemForegroundSelected}" />
    </Style>
    <Style Selector="ListBox.combo-dropdown ListBoxItem:selected:pointerover">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Input.ItemBackgroundSelected}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Input.ItemBorderSelected}" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Input.ItemForegroundSelected}" />
    </Style>
    <Style Selector="ListBox.combo-dropdown.settings-input ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.SettingsInput}" />
    </Style>
    <Style Selector="ListBox.combo-dropdown.settings-input ListBoxItem /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="{DynamicResource MAA.App.Thickness.SettingsInputItemPadding}" />
      <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.SettingsInput}" />
      <Setter Property="TextBlock.Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ItemForeground}" />
    </Style>
    <Style Selector="ListBox.combo-dropdown.settings-input ListBoxItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.ItemBackgroundHover}" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="TextBlock.Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ItemForegroundHover}" />
    </Style>
    <Style Selector="ListBox.combo-dropdown.settings-input ListBoxItem:selected">
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBox.combo-dropdown.settings-input ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.ItemBackgroundSelected}" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="TextBlock.Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ItemForegroundSelected}" />
    </Style>
    <Style Selector="ListBox.combo-dropdown.settings-input ListBoxItem:selected:pointerover">
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBox.combo-dropdown.settings-input ListBoxItem:selected:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.ItemBackgroundSelected}" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="TextBlock.Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ItemForegroundSelected}" />
    </Style>
    <Style Selector="ListBox.combo-dropdown.settings-input ListBoxItem:disabled /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="TextBlock.Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ItemForegroundDisabled}" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="ContentPresenter.combo-custom-content">
      <Setter Property="Margin" Value="2" />
    </Style>
    <Style Selector="ContentPresenter.combo-custom-content.settings-input">
      <Setter Property="Margin" Value="0" />
    </Style>
  </UserControl.Styles>

  <Grid>
    <Border x:Name="ShellBorder"
            Classes="combo-shell"
            Classes.compact-shell="{Binding UseCompactChevron, ElementName=Root}"
            PointerPressed="OnShellPointerPressed">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock x:Name="HeaderTextBlock"
                   Classes="combo-display"
                   TextTrimming="CharacterEllipsis" />
        <TextBox x:Name="EditableTextBox"
                 Classes="combo-editor"
                 Text="{Binding Text, ElementName=Root, Mode=TwoWay}"
                 Watermark="{Binding Watermark, ElementName=Root}"
                 GotFocus="OnEditableTextBoxGotFocus"
                 LostFocus="OnEditableTextBoxLostFocus"
                 KeyDown="OnEditableTextBoxKeyDown" />
        <Button Grid.Column="1"
                x:Name="ToggleButton"
                Classes="combo-arrow"
                Classes.compact-chevron="{Binding UseCompactChevron, ElementName=Root}"
                Click="OnToggleButtonClick">
          <Path x:Name="ToggleIconPath"
                Classes="combo-arrow-icon"
                Classes.compact-chevron="{Binding UseCompactChevron, ElementName=Root}"
                Data="M 1 1 L 5 5 L 9 1"
                Stroke="{DynamicResource MAA.Brush.Text.Secondary}"
                StrokeLineCap="Round" />
        </Button>
      </Grid>
    </Border>

    <Popup x:Name="DropDownPopup"
           Classes="combo-popup"
           IsOpen="{Binding IsDropDownOpen, ElementName=Root, Mode=TwoWay}"
           Placement="BottomEdgeAlignedLeft"
           VerticalOffset="4"
           IsLightDismissEnabled="True"
           Closed="OnPopupClosed">
      <Border x:Name="DropDownPanelBorder"
              Classes="combo-dropdown-panel"
              MinWidth="{Binding Bounds.Width, ElementName=ShellBorder}"
              HorizontalAlignment="Left">
        <ScrollViewer MaxHeight="{Binding MaxDropDownHeight, ElementName=Root}"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <Grid>
            <TreeView x:Name="TreeModeView"
                      Classes="combo-dropdown"
                      ItemsSource="{Binding ItemsSource, ElementName=Root}"
                      SelectionChanged="OnTreeViewSelectionChanged">
              <TreeView.ItemTemplate>
                <TreeDataTemplate ItemsSource="{Binding Children}">
                  <TextBlock Margin="4,2"
                             Text="{Binding}" />
                </TreeDataTemplate>
              </TreeView.ItemTemplate>
            </TreeView>

            <ListBox x:Name="FlatListBox"
                     Classes="combo-dropdown"
                     ItemsSource="{Binding ItemsSource, ElementName=Root}"
                     SelectedItem="{Binding SelectedItem, ElementName=Root, Mode=TwoWay}"
                     SelectionChanged="OnFlatListBoxSelectionChanged"
                     ItemTemplate="{Binding ItemTemplate, ElementName=Root}" />

            <ContentPresenter x:Name="CustomContentPresenter"
                              Classes="combo-custom-content"
                              Content="{Binding DropDownContent, ElementName=Root}" />
          </Grid>
        </ScrollViewer>
      </Border>
    </Popup>
  </Grid>
</UserControl>
