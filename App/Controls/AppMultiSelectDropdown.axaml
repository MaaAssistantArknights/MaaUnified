<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Controls.AppMultiSelectDropdown"
             x:Name="Root">
  <UserControl.Styles>
    <Style Selector="Border.app-dropdown-shell">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.Background}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.Border}" />
      <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
      <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.SettingsInput}" />
      <Setter Property="Height" Value="{DynamicResource MAA.App.Size.InputHeight}" />
      <Setter Property="MinHeight" Value="{DynamicResource MAA.App.Size.InputHeight}" />
      <Setter Property="Padding" Value="{DynamicResource MAA.App.Thickness.SettingsInputShellPadding}" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.11" />
          <BrushTransition Property="BorderBrush" Duration="0:0:0.11" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="Border.app-dropdown-shell:pointerover">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.BackgroundHover}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.BorderHover}" />
    </Style>
    <Style Selector="Border.app-dropdown-shell.open">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.BackgroundHover}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.BorderFocus}" />
      <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
      <Setter Property="BoxShadow" Value="{DynamicResource MAA.App.BoxShadow.InputFocus}" />
    </Style>
    <Style Selector="Border.app-dropdown-shell:disabled">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.BackgroundDisabled}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.BorderDisabled}" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="TextBlock.app-dropdown-display">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.Foreground}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.app-dropdown-display.empty">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ItemForeground}" />
    </Style>
    <Style Selector="TextBlock.app-dropdown-display:disabled">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ForegroundDisabled}" />
    </Style>
    <Style Selector="Button.app-dropdown-arrow">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.Chevron}" />
      <Setter Property="Width" Value="{DynamicResource MAA.App.Size.SettingsInputDropDownButtonWidth}" />
      <Setter Property="MinWidth" Value="{DynamicResource MAA.App.Size.SettingsInputDropDownButtonWidth}" />
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
      <Setter Property="Focusable" Value="False" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <ControlTemplate>
          <Border Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                  CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                              Content="{TemplateBinding Content}"
                              ContentTemplate="{TemplateBinding ContentTemplate}"
                              Margin="{TemplateBinding Padding}" />
          </Border>
        </ControlTemplate>
      </Setter>
    </Style>
    <Style Selector="Button.app-dropdown-arrow:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronHover}" />
    </Style>
    <Style Selector="Button.app-dropdown-arrow:pressed">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="Button.app-dropdown-arrow:disabled">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronDisabled}" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="Path.app-dropdown-arrow-icon">
      <Setter Property="Width" Value="{DynamicResource MAA.App.Size.SettingsInputChevronWidth}" />
      <Setter Property="Height" Value="{DynamicResource MAA.App.Size.SettingsInputChevronHeight}" />
      <Setter Property="StrokeThickness" Value="1.4" />
      <Setter Property="Stroke" Value="{DynamicResource MAA.Brush.App.SettingsInput.Chevron}" />
      <Setter Property="Stretch" Value="Fill" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.app-dropdown-arrow:pointerover Path.app-dropdown-arrow-icon">
      <Setter Property="Stroke" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronHover}" />
    </Style>
    <Style Selector="Button.app-dropdown-arrow:disabled Path.app-dropdown-arrow-icon">
      <Setter Property="Stroke" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronDisabled}" />
    </Style>
    <Style Selector="Popup.app-dropdown-popup">
      <Setter Property="WindowManagerAddShadowHint" Value="False" />
    </Style>
    <Style Selector="Border.app-dropdown-panel">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.PopupBackground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.PopupBorder}" />
      <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
      <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.SettingsInputPopup}" />
      <Setter Property="Padding" Value="{DynamicResource MAA.App.Thickness.SettingsInputPopupPadding}" />
    </Style>
    <Style Selector="Border.app-dropdown-panel ScrollViewer">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.PopupScrollViewerBackground}" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="ListBox.app-dropdown-list">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBox.app-dropdown-list ListBoxItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ItemForeground}" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.SettingsInput}" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Opacity" Value="1" />
    </Style>
    <Style Selector="ListBox.app-dropdown-list ListBoxItem /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="{DynamicResource MAA.App.Thickness.SettingsInputItemPadding}" />
      <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.SettingsInput}" />
      <Setter Property="TextBlock.Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ItemForeground}" />
    </Style>
    <Style Selector="ListBox.app-dropdown-list ListBoxItem:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.ItemBackgroundHover}" />
      <Setter Property="TextBlock.Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ItemForegroundHover}" />
    </Style>
  </UserControl.Styles>

  <Grid>
    <Border x:Name="ShellBorder"
            Classes="app-dropdown-shell"
            PointerPressed="OnShellPointerPressed">
      <Grid ColumnDefinitions="*,Auto">
        <TextBlock x:Name="HeaderTextBlock"
                   Classes="app-dropdown-display"
                   Text="{Binding HeaderText, ElementName=Root}"
                   TextTrimming="CharacterEllipsis" />
        <Button Grid.Column="1"
                Classes="app-dropdown-arrow"
                Click="OnToggleButtonClick">
          <Path Classes="app-dropdown-arrow-icon"
                Data="M 1 1 L 5 5 L 9 1"
                StrokeLineCap="Round" />
        </Button>
      </Grid>
    </Border>

    <Popup x:Name="DropDownPopup"
           Classes="app-dropdown-popup"
           IsOpen="{Binding IsDropDownOpen, ElementName=Root, Mode=TwoWay}"
           Placement="BottomEdgeAlignedLeft"
           VerticalOffset="4"
           IsLightDismissEnabled="True"
           Closed="OnPopupClosed">
      <Border Classes="app-dropdown-panel"
              MinWidth="{Binding Bounds.Width, ElementName=ShellBorder}"
              HorizontalAlignment="Left">
        <ScrollViewer MaxHeight="{Binding MaxDropDownHeight, ElementName=Root}"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <ContentPresenter Content="{Binding DropDownContent, ElementName=Root}" />
        </ScrollViewer>
      </Border>
    </Popup>
  </Grid>
</UserControl>
