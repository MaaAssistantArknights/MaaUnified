<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Controls.TooltipHint"
             x:Name="Root"
             HorizontalAlignment="Left"
             VerticalAlignment="Center"
             ClipToBounds="False"
             UseLayoutRounding="True"
             ToolTip.ShowDelay="500"
             ToolTip.BetweenShowDelay="-1"
             ToolTip.Placement="Top"
             ToolTip.VerticalOffset="6"
             PointerExited="OnGlyphPointerExited">
  <UserControl.Styles>
    <Style Selector="Border.tooltip-hint-glyph">
      <Setter Property="Width" Value="16" />
      <Setter Property="Height" Value="16" />
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Surface.Card}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Border.Card}" />
      <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>

    <Style Selector="Border.tooltip-hint-glyph:pointerover">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Action.SubtleBackgroundHover}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Text.Muted}" />
    </Style>

    <Style Selector="Border.tooltip-hint-glyph:disabled">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Action.DisabledBackground}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Action.DisabledBorder}" />
    </Style>

    <Style Selector="Border.tooltip-hint-card">
      <Setter Property="MaxWidth" Value="340" />
      <Setter Property="Padding" Value="12,9" />
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.Dialog.CardSurface}" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.Badge}" />
      <Setter Property="BoxShadow" Value="{DynamicResource MAA.App.BoxShadow.Card}" />
      <Setter Property="ClipToBounds" Value="False" />
      <Setter Property="Opacity" Value="1" />
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity"
                            Duration="0:0:0.12" />
        </Transitions>
      </Setter>
    </Style>

    <Style Selector="TextBlock.tooltip-hint-glyph-text">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Muted}" />
      <Setter Property="FontSize" Value="10.5" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
  </UserControl.Styles>

  <ToolTip.Tip>
    <Grid Margin="14"
          Background="Transparent"
          ClipToBounds="False">
      <Border Classes="tooltip-hint-card">
        <TextBlock Classes="long-wrap"
                   MaxWidth="316"
                   Foreground="{DynamicResource MAA.Brush.Text.Primary}"
                   Text="{Binding Tip, ElementName=Root}"
                   TextWrapping="Wrap" />
      </Border>
    </Grid>
  </ToolTip.Tip>

  <Border x:Name="GlyphHost"
          Classes="tooltip-hint-glyph"
          HorizontalAlignment="Left"
          VerticalAlignment="Center"
          Margin="{Binding GlyphMargin, ElementName=Root}">
    <TextBlock Classes="tooltip-hint-glyph-text"
               HorizontalAlignment="Center"
               VerticalAlignment="Center"
               Text="{Binding GlyphText, ElementName=Root}" />
  </Border>
</UserControl>
