<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             xmlns:settingsVm="clr-namespace:MAAUnified.App.ViewModels.Settings"
             x:Name="RootView"
             x:Class="MAAUnified.App.Features.Root.SettingsView">
  <Grid ColumnDefinitions="Auto,24,*">
    <Border Grid.Column="0"
            Classes="settings-rail">
      <controls:AppSelectionList ItemsSource="{Binding Sections}"
                                 SelectedItem="{Binding SelectedSection}"
                                 SelectionChanged="OnSectionSelectionChanged"
                                 Classes="settings-rail"
                                 VisualMode="Rail"
                                 Focusable="False">
        <controls:AppSelectionList.ItemTemplate>
          <DataTemplate DataType="settingsVm:SettingsSectionViewModel">
            <Border Classes="app-selection-list-item-shell settings-rail-item">
              <TextBlock Classes="settings-rail-item-text long-wrap"
                         Text="{Binding DisplayName}" />
            </Border>
          </DataTemplate>
        </controls:AppSelectionList.ItemTemplate>
      </controls:AppSelectionList>
    </Border>

    <Grid Grid.Column="2">
      <ScrollViewer x:Name="SectionScrollViewer"
                    Margin="0,4,0,0"
                    Classes="settings-content-scroll"
                    ScrollChanged="OnSectionScrollChanged">
        <StackPanel x:Name="SectionContentPanel"
                    Classes="settings-content-panel">
          <Border x:Name="SectionConfigurationManager"
                  Classes="settings-section-anchor" />
          <Border x:Name="SectionTimer"
                  Classes="settings-section-anchor" />
          <Border x:Name="SectionPerformance"
                  Classes="settings-section-anchor" />
          <Border x:Name="SectionGame"
                  Classes="settings-section-anchor" />
          <Border x:Name="SectionConnect"
                  Classes="settings-section-anchor" />
          <Border x:Name="SectionStart"
                  Classes="settings-section-anchor" />
          <Border x:Name="SectionRemoteControl"
                  Classes="settings-section-anchor" />
          <Border x:Name="SectionGui"
                  Classes="settings-section-anchor" />
          <Border x:Name="SectionBackground"
                  Classes="settings-section-anchor" />
          <Border x:Name="SectionExternalNotification"
                  Classes="settings-section-anchor" />
          <Border x:Name="SectionHotKey"
                  Classes="settings-section-anchor" />
          <Border x:Name="SectionAchievement"
                  Classes="settings-section-anchor" />
          <Border x:Name="SectionVersionUpdate"
                  Classes="settings-section-anchor" />
          <Border x:Name="SectionIssueReport"
                  Classes="settings-section-anchor" />
          <Border x:Name="SectionAbout"
                  Classes="settings-section-anchor" />
        </StackPanel>
      </ScrollViewer>
    </Grid>
  </Grid>
</UserControl>
