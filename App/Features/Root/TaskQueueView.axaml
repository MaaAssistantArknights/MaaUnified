<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             xmlns:taskViews="clr-namespace:MAAUnified.App.Features.TaskQueue"
             xmlns:taskVm="clr-namespace:MAAUnified.App.ViewModels.TaskQueue"
             x:Class="MAAUnified.App.Features.Root.TaskQueueView">
  <UserControl.DataTemplates>
    <DataTemplate DataType="taskVm:StartUpTaskModuleViewModel">
      <taskViews:StartUpTaskView />
    </DataTemplate>
    <DataTemplate DataType="taskVm:FightTaskModuleViewModel">
      <taskViews:FightSettingsView />
    </DataTemplate>
    <DataTemplate DataType="taskVm:RecruitTaskModuleViewModel">
      <taskViews:RecruitSettingsView />
    </DataTemplate>
    <DataTemplate DataType="taskVm:InfrastModuleViewModel">
      <taskViews:InfrastSettingsView />
    </DataTemplate>
    <DataTemplate DataType="taskVm:MallModuleViewModel">
      <taskViews:MallSettingsView />
    </DataTemplate>
    <DataTemplate DataType="taskVm:AwardModuleViewModel">
      <taskViews:AwardSettingsView />
    </DataTemplate>
    <DataTemplate DataType="taskVm:RoguelikeModuleViewModel">
      <taskViews:RoguelikeSettingsView />
    </DataTemplate>
    <DataTemplate DataType="taskVm:ReclamationModuleViewModel">
      <taskViews:ReclamationSettingsView />
    </DataTemplate>
    <DataTemplate DataType="taskVm:UserDataUpdateModuleViewModel">
      <taskViews:UserDataUpdateSettingsView />
    </DataTemplate>
    <DataTemplate DataType="taskVm:CustomModuleViewModel">
      <taskViews:CustomSettingsView />
    </DataTemplate>
    <DataTemplate DataType="taskVm:PostActionModuleViewModel">
      <taskViews:PostActionSettingsView />
    </DataTemplate>
  </UserControl.DataTemplates>
  <UserControl.Styles>
    <Style Selector="Button.wpf-button.overlay-toggle">
      <Setter Property="MinWidth" Value="112" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="12,0" />
    </Style>
    <Style Selector="Border.overlay-indicator">
      <Setter Property="Width" Value="10" />
      <Setter Property="Height" Value="10" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.Text.Secondary}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.overlay-indicator.mode-preview">
      <Setter Property="Background" Value="#D9A441" />
    </Style>
    <Style Selector="Border.overlay-indicator.mode-native">
      <Setter Property="Background" Value="#4FA86C" />
    </Style>
    <Style Selector="Border.overlay-indicator.mode-hidden">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.Text.Secondary}" />
    </Style>
  </UserControl.Styles>

  <Grid ColumnDefinitions="Auto,*,Auto">
    <Border Grid.Column="0"
            Width="{DynamicResource MAA.Size.TaskQueue.ListPanelWidth}"
            Classes="wpf-panel">
      <Grid RowDefinitions="Auto,*,Auto,Auto,Auto">
        <TextBlock Classes="section-title" Text="{Binding TaskListTitleText}" />

        <ListBox Grid.Row="1"
                 Classes="wpf-list-no-highlight"
                 Margin="{DynamicResource MAA.Thickness.MarginTopList}"
                 ItemsSource="{Binding Tasks}"
                 SelectedItem="{Binding SelectedTask}">
          <ListBox.ItemTemplate>
            <DataTemplate>
              <Border Classes="wpf-card wpf-card-compact task-row-card"
                      Classes.status-running="{Binding IsStatusRunning}"
                      Classes.status-success="{Binding IsStatusSuccess}"
                      Classes.status-error="{Binding IsStatusError}"
                      Classes.status-skipped="{Binding IsStatusSkipped}"
                      Classes.status-idle="{Binding IsStatusIdle}"
                      Tag="{Binding}"
                      DragDrop.AllowDrop="True"
                      DragDrop.DragOver="OnTaskRowDragOver"
                      DragDrop.Drop="OnTaskRowDrop"
                      PointerPressed="OnTaskRowPointerPressed"
                      PointerMoved="OnTaskRowPointerMoved"
                      ToolTip.Tip="{Binding ToolTipText}">
                <Border.ContextMenu>
                  <ContextMenu>
                    <MenuItem Header="{Binding TaskMenuRunOnceText}"
                              IsEnabled="{Binding CanEdit}"
                              CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              Click="OnTaskMenuRunOnceClick" />
                    <MenuItem Header="{Binding TaskMenuMoveUpText}"
                              IsEnabled="{Binding CanEdit}"
                              CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              Click="OnTaskMenuMoveUpClick" />
                    <MenuItem Header="{Binding TaskMenuMoveDownText}"
                              IsEnabled="{Binding CanEdit}"
                              CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              Click="OnTaskMenuMoveDownClick" />
                    <MenuItem Header="{Binding TaskMenuRenameText}"
                              IsEnabled="{Binding CanEdit}"
                              CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              Click="OnTaskMenuRenameClick" />
                    <MenuItem Header="{Binding TaskMenuDeleteText}"
                              IsEnabled="{Binding CanEdit}"
                              CommandParameter="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              Click="OnTaskMenuRemoveClick" />
                  </ContextMenu>
                </Border.ContextMenu>
                <Grid MinHeight="{DynamicResource MAA.Size.TaskQueue.RowHeight}"
                      ColumnDefinitions="Auto,*,Auto">
                  <CheckBox IsChecked="{Binding IsEnabled}"
                            VerticalAlignment="Center"
                            Margin="{DynamicResource MAA.Thickness.TaskQueue.CheckboxMargin}"
                            IsEnabled="{Binding DataContext.CanEdit, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                  <TextBlock Grid.Column="1"
                             Classes="long-ellipsis"
                             VerticalAlignment="Center"
                             Margin="{DynamicResource MAA.Thickness.MarginLeftSmall}"
                             Text="{Binding DisplayName}" />
                  <Button Grid.Column="2"
                          Classes="wpf-button task-row-gear"
                          Margin="{DynamicResource MAA.Thickness.MarginActionButtonLeft}"
                          Content="{Binding DataContext.TaskMenuIconText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          ToolTip.Tip="{Binding DataContext.TaskMenuTooltipText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          Click="OnTaskGearClick" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Row="2"
              Margin="{DynamicResource MAA.Thickness.MarginTopSection}"
              ColumnDefinitions="Auto,Auto,Auto"
              HorizontalAlignment="Center"
              IsEnabled="{Binding CanEdit}">
          <Button x:Name="AddTaskButton"
                  Grid.Column="0"
                  Classes="wpf-button compact icon-only queue-segment segment-left"
                  Content="{Binding AddTaskButtonText}"
                  Click="OnOpenButtonContextMenuClick">
            <Button.ContextMenu>
              <ContextMenu>
                <MenuItem Header="{Binding AddTaskMenuStartUpText}" Tag="StartUp" Click="OnAddTaskModuleClick" />
                <MenuItem Header="{Binding AddTaskMenuFightText}" Tag="Fight" Click="OnAddTaskModuleClick" />
                <MenuItem Header="{Binding AddTaskMenuInfrastText}" Tag="Infrast" Click="OnAddTaskModuleClick" />
                <MenuItem Header="{Binding AddTaskMenuRecruitText}" Tag="Recruit" Click="OnAddTaskModuleClick" />
                <MenuItem Header="{Binding AddTaskMenuMallText}" Tag="Mall" Click="OnAddTaskModuleClick" />
                <MenuItem Header="{Binding AddTaskMenuAwardText}" Tag="Award" Click="OnAddTaskModuleClick" />
                <MenuItem Header="{Binding AddTaskMenuRoguelikeText}" Tag="Roguelike" Click="OnAddTaskModuleClick" />
                <MenuItem Header="{Binding AddTaskMenuReclamationText}" Tag="Reclamation" Click="OnAddTaskModuleClick" />
                <MenuItem Header="{Binding AddTaskMenuUserDataUpdateText}" Tag="UserDataUpdate" Click="OnAddTaskModuleClick" />
                <MenuItem Header="{Binding AddTaskMenuCustomText}" Tag="Custom" Click="OnAddTaskModuleClick" />
              </ContextMenu>
            </Button.ContextMenu>
          </Button>
          <Button Grid.Column="1"
                  Classes="wpf-button compact queue-segment segment-middle"
                  Content="{Binding SelectAllButtonText}"
                  Click="OnSelectAllClick" />
          <Button Grid.Column="2"
                  Classes="wpf-button compact queue-segment segment-right"
                  Content="{Binding BatchActionText}"
                  Click="OnBatchActionClick">
            <Button.ContextMenu>
              <ContextMenu>
                <MenuItem Header="{Binding BatchToggleMenuText}"
                          IsVisible="{Binding ShowBatchModeToggle}"
                          Click="OnToggleBatchModeClick" />
              </ContextMenu>
            </Button.ContextMenu>
          </Button>
        </Grid>

        <Border Grid.Row="3"
                Classes="wpf-card"
                Margin="{DynamicResource MAA.Thickness.MarginTopSection}">
          <Grid ColumnDefinitions="*,Auto">
            <StackPanel HorizontalAlignment="Center"
                        Width="{DynamicResource MAA.Size.TaskQueue.PostActionSummaryWidth}"
                        Margin="{DynamicResource MAA.Thickness.TaskQueue.PostActionSummaryMargin}"
                        Spacing="{DynamicResource MAA.Spacing.Tight}">
              <TextBlock Classes="section-title long-ellipsis"
                         HorizontalAlignment="Center"
                         TextAlignment="Center"
                         Text="{Binding PostActionActionTitle}" />
              <Border Height="{DynamicResource MAA.Size.TaskQueue.PostActionDividerHeight}"
                      Margin="{DynamicResource MAA.Thickness.TaskQueue.PostActionDividerMargin}"
                      Background="{DynamicResource MAA.Brush.Border.Default}" />
              <TextBlock Width="{DynamicResource MAA.Size.TaskQueue.PostActionDescriptionWidth}"
                         HorizontalAlignment="Center"
                         TextAlignment="Center"
                         Classes="long-wrap subtle"
                         Text="{Binding PostActionActionDescription}" />
            </StackPanel>
            <Button Grid.Column="1"
                    Classes="wpf-button wpf-button-subtle compact icon-only"
                    Margin="{DynamicResource MAA.Thickness.MarginActionButtonLeft}"
                    Content="{Binding TaskMenuIconText}"
                    Click="OnOpenPostActionClick" />
          </Grid>
        </Border>

        <Grid Grid.Row="4"
              Margin="{DynamicResource MAA.Thickness.MarginTopSection}"
              RowDefinitions="Auto,Auto,Auto"
              HorizontalAlignment="Center">
          <Button Classes="wpf-button queue-run"
                  Grid.Row="0"
                  HorizontalAlignment="Center"
                  Content="{Binding RunButtonText}"
                  IsEnabled="{Binding CanToggleRun}"
                  Click="OnToggleRunClick" />
          <TextBlock Grid.Row="1"
                     Classes="long-wrap state-warning"
                     Width="{DynamicResource MAA.Size.TaskQueue.PostActionSummaryWidth}"
                     Margin="{DynamicResource MAA.Thickness.MarginTopList}"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"
                     Text="{Binding CoreInitializationMessage}"
                     IsVisible="{Binding HasCoreInitializationMessage}" />
          <TextBlock Grid.Row="2"
                     Classes="long-wrap state-warning"
                     Width="{DynamicResource MAA.Size.TaskQueue.PostActionSummaryWidth}"
                     Margin="{DynamicResource MAA.Thickness.MarginTopList}"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"
                     Text="{Binding StartPrecheckWarningMessage}"
                     IsVisible="{Binding HasStartPrecheckWarningMessage}" />
        </Grid>
      </Grid>
    </Border>

    <Grid Grid.Column="1"
          Margin="{DynamicResource MAA.Thickness.MarginRightSection}">
      <Grid RowDefinitions="Auto,*,Auto,Auto"
            Width="{DynamicResource MAA.Size.TaskQueue.ConfigPanelWidth}"
            HorizontalAlignment="Center">
        <TextBlock Classes="section-title" Text="{Binding TaskConfigTitleText}" />

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled">
          <StackPanel Spacing="{DynamicResource MAA.Spacing.Small}"
                      Margin="{DynamicResource MAA.Thickness.TaskQueue.ConfigContentMargin}">
            <TextBlock Classes="muted"
                       Text="{Binding NoTaskSelectedHint}"
                       IsVisible="{Binding ShowTaskConfigHint}" />
            <ContentControl x:Name="TaskSettingsHost"
                            IsEnabled="{Binding CanEdit}" />
          </StackPanel>
        </ScrollViewer>

        <Grid Grid.Row="2"
              IsVisible="{Binding ShowSettingsModeSwitch}"
              ColumnDefinitions="Auto,Auto"
              Margin="{DynamicResource MAA.Thickness.MarginTopSection}"
              HorizontalAlignment="Center">
          <Button Classes="wpf-button compact queue-mode segment-left"
                  Classes.mode-selected="{Binding IsGeneralSettingsSelected}"
                  Content="{Binding GeneralSettingsButtonText}"
                  Click="OnSelectGeneralSettingsClick" />
          <Button Grid.Column="1"
                  Classes="wpf-button compact queue-mode segment-right"
                  Classes.mode-selected="{Binding IsAdvancedSettingsSelected}"
                  Content="{Binding AdvancedSettingsButtonText}"
                  IsEnabled="{Binding CanUseAdvancedSettings}"
                  Click="OnSelectAdvancedSettingsClick" />
        </Grid>

        <ScrollViewer Grid.Row="3"
                      Margin="{DynamicResource MAA.Thickness.MarginTopSection}"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <StackPanel Spacing="{DynamicResource MAA.Spacing.Tight}">
            <Grid ColumnDefinitions="Auto,Auto,*">
              <TextBlock Classes="subtle" Text="{Binding DailyStageLabelText}" />
              <controls:TooltipHint Grid.Column="1"
                                    Tip="{Binding DailyStageTooltipText}" />
            </Grid>
            <TextBlock Classes="long-wrap subtle" Text="{Binding DailyStageHint}" />
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Grid>

    <Grid Grid.Column="2"
          Width="{DynamicResource MAA.Size.TaskQueue.LogPanelWidth}">
      <Grid RowDefinitions="Auto,Auto,*">
        <Grid ColumnDefinitions="*,Auto">
          <TextBlock Classes="section-title" Text="{Binding LogsTitleText}" />
          <Button Grid.Column="1"
                  Classes="wpf-button wpf-button-secondary overlay-toggle"
                  ToolTip.Tip="{Binding OverlayButtonToolTip}"
                  Click="OnToggleOverlayClick"
                  PointerPressed="OnOverlayButtonPointerPressed">
            <StackPanel Orientation="Horizontal"
                        Spacing="{DynamicResource MAA.Spacing.Tight}">
              <Border Classes="overlay-indicator"
                      Classes.mode-hidden="{Binding IsOverlayHiddenMode}"
                      Classes.mode-preview="{Binding IsOverlayPreviewMode}"
                      Classes.mode-native="{Binding IsOverlayNativeMode}" />
              <TextBlock Text="{Binding OverlayButtonText}" />
            </StackPanel>
          </Button>
        </Grid>

        <ContentControl Grid.Row="1"
                        IsVisible="{Binding HasDownloadLog}"
                        Content="{Binding DownloadLogEntry}"
                        Margin="{DynamicResource MAA.Thickness.MarginTopList}">
          <ContentControl.ContentTemplate>
            <DataTemplate>
              <Border Classes="wpf-card">
                <Grid ColumnDefinitions="Auto,*">
                  <TextBlock Classes="subtle"
                             VerticalAlignment="Top"
                             Text="{Binding Time}" />
                  <TextBlock Grid.Column="1"
                             Classes="long-wrap"
                             Margin="{DynamicResource MAA.Thickness.MarginActionButtonLeft}"
                             Text="{Binding Content}" />
                </Grid>
              </Border>
            </DataTemplate>
          </ContentControl.ContentTemplate>
        </ContentControl>

        <Grid Grid.Row="2"
              Margin="{DynamicResource MAA.Thickness.MarginTopSection}">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding LogCards}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Classes="wpf-card">
                    <Grid ColumnDefinitions="104,*">
                      <Grid RowDefinitions="Auto,Auto,Auto"
                            IsVisible="{Binding ShowThumbnail}">
                        <TextBlock Classes="subtle"
                                   Width="88"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Top"
                                   TextAlignment="Center"
                                   Text="{Binding StartTime}"
                                   TextWrapping="NoWrap"
                                   IsVisible="{Binding ShowStartTime}" />
                        <Image Grid.Row="1"
                               Width="72"
                               Margin="{DynamicResource MAA.Thickness.MarginTopSection}"
                               HorizontalAlignment="Center"
                               Source="{Binding Thumbnail}"
                               Stretch="Uniform"
                               IsVisible="{Binding ShowThumbnail}"
                               ToolTip.ShowDelay="200">
                          <ToolTip.Tip>
                            <Border Classes="wpf-card">
                              <Image MaxWidth="960"
                                     MaxHeight="540"
                                     Source="{Binding Thumbnail}"
                                     Stretch="Uniform" />
                            </Border>
                          </ToolTip.Tip>
                        </Image>
                        <TextBlock Grid.Row="2"
                                   Classes="subtle"
                                   Width="88"
                                   HorizontalAlignment="Center"
                                   Margin="{DynamicResource MAA.Thickness.MarginTopSection}"
                                   TextAlignment="Center"
                                   Text="{Binding EndTime}"
                                   TextWrapping="NoWrap"
                                   IsVisible="{Binding ShowEndTime}" />
                      </Grid>

                      <StackPanel HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  IsVisible="{Binding ShowTimeOnlyLayout}">
                        <TextBlock Classes="subtle"
                                   Width="88"
                                   HorizontalAlignment="Center"
                                   TextAlignment="Center"
                                   Text="{Binding StartTime}"
                                   TextWrapping="NoWrap"
                                   IsVisible="{Binding ShowStartTime}" />
                        <TextBlock Classes="subtle"
                                   Width="88"
                                   HorizontalAlignment="Center"
                                   Margin="{DynamicResource MAA.Thickness.MarginTopSection}"
                                   TextAlignment="Center"
                                   Text="{Binding EndTime}"
                                   TextWrapping="NoWrap"
                                   IsVisible="{Binding ShowEndTime}" />
                      </StackPanel>

                      <ItemsControl Grid.Column="1"
                                    ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <TextBlock Classes="long-wrap"
                                       Classes.state-error="{Binding IsError}"
                                       Classes.state-warning="{Binding IsWarning}"
                                       Classes.state-success="{Binding IsSuccess}"
                                       Margin="{DynamicResource MAA.Thickness.MarginTopSection}"
                                       Text="{Binding Content}" />
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>

        </Grid>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
