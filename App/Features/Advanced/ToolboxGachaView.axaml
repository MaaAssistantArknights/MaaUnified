<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Advanced.ToolboxGachaView">
  <UserControl.Styles>
    <Style Selector="StackPanel.toolbox-gacha-section">
      <Setter Property="Spacing" Value="14" />
    </Style>

    <Style Selector="StackPanel.toolbox-gacha-section-stack">
      <Setter Property="Spacing" Value="14" />
    </Style>

    <Style Selector="TextBlock.toolbox-gacha-summary">
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="TextAlignment" Value="Center" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Border.toolbox-gacha-preview-frame">
      <Setter Property="Background" Value="#10151D" />
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="MinHeight" Value="240" />
      <Setter Property="Padding" Value="16" />
    </Style>

    <Style Selector="Image.toolbox-gacha-preview-image">
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.toolbox-gacha-fps-badge">
      <Setter Property="HorizontalAlignment" Value="Left" />
      <Setter Property="VerticalAlignment" Value="Top" />
      <Setter Property="Margin" Value="16" />
    </Style>

    <Style Selector="TextBlock.toolbox-gacha-disclaimer-lead">
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="TextAlignment" Value="Center" />
      <Setter Property="FontSize" Value="26" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="TextBlock.toolbox-gacha-disclaimer-body">
      <Setter Property="MaxWidth" Value="{DynamicResource MAA.Size.Toolbox.WarningTextMaxWidth}" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.toolbox-gacha-disclaimer-action">
      <Setter Property="Width" Value="{DynamicResource MAA.Size.Toolbox.WarningButtonWidth}" />
      <Setter Property="Height" Value="{DynamicResource MAA.Size.Toolbox.WarningButtonHeight}" />
      <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style Selector="CheckBox.toolbox-gacha-disclaimer-toggle">
      <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style Selector="WrapPanel.toolbox-gacha-actions">
      <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.toolbox-gacha-action">
      <Setter Property="Width" Value="{DynamicResource MAA.Size.Toolbox.ActionButtonWidth}" />
      <Setter Property="Height" Value="{DynamicResource MAA.Size.Toolbox.ActionButtonHeight}" />
      <Setter Property="Margin" Value="{DynamicResource MAA.Thickness.Toolbox.ButtonWideMargin}" />
    </Style>
  </UserControl.Styles>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
    <Grid Margin="{DynamicResource MAA.Thickness.Toolbox.PageMarginFlat}"
          RowDefinitions="Auto,Auto,Auto,Auto">
      <StackPanel Grid.Row="0"
                  Classes="toolbox-gacha-section"
                  IsVisible="{Binding ShowGachaControls}">
        <TextBlock Classes="app-window-subtitle long-wrap toolbox-gacha-summary"
                   Text="{Binding GachaInfo}" />
      </StackPanel>

      <StackPanel Grid.Row="1"
                  Margin="0,14,0,0"
                  Classes="toolbox-gacha-section"
                  IsVisible="{Binding ShowGachaControls}">
        <Grid>
          <Border Classes="toolbox-gacha-preview-frame">
            <Image Classes="toolbox-gacha-preview-image"
                   Source="{Binding PeepImage}"
                   Stretch="Uniform"
                   MaxHeight="{DynamicResource MAA.Size.Toolbox.GachaPreviewMaxHeight}" />
          </Border>

          <Border Classes="app-badge toolbox-gacha-fps-badge"
                  IsVisible="{Binding ShowGachaPreview}">
            <TextBlock Classes="app-badge-text"
                       Text="{Binding PeepScreenFps, StringFormat='{}{0:F2} FPS'}" />
          </Border>
        </Grid>
      </StackPanel>

      <StackPanel Grid.Row="2"
                  Margin="0,14,0,0"
                  Classes="toolbox-gacha-section toolbox-gacha-section-stack"
                  IsVisible="{Binding GachaShowDisclaimer}">
        <TextBlock Classes="toolbox-gacha-disclaimer-lead"
                   Text="{Binding GachaDisclaimerLeadText}" />

        <TextBlock x:Name="GachaDisclaimerEmphasisText"
                   Margin="{DynamicResource MAA.Thickness.Toolbox.WarningEmphasisMargin}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   FontSize="{DynamicResource MAA.FontSize.Toolbox.WarningEmphasis}"
                   FontWeight="Bold"
                   Text="{Binding GachaDisclaimerEmphasisText}"
                   TextWrapping="Wrap">
          <TextBlock.Foreground>
            <LinearGradientBrush StartPoint="0%,50%"
                                 EndPoint="100%,50%"
                                 SpreadMethod="Repeat">
              <GradientStop Offset="0.00" Color="#F05A22" />
              <GradientStop Offset="0.50" Color="#E0A72B" />
              <GradientStop Offset="1.00" Color="#2C6E91" />
            </LinearGradientBrush>
          </TextBlock.Foreground>
        </TextBlock>

        <TextBlock Classes="app-body long-wrap toolbox-gacha-disclaimer-body"
                   Text="{Binding GachaDisclaimerBodyText}" />

        <Button Classes="app-button app-primary toolbox-gacha-disclaimer-action"
                Content="{Binding GachaDisclaimerAcknowledgeText}"
                Click="OnGachaAgreeDisclaimerClick" />

        <CheckBox Classes="app-checkbox toolbox-gacha-disclaimer-toggle"
                  Content="{Binding GachaDisclaimerNoMoreText}"
                  IsChecked="{Binding GachaShowDisclaimerNoMore}" />
      </StackPanel>

      <StackPanel Grid.Row="3"
                  Margin="0,14,0,0"
                  Classes="toolbox-gacha-section"
                  IsVisible="{Binding ShowGachaControls}">
        <WrapPanel Classes="toolbox-gacha-actions">
          <Button Classes="app-button app-secondary toolbox-gacha-action"
                  Content="{Binding GachaDrawOnceText}"
                  Click="OnGachaOnceClick" />
          <Button Classes="app-button app-secondary toolbox-gacha-action"
                  Content="{Binding GachaDrawTenText}"
                  Click="OnGachaTenTimesClick" />
          <Button Classes="app-button app-primary toolbox-gacha-action"
                  Content="{Binding PeepCommandText}"
                  Click="OnGachaPeepClick" />
        </WrapPanel>
      </StackPanel>
    </Grid>
  </ScrollViewer>
</UserControl>
