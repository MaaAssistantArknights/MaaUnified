<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             xmlns:taskVm="clr-namespace:MAAUnified.App.ViewModels.TaskQueue"
             x:Class="MAAUnified.App.Features.Advanced.CopilotView"
             DragDrop.AllowDrop="True"
             DragDrop.DragOver="OnCopilotDragOver"
             DragDrop.Drop="OnCopilotDrop">
  <UserControl.Styles>
    <Style Selector="Border.copilot-main-section">
      <Setter Property="Padding" Value="22" />
    </Style>
    <Style Selector="Border.copilot-side-section">
      <Setter Property="Padding" Value="18" />
    </Style>
    <Style Selector="Border.copilot-file-strip">
      <Setter Property="Padding" Value="14" />
    </Style>
    <Style Selector="Border.copilot-config-card">
      <Setter Property="Padding" Value="18" />
    </Style>
    <Style Selector="Border.copilot-list-panel">
      <Setter Property="Padding" Value="14" />
    </Style>
    <Style Selector="Border.copilot-status-card">
      <Setter Property="Padding" Value="14" />
    </Style>
    <Style Selector="Border.copilot-log-panel">
      <Setter Property="Padding" Value="12,12,8,12" />
    </Style>
    <Style Selector="Border.copilot-feedback-card">
      <Setter Property="Padding" Value="14" />
    </Style>
    <Style Selector="Border.copilot-popup-shell">
      <Setter Property="Padding" Value="16" />
    </Style>
    <Style Selector="Border.copilot-log-entry">
      <Setter Property="Margin" Value="0,0,0,10" />
      <Setter Property="Padding" Value="12,10" />
    </Style>
    <Style Selector="StackPanel.copilot-option-stack">
      <Setter Property="Spacing" Value="10" />
    </Style>
    <Style Selector="TextBlock.copilot-popup-title">
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
    <Style Selector="Button.app-button.copilot-icon">
      <Setter Property="MinWidth" Value="36" />
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="10,0" />
    </Style>
    <Style Selector="Button.app-button.copilot-list-action">
      <Setter Property="MinWidth" Value="44" />
      <Setter Property="Height" Value="34" />
      <Setter Property="Padding" Value="12,0" />
    </Style>
    <Style Selector="Button.app-button.copilot-link">
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Height" Value="NaN" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Accent}" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Button.app-button.copilot-link:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="Button.app-button.copilot-link:pressed">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ComboBox.copilot-combo">
      <Setter Property="Height" Value="{DynamicResource MAA.App.Size.InputHeight}" />
      <Setter Property="Padding" Value="{DynamicResource MAA.App.Thickness.InputPadding}" />
      <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.Input}" />
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Input.Background}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Input.Border}" />
      <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="ComboBox.copilot-combo:pointerover">
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Input.BorderHover}" />
    </Style>
    <Style Selector="ComboBox.copilot-combo:focus">
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Input.BorderFocus}" />
    </Style>
    <Style Selector="ComboBox.copilot-combo:focus-visible">
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Input.BorderFocus}" />
    </Style>
    <Style Selector="controls|ReorderableList ListBox">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="controls|ReorderableList ListBoxItem">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0,0,0,10" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Border.copilot-list-item-shell">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Surface.Card}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Border.Card}" />
      <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
      <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.Card}" />
      <Setter Property="Padding" Value="12" />
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background"
                           Duration="0:0:0.18" />
          <BrushTransition Property="BorderBrush"
                           Duration="0:0:0.18" />
        </Transitions>
      </Setter>
    </Style>
    <Style Selector="controls|ReorderableList ListBoxItem:pointerover Border.copilot-list-item-shell">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Surface.Section}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Border.Section}" />
    </Style>
    <Style Selector="controls|ReorderableList ListBoxItem:selected Border.copilot-list-item-shell">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Selection.Background}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Selection.Border}" />
    </Style>
    <Style Selector="controls|ReorderableList ListBoxItem:selected:pointerover Border.copilot-list-item-shell">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Selection.Background}" />
      <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Selection.Border}" />
    </Style>
  </UserControl.Styles>
  <UserControl.DataTemplates>
    <DataTemplate DataType="taskVm:TaskQueueLogEntryViewModel">
      <Border Classes="app-surface app-card copilot-log-entry">
        <Grid ColumnDefinitions="Auto,*">
          <TextBlock Classes="app-caption"
                     VerticalAlignment="Top"
                     IsVisible="{Binding HasTime}"
                     Text="{Binding Time}" />
          <TextBlock Grid.Column="1"
                     Classes="app-body long-wrap"
                     Classes.state-error="{Binding IsError}"
                     Classes.state-warning="{Binding IsWarning}"
                     Margin="{DynamicResource MAA.Thickness.MarginActionButtonLeft}"
                     Text="{Binding Content}" />
        </Grid>
      </Border>
    </DataTemplate>
  </UserControl.DataTemplates>

  <Grid ColumnDefinitions="*,20,Auto"
        Margin="{DynamicResource MAA.Thickness.CopilotRootMargin}">
    <Border Grid.Column="0"
            Classes="app-surface app-section copilot-main-section">
      <Grid RowDefinitions="Auto,*,Auto">
        <StackPanel Grid.Row="0"
                    HorizontalAlignment="Stretch"
                    Spacing="14">
          <TabStrip Classes="copilot-nav"
                    SelectedIndex="{Binding CopilotTabIndex}"
                    IsEnabled="{Binding CanEdit}">
            <TabStripItem Content="{Binding MainTabTitle}" />
            <TabStripItem Content="{Binding SecurityTabTitle}" />
            <TabStripItem Content="{Binding ParadoxTabTitle}" />
            <TabStripItem Content="{Binding OtherTabTitle}" />
          </TabStrip>

          <Border Classes="app-surface app-card copilot-file-strip">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
              <controls:CheckComboBox Grid.Column="0"
                                      Text="{Binding DisplayFilename}"
                                      Watermark="{Binding PathOrCodeWatermark}"
                                      IsEditable="True"
                                      IsEnabled="{Binding CanEdit}"
                                      IsTreeMode="True"
                                      ItemsSource="{Binding FileItems}"
                                      IsDropDownOpen="{Binding IsFilePopupOpen}"
                                      DragDrop.AllowDrop="True"
                                      DragDrop.DragOver="OnCopilotDragOver"
                                      DragDrop.Drop="OnCopilotDrop"
                                      EditorCommitted="OnFileSelectorEditorCommitted"
                                      SelectionCommitted="OnFileSelectorSelectionCommitted" />

              <Button Grid.Column="1"
                      Classes="app-button app-secondary copilot-icon"
                      Margin="8,0,0,0"
                      Content="{Binding FileButtonText}"
                      ToolTip.Tip="{Binding FileButtonTip}"
                      Click="OnSelectFileClick"
                      IsEnabled="{Binding CanEdit}" />
              <Button Grid.Column="2"
                      Classes="app-button app-secondary copilot-icon"
                      Margin="8,0,0,0"
                      Content="{Binding PasteButtonText}"
                      ToolTip.Tip="{Binding PasteButtonTip}"
                      Click="OnPasteClipboardClick"
                      IsEnabled="{Binding CanEdit}" />
              <Button Grid.Column="3"
                      Classes="app-button app-secondary copilot-icon"
                      Margin="8,0,0,0"
                      Content="{Binding PasteSetButtonText}"
                      ToolTip.Tip="{Binding PasteSetButtonTip}"
                      Click="OnPasteClipboardSetClick"
                      IsVisible="{Binding ShowClipboardSetButton}"
                      IsEnabled="{Binding CanEdit}" />
            </Grid>
          </Border>
        </StackPanel>

        <Grid Grid.Row="1"
              Margin="0,18,0,0"
              ColumnDefinitions="*,18,Auto">
          <Border Grid.Column="0"
                  Classes="app-surface app-card copilot-config-card">
            <Grid RowDefinitions="Auto,*">
              <Grid HorizontalAlignment="Center">
                <Button Width="120"
                        Height="46"
                        Classes="app-button app-primary"
                        Content="{Binding StartButtonText}"
                        Click="OnStartClick"
                        IsVisible="{Binding CanEdit}"
                        IsEnabled="{Binding CanStart}" />
                <Button Width="120"
                        Height="46"
                        Classes="app-button app-secondary"
                        Content="{Binding StopButtonText}"
                        Click="OnStopClick"
                        IsVisible="{Binding CanStop}"
                        IsEnabled="{Binding CanStop}" />
              </Grid>

              <StackPanel Grid.Row="1"
                          Margin="0,16,0,0"
                          HorizontalAlignment="Stretch"
                          Classes="copilot-option-stack"
                          IsEnabled="{Binding CanEdit}">
                <StackPanel Orientation="Horizontal"
                            IsVisible="{Binding ShowFormationGroup}">
                  <CheckBox Classes="app-checkbox"
                            Content="{Binding AutoSquadText}"
                            IsChecked="{Binding Form}" />
                  <controls:TooltipHint Margin="{DynamicResource MAA.Thickness.MarginLeftTooltip}"
                                        Tip="{Binding AutoSquadTip}" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            Margin="24,0,0,0"
                            IsVisible="{Binding ShowUseFormation}">
                  <CheckBox Classes="app-checkbox"
                            Content="{Binding UseFormationText}"
                            IsChecked="{Binding UseFormation}" />
                  <ComboBox Width="100"
                            Margin="8,0,0,0"
                            Classes="copilot-combo"
                            IsVisible="{Binding UseFormation}"
                            ItemsSource="{Binding FormationOptions}"
                            SelectedValueBinding="{Binding Value}"
                            SelectedValue="{Binding FormationIndex}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding DisplayName}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            IsVisible="{Binding ShowIgnoreRequirements}">
                  <CheckBox Classes="app-checkbox"
                            Content="{Binding IgnoreRequirementsText}"
                            IsChecked="{Binding IgnoreRequirements}" />
                  <controls:TooltipHint Margin="{DynamicResource MAA.Thickness.MarginLeftTooltip}"
                                        Tip="{Binding IgnoreRequirementsTip}" />
                </StackPanel>

                <StackPanel Classes="copilot-option-stack"
                            IsVisible="{Binding ShowSupportUnitUsage}">
                  <StackPanel Orientation="Horizontal">
                    <CheckBox Classes="app-checkbox"
                              Content="{Binding UseSupportUnitText}"
                              IsChecked="{Binding UseSupportUnitUsage}" />
                    <controls:TooltipHint Margin="{DynamicResource MAA.Thickness.MarginLeftTooltip}"
                                          Tip="{Binding UseSupportUnitTip}" />
                  </StackPanel>
                  <ComboBox Width="120"
                            Margin="24,0,0,0"
                            Classes="copilot-combo"
                            IsVisible="{Binding UseSupportUnitUsage}"
                            ItemsSource="{Binding SupportUnitUsageOptions}"
                            SelectedValueBinding="{Binding Value}"
                            SelectedValue="{Binding SupportUnitUsage}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate>
                        <TextBlock Text="{Binding DisplayName}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>

                <CheckBox Classes="app-checkbox"
                          Content="{Binding AddTrustText}"
                          IsChecked="{Binding AddTrust}"
                          IsVisible="{Binding ShowAddTrust}" />

                <StackPanel Orientation="Horizontal"
                            IsVisible="{Binding ShowAddUserAdditional}">
                  <CheckBox Classes="app-checkbox"
                            Content="{Binding AddUserAdditionalText}"
                            IsChecked="{Binding AddUserAdditional}" />
                  <Button x:Name="UserAdditionalButton"
                          Classes="app-button app-secondary copilot-icon"
                          Margin="8,0,0,0"
                          Content="{Binding EditButtonText}"
                          Click="OnOpenUserAdditionalPopupClick" />
                  <controls:TooltipHint Margin="{DynamicResource MAA.Thickness.MarginLeftTooltip}"
                                        Tip="{Binding UserAdditionalFormatTip}" />
                  <Popup IsOpen="{Binding IsUserAdditionalPopupOpen}"
                         Placement="Bottom"
                         PlacementTarget="{Binding ElementName=UserAdditionalButton}"
                         IsLightDismissEnabled="True">
                    <Border Width="520"
                            MaxHeight="420"
                            Classes="app-floating-card copilot-popup-shell">
                      <Grid RowDefinitions="Auto,*,Auto">
                        <TextBlock Classes="section-title copilot-popup-title"
                                   Text="{Binding UserAdditionalPopupTitle}" />
                        <ScrollViewer Grid.Row="1"
                                      Margin="0,10,0,12"
                                      MaxHeight="320">
                          <ItemsControl ItemsSource="{Binding UserAdditionalItems}">
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <Grid ColumnDefinitions="*,72,120,Auto"
                                      Margin="0,0,0,8">
                                  <TextBox Classes="app-input"
                                           Text="{Binding Name}"
                                           Watermark="{Binding DataContext.OperatorNameWatermark, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                                  <controls:VerticalSpinNumberBox Grid.Column="1"
                                                                  Margin="8,0,0,0"
                                                                  Minimum="0"
                                                                  Maximum="3"
                                                                  Value="{Binding Skill}" />
                                  <ComboBox Grid.Column="2"
                                            Margin="8,0,0,0"
                                            Classes="copilot-combo"
                                            ItemsSource="{Binding DataContext.ModuleOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            SelectedIndex="{Binding Module}">
                                    <ComboBox.ItemTemplate>
                                      <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}" />
                                      </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                  </ComboBox>
                                  <Button Grid.Column="3"
                                          Classes="app-button app-secondary copilot-list-action"
                                          Margin="8,0,0,0"
                                          Content="{Binding DataContext.DeleteButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          Tag="{Binding}"
                                          Click="OnRemoveUserAdditionalItemClick" />
                                </Grid>
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </ScrollViewer>
                        <Grid Grid.Row="2"
                              ColumnDefinitions="*,Auto,Auto">
                          <Button Classes="app-button app-secondary"
                                  Content="{Binding AddButtonText}"
                                  HorizontalAlignment="Left"
                                  Click="OnAddUserAdditionalItemClick" />
                          <Button Grid.Column="1"
                                  Classes="app-button app-primary"
                                  Margin="8,0,0,0"
                                  Content="{Binding ConfirmButtonText}"
                                  Click="OnSaveUserAdditionalClick" />
                          <Button Grid.Column="2"
                                  Classes="app-button app-secondary"
                                  Margin="8,0,0,0"
                                  Content="{Binding CancelButtonText}"
                                  Click="OnCancelUserAdditionalClick" />
                        </Grid>
                      </Grid>
                    </Border>
                  </Popup>
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            IsVisible="{Binding ShowUseCopilotList}">
                  <CheckBox Classes="app-checkbox"
                            Content="{Binding BattleListText}"
                            IsChecked="{Binding UseCopilotList}" />
                  <controls:TooltipHint Margin="{DynamicResource MAA.Thickness.MarginLeftTooltip}"
                                        Tip="{Binding BattleListTip}" />
                </StackPanel>

                <CheckBox Classes="app-checkbox"
                          Content="{Binding UseSanityPotionText}"
                          IsChecked="{Binding UseSanityPotion}"
                          IsVisible="{Binding ShowUseSanityPotion}" />

                <StackPanel Orientation="Horizontal"
                            IsVisible="{Binding ShowLoopSetting}">
                  <CheckBox Classes="app-checkbox"
                            Content="{Binding LoopTimesText}"
                            IsChecked="{Binding Loop}" />
                  <controls:VerticalSpinNumberBox Margin="8,0,0,0"
                                                  Minimum="1"
                                                  Maximum="9999"
                                                  Value="{Binding LoopTimes}" />
                </StackPanel>
              </StackPanel>
            </Grid>
          </Border>

          <Border Grid.Column="2"
                  Classes="app-surface app-card copilot-list-panel"
                  IsVisible="{Binding ShowCopilotListPanel}">
            <Grid RowDefinitions="*,Auto">
              <controls:ReorderableList HeaderText="{Binding BattleListText}"
                                        ItemsSource="{Binding Items}"
                                        SelectedItem="{Binding SelectedItem}"
                                        CanReorder="{Binding CanEdit}"
                                        Reordered="OnCopilotListReordered">
                <controls:ReorderableList.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="copilot-list-item-shell">
                      <Grid ColumnDefinitions="*,Auto,Auto">
                        <CheckBox Classes="app-checkbox"
                                  Content="{Binding DisplayName}"
                                  IsChecked="{Binding IsChecked}"
                                  ToolTip.Tip="{Binding ExecutionPathHint}" />
                        <Button Grid.Column="1"
                                Classes="app-button app-secondary copilot-list-action"
                                Margin="8,0,0,0"
                                Content="{Binding DataContext.LoadButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Tag="{Binding}"
                                Click="OnLoadListItemClick"
                                PointerPressed="OnLoadListItemPointerPressed" />
                        <Button Grid.Column="2"
                                Classes="app-button app-secondary copilot-list-action"
                                Margin="8,0,0,0"
                                Content="{Binding DataContext.DeleteButtonText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                Tag="{Binding}"
                                Click="OnDeleteListItemClick" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </controls:ReorderableList.ItemTemplate>
              </controls:ReorderableList>

              <Grid Grid.Row="1"
                    Margin="0,14,0,0"
                    ColumnDefinitions="Auto,*,Auto,Auto">
                <Button Grid.Column="0"
                        Classes="app-button app-secondary copilot-list-action"
                        Content="{Binding ImportBatchButtonText}"
                        ToolTip.Tip="{Binding ImportBatchButtonTip}"
                        Click="OnImportFilesClick"
                        IsEnabled="{Binding CanEdit}" />
                <TextBox Grid.Column="1"
                         Margin="8,0,0,0"
                         Classes="app-input"
                         Text="{Binding CopilotTaskName}"
                         Watermark="{Binding StageNameWatermark}"
                         ToolTip.Tip="{Binding StageNameTip}" />
                <Button Grid.Column="2"
                        Classes="app-button app-secondary copilot-list-action"
                        Margin="8,0,0,0"
                        Content="{Binding AddListButtonText}"
                        ToolTip.Tip="{Binding AddListButtonTip}"
                        Click="OnAddCurrentToListClick"
                        PointerPressed="OnAddCurrentToListPointerPressed"
                        IsEnabled="{Binding CanEdit}" />
                <Button Grid.Column="3"
                        Classes="app-button app-secondary copilot-list-action"
                        Margin="8,0,0,0"
                        Content="{Binding ClearButtonText}"
                        ToolTip.Tip="{Binding ClearButtonTip}"
                        Click="OnClearListClick"
                        PointerPressed="OnClearListPointerPressed"
                        IsEnabled="{Binding CanEdit}" />
              </Grid>
            </Grid>
          </Border>
        </Grid>

        <Button Grid.Row="2"
                Classes="app-button app-subtle copilot-link"
                Margin="0,12,0,0"
                Content="{Binding CopilotUrl}"
                Click="OnOpenCopilotUrlClick" />
      </Grid>
    </Border>

    <Border Grid.Column="2"
            Width="{DynamicResource MAA.Size.Copilot.SidePanelWidth}"
            Classes="app-surface app-section copilot-side-section">
      <Grid RowDefinitions="Auto,12,*,Auto,Auto">
        <Border Grid.Row="0"
                Classes="tool-status-panel copilot-status-card">
          <StackPanel Spacing="6">
            <TextBlock Classes="app-body"
                       Text="{Binding StatusMessage}" />
            <TextBlock Classes="state-error long-wrap"
                       Text="{Binding LastErrorMessage}" />
            <TextBlock Classes="app-caption"
                       Text="{Binding ListSelectionHint}" />
          </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Classes="app-surface app-card copilot-log-panel">
          <ScrollViewer HorizontalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding Logs}" />
          </ScrollViewer>
        </Border>

        <Border Grid.Row="3"
                Margin="0,12,0,0"
                Classes="app-surface app-card copilot-feedback-card"
                IsVisible="{Binding CouldLikeWebJson}">
          <Grid ColumnDefinitions="*,Auto,Auto">
            <TextBlock VerticalAlignment="Center"
                       Classes="app-body"
                       Text="{Binding RatingPromptText}"
                       TextWrapping="Wrap" />
            <Button Grid.Column="1"
                    Classes="app-button app-secondary"
                    Margin="8,0,0,0"
                    Content="{Binding LikeButtonText}"
                    Click="OnLikeLoadedClick" />
            <Button Grid.Column="2"
                    Classes="app-button app-secondary"
                    Margin="8,0,0,0"
                    Content="{Binding DislikeButtonText}"
                    Click="OnDislikeLoadedClick" />
          </Grid>
        </Border>

        <Button Grid.Row="4"
                Classes="app-button app-subtle copilot-link"
                Margin="0,12,0,0"
                Content="{Binding MapUrl}"
                Click="OnOpenMapUrlClick" />
      </Grid>
    </Border>
  </Grid>
</UserControl>
