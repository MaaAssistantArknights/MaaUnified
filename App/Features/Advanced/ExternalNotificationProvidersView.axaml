<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Advanced.ExternalNotificationProvidersView">
  <UserControl.Styles>
    <Style Selector="Border.external-notification-providers-section">
      <Setter Property="Margin" Value="0,14,0,0" />
      <Setter Property="Padding" Value="22" />
    </Style>

    <Style Selector="Border.external-notification-providers-card">
      <Setter Property="Padding" Value="16" />
    </Style>

    <Style Selector="StackPanel.external-notification-providers-stack">
      <Setter Property="Spacing" Value="16" />
    </Style>

    <Style Selector="TextBlock.external-notification-providers-card-title">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>
  </UserControl.Styles>

  <Grid Margin="4"
        RowDefinitions="Auto,Auto,Auto">
    <Border Classes="app-surface app-section"
            Padding="22">
      <StackPanel Classes="external-notification-providers-stack">
        <TextBlock Classes="app-window-title"
                   Text="{Binding Texts[Toolbox.Advanced.ExternalNotification.Title]}" />
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Classes="app-surface app-section external-notification-providers-section">
      <StackPanel Classes="external-notification-providers-stack">
        <TextBlock Classes="app-body external-notification-providers-card-title"
                   Text="{Binding Texts[Toolbox.Advanced.ExternalNotification.Title]}" />

        <Border Classes="app-surface app-card external-notification-providers-card">
          <StackPanel Classes="external-notification-providers-stack">
            <StackPanel Spacing="8">
              <TextBlock Classes="app-caption"
                         Text="{Binding Texts[Toolbox.Advanced.ExternalNotification.Provider]}" />
              <ComboBox Width="240"
                        ItemsSource="{Binding Providers}"
                        SelectedItem="{Binding SelectedProvider}" />
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Classes="app-caption"
                         Text="{Binding Texts[Toolbox.Advanced.ExternalNotification.Parameters]}" />
              <TextBox Classes="app-input app-input-block"
                       Text="{Binding ParametersText}"
                       Watermark="{Binding Texts[Toolbox.Advanced.ExternalNotification.Parameters.Watermark]}" />
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Classes="app-caption"
                         Text="{Binding Texts[Toolbox.Advanced.ExternalNotification.MessageTitle]}" />
              <TextBox Classes="app-input"
                       Width="320"
                       Text="{Binding Title}" />
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Classes="app-caption"
                         Text="{Binding Texts[Toolbox.Advanced.ExternalNotification.MessageBody]}" />
              <TextBox Classes="app-input app-input-block"
                       Text="{Binding Message}" />
            </StackPanel>
          </StackPanel>
        </Border>
      </StackPanel>
    </Border>

    <Border Grid.Row="2"
            Classes="app-surface app-section external-notification-providers-section">
      <StackPanel Classes="external-notification-providers-stack">
        <StackPanel Orientation="Horizontal"
                    Spacing="{DynamicResource MAA.Spacing.Small}">
          <Button Classes="app-button app-secondary"
                  Content="{Binding Texts[Toolbox.Advanced.ExternalNotification.RefreshProviders]}"
                  Click="OnRefreshProvidersClick" />
          <Button Classes="app-button app-secondary"
                  Content="{Binding Texts[Toolbox.Advanced.ExternalNotification.ValidateParameters]}"
                  Click="OnValidateClick" />
          <Button Classes="app-button app-primary"
                  Content="{Binding Texts[Toolbox.Advanced.ExternalNotification.SendTest]}"
                  Click="OnSendTestClick" />
        </StackPanel>

        <Border Classes="app-surface app-card external-notification-providers-card">
          <StackPanel Spacing="8">
            <TextBlock Classes="app-body long-wrap"
                       Text="{Binding StatusMessage}" />
            <TextBlock Classes="state-error long-wrap"
                       Text="{Binding LastErrorMessage}" />
          </StackPanel>
        </Border>
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
