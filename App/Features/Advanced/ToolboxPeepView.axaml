<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             x:Class="MAAUnified.App.Features.Advanced.ToolboxPeepView">
  <UserControl.Styles>
    <Style Selector="Border.toolbox-peep-section">
      <Setter Property="Padding" Value="22" />
    </Style>

    <Style Selector="Border.toolbox-peep-card">
      <Setter Property="Padding" Value="18" />
    </Style>

    <Style Selector="Border.toolbox-peep-preview-card">
      <Setter Property="Padding" Value="12" />
    </Style>

    <Style Selector="TextBlock.toolbox-peep-empty-text">
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="TextAlignment" Value="Center" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="FontSize" Value="{DynamicResource MAA.FontSize.Toolbox.PeepTip}" />
    </Style>

    <Style Selector="Border.toolbox-peep-preview-frame">
      <Setter Property="Background" Value="#10151D" />
      <Setter Property="CornerRadius" Value="18" />
      <Setter Property="MinHeight" Value="240" />
      <Setter Property="Padding" Value="16" />
    </Style>

    <Style Selector="Image.toolbox-peep-preview-image">
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.toolbox-peep-fps-badge">
      <Setter Property="HorizontalAlignment" Value="Left" />
      <Setter Property="VerticalAlignment" Value="Top" />
      <Setter Property="Margin" Value="16" />
    </Style>

    <Style Selector="WrapPanel.toolbox-peep-controls">
      <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>

    <Style Selector="Border.toolbox-peep-control-card">
      <Setter Property="Margin" Value="0,0,14,14" />
      <Setter Property="MinWidth" Value="200" />
    </Style>

    <Style Selector="StackPanel.toolbox-peep-control-stack">
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="Spacing" Value="10" />
    </Style>

    <Style Selector="Button.toolbox-peep-action">
      <Setter Property="Width" Value="{DynamicResource MAA.Size.Toolbox.ActionButtonWidth}" />
      <Setter Property="Height" Value="{DynamicResource MAA.Size.Toolbox.ActionButtonHeight}" />
    </Style>

    <Style Selector="controls|VerticalSpinNumberBox.toolbox-peep-fps-input">
      <Setter Property="Width" Value="{DynamicResource MAA.Size.Toolbox.PeepFpsWidth}" />
    </Style>
  </UserControl.Styles>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
    <Grid Margin="{DynamicResource MAA.Thickness.Toolbox.PageMarginFlat}"
          RowDefinitions="Auto,Auto,Auto">
      <Border Classes="app-surface app-section toolbox-peep-section"
              IsVisible="{Binding ShowPeepTip}">
        <Border Classes="app-surface app-card toolbox-peep-card">
          <TextBlock Classes="app-body toolbox-peep-empty-text"
                     Text="{Binding PeepTip}" />
        </Border>
      </Border>

      <Border Grid.Row="1"
              Margin="0,14,0,0"
              Classes="app-surface app-section toolbox-peep-section"
              IsVisible="{Binding ShowPeepPreview}">
        <Border Classes="app-surface app-card toolbox-peep-card toolbox-peep-preview-card">
          <Grid>
            <Border Classes="toolbox-peep-preview-frame">
              <Image Classes="toolbox-peep-preview-image"
                     Source="{Binding PeepImage}"
                     Stretch="Uniform"
                     MaxHeight="{DynamicResource MAA.Size.Toolbox.PeepPreviewMaxHeight}" />
            </Border>

            <Border Classes="app-badge toolbox-peep-fps-badge">
              <TextBlock Classes="app-badge-text"
                         Text="{Binding PeepScreenFps, StringFormat='{}{0:F2} FPS'}" />
            </Border>
          </Grid>
        </Border>
      </Border>

      <Border Grid.Row="2"
              Margin="0,14,0,0"
              Classes="app-surface app-section toolbox-peep-section">
        <WrapPanel Classes="toolbox-peep-controls">
          <Border Classes="app-surface app-card toolbox-peep-card toolbox-peep-control-card">
            <StackPanel Classes="toolbox-peep-control-stack">
              <Button Classes="app-button app-primary toolbox-peep-action"
                      Content="{Binding PeepCommandText}"
                      IsEnabled="{Binding CanTogglePeep}"
                      Click="OnPeepCommandClick" />
            </StackPanel>
          </Border>

          <Border Classes="app-surface app-card toolbox-peep-card toolbox-peep-control-card">
            <StackPanel Classes="toolbox-peep-control-stack">
              <TextBlock Classes="app-caption"
                         HorizontalAlignment="Center"
                         Text="{Binding PeepTargetFpsText}" />
              <controls:VerticalSpinNumberBox Classes="toolbox-peep-fps-input"
                                              Minimum="1"
                                              Maximum="60"
                                              Value="{Binding PeepTargetFps}" />
            </StackPanel>
          </Border>
        </WrapPanel>
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>
