<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Advanced.StageManagerView">
  <UserControl.Styles>
    <Style Selector="StackPanel.stage-manager-section-stack">
      <Setter Property="Spacing" Value="14" />
    </Style>

    <Style Selector="StackPanel.stage-manager-card-stack">
      <Setter Property="Spacing" Value="10" />
    </Style>

    <Style Selector="StackPanel.stage-manager-actions">
      <Setter Property="Orientation" Value="Horizontal" />
      <Setter Property="Spacing" Value="10" />
    </Style>

    <Style Selector="TextBlock.stage-manager-card-title">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
    </Style>

    <Style Selector="TextBlock.stage-manager-field-label">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Secondary}" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Border.stage-manager-card">
      <Setter Property="Padding" Value="16" />
    </Style>

    <Style Selector="TextBox.stage-manager-editor">
      <Setter Property="MinHeight" Value="180" />
    </Style>

    <Style Selector="TextBox.stage-manager-reference">
      <Setter Property="MinHeight" Value="140" />
    </Style>
  </UserControl.Styles>

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="4"
                Classes="settings-form">
      <Border Classes="app-surface app-section"
              Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}">
        <StackPanel Classes="stage-manager-section-stack">
          <TextBlock Classes="section-title"
                     Text="{Binding Texts[Toolbox.Advanced.StageManager.Title]}" />

          <StackPanel Spacing="6">
            <TextBlock Classes="app-caption stage-manager-field-label"
                       Text="{Binding Texts[Toolbox.Advanced.StageManager.ClientType]}" />
            <ComboBox Classes="app-input"
                      MinWidth="220"
                      HorizontalAlignment="Left"
                      ItemsSource="{Binding ClientTypeOptions}"
                      SelectedItem="{Binding ClientType}" />
          </StackPanel>

          <WrapPanel Classes="tool-action-bar">
            <Button Classes="app-button app-secondary"
                    Content="{Binding Texts[Toolbox.Advanced.StageManager.RefreshLocal]}"
                    Click="OnRefreshLocalClick" />
            <Button Classes="app-button app-secondary"
                    Content="{Binding Texts[Toolbox.Advanced.StageManager.RefreshWeb]}"
                    Click="OnRefreshWebClick" />
            <Button Classes="app-button app-primary"
                    Content="{Binding Texts[Toolbox.Advanced.StageManager.Validate]}"
                    Click="OnValidateClick" />
          </WrapPanel>
        </StackPanel>
      </Border>

      <Border Classes="app-surface app-section"
              Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}">
        <Border Classes="app-surface app-card stage-manager-card">
          <StackPanel Classes="stage-manager-card-stack">
            <TextBlock Classes="stage-manager-card-title"
                       Text="{Binding Texts[Toolbox.Advanced.StageManager.StageCodes]}" />
            <TextBox Classes="app-input app-input-block stage-manager-editor"
                     Text="{Binding StageCodesText}"
                     AcceptsReturn="True"
                     Watermark="{Binding Texts[Toolbox.Advanced.StageManager.StageCodes.Watermark]}"
                     TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </Border>

      <Border Classes="app-surface app-section"
              Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}">
        <WrapPanel Classes="settings-wrap">
          <Border Classes="tool-compare-card">
            <StackPanel Classes="stage-manager-card-stack">
              <Border Classes="app-badge"
                      HorizontalAlignment="Left">
                <TextBlock Classes="app-badge-text"
                           Text="{Binding Texts[Toolbox.Advanced.StageManager.LocalResources]}" />
              </Border>
              <TextBox Classes="app-input app-input-block stage-manager-reference"
                       Text="{Binding LocalStageCodesText}"
                       AcceptsReturn="True"
                       IsReadOnly="True"
                       TextWrapping="Wrap" />
            </StackPanel>
          </Border>

          <Border Classes="tool-compare-card">
            <StackPanel Classes="stage-manager-card-stack">
              <Border Classes="app-badge"
                      HorizontalAlignment="Left">
                <TextBlock Classes="app-badge-text"
                           Text="{Binding Texts[Toolbox.Advanced.StageManager.WebResources]}" />
              </Border>
              <TextBox Classes="app-input app-input-block stage-manager-reference"
                       Text="{Binding WebStageCodesText}"
                       AcceptsReturn="True"
                       IsReadOnly="True"
                       TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </WrapPanel>
      </Border>

      <Border Classes="app-surface app-section"
              Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}">
        <WrapPanel Classes="settings-wrap">
          <Border Classes="app-surface app-card stage-manager-card">
            <CheckBox Classes="app-checkbox"
                      Content="{Binding Texts[Toolbox.Advanced.StageManager.AutoIterate]}"
                      IsChecked="{Binding AutoIterate}" />
          </Border>

          <Border Classes="app-surface app-card stage-manager-card">
            <StackPanel Classes="stage-manager-card-stack">
              <TextBlock Classes="app-caption stage-manager-field-label"
                         Text="{Binding Texts[Toolbox.Advanced.StageManager.LastSelectedStage]}" />
              <StackPanel Orientation="Horizontal"
                          Spacing="12">
                <TextBox Classes="app-input"
                         Width="220"
                         Text="{Binding LastSelectedStage}" />
                <Button Classes="app-button app-primary"
                        Content="{Binding Texts[Toolbox.Advanced.StageManager.Save]}"
                        Click="OnSaveClick" />
              </StackPanel>
            </StackPanel>
          </Border>
        </WrapPanel>
      </Border>

      <Border Classes="app-surface app-section"
              Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}">
        <StackPanel Spacing="8">
          <TextBlock Classes="app-body long-wrap"
                     Text="{Binding StatusMessage}" />
          <TextBlock Classes="state-error long-wrap"
                     Text="{Binding LastErrorMessage}" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
