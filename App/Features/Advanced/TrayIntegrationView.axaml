<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             x:Class="MAAUnified.App.Features.Advanced.TrayIntegrationView">
  <UserControl.Styles>
    <Style Selector="Border.tray-section">
      <Setter Property="Padding" Value="22" />
    </Style>

    <Style Selector="Border.tray-card">
      <Setter Property="Padding" Value="16" />
    </Style>

    <Style Selector="StackPanel.tray-stack">
      <Setter Property="Spacing" Value="16" />
    </Style>

    <Style Selector="TextBlock.tray-card-title">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBox.tray-title-input">
      <Setter Property="Width" Value="320" />
    </Style>

    <Style Selector="TextBox.tray-body-input">
      <Setter Property="MinWidth" Value="320" />
    </Style>
  </UserControl.Styles>

  <Grid Margin="4"
        RowDefinitions="Auto,Auto,Auto,*">
    <Border Classes="app-surface app-section tray-section">
      <StackPanel Classes="tray-stack">
        <TextBlock Classes="app-window-title"
                   Text="{Binding Texts[Toolbox.Advanced.Tray.Title]}" />
        <TextBlock Classes="app-caption long-wrap"
                   Text="{Binding CapabilitySummary}" />
        <Button Classes="app-button app-secondary"
                HorizontalAlignment="Left"
                Content="{Binding Texts[Toolbox.Advanced.Tray.RefreshCapability]}"
                Click="OnRefreshCapabilityClick" />
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Margin="0,14,0,0"
            Classes="app-surface app-section tray-section">
      <StackPanel Classes="tray-stack">
        <TextBlock Classes="app-body tray-card-title"
                   Text="{Binding Texts[Toolbox.Advanced.Tray.Visible]}" />

        <Border Classes="app-surface app-card tray-card">
          <StackPanel Classes="tray-stack">
            <CheckBox Classes="app-checkbox"
                      Content="{Binding Texts[Toolbox.Advanced.Tray.Visible]}"
                      IsChecked="{Binding TrayVisible}" />

            <StackPanel Orientation="Horizontal"
                        Spacing="{DynamicResource MAA.Spacing.Small}">
              <Button Classes="app-button app-primary"
                      Content="{Binding Texts[Toolbox.Advanced.Tray.ApplyVisibility]}"
                      Click="OnApplyTrayVisibilityClick" />
              <Button Classes="app-button app-secondary"
                      Content="{Binding Texts[Toolbox.Advanced.Tray.SyncMenuState]}"
                      Click="OnSyncMenuStateClick" />
            </StackPanel>
          </StackPanel>
        </Border>
      </StackPanel>
    </Border>

    <Border Grid.Row="2"
            Margin="0,14,0,0"
            Classes="app-surface app-section tray-section">
      <StackPanel Classes="tray-stack">
        <TextBlock Classes="app-body tray-card-title"
                   Text="{Binding Texts[Toolbox.Advanced.Tray.SendMessage]}" />

        <Border Classes="app-surface app-card tray-card">
          <StackPanel Classes="tray-stack">
            <StackPanel Spacing="8">
              <TextBlock Classes="app-caption"
                         Text="{Binding Texts[Toolbox.Advanced.Tray.MessageTitle]}" />
              <controls:AppTextInput Classes="tray-title-input"
                                     Text="{Binding TrayMessageTitle}" />
            </StackPanel>

            <StackPanel Spacing="8">
              <TextBlock Classes="app-caption"
                         Text="{Binding Texts[Toolbox.Advanced.Tray.MessageBody]}" />
              <controls:AppTextInput Classes="settings-input-block tray-body-input"
                                     Text="{Binding TrayMessageBody}" />
            </StackPanel>

            <Button Classes="app-button app-primary"
                    HorizontalAlignment="Left"
                    Content="{Binding Texts[Toolbox.Advanced.Tray.SendMessage]}"
                    Click="OnSendTrayMessageClick" />
          </StackPanel>
        </Border>
      </StackPanel>
    </Border>

    <Border Grid.Row="3"
            Margin="0,14,0,0"
            Classes="app-surface app-section tray-section">
      <Border Classes="app-surface app-card tray-card">
        <StackPanel Spacing="8">
          <TextBlock Classes="app-body long-wrap"
                     Text="{Binding StatusMessage}" />
          <TextBlock Classes="state-error long-wrap"
                     Text="{Binding LastErrorMessage}" />
        </StackPanel>
      </Border>
    </Border>
  </Grid>
</UserControl>
