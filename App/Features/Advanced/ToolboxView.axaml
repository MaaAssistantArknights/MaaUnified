<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             x:Class="MAAUnified.App.Features.Advanced.ToolboxView">
  <Grid RowDefinitions="*,Auto">
    <TabControl Grid.Row="0"
                Classes="toolbox-nav"
                SelectedIndex="{Binding SelectedTabIndex}"
                Margin="{DynamicResource MAA.Thickness.MarginSectionVertical}">
      <TabItem Header="{Binding RecruitTabTitle}">
        <Grid Margin="{DynamicResource MAA.Thickness.Toolbox.PageMargin}"
              RowDefinitions="*,Auto">
          <ScrollViewer Grid.Row="0"
                        Margin="{DynamicResource MAA.Thickness.Toolbox.InnerHorizontalMargin}"
                        VerticalScrollBarVisibility="Auto"
                        HorizontalScrollBarVisibility="Disabled">
            <StackPanel>
              <TextBlock Margin="{DynamicResource MAA.Thickness.Toolbox.InfoMargin}"
                         Classes="long-wrap"
                         FontWeight="SemiBold"
                         Text="{Binding RecruitInfo}" />
              <StackPanel Margin="{DynamicResource MAA.Thickness.Toolbox.InfoMargin}"
                          IsVisible="{Binding HasRecruitResults}"
                          MinHeight="{DynamicResource MAA.Size.Toolbox.RecruitResultMinHeight}">
                <ItemsControl ItemsSource="{Binding RecruitResultLines}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <StackPanel>
                        <ItemsControl ItemsSource="{Binding Segments}"
                                      IsVisible="{Binding HasSegments}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <WrapPanel />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <TextBlock Margin="0,0,12,0"
                                         Text="{Binding Text}"
                                         Foreground="{Binding Foreground}"
                                         TextWrapping="NoWrap" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Border Height="{Binding SpacerHeight}"
                                Background="Transparent"
                                IsVisible="{Binding HasSpacer}" />
                      </StackPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </StackPanel>
          </ScrollViewer>

          <Grid Grid.Row="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                ColumnDefinitions="Auto,Auto,Auto">
            <StackPanel Grid.Column="0"
                        Margin="{DynamicResource MAA.Thickness.Toolbox.InnerHorizontalMargin}"
                        VerticalAlignment="Center">
              <CheckBox Margin="{DynamicResource MAA.Thickness.Toolbox.CheckboxMargin}"
                        Content="{Binding RecruitAutoSetTimeText}"
                        IsChecked="{Binding RecruitAutoSetTime}" />
              <StackPanel Orientation="Horizontal">
                <CheckBox Margin="{DynamicResource MAA.Thickness.Toolbox.CheckboxWrapMargin}"
                          IsChecked="{Binding RecruitmentShowPotential}">
                  <TextBlock MaxWidth="{DynamicResource MAA.Size.Toolbox.RecruitPotentialTextMaxWidth}"
                             Text="{Binding RecruitShowPotentialText}"
                             TextWrapping="Wrap" />
                </CheckBox>
                <controls:TooltipHint Tip="{Binding RecruitPotentialTip}" />
              </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Margin="{DynamicResource MAA.Thickness.Toolbox.InnerHorizontalMargin}"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center">
              <StackPanel Orientation="Horizontal"
                          Spacing="{DynamicResource MAA.Spacing.Small}">
                <CheckBox Margin="{DynamicResource MAA.Thickness.Toolbox.CheckboxMargin}"
                          VerticalAlignment="Bottom"
                          Content="{Binding RecruitAutoSelect3Text}"
                          IsChecked="{Binding ChooseLevel3}" />
                <StackPanel Orientation="Horizontal"
                            Spacing="{DynamicResource MAA.Spacing.Small}"
                            IsVisible="{Binding ShowRecruitAutoSetTimeControls}">
                  <controls:VerticalSpinNumberBox Width="{DynamicResource MAA.Size.Toolbox.RecruitTimePickerWidth}"
                                                  Minimum="1"
                                                  Maximum="9"
                                                  Value="{Binding RecruitLevel3Hour}" />
                  <TextBlock VerticalAlignment="Center"
                             Text=":" />
                  <controls:VerticalSpinNumberBox Width="{DynamicResource MAA.Size.Toolbox.RecruitTimePickerWidth}"
                                                  Minimum="0"
                                                  Maximum="50"
                                                  Increment="10"
                                                  Value="{Binding RecruitLevel3Minute}" />
                </StackPanel>
              </StackPanel>

              <StackPanel Orientation="Horizontal"
                          Spacing="{DynamicResource MAA.Spacing.Small}">
                <CheckBox Margin="{DynamicResource MAA.Thickness.Toolbox.CheckboxMargin}"
                          VerticalAlignment="Bottom"
                          Content="{Binding RecruitAutoSelect4Text}"
                          IsChecked="{Binding ChooseLevel4}" />
                <StackPanel Orientation="Horizontal"
                            Spacing="{DynamicResource MAA.Spacing.Small}"
                            IsVisible="{Binding ShowRecruitAutoSetTimeControls}">
                  <controls:VerticalSpinNumberBox Width="{DynamicResource MAA.Size.Toolbox.RecruitTimePickerWidth}"
                                                  Minimum="1"
                                                  Maximum="9"
                                                  Value="{Binding RecruitLevel4Hour}" />
                  <TextBlock VerticalAlignment="Center"
                             Text=":" />
                  <controls:VerticalSpinNumberBox Width="{DynamicResource MAA.Size.Toolbox.RecruitTimePickerWidth}"
                                                  Minimum="0"
                                                  Maximum="50"
                                                  Increment="10"
                                                  Value="{Binding RecruitLevel4Minute}" />
                </StackPanel>
              </StackPanel>

              <StackPanel Orientation="Horizontal"
                          Spacing="{DynamicResource MAA.Spacing.Small}">
                <CheckBox Margin="{DynamicResource MAA.Thickness.Toolbox.CheckboxMargin}"
                          VerticalAlignment="Bottom"
                          Content="{Binding RecruitAutoSelect5Text}"
                          IsChecked="{Binding ChooseLevel5}" />
                <StackPanel Orientation="Horizontal"
                            Spacing="{DynamicResource MAA.Spacing.Small}"
                            IsVisible="{Binding ShowRecruitAutoSetTimeControls}">
                  <controls:VerticalSpinNumberBox Width="{DynamicResource MAA.Size.Toolbox.RecruitTimePickerWidth}"
                                                  Minimum="1"
                                                  Maximum="9"
                                                  Value="{Binding RecruitLevel5Hour}" />
                  <TextBlock VerticalAlignment="Center"
                             Text=":" />
                  <controls:VerticalSpinNumberBox Width="{DynamicResource MAA.Size.Toolbox.RecruitTimePickerWidth}"
                                                  Minimum="0"
                                                  Maximum="50"
                                                  Increment="10"
                                                  Value="{Binding RecruitLevel5Minute}" />
                </StackPanel>
              </StackPanel>

              <StackPanel Orientation="Horizontal"
                          Spacing="{DynamicResource MAA.Spacing.Small}">
                <CheckBox Margin="{DynamicResource MAA.Thickness.Toolbox.CheckboxMargin}"
                          VerticalAlignment="Bottom"
                          Content="{Binding RecruitAutoSelect6Text}"
                          IsChecked="{Binding ChooseLevel6}" />
                <StackPanel Orientation="Horizontal"
                            Spacing="{DynamicResource MAA.Spacing.Small}"
                            IsVisible="{Binding ShowRecruitAutoSetTimeControls}">
                  <TextBlock VerticalAlignment="Center"
                             Classes="subtle"
                             Text="{Binding RecruitFixedSixStarText}" />
                </StackPanel>
              </StackPanel>
            </StackPanel>

            <Button Grid.Column="2"
                    Width="{DynamicResource MAA.Size.Toolbox.ActionButtonWidth}"
                    Height="{DynamicResource MAA.Size.Toolbox.ActionButtonHeight}"
                    Margin="{DynamicResource MAA.Thickness.Toolbox.InnerHorizontalMargin}"
                    Classes="wpf-button"
                    Content="{Binding StartRecognitionText}"
                    Click="OnRecruitStartClick" />
          </Grid>
        </Grid>
      </TabItem>

      <TabItem Header="{Binding OperBoxTabTitle}">
        <Grid Margin="{DynamicResource MAA.Thickness.Toolbox.PageMargin}"
              RowDefinitions="Auto,Auto,*,Auto">
        <TextBlock Grid.Row="0"
                   HorizontalAlignment="Center"
                   Classes="long-wrap"
                   FontWeight="SemiBold"
                   Text="{Binding LastOperBoxSyncDisplayText}"
                   IsVisible="{Binding HasLastOperBoxSyncTime}" />
        <TextBlock Grid.Row="1"
                   Margin="{DynamicResource MAA.Thickness.Toolbox.InfoMargin}"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   Classes="long-wrap"
                   FontWeight="SemiBold"
                   Text="{Binding OperBoxInfo}" />

        <TabControl Grid.Row="2"
                    SelectedIndex="{Binding OperBoxSelectedIndex}">
          <TabItem Header="{Binding OperBoxNotHaveHeader}">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
              <ItemsControl Width="{Binding OperBoxNotHavePanelWidth}"
                            HorizontalAlignment="Center"
                            ItemsSource="{Binding OperBoxNotHaveList}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel ItemWidth="{DynamicResource MAA.Size.Toolbox.OperBoxWrapItemWidth}" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="wpf-card"
                            Margin="{DynamicResource MAA.Thickness.Toolbox.CardMargin}"
                            MinWidth="{DynamicResource MAA.Size.Toolbox.OperBoxCardMinWidth}"
                            MinHeight="{DynamicResource MAA.Size.Toolbox.OperBoxCardMinHeight}"
                            Padding="{DynamicResource MAA.Thickness.Toolbox.OperBoxCardPadding}">
                      <StackPanel HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Spacing="{DynamicResource MAA.Spacing.Small}">
                        <TextBlock HorizontalAlignment="Center"
                                   Classes="long-wrap"
                                   Text="{Binding Name}"
                                   TextAlignment="Center" />
                        <TextBlock HorizontalAlignment="Center"
                                   Foreground="{Binding RarityBrush}"
                                   Text="{Binding RarityStars}"
                                   TextAlignment="Center" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </TabItem>

          <TabItem Header="{Binding OperBoxHaveHeader}">
            <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
              <ItemsControl Width="{Binding OperBoxHavePanelWidth}"
                            HorizontalAlignment="Center"
                            ItemsSource="{Binding OperBoxHaveList}">
                <ItemsControl.ItemsPanel>
                  <ItemsPanelTemplate>
                    <WrapPanel ItemWidth="{DynamicResource MAA.Size.Toolbox.OperBoxWrapItemWidth}" />
                  </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Classes="wpf-card"
                            Margin="{DynamicResource MAA.Thickness.Toolbox.CardMargin}"
                            MinWidth="{DynamicResource MAA.Size.Toolbox.OperBoxCardMinWidth}"
                            MinHeight="{DynamicResource MAA.Size.Toolbox.OperBoxCardMinHeight}"
                            Padding="{DynamicResource MAA.Thickness.Toolbox.OperBoxCardPadding}">
                      <StackPanel HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Spacing="{DynamicResource MAA.Spacing.Small}">
                        <TextBlock HorizontalAlignment="Center"
                                   Classes="long-wrap"
                                   Text="{Binding Name}"
                                   TextAlignment="Center" />
                        <TextBlock HorizontalAlignment="Center"
                                   Foreground="{Binding RarityBrush}"
                                   Text="{Binding RarityStars}"
                                   TextAlignment="Center" />
                        <StackPanel HorizontalAlignment="Center"
                                    Orientation="Horizontal"
                                    Spacing="{DynamicResource MAA.Spacing.Small}">
                          <Image Width="{DynamicResource MAA.Size.Toolbox.OperBoxBadgeIcon}"
                                 Height="{DynamicResource MAA.Size.Toolbox.OperBoxBadgeIcon}"
                                 Margin="{DynamicResource MAA.Thickness.Toolbox.OperBoxBadgeMargin}"
                                 Source="{Binding EliteIconImage}"
                                 Stretch="Uniform">
                            <Image.Effect>
                              <DropShadowDirectionEffect BlurRadius="8"
                                                         ShadowDepth="2"
                                                         Opacity="0.55"
                                                         Color="Black" />
                            </Image.Effect>
                          </Image>
                          <TextBlock VerticalAlignment="Center"
                                     FontWeight="SemiBold"
                                     Text="{Binding LevelDisplay}" />
                          <Image Width="{DynamicResource MAA.Size.Toolbox.OperBoxBadgeIcon}"
                                 Height="{DynamicResource MAA.Size.Toolbox.OperBoxBadgeIcon}"
                                 Margin="{DynamicResource MAA.Thickness.Toolbox.OperBoxBadgeMargin}"
                                 Source="{Binding PotentialIconImage}"
                                 Stretch="Uniform">
                            <Image.Effect>
                              <DropShadowDirectionEffect BlurRadius="8"
                                                         ShadowDepth="2"
                                                         Opacity="0.55"
                                                         Color="Black" />
                            </Image.Effect>
                          </Image>
                        </StackPanel>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </TabItem>
        </TabControl>

        <StackPanel Grid.Row="3"
                    Margin="{DynamicResource MAA.Thickness.Toolbox.ActionTopMargin}"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
          <Button Width="{DynamicResource MAA.Size.Toolbox.ActionButtonWidth}"
                  Height="{DynamicResource MAA.Size.Toolbox.ActionButtonHeight}"
                  Margin="{DynamicResource MAA.Thickness.Toolbox.ButtonWideMargin}"
                  Classes="wpf-button"
                  Click="OnOperBoxExportClick">
            <TextBlock Text="{Binding OperBoxCopyToClipboardText}"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
          </Button>
          <Button Width="{DynamicResource MAA.Size.Toolbox.ActionButtonWidth}"
                  Height="{DynamicResource MAA.Size.Toolbox.ActionButtonHeight}"
                  Margin="{DynamicResource MAA.Thickness.Toolbox.ButtonWideMargin}"
                  Classes="wpf-button"
                  Content="{Binding StartRecognitionText}"
                  Click="OnOperBoxStartClick" />
        </StackPanel>
      </Grid>
      </TabItem>

      <TabItem Header="{Binding DepotTabTitle}">
        <Grid Margin="{DynamicResource MAA.Thickness.Toolbox.PageMargin}"
              RowDefinitions="Auto,*,Auto">
        <StackPanel Grid.Row="0">
          <TextBlock HorizontalAlignment="Center"
                     Text="{Binding LastDepotSyncDisplayText}"
                     IsVisible="{Binding HasLastDepotSyncTime}" />
          <TextBlock Margin="{DynamicResource MAA.Thickness.Toolbox.CheckboxMargin}"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"
                     Classes="long-wrap"
                     FontWeight="SemiBold"
                     Text="{Binding DepotInfo}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <ItemsControl Width="{Binding DepotPanelWidth}"
                        HorizontalAlignment="Center"
                        ItemsSource="{Binding DepotResult}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel ItemWidth="{DynamicResource MAA.Size.Toolbox.DepotWrapItemWidth}" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Classes="wpf-card"
                        Margin="{DynamicResource MAA.Thickness.Toolbox.CardMargin}"
                        MinWidth="{DynamicResource MAA.Size.Toolbox.DepotCardMinWidth}">
                  <StackPanel HorizontalAlignment="Center"
                              Orientation="Vertical">
                    <Image Width="{DynamicResource MAA.Size.Toolbox.DepotCardImage}"
                           Height="{DynamicResource MAA.Size.Toolbox.DepotCardImage}"
                           Source="{Binding ItemImage}"
                           Stretch="Uniform" />
                    <TextBlock HorizontalAlignment="Center"
                               Text="{Binding Name}"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                    <TextBlock HorizontalAlignment="Center"
                               FontWeight="Bold"
                               Text="{Binding DisplayCount}"
                               TextAlignment="Center" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Margin="{DynamicResource MAA.Thickness.Toolbox.ActionTopMargin}"
                    HorizontalAlignment="Center"
                    Orientation="Horizontal">
          <Button Width="{DynamicResource MAA.Size.Toolbox.ActionButtonWidth}"
                  Height="{DynamicResource MAA.Size.Toolbox.ActionButtonHeight}"
                  Margin="{DynamicResource MAA.Thickness.Toolbox.ButtonWideMargin}"
                  Classes="wpf-button"
                  Click="OnDepotExportArkPlannerClick">
            <TextBlock Text="{Binding DepotExportArkPlannerText}"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
          </Button>
          <Button Width="{DynamicResource MAA.Size.Toolbox.ActionButtonWidth}"
                  Height="{DynamicResource MAA.Size.Toolbox.ActionButtonHeight}"
                  Margin="{DynamicResource MAA.Thickness.Toolbox.ButtonWideMargin}"
                  Classes="wpf-button"
                  Click="OnDepotExportLoliconClick">
            <TextBlock Text="{Binding DepotExportLoliconText}"
                       TextAlignment="Center"
                       TextWrapping="Wrap" />
          </Button>
          <Button Width="{DynamicResource MAA.Size.Toolbox.ActionButtonWidth}"
                  Height="{DynamicResource MAA.Size.Toolbox.ActionButtonHeight}"
                  Margin="{DynamicResource MAA.Thickness.Toolbox.ButtonWideMargin}"
                  Classes="wpf-button"
                  Content="{Binding StartRecognitionText}"
                  Click="OnDepotStartClick" />
        </StackPanel>
      </Grid>
      </TabItem>

      <TabItem Header="{Binding GachaTabTitle}">
        <Grid Margin="{DynamicResource MAA.Thickness.Toolbox.PageMarginFlat}"
              RowDefinitions="Auto,*,Auto">
        <TextBlock Grid.Row="0"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   TextAlignment="Center"
                   Classes="long-wrap"
                   FontWeight="SemiBold"
                   Text="{Binding GachaInfo}"
                   IsVisible="{Binding ShowGachaControls}" />

        <Grid Grid.Row="1"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              IsVisible="{Binding ShowGachaControls}">
          <Border Classes="wpf-panel"
                  Padding="{DynamicResource MAA.Thickness.SectionPadding}">
            <Image Source="{Binding PeepImage}"
                   Stretch="Uniform"
                   MaxHeight="{DynamicResource MAA.Size.Toolbox.GachaPreviewMaxHeight}" />
          </Border>
          <Canvas IsVisible="{Binding ShowGachaPreview}">
            <Border Canvas.Left="15"
                    Canvas.Top="15"
                    Padding="{DynamicResource MAA.Thickness.Toolbox.BadgePadding}"
                    Background="{DynamicResource MAA.Brush.Toolbox.PreviewBadgeBackground}"
                    CornerRadius="{DynamicResource MAA.CornerRadius.Item}">
              <TextBlock FontWeight="Bold"
                         Foreground="{DynamicResource MAA.Brush.Toolbox.PreviewBadgeForeground}"
                         Text="{Binding PeepScreenFps, StringFormat='{}{0:F2} FPS'}" />
            </Border>
          </Canvas>
        </Grid>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Vertical"
                    IsVisible="{Binding GachaShowDisclaimer}">
          <Border Classes="wpf-panel wpf-panel-warning"
                  Padding="{DynamicResource MAA.Thickness.Toolbox.WarningPadding}">
            <StackPanel HorizontalAlignment="Center"
                        Spacing="{DynamicResource MAA.Spacing.Small}">
              <TextBlock Margin="{DynamicResource MAA.Thickness.Toolbox.WarningLeadMargin}"
                         HorizontalAlignment="Center"
                         TextAlignment="Center"
                         FontSize="{DynamicResource MAA.FontSize.Toolbox.WarningLead}"
                         FontWeight="Bold"
                         Text="{Binding GachaDisclaimerLeadText}"
                         TextWrapping="Wrap" />
              <TextBlock x:Name="GachaDisclaimerEmphasisText"
                         Margin="{DynamicResource MAA.Thickness.Toolbox.WarningEmphasisMargin}"
                         HorizontalAlignment="Center"
                         TextAlignment="Center"
                         FontSize="{DynamicResource MAA.FontSize.Toolbox.WarningEmphasis}"
                         FontWeight="Bold"
                         Text="{Binding GachaDisclaimerEmphasisText}"
                         TextWrapping="Wrap">
                  <TextBlock.Foreground>
                    <LinearGradientBrush StartPoint="0%,50%"
                                         EndPoint="100%,50%"
                                         SpreadMethod="Repeat">
                      <GradientStop Offset="0.00" Color="Red" />
                      <GradientStop Offset="0.17" Color="Orange" />
                      <GradientStop Offset="0.33" Color="Yellow" />
                      <GradientStop Offset="0.50" Color="Green" />
                      <GradientStop Offset="0.67" Color="Blue" />
                      <GradientStop Offset="0.83" Color="Indigo" />
                      <GradientStop Offset="1.00" Color="Violet" />
                    </LinearGradientBrush>
                  </TextBlock.Foreground>
                  <TextBlock.Effect>
                    <DropShadowDirectionEffect BlurRadius="8"
                                               ShadowDepth="4"
                                               Opacity="0.6"
                                               Color="Black" />
                  </TextBlock.Effect>
              </TextBlock>

              <TextBlock MaxWidth="{DynamicResource MAA.Size.Toolbox.WarningTextMaxWidth}"
                         HorizontalAlignment="Center"
                         TextAlignment="Center"
                         Classes="long-wrap"
                         Text="{Binding GachaDisclaimerBodyText}" />

              <Button Width="{DynamicResource MAA.Size.Toolbox.WarningButtonWidth}"
                      Height="{DynamicResource MAA.Size.Toolbox.WarningButtonHeight}"
                      Margin="{DynamicResource MAA.Thickness.Toolbox.WarningButtonMargin}"
                      HorizontalAlignment="Center"
                      Classes="wpf-button"
                      Content="{Binding GachaDisclaimerAcknowledgeText}"
                      Click="OnGachaAgreeDisclaimerClick" />

              <CheckBox Margin="{DynamicResource MAA.Thickness.ItemPadding}"
                        HorizontalAlignment="Center"
                        VerticalContentAlignment="Center"
                        Content="{Binding GachaDisclaimerNoMoreText}"
                        IsChecked="{Binding GachaShowDisclaimerNoMore}" />
            </StackPanel>
          </Border>
        </StackPanel>

        <StackPanel Grid.Row="2"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    IsVisible="{Binding ShowGachaControls}">
          <Button Width="{DynamicResource MAA.Size.Toolbox.ActionButtonWidth}"
                  Height="{DynamicResource MAA.Size.Toolbox.ActionButtonHeight}"
                  Margin="{DynamicResource MAA.Thickness.Toolbox.ButtonMediumMargin}"
                  Classes="wpf-button"
                  Content="{Binding GachaDrawOnceText}"
                  Click="OnGachaOnceClick" />
          <Button Width="{DynamicResource MAA.Size.Toolbox.ActionButtonWidth}"
                  Height="{DynamicResource MAA.Size.Toolbox.ActionButtonHeight}"
                  Margin="{DynamicResource MAA.Thickness.Toolbox.ButtonMediumMargin}"
                  Classes="wpf-button"
                  Content="{Binding GachaDrawTenText}"
                  Click="OnGachaTenTimesClick" />
          <Button Width="{DynamicResource MAA.Size.Toolbox.ActionButtonWidth}"
                  Height="{DynamicResource MAA.Size.Toolbox.ActionButtonHeight}"
                  Margin="{DynamicResource MAA.Thickness.Toolbox.ButtonMediumMargin}"
                  Classes="wpf-button"
                  Content="{Binding PeepCommandText}"
                  Click="OnGachaPeepClick" />
        </StackPanel>
      </Grid>
      </TabItem>

      <TabItem Header="{Binding PeepTabTitle}">
        <Grid Margin="{DynamicResource MAA.Thickness.Toolbox.PageMarginFlat}"
              RowDefinitions="*,Auto">
        <TextBlock Grid.Row="0"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center"
                   FontSize="{DynamicResource MAA.FontSize.Toolbox.PeepTip}"
                   Text="{Binding PeepTip}"
                   IsVisible="{Binding ShowPeepTip}" />

        <Grid Grid.Row="0"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
              IsVisible="{Binding ShowPeepPreview}">
          <Border Classes="wpf-panel"
                  Padding="{DynamicResource MAA.Thickness.SectionPadding}">
            <Image Source="{Binding PeepImage}"
                   Stretch="Uniform"
                   MaxHeight="{DynamicResource MAA.Size.Toolbox.PeepPreviewMaxHeight}" />
          </Border>
          <Canvas>
            <Border Canvas.Left="15"
                    Canvas.Top="15"
                    Padding="{DynamicResource MAA.Thickness.Toolbox.BadgePadding}"
                    Background="{DynamicResource MAA.Brush.Toolbox.PreviewBadgeBackground}"
                    CornerRadius="{DynamicResource MAA.CornerRadius.Item}">
              <TextBlock FontWeight="Bold"
                         Foreground="{DynamicResource MAA.Brush.Toolbox.PreviewBadgeForeground}"
                         Text="{Binding PeepScreenFps, StringFormat='{}{0:F2} FPS'}" />
            </Border>
          </Canvas>
        </Grid>

        <StackPanel Grid.Row="1"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Orientation="Horizontal"
                    Spacing="{DynamicResource MAA.Spacing.Large}">
          <Button Width="{DynamicResource MAA.Size.Toolbox.ActionButtonWidth}"
                  Height="{DynamicResource MAA.Size.Toolbox.ActionButtonHeight}"
                  Classes="wpf-button"
                  Content="{Binding PeepCommandText}"
                  IsEnabled="{Binding CanTogglePeep}"
                  Click="OnPeepCommandClick" />
          <StackPanel VerticalAlignment="Center">
            <TextBlock HorizontalAlignment="Center"
                       Text="{Binding PeepTargetFpsText}" />
            <controls:VerticalSpinNumberBox Width="{DynamicResource MAA.Size.Toolbox.PeepFpsWidth}"
                                            Minimum="1"
                                            Maximum="60"
                                            Value="{Binding PeepTargetFps}" />
          </StackPanel>
        </StackPanel>
      </Grid>
      </TabItem>

      <TabItem Header="{Binding MiniGameTabTitle}">
        <Grid Margin="{DynamicResource MAA.Thickness.Toolbox.PageMarginFlat}"
              RowDefinitions="Auto,Auto,*,Auto">
        <Grid Width="{DynamicResource MAA.Size.Toolbox.FormPanelWidth}"
              HorizontalAlignment="Center"
              ColumnDefinitions="Auto,*">
          <TextBlock VerticalAlignment="Center"
                     Text="{Binding MiniGameNameText}" />
          <ComboBox Grid.Column="1"
                    Margin="{DynamicResource MAA.Thickness.Toolbox.FieldMargin}"
                    ItemsSource="{Binding MiniGameTaskList}"
                    SelectedValueBinding="{Binding Value}"
                    SelectedValue="{Binding MiniGameTaskName}">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Display}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </Grid>

        <Grid Grid.Row="1"
              Width="{DynamicResource MAA.Size.Toolbox.FormPanelWidth}"
              HorizontalAlignment="Center"
              Margin="{DynamicResource MAA.Thickness.Toolbox.ActionTopMargin}"
              IsVisible="{Binding IsMiniGameSecretFront}"
              RowDefinitions="Auto,Auto">
          <Grid ColumnDefinitions="Auto,*">
            <TextBlock VerticalAlignment="Center"
                       Text="{Binding MiniGameEndingText}" />
            <ComboBox Grid.Column="1"
                      Margin="{DynamicResource MAA.Thickness.Toolbox.FieldMargin}"
                      ItemsSource="{Binding MiniGameSecretFrontEndingOptions}"
                      SelectedItem="{Binding MiniGameSecretFrontEnding}" />
          </Grid>

          <Grid Grid.Row="1"
                Margin="{DynamicResource MAA.Thickness.Toolbox.ActionTopMargin}"
                ColumnDefinitions="Auto,*">
            <TextBlock VerticalAlignment="Center"
                       Text="{Binding MiniGameEventPriorityText}" />
            <ComboBox Grid.Column="1"
                      Margin="{DynamicResource MAA.Thickness.Toolbox.FieldMargin}"
                      ItemsSource="{Binding MiniGameSecretFrontEventOptions}"
                      SelectedValueBinding="{Binding Value}"
                      SelectedValue="{Binding MiniGameSecretFrontEvent}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Label}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>
        </Grid>

        <TextBlock Grid.Row="2"
                   Width="{DynamicResource MAA.Size.Toolbox.FormPanelWidth}"
                   HorizontalAlignment="Center"
                   Margin="{DynamicResource MAA.Thickness.Toolbox.ActionTopMargin}"
                   Classes="long-wrap"
                   Text="{Binding MiniGameTip}" />

        <Button Grid.Row="3"
                Width="{DynamicResource MAA.Size.Toolbox.MiniGameButtonWidth}"
                Height="{DynamicResource MAA.Size.Toolbox.MiniGameButtonHeight}"
                Margin="{DynamicResource MAA.Thickness.Toolbox.MiniGameButtonMargin}"
                HorizontalAlignment="Center"
                Classes="wpf-button"
                Content="{Binding MiniGameCommandText}"
                Click="OnMiniGameCommandClick" />
      </Grid>
      </TabItem>

    </TabControl>

    <Border Grid.Row="1"
            Margin="{DynamicResource MAA.Thickness.MarginSectionVertical}"
            Padding="{DynamicResource MAA.Thickness.SectionPadding}"
            Classes="wpf-panel wpf-panel-strong">
      <Grid RowDefinitions="Auto,Auto,Auto,Auto,*">
        <TextBlock Classes="section-title"
                   Text="{Binding ExecutionReviewTitle}" />

        <StackPanel Grid.Row="1"
                    Margin="{DynamicResource MAA.Thickness.Toolbox.InfoMargin}"
                    Spacing="{DynamicResource MAA.Spacing.Small}">
          <TextBlock Classes="subtle"
                     Text="{Binding ExecutionReviewResultLabelText}" />
          <TextBlock Classes="long-wrap"
                     Text="{Binding ResultText}" />
        </StackPanel>

        <StackPanel Grid.Row="2"
                    Margin="{DynamicResource MAA.Thickness.Toolbox.InfoMargin}"
                    Spacing="{DynamicResource MAA.Spacing.Small}">
          <TextBlock Classes="subtle"
                     Text="{Binding ExecutionReviewParametersLabelText}" />
          <TextBlock Classes="long-wrap"
                     Text="{Binding CurrentToolParameters}" />
        </StackPanel>

        <StackPanel Grid.Row="3"
                    Margin="{DynamicResource MAA.Thickness.Toolbox.InfoMargin}"
                    Spacing="{DynamicResource MAA.Spacing.Small}">
          <TextBlock Classes="subtle"
                     Text="{Binding ExecutionReviewHistoryLabelText}" />
        </StackPanel>

        <ScrollViewer Grid.Row="4"
                      Margin="{DynamicResource MAA.Thickness.Toolbox.InfoMargin}"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
          <ItemsControl ItemsSource="{Binding ExecutionHistory}"
                        IsVisible="{Binding HasExecutionHistory}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Classes="wpf-card"
                        Classes.status-success="{Binding Success}"
                        Classes.status-error="{Binding HasErrorCode}"
                        Margin="{DynamicResource MAA.Thickness.Toolbox.CardMargin}">
                  <StackPanel Margin="{DynamicResource MAA.Thickness.Toolbox.InfoMargin}"
                              Spacing="{DynamicResource MAA.Spacing.Small}">
                    <Grid ColumnDefinitions="Auto,*,Auto">
                      <TextBlock Classes="subtle"
                                 Text="{Binding ExecutedAt, StringFormat='{}{0:yyyy-MM-dd HH:mm:ss}'}" />
                      <TextBlock Grid.Column="1"
                                 FontWeight="SemiBold"
                                 Text="{Binding ToolName}" />
                      <TextBlock Grid.Column="2"
                                 Classes="subtle"
                                 IsVisible="{Binding HasErrorCode}"
                                 Text="{Binding ErrorCode}" />
                    </Grid>
                    <TextBlock Classes="long-wrap"
                               Text="{Binding ParameterSummary}" />
                    <TextBlock Classes="long-wrap"
                               Text="{Binding ResultSummary}" />
                  </StackPanel>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Grid>
    </Border>
  </Grid>
</UserControl>
