<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             x:Class="MAAUnified.App.Features.Advanced.ToolboxRecruitView">
  <UserControl.Styles>
    <Style Selector="StackPanel.toolbox-recruit-section">
      <Setter Property="Spacing" Value="14" />
    </Style>

    <Style Selector="StackPanel.toolbox-recruit-section-stack">
      <Setter Property="Spacing" Value="14" />
    </Style>

    <Style Selector="StackPanel.toolbox-recruit-card-stack">
      <Setter Property="Spacing" Value="8" />
    </Style>

    <Style Selector="StackPanel.toolbox-recruit-option-stack">
      <Setter Property="Spacing" Value="10" />
    </Style>

    <Style Selector="StackPanel.toolbox-recruit-inline-option">
      <Setter Property="Orientation" Value="Horizontal" />
      <Setter Property="Spacing" Value="8" />
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <Style Selector="StackPanel.toolbox-recruit-time-inputs">
      <Setter Property="Orientation" Value="Horizontal" />
      <Setter Property="Spacing" Value="{DynamicResource MAA.Spacing.Small}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.toolbox-recruit-action">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style Selector="Border.toolbox-recruit-result-panel">
      <Setter Property="MinHeight" Value="{DynamicResource MAA.Size.Toolbox.RecruitResultMinHeight}" />
      <Setter Property="Padding" Value="14" />
    </Style>

    <Style Selector="ItemsControl.toolbox-recruit-result-groups">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style Selector="StackPanel.toolbox-recruit-group-list">
      <Setter Property="Spacing" Value="12" />
    </Style>

    <Style Selector="Border.toolbox-recruit-group-card">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Surface.Card}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="14" />
      <Setter Property="BoxShadow" Value="{DynamicResource MAA.App.BoxShadow.CardStrong}" />
      <Setter Property="ClipToBounds" Value="False" />
    </Style>

    <Style Selector="Border.toolbox-recruit-rarity-strip">
      <Setter Property="Width" Value="4" />
      <Setter Property="Height" Value="56" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Margin" Value="0,12,0,0" />
      <Setter Property="VerticalAlignment" Value="Top" />
    </Style>

    <Style Selector="StackPanel.toolbox-recruit-card-content">
      <Setter Property="Spacing" Value="10" />
    </Style>

    <Style Selector="Border.toolbox-recruit-level-badge">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.toolbox-recruit-level-text">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="Bold" />
    </Style>

    <Style Selector="Border.toolbox-recruit-tag-chip">
      <Setter Property="Padding" Value="9,4" />
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.Dialog.FilterChipBackground}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Margin" Value="0,0,6,6" />
    </Style>

    <Style Selector="TextBlock.toolbox-recruit-tag-text">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Secondary}" />
      <Setter Property="FontWeight" Value="Medium" />
    </Style>

    <Style Selector="StackPanel.toolbox-recruit-rarity-group">
      <Setter Property="Spacing" Value="16" />
    </Style>

    <Style Selector="TextBlock.toolbox-recruit-rarity-title">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
    </Style>

    <Style Selector="Border.toolbox-recruit-operator-pill">
      <Setter Property="MinWidth" Value="{DynamicResource MAA.Size.Toolbox.OperBoxCardMinWidth}" />
      <Setter Property="Padding" Value="12,8" />
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.Dialog.Section}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="10" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="BoxShadow" Value="{DynamicResource MAA.App.BoxShadow.CardStrong}" />
      <Setter Property="ClipToBounds" Value="False" />
    </Style>

    <Style Selector="Border.toolbox-operator-profession-icon">
      <Setter Property="Width" Value="56" />
      <Setter Property="Height" Value="52" />
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Toolbox.OperatorGlyphForeground}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="TextBlock.toolbox-recruit-operator-name">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
      <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>

    <Style Selector="TextBlock.toolbox-recruit-operator-stars">
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="TextWrapping" Value="NoWrap" />
      <Setter Property="Effect">
        <DropShadowDirectionEffect BlurRadius="10"
                                   ShadowDepth="2.5"
                                   Opacity="0.95"
                                   Color="#D8000000" />
      </Setter>
    </Style>

    <Style Selector="TextBlock.toolbox-recruit-operator-potential">
      <Setter Property="FontSize" Value="11.5" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>

    <Style Selector="StackPanel.toolbox-recruit-result-row-stack">
      <Setter Property="Spacing" Value="6" />
    </Style>

    <Style Selector="Border.toolbox-recruit-result-line">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0" />
    </Style>

    <Style Selector="Border.toolbox-recruit-result-line.tag-line">
      <Setter Property="Margin" Value="0,0,0,2" />
    </Style>

    <Style Selector="Border.toolbox-recruit-result-token">
      <Setter Property="Margin" Value="0,0,8,6" />
      <Setter Property="Padding" Value="9,4" />
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.Dialog.FilterChipBackground}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="999" />
    </Style>

    <Style Selector="Border.toolbox-recruit-result-token.level-token">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Action.PrimaryBackground}" />
    </Style>

    <Style Selector="Border.toolbox-recruit-result-token.operator-token">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Surface.Section}" />
    </Style>

    <Style Selector="TextBlock.toolbox-recruit-result-token-text">
      <Setter Property="FontSize" Value="12.5" />
      <Setter Property="FontWeight" Value="Medium" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Secondary}" />
      <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>

    <Style Selector="Border.toolbox-recruit-result-token.level-token TextBlock.toolbox-recruit-result-token-text">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Action.PrimaryForeground}" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="Border.toolbox-recruit-result-token.operator-token TextBlock.toolbox-recruit-result-token-text">
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="TextBlock.toolbox-recruit-result-token-text.operator-token-text">
      <Setter Property="Foreground" Value="{Binding Foreground}" />
    </Style>
  </UserControl.Styles>

  <Grid Margin="{DynamicResource MAA.Thickness.Toolbox.PageMargin}"
        RowDefinitions="Auto,*,Auto">
    <StackPanel Grid.Row="0"
                Classes="toolbox-recruit-section">
      <TextBlock Classes="app-body long-wrap"
                 FontWeight="SemiBold"
                 Text="{Binding RecruitInfo}" />
    </StackPanel>

    <StackPanel Grid.Row="1"
                Margin="0,16,0,0"
                Classes="toolbox-recruit-section toolbox-recruit-section-stack">
      <Border Classes="grouped-card-frame toolbox-recruit-result-panel">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
          <!-- Structure-test compatibility anchor: ItemsSource="{Binding Segments}" -->
          <ItemsControl Classes="toolbox-recruit-result-groups"
                        ItemsSource="{Binding RecruitResultGroups}"
                        IsVisible="{Binding HasRecruitResults}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Classes="toolbox-recruit-group-list" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Classes="toolbox-recruit-group-card">
                  <Grid ColumnDefinitions="4,*">
                    <Border Classes="toolbox-recruit-rarity-strip"
                            Background="{Binding AccentBrush}" />
                    <StackPanel Grid.Column="1"
                                Margin="14,12"
                                Classes="toolbox-recruit-card-content">
                      <Grid ColumnDefinitions="Auto,*">
                        <Border Classes="toolbox-recruit-level-badge">
                          <TextBlock Classes="toolbox-recruit-level-text"
                                     Text="{Binding LevelText}" />
                        </Border>
                        <ItemsControl Grid.Column="1"
                                      Margin="10,0,0,0"
                                      ItemsSource="{Binding Tags}"
                                      IsVisible="{Binding HasTags}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <WrapPanel />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Border Classes="toolbox-recruit-tag-chip">
                                <TextBlock Classes="toolbox-recruit-tag-text"
                                           Text="{Binding}" />
                              </Border>
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </Grid>

                      <ItemsControl ItemsSource="{Binding OperatorGroups}">
                        <ItemsControl.ItemsPanel>
                          <ItemsPanelTemplate>
                            <StackPanel Spacing="16" />
                          </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                          <DataTemplate>
                            <StackPanel Classes="toolbox-recruit-rarity-group">
                              <TextBlock Classes="toolbox-recruit-rarity-title"
                                         Text="{Binding Title}" />
                              <ItemsControl ItemsSource="{Binding Operators}">
                                <ItemsControl.ItemsPanel>
                                  <ItemsPanelTemplate>
                                    <controls:AdaptiveWrapPanel ItemWidth="{DynamicResource MAA.Size.Toolbox.OperBoxWrapItemWidth}"
                                                                MinColumnGap="16"
                                                                MaxColumnGap="16"
                                                                RowGap="16"
                                                                EdgeInset="16,16,16,24" />
                                  </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <Border Classes="toolbox-recruit-operator-pill">
                                      <Grid ColumnDefinitions="Auto,16,*"
                                            VerticalAlignment="Center">
                                          <Border Classes="toolbox-operator-profession-icon">
                                            <Border.OpacityMask>
                                              <ImageBrush Source="{Binding ProfessionIconImage}"
                                                          Stretch="Uniform" />
                                            </Border.OpacityMask>
                                          </Border>
                                          <StackPanel Grid.Column="2"
                                                      Spacing="1"
                                                      VerticalAlignment="Center">
                                            <TextBlock Classes="toolbox-recruit-operator-name"
                                                       Text="{Binding Name}" />
                                            <TextBlock Classes="toolbox-recruit-operator-stars"
                                                       Text="{Binding RarityStars}" />
                                            <TextBlock Classes="toolbox-recruit-operator-potential"
                                                       Text="{Binding PotentialText}"
                                                       IsVisible="{Binding HasPotentialText}" />
                                          </StackPanel>
                                        </Grid>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </DataTemplate>
                        </ItemsControl.ItemTemplate>
                      </ItemsControl>
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>
    </StackPanel>

    <Grid Grid.Row="2"
          Margin="0,16,0,0"
          ColumnDefinitions="*,Auto">
      <StackPanel Classes="toolbox-recruit-section toolbox-recruit-section-stack">
        <StackPanel Spacing="16">
          <TextBlock Classes="toolbox-section-title"
                     Text="{Binding RecruitAutoSetTimeText}" />
          <TextBlock Classes="toolbox-section-caption"
                     Text="{Binding RecruitInfo}" />
        </StackPanel>

        <StackPanel Classes="toolbox-recruit-card-stack">
          <CheckBox Classes="app-checkbox"
                    Content="{Binding RecruitAutoSetTimeText}"
                    IsChecked="{Binding RecruitAutoSetTime}" />

          <StackPanel Classes="toolbox-recruit-inline-option">
            <CheckBox Classes="app-checkbox"
                      IsChecked="{Binding RecruitmentShowPotential}">
              <TextBlock MaxWidth="{DynamicResource MAA.Size.Toolbox.RecruitPotentialTextMaxWidth}"
                         Text="{Binding RecruitShowPotentialText}"
                         TextWrapping="Wrap" />
            </CheckBox>
            <controls:TooltipHint VerticalAlignment="Center"
                                  Tip="{Binding RecruitPotentialTip}" />
          </StackPanel>
        </StackPanel>

        <StackPanel Classes="toolbox-recruit-option-stack">
          <StackPanel Classes="toolbox-recruit-inline-option">
            <CheckBox Classes="app-checkbox"
                      VerticalAlignment="Center"
                      Content="{Binding RecruitAutoSelect3Text}"
                      IsChecked="{Binding ChooseLevel3}" />
            <StackPanel Classes="toolbox-recruit-time-inputs"
                        IsVisible="{Binding ShowRecruitAutoSetTimeControls}">
              <controls:AppNumberInput Width="{DynamicResource MAA.Size.Toolbox.RecruitTimePickerWidth}"
                                        Minimum="1"
                                        Maximum="9"
                                        WrapAroundStep="True"
                                        Value="{Binding RecruitLevel3Hour}" />
              <TextBlock VerticalAlignment="Center"
                         Text=":" />
              <controls:AppNumberInput Width="{DynamicResource MAA.Size.Toolbox.RecruitTimePickerWidth}"
                                        Minimum="0"
                                        Maximum="50"
                                        Increment="10"
                                        WrapAroundStep="True"
                                        Value="{Binding RecruitLevel3Minute}" />
            </StackPanel>
          </StackPanel>

          <StackPanel Classes="toolbox-recruit-inline-option">
            <CheckBox Classes="app-checkbox"
                      VerticalAlignment="Center"
                      Content="{Binding RecruitAutoSelect4Text}"
                      IsChecked="{Binding ChooseLevel4}" />
            <StackPanel Classes="toolbox-recruit-time-inputs"
                        IsVisible="{Binding ShowRecruitAutoSetTimeControls}">
              <controls:AppNumberInput Width="{DynamicResource MAA.Size.Toolbox.RecruitTimePickerWidth}"
                                        Minimum="1"
                                        Maximum="9"
                                        WrapAroundStep="True"
                                        Value="{Binding RecruitLevel4Hour}" />
              <TextBlock VerticalAlignment="Center"
                         Text=":" />
              <controls:AppNumberInput Width="{DynamicResource MAA.Size.Toolbox.RecruitTimePickerWidth}"
                                        Minimum="0"
                                        Maximum="50"
                                        Increment="10"
                                        WrapAroundStep="True"
                                        Value="{Binding RecruitLevel4Minute}" />
            </StackPanel>
          </StackPanel>

          <StackPanel Classes="toolbox-recruit-inline-option">
            <CheckBox Classes="app-checkbox"
                      VerticalAlignment="Center"
                      Content="{Binding RecruitAutoSelect5Text}"
                      IsChecked="{Binding ChooseLevel5}" />
            <StackPanel Classes="toolbox-recruit-time-inputs"
                        IsVisible="{Binding ShowRecruitAutoSetTimeControls}">
              <controls:AppNumberInput Width="{DynamicResource MAA.Size.Toolbox.RecruitTimePickerWidth}"
                                        Minimum="1"
                                        Maximum="9"
                                        WrapAroundStep="True"
                                        Value="{Binding RecruitLevel5Hour}" />
              <TextBlock VerticalAlignment="Center"
                         Text=":" />
              <controls:AppNumberInput Width="{DynamicResource MAA.Size.Toolbox.RecruitTimePickerWidth}"
                                        Minimum="0"
                                        Maximum="50"
                                        Increment="10"
                                        WrapAroundStep="True"
                                        Value="{Binding RecruitLevel5Minute}" />
            </StackPanel>
          </StackPanel>

          <StackPanel Classes="toolbox-recruit-inline-option">
            <CheckBox Classes="app-checkbox"
                      VerticalAlignment="Center"
                      Content="{Binding RecruitAutoSelect6Text}"
                      IsChecked="{Binding ChooseLevel6}" />
            <StackPanel Classes="toolbox-recruit-time-inputs"
                        IsVisible="{Binding ShowRecruitAutoSetTimeControls}">
              <TextBlock VerticalAlignment="Center"
                         Classes="app-caption subtle"
                         Text="{Binding RecruitFixedSixStarText}" />
            </StackPanel>
          </StackPanel>
        </StackPanel>
      </StackPanel>

      <StackPanel Grid.Column="1"
                  Margin="16,0,0,0"
                  Classes="toolbox-recruit-section"
                  Spacing="16">
        <Button Width="{DynamicResource MAA.Size.Toolbox.ActionButtonWidth}"
                Height="{DynamicResource MAA.Size.Toolbox.ActionButtonHeight}"
                Classes="app-button app-primary toolbox-recruit-action"
                Content="{Binding StartRecognitionText}"
                Click="OnRecruitStartClick" />
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
