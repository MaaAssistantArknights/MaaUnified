<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Advanced.ToolboxMiniGameView">
  <UserControl.Styles>
    <Style Selector="Border.toolbox-minigame-section">
      <Setter Property="Padding" Value="22" />
    </Style>

    <Style Selector="Border.toolbox-minigame-card">
      <Setter Property="Padding" Value="16" />
    </Style>

    <Style Selector="Border.toolbox-minigame-action-card">
      <Setter Property="Padding" Value="18" />
    </Style>

    <Style Selector="StackPanel.toolbox-minigame-section-stack">
      <Setter Property="Spacing" Value="16" />
    </Style>

    <Style Selector="StackPanel.toolbox-minigame-card-stack">
      <Setter Property="Spacing" Value="12" />
    </Style>

    <Style Selector="TextBlock.toolbox-minigame-field-label">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Secondary}" />
    </Style>

    <Style Selector="ComboBox.toolbox-minigame-selector">
      <Setter Property="MinWidth" Value="220" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style Selector="Button.toolbox-minigame-action">
      <Setter Property="MinWidth" Value="{DynamicResource MAA.Size.Toolbox.MiniGameButtonWidth}" />
      <Setter Property="Height" Value="{DynamicResource MAA.Size.Toolbox.MiniGameButtonHeight}" />
      <Setter Property="HorizontalAlignment" Value="Center" />
    </Style>
  </UserControl.Styles>

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Width="{DynamicResource MAA.Size.Toolbox.FormPanelWidth}"
                Margin="4"
                HorizontalAlignment="Center"
                Spacing="14">
      <Border Classes="app-surface app-section toolbox-minigame-section">
        <StackPanel Classes="toolbox-minigame-section-stack">
          <TextBlock Classes="app-window-title"
                     Text="{Binding MiniGameNameText}" />

          <Border Classes="app-surface app-card toolbox-minigame-card">
            <ComboBox Classes="app-input toolbox-minigame-selector"
                      ItemsSource="{Binding MiniGameTaskList}"
                      SelectedValueBinding="{Binding Value}"
                      SelectedValue="{Binding MiniGameTaskName}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Display}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Border>
        </StackPanel>
      </Border>

      <Border Classes="app-surface app-section toolbox-minigame-section"
              IsVisible="{Binding IsMiniGameSecretFront}">
        <StackPanel Classes="toolbox-minigame-section-stack">
          <Border Classes="app-badge"
                  HorizontalAlignment="Left">
            <TextBlock Classes="app-badge-text"
                       Text="{Binding SelectedMiniGameEntry.Display}" />
          </Border>

          <Border Classes="app-surface app-card toolbox-minigame-card">
            <StackPanel Classes="toolbox-minigame-card-stack">
              <Grid ColumnDefinitions="140,*">
                <TextBlock Classes="app-caption toolbox-minigame-field-label"
                           Text="{Binding MiniGameEndingText}" />
                <ComboBox Grid.Column="1"
                          Classes="app-input toolbox-minigame-selector"
                          Margin="12,0,0,0"
                          ItemsSource="{Binding MiniGameSecretFrontEndingOptions}"
                          SelectedItem="{Binding MiniGameSecretFrontEnding}" />
              </Grid>

              <Grid ColumnDefinitions="140,*">
                <TextBlock Classes="app-caption toolbox-minigame-field-label"
                           Text="{Binding MiniGameEventPriorityText}" />
                <ComboBox Grid.Column="1"
                          Classes="app-input toolbox-minigame-selector"
                          Margin="12,0,0,0"
                          ItemsSource="{Binding MiniGameSecretFrontEventOptions}"
                          SelectedValueBinding="{Binding Value}"
                          SelectedValue="{Binding MiniGameSecretFrontEvent}">
                  <ComboBox.ItemTemplate>
                    <DataTemplate>
                      <TextBlock Text="{Binding Label}" />
                    </DataTemplate>
                  </ComboBox.ItemTemplate>
                </ComboBox>
              </Grid>
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <Border Classes="app-surface app-section toolbox-minigame-section">
        <StackPanel Classes="toolbox-minigame-section-stack">
          <Border Classes="app-badge"
                  HorizontalAlignment="Left">
            <TextBlock Classes="app-badge-text"
                       Text="{Binding SelectedMiniGameEntry.Display}" />
          </Border>

          <Border Classes="app-surface app-card toolbox-minigame-card">
            <TextBlock Classes="app-body long-wrap"
                       Text="{Binding MiniGameTip}" />
          </Border>
        </StackPanel>
      </Border>

      <Border Classes="app-surface app-section toolbox-minigame-section">
        <Border Classes="app-surface app-card toolbox-minigame-action-card">
          <Button Classes="app-button app-primary toolbox-minigame-action"
                  Content="{Binding MiniGameCommandText}"
                  Click="OnMiniGameCommandClick" />
        </Border>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
