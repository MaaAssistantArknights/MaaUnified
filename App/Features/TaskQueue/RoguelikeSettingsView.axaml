<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             xmlns:vm="clr-namespace:MAAUnified.App.ViewModels.TaskQueue"
             x:Class="MAAUnified.App.Features.TaskQueue.RoguelikeSettingsView">
  <UserControl.Styles>
  </UserControl.Styles>

  <ScrollViewer HorizontalScrollBarVisibility="Disabled">
    <Grid RowDefinitions="Auto,Auto" Margin="2">
      <TextBlock Classes="section-title" Text="{Binding Texts[Roguelike.Title]}" />

      <controls:AdaptiveSpacingStackPanel Grid.Row="1"
                  Classes="settings-form roguelike-layout"
                  Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}">
        <controls:AdaptiveSpacingStackPanel IsVisible="{Binding IsGeneralMode}" Classes="roguelike-section-content">
          <Border Classes="app-surface app-card">
            <controls:AdaptiveSpacingStackPanel Classes="roguelike-card-content">
              <controls:SettingsInlineRow>
                <TextBlock Classes="settings-field-caption" Text="{Binding Texts[Roguelike.Theme]}" />
                <controls:AppSelect ItemsSource="{Binding ThemeOptions}"
                                    SelectedValueBinding="{Binding Type}"
                                    SelectedValue="{Binding Theme}">
                  <controls:AppSelect.ItemTemplate>
                    <DataTemplate x:DataType="vm:TaskModuleOption">
                      <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                  </controls:AppSelect.ItemTemplate>
                </controls:AppSelect>
              </controls:SettingsInlineRow>

              <controls:SettingsInlineRow>
                <TextBlock Classes="settings-field-caption"
                           Margin="0"
                           TextWrapping="Wrap">
                  <Run Text="{Binding Texts[Roguelike.Difficulty]}" />
                  <Run Text="&#160;" />
                  <InlineUIContainer BaselineAlignment="Center">
                    <controls:TooltipHint IsVisible="{Binding ShowJieGardenDifficultyTip}"
                                          Tip="{Binding Texts[Roguelike.JieGardenDifficultyTip]}" />
                  </InlineUIContainer>
                </TextBlock>
                <controls:AppSelect ItemsSource="{Binding DifficultyOptions}"
                                    SelectedValueBinding="{Binding Value}"
                                    SelectedValue="{Binding Difficulty}">
                  <controls:AppSelect.ItemTemplate>
                    <DataTemplate x:DataType="vm:RoguelikeModuleViewModel+IntOption">
                      <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                  </controls:AppSelect.ItemTemplate>
                </controls:AppSelect>
              </controls:SettingsInlineRow>

              <controls:SettingsInlineRow FieldWidth="{DynamicResource MAA.Size.Settings.FieldWideWidth}">
                <TextBlock Classes="settings-field-caption" Text="{Binding Texts[Roguelike.Mode]}" />
                <controls:AppSelect ItemsSource="{Binding ModeOptions}"
                                    SelectedValueBinding="{Binding Value}"
                                    SelectedValue="{Binding Mode}">
                  <controls:AppSelect.ItemTemplate>
                    <DataTemplate x:DataType="vm:RoguelikeModuleViewModel+IntOption">
                      <TextBlock Text="{Binding DisplayName}" TextWrapping="Wrap" />
                    </DataTemplate>
                  </controls:AppSelect.ItemTemplate>
                </controls:AppSelect>
              </controls:SettingsInlineRow>

              <controls:SettingsInlineRow IsVisible="{Binding ShowCollectibleModeSquad}">
                <TextBlock Classes="settings-field-caption"
                           Text="{Binding Texts[Roguelike.CollectibleModeSquad]}" />
                <controls:AppSelect ItemsSource="{Binding SquadOptions}"
                                    SelectedValueBinding="{Binding Type}"
                                    SelectedValue="{Binding CollectibleModeSquad}">
                  <controls:AppSelect.ItemTemplate>
                    <DataTemplate x:DataType="vm:TaskModuleOption">
                      <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                  </controls:AppSelect.ItemTemplate>
                </controls:AppSelect>
              </controls:SettingsInlineRow>
            </controls:AdaptiveSpacingStackPanel>
          </Border>

          <Border Classes="app-surface app-card">
            <controls:AdaptiveSpacingStackPanel Classes="roguelike-card-content">
              <controls:SettingsInlineRow>
                <TextBlock Classes="settings-field-caption" Text="{Binding Texts[Roguelike.Squad]}" />
                <controls:AppSelect ItemsSource="{Binding SquadOptions}"
                                    SelectedValueBinding="{Binding Type}"
                                    SelectedValue="{Binding Squad}">
                  <controls:AppSelect.ItemTemplate>
                    <DataTemplate x:DataType="vm:TaskModuleOption">
                      <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                  </controls:AppSelect.ItemTemplate>
                </controls:AppSelect>
              </controls:SettingsInlineRow>

              <controls:SettingsInlineRow FieldWidth="{DynamicResource MAA.Size.Settings.FieldWideWidth}">
                <TextBlock Classes="settings-field-caption" Text="{Binding Texts[Roguelike.Roles]}" />
                <controls:AppSelect ItemsSource="{Binding RolesOptions}"
                                    SelectedValueBinding="{Binding Type}"
                                    SelectedValue="{Binding Roles}">
                  <controls:AppSelect.ItemTemplate>
                    <DataTemplate x:DataType="vm:TaskModuleOption">
                      <TextBlock Text="{Binding DisplayName}" TextWrapping="Wrap" />
                    </DataTemplate>
                  </controls:AppSelect.ItemTemplate>
                </controls:AppSelect>
              </controls:SettingsInlineRow>

              <controls:SettingsInlineRow IsVisible="{Binding ShowFindPlayTimeTarget}"
                                          FieldWidth="{DynamicResource MAA.Size.Settings.FieldWideWidth}">
                <TextBlock Classes="settings-field-caption"
                           Text="{Binding Texts[Roguelike.FindPlayTimeTarget]}" />
                <controls:AppSelect ItemsSource="{Binding FindPlayTimeTargetOptions}"
                                    SelectedValueBinding="{Binding Value}"
                                    SelectedValue="{Binding FindPlayTimeTarget}">
                  <controls:AppSelect.ItemTemplate>
                    <DataTemplate x:DataType="vm:RoguelikeModuleViewModel+IntOption">
                      <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                  </controls:AppSelect.ItemTemplate>
                </controls:AppSelect>
              </controls:SettingsInlineRow>

              <controls:SettingsInlineRow FieldWidth="{DynamicResource MAA.Size.Settings.FieldWideWidth}">
                <TextBlock Classes="settings-field-caption"
                           Margin="0"
                           TextWrapping="Wrap">
                  <Run Text="{Binding Texts[Roguelike.CoreChar]}" />
                  <Run Text="&#160;" />
                  <InlineUIContainer BaselineAlignment="Center">
                    <controls:TooltipHint Tip="{Binding CoreCharTipText}" />
                  </InlineUIContainer>
                </TextBlock>
                <controls:AppSuggestInput ItemsSource="{Binding CoreCharNameOptions}"
                                          MinimumPrefixLength="0"
                                          Text="{Binding CoreCharDisplayText, UpdateSourceTrigger=PropertyChanged}" />
              </controls:SettingsInlineRow>
            </controls:AdaptiveSpacingStackPanel>
          </Border>
        </controls:AdaptiveSpacingStackPanel>

        <controls:AdaptiveSpacingStackPanel IsVisible="{Binding IsAdvancedMode}" Classes="roguelike-section-content">
          <Border Classes="app-surface app-card">
            <controls:AdaptiveSpacingStackPanel Classes="roguelike-card-content">
              <controls:SettingsInlineRow>
                <TextBlock Classes="settings-field-caption" Text="{Binding Texts[Roguelike.StartsCount]}" />
                <controls:AppNumberInput Minimum="0"
                                         Maximum="9999999"
                                         Value="{Binding StartsCount}" />
              </controls:SettingsInlineRow>

              <CheckBox Classes="app-checkbox"
                        Content="{Binding Texts[Roguelike.InvestmentEnabled]}"
                        IsChecked="{Binding InvestmentEnabled}"
                        IsEnabled="{Binding CanToggleInvestmentEnabled}" />
              <CheckBox Classes="app-checkbox"
                        Content="{Binding Texts[Roguelike.StopWhenInvestmentFull]}"
                        IsChecked="{Binding StopWhenInvestmentFull}"
                        IsVisible="{Binding ShowStopWhenInvestmentFull}" />
              <CheckBox Classes="app-checkbox"
                        Content="{Binding Texts[Roguelike.InvestmentWithMoreScore]}"
                        IsChecked="{Binding InvestmentWithMoreScore}"
                        IsVisible="{Binding ShowInvestmentWithMoreScore}" />
              <CheckBox Classes="app-checkbox"
                        Content="{Binding Texts[Roguelike.CollectibleModeShopping]}"
                        IsChecked="{Binding CollectibleModeShopping}"
                        IsVisible="{Binding ShowCollectibleModeShopping}" />

              <controls:SettingsInlineRow IsVisible="{Binding ShowInvestmentsCount}">
                <TextBlock Classes="settings-field-caption"
                           Text="{Binding Texts[Roguelike.InvestmentsCount]}" />
                <controls:AppNumberInput Minimum="0"
                                         Maximum="999999"
                                         Value="{Binding InvestmentsCount}" />
              </controls:SettingsInlineRow>

              <CheckBox Classes="app-checkbox"
                        Content="{Binding Texts[Roguelike.RefreshTraderWithDice]}"
                        IsChecked="{Binding RefreshTraderWithDice}"
                        IsVisible="{Binding ShowRefreshTraderWithDice}" />

              <CheckBox Classes="app-checkbox"
                        Content="{Binding Texts[Roguelike.StartWithEliteTwo]}"
                        IsChecked="{Binding StartWithEliteTwo}"
                        IsVisible="{Binding ShowStartWithEliteTwo}" />
              <CheckBox Classes="app-checkbox"
                        Content="{Binding Texts[Roguelike.OnlyStartWithEliteTwo]}"
                        IsChecked="{Binding OnlyStartWithEliteTwo}"
                        IsVisible="{Binding ShowOnlyStartWithEliteTwoOption}" />

              <controls:AppMultiSelectDropdown IsVisible="{Binding ShowCollectibleStartRewardOptions}"
                                                HeaderText="{Binding CollectibleStartRewardSummary}">
                <controls:AppMultiSelectDropdown.DropDownContent>
                  <controls:AdaptiveSpacingStackPanel Classes="roguelike-card-content">
                    <CheckBox Classes="app-checkbox"
                              Content="{Binding Texts[Roguelike.Collectible.HotWater]}"
                              IsChecked="{Binding CollectibleHotWater}"
                              IsVisible="{Binding ShowCollectibleHotWater}" />
                    <CheckBox Classes="app-checkbox"
                              Content="{Binding Texts[Roguelike.Collectible.Shield]}"
                              IsChecked="{Binding CollectibleShield}"
                              IsVisible="{Binding ShowCollectibleShield}" />
                    <CheckBox Classes="app-checkbox"
                              Content="{Binding Texts[Roguelike.Collectible.Ingot]}"
                              IsChecked="{Binding CollectibleIngot}"
                              IsVisible="{Binding ShowCollectibleIngot}" />
                    <CheckBox Classes="app-checkbox"
                              Content="{Binding Texts[Roguelike.Collectible.Hope]}"
                              IsChecked="{Binding CollectibleHope}"
                              IsVisible="{Binding ShowCollectibleHope}" />
                    <CheckBox Classes="app-checkbox"
                              Content="{Binding Texts[Roguelike.Collectible.Random]}"
                              IsChecked="{Binding CollectibleRandom}"
                              IsVisible="{Binding ShowCollectibleRandom}" />
                    <CheckBox Classes="app-checkbox"
                              Content="{Binding Texts[Roguelike.Collectible.Key]}"
                              IsChecked="{Binding CollectibleKey}"
                              IsVisible="{Binding ShowCollectibleKey}" />
                    <CheckBox Classes="app-checkbox"
                              Content="{Binding Texts[Roguelike.Collectible.Dice]}"
                              IsChecked="{Binding CollectibleDice}"
                              IsVisible="{Binding ShowCollectibleDice}" />
                    <CheckBox Classes="app-checkbox"
                              Content="{Binding Texts[Roguelike.Collectible.Ideas]}"
                              IsChecked="{Binding CollectibleIdeas}"
                              IsVisible="{Binding ShowCollectibleIdeas}" />
                    <CheckBox Classes="app-checkbox"
                              Content="{Binding Texts[Roguelike.Collectible.Ticket]}"
                              IsChecked="{Binding CollectibleTicket}"
                              IsVisible="{Binding ShowCollectibleTicket}" />
                  </controls:AdaptiveSpacingStackPanel>
                </controls:AppMultiSelectDropdown.DropDownContent>
              </controls:AppMultiSelectDropdown>
            </controls:AdaptiveSpacingStackPanel>
          </Border>

          <Border Classes="app-surface app-card">
            <controls:AdaptiveSpacingStackPanel Classes="roguelike-card-content">
              <controls:AdaptiveSpacingStackPanel Classes="roguelike-card-content">
                <CheckBox Classes="app-checkbox"
                          Content="{Binding Texts[Roguelike.FirstFloorFoldartal]}"
                          IsChecked="{Binding FirstFloorFoldartalEnabled}"
                          IsVisible="{Binding ShowFirstFloorFoldartalToggle}" />
                <controls:AppTextInput MaxWidth="{DynamicResource MAA.Size.Settings.FieldWideWidth}"
                                       HorizontalAlignment="Stretch"
                                       IsVisible="{Binding ShowFirstFloorFoldartalText}"
                                       Text="{Binding FirstFloorFoldartal, UpdateSourceTrigger=LostFocus}" />
              </controls:AdaptiveSpacingStackPanel>

              <controls:AdaptiveSpacingStackPanel Classes="roguelike-card-content">
                <controls:AppHintedCheckBox HorizontalAlignment="Left"
                                             Text="{Binding Texts[Roguelike.StartFoldartalList]}"
                                             Tip="{Binding Texts[Roguelike.StartFoldartalTip]}"
                                             IsChecked="{Binding StartFoldartalListEnabled}"
                                             IsVisible="{Binding ShowStartFoldartalListToggle}" />
                <controls:AppTextInput MaxWidth="{DynamicResource MAA.Size.Settings.FieldWideWidth}"
                                       HorizontalAlignment="Stretch"
                                       IsVisible="{Binding ShowStartFoldartalListText}"
                                       Text="{Binding StartFoldartalListText, UpdateSourceTrigger=LostFocus}" />
              </controls:AdaptiveSpacingStackPanel>

              <controls:SettingsInlineRow IsVisible="{Binding ShowExpectedCollapsalParadigms}"
                                          FieldWidth="{DynamicResource MAA.Size.Settings.FieldWideWidth}">
                <TextBlock Classes="settings-field-caption"
                           Margin="0"
                           TextWrapping="Wrap">
                  <Run Text="{Binding Texts[Roguelike.ExpectedCollapsalParadigms]}" />
                  <Run Text="&#160;" />
                  <InlineUIContainer BaselineAlignment="Center">
                    <controls:TooltipHint Tip="{Binding Texts[Roguelike.ExpectedCollapsalParadigmsTip]}" />
                  </InlineUIContainer>
                </TextBlock>
                <controls:AppTextInput Text="{Binding ExpectedCollapsalParadigmsText, UpdateSourceTrigger=LostFocus}" />
              </controls:SettingsInlineRow>

              <controls:AdaptiveSpacingStackPanel Classes="roguelike-card-content">
                <CheckBox Classes="app-checkbox"
                          Content="{Binding Texts[Roguelike.StartWithSeed]}"
                          IsChecked="{Binding StartWithSeedEnabled}"
                          IsVisible="{Binding ShowStartWithSeedToggle}" />
                <controls:AppTextInput MaxWidth="{DynamicResource MAA.Size.Settings.FieldWideWidth}"
                                       HorizontalAlignment="Stretch"
                                       IsVisible="{Binding ShowStartWithSeedInput}"
                                       Text="{Binding StartWithSeed, UpdateSourceTrigger=PropertyChanged}" />
              </controls:AdaptiveSpacingStackPanel>
            </controls:AdaptiveSpacingStackPanel>
          </Border>

          <Border Classes="app-surface app-card">
            <controls:AdaptiveSpacingStackPanel Classes="roguelike-card-content">
              <controls:AppHintedCheckBox HorizontalAlignment="Left"
                                           Text="{Binding Texts[Roguelike.UseSupport]}"
                                           Tip="{Binding Texts[Roguelike.UseSupportTip]}"
                                           IsChecked="{Binding UseSupport}"
                                           CheckBoxIsEnabled="{Binding CanUseSupport}" />

              <Grid HorizontalAlignment="Left"
                    ColumnDefinitions="Auto,*"
                    IsVisible="{Binding ShowUseNonfriendSupport}">
                <TextBlock Margin="0,0,4,0" Text="└" />
                <CheckBox Grid.Column="1"
                          Classes="app-checkbox"
                          Content="{Binding Texts[Roguelike.UseNonfriendSupport]}"
                          IsChecked="{Binding UseNonfriendSupport}" />
              </Grid>

              <CheckBox Classes="app-checkbox"
                        Content="{Binding Texts[Roguelike.StopAtFinalBoss]}"
                        IsChecked="{Binding StopAtFinalBoss}"
                        IsVisible="{Binding ShowStopAtFinalBoss}" />
              <CheckBox Classes="app-checkbox"
                        Content="{Binding Texts[Roguelike.MonthlySquadAutoIterate]}"
                        IsChecked="{Binding MonthlySquadAutoIterate}"
                        IsVisible="{Binding ShowMonthlySquadAutoIterate}" />
              <CheckBox Classes="app-checkbox"
                        Content="{Binding Texts[Roguelike.MonthlySquadCheckComms]}"
                        IsChecked="{Binding MonthlySquadCheckComms}"
                        IsVisible="{Binding ShowMonthlySquadCheckComms}" />
              <CheckBox Classes="app-checkbox"
                        Content="{Binding Texts[Roguelike.DeepExplorationAutoIterate]}"
                        IsChecked="{Binding DeepExplorationAutoIterate}"
                        IsVisible="{Binding ShowDeepExplorationAutoIterate}" />
              <CheckBox Classes="app-checkbox"
                        Content="{Binding Texts[Roguelike.StopAtMaxLevel]}"
                        IsChecked="{Binding StopAtMaxLevel}"
                        IsVisible="{Binding ShowStopAtMaxLevel}" />

              <TextBlock Classes="settings-note settings-centered-text long-wrap"
                         FontWeight="Bold"
                         Text="{Binding Texts[Roguelike.MultiTaskSharedTip]}"
                         TextAlignment="Left" />
              <CheckBox Classes="app-checkbox"
                        Content="{Binding Texts[Roguelike.DelayAbortUntilCombatComplete]}"
                        IsChecked="{Binding DelayAbortUntilCombatComplete}" />
            </controls:AdaptiveSpacingStackPanel>
          </Border>
        </controls:AdaptiveSpacingStackPanel>

        <controls:AdaptiveSpacingStackPanel Spacing="4">
            <controls:AdaptiveSpacingStackPanel IsVisible="{Binding HasValidationIssues}" Spacing="4">
              <TextBlock Classes="state-warning settings-centered-text"
                         Text="{Binding Texts[Common.ValidationIssues]}" />
              <ListBox MaxHeight="96" ItemsSource="{Binding ValidationMessages}" />
            </controls:AdaptiveSpacingStackPanel>
            <TextBlock Classes="settings-note settings-centered-text long-wrap"
                       Text="{Binding StatusMessage}" />
        </controls:AdaptiveSpacingStackPanel>
      </controls:AdaptiveSpacingStackPanel>
    </Grid>
  </ScrollViewer>
</UserControl>
