<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             x:Class="MAAUnified.App.Features.TaskQueue.PostActionSettingsView">
  <UserControl.Styles>
    <Style Selector="StackPanel.post-action-layout">
      <Setter Property="Spacing" Value="{DynamicResource MAA.App.Settings.PageFlowSpacing}" />
    </Style>

    <Style Selector="StackPanel.post-action-title-stack">
      <Setter Property="Spacing" Value="{DynamicResource MAA.App.Settings.PageCompactFlowSpacing}" />
    </Style>

    <Style Selector="controls|AdaptiveSpacingStackPanel.post-action-toggle-stack">
      <Setter Property="Spacing" Value="{DynamicResource MAA.App.Settings.PageToggleStackSpacing}" />
    </Style>

    <Style Selector="Border.post-action-status-block">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>

    <Style Selector="controls|AdaptiveSpacingStackPanel.post-action-status-list">
      <Setter Property="Spacing" Value="8" />
    </Style>
  </UserControl.Styles>

  <StackPanel Margin="4" Classes="post-action-layout">
    <StackPanel Classes="post-action-title-stack">
      <TextBlock Classes="section-title" Text="{Binding Texts[PostAction.Title]}" />

      <controls:AppHintedCheckBox Text="{Binding Texts[PostAction.Once]}"
                                   Tip="{Binding Texts[PostAction.OnceTip]}"
                                   IsChecked="{Binding Once}" />
    </StackPanel>

    <controls:AdaptiveSpacingStackPanel Classes="post-action-toggle-stack">
      <CheckBox Classes="app-checkbox"
                Content="{Binding Texts[PostAction.BackToHome]}"
                IsChecked="{Binding BackToAndroidHome}" />
      <CheckBox Classes="app-checkbox"
                Content="{Binding Texts[PostAction.ExitArknights]}"
                IsChecked="{Binding ExitArknights}" />
      <CheckBox Classes="app-checkbox"
                Content="{Binding Texts[PostAction.ExitEmulator]}"
                IsChecked="{Binding ExitEmulator}"
                IsVisible="{Binding ShowExitEmulator}" />
      <CheckBox Classes="app-checkbox"
                Content="{Binding Texts[PostAction.ExitSelf]}"
                IsChecked="{Binding ExitSelf}" />
      <CheckBox Classes="app-checkbox"
                Content="{Binding Texts[PostAction.IfNoOther]}"
                IsChecked="{Binding IfNoOtherMaa}"
                IsEnabled="{Binding CanUseIfNoOtherMaa}" />
    </controls:AdaptiveSpacingStackPanel>

    <controls:AdaptiveSpacingStackPanel Classes="post-action-toggle-stack">
      <CheckBox Classes="app-checkbox"
                Content="{Binding Texts[PostAction.Sleep]}"
                IsChecked="{Binding Sleep}" />

      <controls:AppHintedCheckBox Text="{Binding Texts[PostAction.Hibernate]}"
                                   Tip="{Binding Texts[PostAction.HibernateTip]}"
                                   IsChecked="{Binding Hibernate}"
                                   IsVisible="{Binding ShowHibernate}" />

      <CheckBox Classes="app-checkbox"
                Content="{Binding Texts[PostAction.Shutdown]}"
                IsChecked="{Binding Shutdown}" />
    </controls:AdaptiveSpacingStackPanel>

    <Button Classes="app-button app-secondary"
            HorizontalAlignment="Left"
            Content="{Binding Texts[PostAction.Clear]}"
            Click="OnClearClick" />

    <Border Classes="post-action-status-block">
      <controls:AdaptiveSpacingStackPanel Classes="post-action-status-list">
        <TextBlock Classes="app-body long-wrap state-warning"
                   Text="{Binding StatusMessage}" />
        <TextBlock Classes="app-body long-wrap state-error"
                   Text="{Binding LastErrorMessage}" />
      </controls:AdaptiveSpacingStackPanel>
    </Border>
  </StackPanel>
</UserControl>
