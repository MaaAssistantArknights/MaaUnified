<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             xmlns:vm="clr-namespace:MAAUnified.App.ViewModels.TaskQueue"
             x:Class="MAAUnified.App.Features.TaskQueue.MallSettingsView">
  <UserControl.Styles>
    <Style Selector="Border.mall-section">
      <Setter Property="Margin" Value="0,2,0,0" />
    </Style>

    <Style Selector="StackPanel.mall-section-stack,
                     controls|AdaptiveSpacingStackPanel.mall-section-stack">
      <Setter Property="Spacing" Value="{DynamicResource MAA.App.Settings.PageCompactFlowSpacing}" />
    </Style>

    <Style Selector="StackPanel.mall-card-stack,
                     controls|AdaptiveSpacingStackPanel.mall-card-stack">
      <Setter Property="Spacing" Value="{DynamicResource MAA.App.Settings.PageToggleStackSpacing}" />
    </Style>
    <Style Selector="controls|AdaptiveSpacingStackPanel.mall-info-note-stack">
      <Setter Property="Spacing" Value="4" />
      <Setter Property="TargetPitch" Value="44" />
      <Setter Property="MinGap" Value="4" />
      <Setter Property="MaxGap" Value="8" />
      <Setter Property="ShortRowSlot" Value="24" />
      <Setter Property="SupplementaryTextGap" Value="4" />
    </Style>
    <Style Selector="TextBlock.mall-info-note">
      <Setter Property="LineHeight" Value="16" />
    </Style>

    <Style Selector="Border.mall-detail-card">
      <Setter Property="Margin" Value="0,4,0,0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="ClipToBounds" Value="False" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto" Margin="2">
    <controls:AdaptiveSpacingStackPanel Classes="task-settings-section">
      <Border Classes="mall-section"
              IsVisible="{Binding IsGeneralMode}">
        <controls:AdaptiveSpacingStackPanel Classes="mall-section-stack">
          <TextBlock Classes="app-caption">
            <Run Text="{Binding Texts[Mall.VisitFriends]}" />
            <Run Text=" / " />
            <Run Text="{Binding Texts[Mall.CreditFight]}" />
          </TextBlock>

          <Border Classes="app-surface app-card">
            <controls:AdaptiveSpacingStackPanel Classes="mall-card-stack">
              <CheckBox Classes="app-checkbox"
                        Content="{Binding Texts[Mall.VisitFriends]}"
                        IsChecked="{Binding VisitFriends}" />

              <Border Classes="mall-detail-card"
                      IsVisible="{Binding ShowVisitFriendsDetails}">
                <controls:AdaptiveSpacingStackPanel Classes="mall-card-stack">
                  <controls:SettingsDependentRow>
                    <CheckBox Classes="app-checkbox"
                              Content="{Binding Texts[Mall.OnlyOnceADay]}"
                              IsChecked="{Binding VisitFriendsOnceADay}" />
                  </controls:SettingsDependentRow>
                </controls:AdaptiveSpacingStackPanel>
              </Border>
            </controls:AdaptiveSpacingStackPanel>
          </Border>

          <Border Classes="app-surface app-card">
            <controls:AdaptiveSpacingStackPanel Classes="mall-card-stack">
              <controls:AppHintedCheckBox Text="{Binding Texts[Mall.CreditFight]}"
                                           Tip="{Binding Texts[Mall.CreditFightTip]}"
                                           IsChecked="{Binding CreditFight}" />

              <Border Classes="mall-detail-card"
                      IsVisible="{Binding ShowCreditFightDetails}">
                <controls:AdaptiveSpacingStackPanel Classes="mall-card-stack">
                  <controls:SettingsDependentRow Glyph="├">
                    <CheckBox Classes="app-checkbox"
                              Content="{Binding Texts[Mall.OnlyOnceADay]}"
                              IsChecked="{Binding CreditFightOnceADay}" />
                  </controls:SettingsDependentRow>

                  <controls:SettingsDependentRow>
                    <controls:SettingsInlineRow Classes="task-settings-field-stack"
                                                controls:SettingsLabelWidthCoordinator.GroupKey="TaskQueue.Fields">
                      <controls:SettingsLabel Text="{Binding Texts[Mall.UseFormation]}" />
                      <controls:AppSelect ItemsSource="{Binding FormationOptions}"
                                          SelectedValueBinding="{Binding Value}"
                                          SelectedValue="{Binding FormationIndex}">
                        <controls:AppSelect.ItemTemplate>
                          <DataTemplate x:DataType="vm:MallModuleViewModel+IntOption">
                            <TextBlock Text="{Binding DisplayName}" />
                          </DataTemplate>
                        </controls:AppSelect.ItemTemplate>
                      </controls:AppSelect>
                    </controls:SettingsInlineRow>
                  </controls:SettingsDependentRow>
                </controls:AdaptiveSpacingStackPanel>
              </Border>
            </controls:AdaptiveSpacingStackPanel>
          </Border>
        </controls:AdaptiveSpacingStackPanel>
      </Border>

      <Border Classes="mall-section"
              IsVisible="{Binding IsGeneralMode}">
        <controls:AdaptiveSpacingStackPanel Classes="mall-section-stack">
          <TextBlock Classes="app-caption"
                     Text="{Binding Texts[Mall.Shopping]}" />

          <Border Classes="app-surface app-card">
            <controls:AdaptiveSpacingStackPanel Classes="mall-card-stack">
              <CheckBox Classes="app-checkbox"
                        Content="{Binding Texts[Mall.Shopping]}"
                        IsChecked="{Binding Shopping}" />
            </controls:AdaptiveSpacingStackPanel>
          </Border>

          <Border Classes="app-surface app-card">
            <controls:AdaptiveSpacingStackPanel Classes="mall-info-note-stack">
              <TextBlock Classes="app-body task-settings-info-heading mall-info-note"
                         Text="{Binding Texts[Mall.ReceptionOptionsRequireInfrast]}" />
              <TextBlock Classes="app-caption task-settings-info-body mall-info-note"
                         Text="{Binding Texts[Mall.InfrastReceptionMessageBoardReceive]}"
                         TextWrapping="Wrap" />
              <TextBlock Classes="app-caption task-settings-info-body mall-info-note"
                         Text="{Binding Texts[Mall.InfrastReceptionClueExchange]}"
                         TextWrapping="Wrap" />
              <TextBlock Classes="app-caption task-settings-info-body mall-info-note"
                         Text="{Binding Texts[Mall.InfrastReceptionSendClue]}"
                         TextWrapping="Wrap" />
            </controls:AdaptiveSpacingStackPanel>
          </Border>
        </controls:AdaptiveSpacingStackPanel>
      </Border>

      <Border Classes="mall-section"
              IsVisible="{Binding IsAdvancedMode}">
        <controls:AdaptiveSpacingStackPanel Classes="mall-section-stack">
          <TextBlock Classes="app-caption"
                     Text="{Binding Texts[Mall.Shopping]}" />

          <Border Classes="app-surface app-card">
            <controls:AdaptiveSpacingStackPanel Classes="mall-card-stack">
              <controls:SettingsLabel Text="{Binding Texts[Mall.BuyFirst]}"
                                      Tip="{Binding Texts[Mall.Drink]}" />
              <controls:AppTextInput Classes="settings-input-block"
                                     DismissFocusOnEnter="False"
                                     IsEnabled="{Binding IsShoppingSettingsEnabled}"
                                     Text="{Binding BuyFirstText, UpdateSourceTrigger=LostFocus}" />
            </controls:AdaptiveSpacingStackPanel>
          </Border>

          <Border Classes="app-surface app-card">
            <controls:AdaptiveSpacingStackPanel Classes="mall-card-stack">
              <TextBlock Classes="app-caption"
                         Text="{Binding Texts[Mall.Blacklist]}" />
              <controls:AppTextInput Classes="settings-input-block"
                                     DismissFocusOnEnter="False"
                                     IsEnabled="{Binding IsShoppingSettingsEnabled}"
                                     Text="{Binding BlacklistText, UpdateSourceTrigger=LostFocus}" />
            </controls:AdaptiveSpacingStackPanel>
          </Border>

          <Border Classes="app-surface app-card">
            <controls:AdaptiveSpacingStackPanel Classes="mall-card-stack">
              <CheckBox Classes="app-checkbox"
                        Content="{Binding Texts[Mall.ForceShopping]}"
                        IsChecked="{Binding ForceShoppingIfCreditFull}"
                        IsEnabled="{Binding IsShoppingSettingsEnabled}" />
              <controls:AppHintedCheckBox Text="{Binding Texts[Mall.OnlyDiscount]}"
                                           Tip="{Binding Texts[Mall.OnlyDiscountTip]}"
                                           IsChecked="{Binding OnlyBuyDiscount}"
                                           IsEnabled="{Binding IsShoppingSettingsEnabled}" />
              <controls:AppHintedCheckBox Text="{Binding Texts[Mall.Reserve]}"
                                           Tip="{Binding Texts[Mall.ReserveTip]}"
                                           IsChecked="{Binding ReserveMaxCredit}"
                                           IsEnabled="{Binding IsShoppingSettingsEnabled}" />
            </controls:AdaptiveSpacingStackPanel>
          </Border>
        </controls:AdaptiveSpacingStackPanel>
      </Border>
    </controls:AdaptiveSpacingStackPanel>
  </Grid>
</UserControl>
