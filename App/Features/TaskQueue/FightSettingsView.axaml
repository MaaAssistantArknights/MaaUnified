<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             xmlns:vm="clr-namespace:MAAUnified.App.ViewModels.TaskQueue"
             x:Class="MAAUnified.App.Features.TaskQueue.FightSettingsView">
  <UserControl.Styles>
    <Style Selector="CheckBox.fight-compact">
      <Setter Property="Height" Value="28" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="controls|NullableCheckBox.fight-compact">
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBlock.stage-closed">
      <Setter Property="Opacity" Value="0.55" />
    </Style>
    <Style Selector="TextBlock.stage-outdated">
      <Setter Property="TextDecorations" Value="Strikethrough" />
    </Style>
    <Style Selector="StackPanel.fight-settings-root,
                     controls|AdaptiveSpacingStackPanel.fight-settings-root">
      <Setter Property="Spacing" Value="{DynamicResource MAA.App.Settings.PageCompactFlowSpacing}" />
    </Style>
    <Style Selector="StackPanel.fight-settings-group,
                     controls|AdaptiveSpacingStackPanel.fight-settings-group">
      <Setter Property="Spacing" Value="{DynamicResource MAA.App.Settings.PageCompactFlowSpacing}" />
    </Style>
    <Style Selector="StackPanel.fight-settings-card-content,
                     controls|AdaptiveSpacingStackPanel.fight-settings-card-content">
      <Setter Property="Spacing" Value="{DynamicResource MAA.App.Settings.PageToggleStackSpacing}" />
    </Style>
    <Style Selector="Border.fight-settings-card">
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="TextBlock.fight-settings-card-title">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
      <Setter Property="FontWeight" Value="Normal" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="TextBlock.fight-settings-field-label">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Secondary}" />
      <Setter Property="FontWeight" Value="Normal" />
      <Setter Property="HorizontalAlignment" Value="Left" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>
    <Style Selector="Grid.fight-settings-hint-row">
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Grid.fight-settings-hint-row TextBlock">
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Grid.fight-settings-hint-row CheckBox">
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="controls|TooltipHint.fight-settings-tooltip">
      <Setter Property="Grid.Column" Value="1" />
      <Setter Property="Margin" Value="{DynamicResource MAA.App.Settings.HintMargin}" />
      <Setter Property="HorizontalAlignment" Value="Left" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="controls|AppNumberInput.fight-settings-count-input">
      <Setter Property="Width" Value="74" />
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    <Style Selector="controls|AppSelect.fight-settings-inline-select">
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
    <Style Selector="ComboBox.fight-settings-stage-field,
                     controls|AppSelect.fight-settings-stage-field,
                     controls|AppTextInput.fight-settings-stage-field">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="MinWidth" Value="0" />
    </Style>
    <Style Selector="ComboBox.fight-settings-stage-field,
                     controls|AppSelect.fight-settings-stage-field">
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>
    <Style Selector="Border.stage-plan-frame">
      <Setter Property="Padding" Value="4" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="controls|AppSelectionList.stage-plan-selection-list">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="Margin" Value="0" />
    </Style>
    <Style Selector="controls|AppSelectionList.stage-plan-selection-list ListBoxItem">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
    <Style Selector="controls|AppSelectionList.stage-plan-selection-list Border.app-selection-list-item-shell">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="MinHeight" Value="38" />
      <Setter Property="Padding" Value="4" />
    </Style>
    <Style Selector="Button.settings-dropdown-delete-button.stage-plan-delete-button">
      <Setter Property="Margin" Value="2,0,0,0" />
    </Style>
    <Style Selector="ComboBox.stage-plan-embedded-select">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ComboBox.stage-plan-embedded-select /template/ Border#Background,
                     ComboBox.stage-plan-embedded-select /template/ Border#PART_BorderElement,
                     ComboBox.stage-plan-embedded-select /template/ Border#PART_Border">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
      <Setter Property="BoxShadow" Value="0 0 0 0 #00000000" />
    </Style>
    <Style Selector="ComboBox.stage-plan-embedded-select:pointerover,
                     ComboBox.stage-plan-embedded-select:focus,
                     ComboBox.stage-plan-embedded-select:focus-visible">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Action.SubtleBackgroundHover}" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="ComboBox.stage-plan-embedded-select:pointerover /template/ Border#Background,
                     ComboBox.stage-plan-embedded-select:focus /template/ Border#Background,
                     ComboBox.stage-plan-embedded-select:focus-visible /template/ Border#Background,
                     ComboBox.stage-plan-embedded-select:pointerover /template/ Border#PART_BorderElement,
                     ComboBox.stage-plan-embedded-select:focus /template/ Border#PART_BorderElement,
                     ComboBox.stage-plan-embedded-select:focus-visible /template/ Border#PART_BorderElement,
                     ComboBox.stage-plan-embedded-select:pointerover /template/ Border#PART_Border,
                     ComboBox.stage-plan-embedded-select:focus /template/ Border#PART_Border,
                     ComboBox.stage-plan-embedded-select:focus-visible /template/ Border#PART_Border">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Action.SubtleBackgroundHover}" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
    </Style>
    <Style Selector="Grid.stage-plan-panel">
      <Setter Property="MinWidth" Value="0" />
    </Style>
    <Style Selector="Border.stage-plan-actions">
      <Setter Property="Margin" Value="-4,0,-4,-4" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Surface.Card}" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="0,0,10,10" />
      <Setter Property="ClipToBounds" Value="True" />
    </Style>
    <Style Selector="Border.stage-plan-footer-divider">
      <Setter Property="Height" Value="1" />
      <Setter Property="Margin" Value="-4,0,-4,0" />
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Border.Card}" />
    </Style>
    <Style Selector="TextBlock.stage-plan-status">
      <Setter Property="Margin" Value="0" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
  </UserControl.Styles>

  <controls:AdaptiveSpacingStackPanel Margin="4" Classes="fight-settings-root">
    <controls:AdaptiveSpacingStackPanel Classes="fight-settings-root">
      <controls:AdaptiveSpacingStackPanel IsVisible="{Binding IsGeneralMode}" Classes="fight-settings-group task-settings-section">
        <Border Classes="app-surface app-card fight-settings-card">
          <controls:AdaptiveSpacingStackPanel Classes="task-settings-card-content">
            <controls:SettingsInlineRow IsVisible="{Binding ShowStagePlanSelector}"
                                        FieldWidth="{DynamicResource MAA.Size.Settings.FieldCenteredWidth}"
                                        controls:SettingsLabelWidthCoordinator.GroupKey="TaskQueue.Fields">
              <controls:SettingsLabel Text="{Binding StageSelectDisplayText}" />
              <controls:AppSelect Grid.Column="2"
                                  Classes="fight-settings-stage-field"
                                  ItemsSource="{Binding StageOptions}"
                                  SelectedValueBinding="{Binding Value}"
                                  SelectedItem="{Binding SelectedStageOption, Mode=OneWay}"
                                  SelectedValue="{Binding SelectedStageValue, Mode=TwoWay}">
                <controls:AppSelect.ItemTemplate>
                  <DataTemplate x:DataType="vm:FightTaskModuleViewModel+StageOption">
                    <TextBlock Text="{Binding DisplayName}"
                               Classes.stage-closed="{Binding IsClosed}"
                               Classes.stage-outdated="{Binding IsOutdated}"
                               Classes.state-error="{Binding IsOutdated}" />
                  </DataTemplate>
                </controls:AppSelect.ItemTemplate>
              </controls:AppSelect>
            </controls:SettingsInlineRow>

            <controls:SettingsInlineRow IsVisible="{Binding ShowStagePlanList}"
                                        FieldWidth="222"
                                        controls:SettingsLabelWidthCoordinator.GroupKey="TaskQueue.Fields">
              <controls:SettingsLabel Text="{Binding StageSelectDisplayText}" />
              <Border Grid.Column="2"
                      Classes="grouped-card-frame compact stage-plan-frame">
                <Grid Classes="stage-plan-panel"
                      RowDefinitions="Auto,Auto,Auto">
                  <controls:AppSelectionList x:Name="StagePlanSelectionList"
                                             Grid.Row="0"
                                             Classes="app-compact-selection-list stage-plan-selection-list selection-list-section-cards selection-list-no-indicator"
                                             ItemsSource="{Binding StagePlan}"
                                             CanReorderItems="{Binding UseAlternateStage}"
                                             CanReorderFromComboBox="True"
                                             ItemReorderRequested="OnStagePlanItemReorderRequested">
                    <controls:AppSelectionList.ReorderDragPreviewContentTemplate>
                      <DataTemplate x:DataType="vm:FightTaskModuleViewModel+StagePlanEntry">
                        <Border Classes="app-selection-list-item-shell"
                                HorizontalAlignment="Stretch">
                          <Grid Classes="stage-plan-row"
                                HorizontalAlignment="Stretch"
                                ColumnDefinitions="*,4,Auto,4,Auto">
                            <controls:AppSelect Grid.Column="0"
                                                Classes="fight-settings-stage-field stage-plan-embedded-select"
                                                HorizontalAlignment="Stretch"
                                                MinWidth="0"
                                                IsVisible="{Binding DataContext.ShowStagePlanComboBox, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                ItemsSource="{Binding DataContext.StageOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                SelectedValueBinding="{Binding Value}"
                                                SelectedItem="{Binding SelectedStageOption, Mode=OneWay}"
                                                SelectedValue="{Binding SelectedStageValue, Mode=TwoWay}">
                              <controls:AppSelect.ItemTemplate>
                                <DataTemplate x:DataType="vm:FightTaskModuleViewModel+StageOption">
                                  <TextBlock Text="{Binding DisplayName}"
                                             Classes.stage-closed="{Binding IsClosed}"
                                             Classes.stage-outdated="{Binding IsOutdated}"
                                             Classes.state-error="{Binding IsOutdated}" />
                                </DataTemplate>
                              </controls:AppSelect.ItemTemplate>
                            </controls:AppSelect>

                            <controls:AppTextInput Grid.Column="0"
                                                   Classes="fight-settings-stage-field"
                                                   HorizontalAlignment="Stretch"
                                                   MinWidth="0"
                                                   IsVisible="{Binding DataContext.ShowStagePlanTextBox, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   Text="{Binding EditableStageText}"
                                                   Watermark="{Binding DataContext.Texts[Fight.DefaultStage], RelativeSource={RelativeSource AncestorType=UserControl}}" />

                            <TextBlock Grid.Column="2"
                                       Classes="app-caption stage-closed stage-plan-status"
                                       Text="{Binding StatusText}"
                                       Classes.stage-closed="{Binding IsClosed}"
                                       Classes.stage-outdated="{Binding IsOutdated}"
                                       Classes.state-error="{Binding IsOutdated}" />
                            <Button Grid.Column="4"
                                    Classes="settings-dropdown-delete-button stage-plan-delete-button"
                                    IsEnabled="{Binding DataContext.CanRemoveStagePlanEntry, RelativeSource={RelativeSource AncestorType=UserControl}}" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </controls:AppSelectionList.ReorderDragPreviewContentTemplate>
                    <controls:AppSelectionList.ItemTemplate>
                      <DataTemplate x:DataType="vm:FightTaskModuleViewModel+StagePlanEntry">
                        <Border Classes="app-selection-list-item-shell"
                                HorizontalAlignment="Stretch">
                          <Grid Classes="stage-plan-row"
                                HorizontalAlignment="Stretch"
                                ColumnDefinitions="*,4,Auto,4,Auto">
                            <controls:AppSelect Grid.Column="0"
                                                Classes="fight-settings-stage-field stage-plan-embedded-select"
                                                HorizontalAlignment="Stretch"
                                                MinWidth="0"
                                                IsVisible="{Binding DataContext.ShowStagePlanComboBox, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                ItemsSource="{Binding DataContext.StageOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                SelectedValueBinding="{Binding Value}"
                                                SelectedItem="{Binding SelectedStageOption, Mode=OneWay}"
                                                SelectedValue="{Binding SelectedStageValue, Mode=TwoWay}">
                              <controls:AppSelect.ItemTemplate>
                                <DataTemplate x:DataType="vm:FightTaskModuleViewModel+StageOption">
                                  <TextBlock Text="{Binding DisplayName}"
                                             Classes.stage-closed="{Binding IsClosed}"
                                             Classes.stage-outdated="{Binding IsOutdated}"
                                             Classes.state-error="{Binding IsOutdated}" />
                                </DataTemplate>
                              </controls:AppSelect.ItemTemplate>
                            </controls:AppSelect>

                            <controls:AppTextInput Grid.Column="0"
                                                   Classes="fight-settings-stage-field"
                                                   HorizontalAlignment="Stretch"
                                                   MinWidth="0"
                                                   IsVisible="{Binding DataContext.ShowStagePlanTextBox, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                   Text="{Binding EditableStageText}"
                                                   Watermark="{Binding DataContext.Texts[Fight.DefaultStage], RelativeSource={RelativeSource AncestorType=UserControl}}" />

                            <TextBlock Grid.Column="2"
                                       Classes="app-caption stage-closed stage-plan-status"
                                       Text="{Binding StatusText}"
                                       Classes.stage-closed="{Binding IsClosed}"
                                       Classes.stage-outdated="{Binding IsOutdated}"
                                       Classes.state-error="{Binding IsOutdated}" />
                            <Button Grid.Column="4"
                                    Classes="settings-dropdown-delete-button stage-plan-delete-button"
                                    IsEnabled="{Binding DataContext.CanRemoveStagePlanEntry, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Tag="{Binding}"
                                    ToolTip.Tip="{Binding DataContext.RemoveStagePlanEntryText, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                    Click="OnRemoveStagePlanEntryClick" />
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </controls:AppSelectionList.ItemTemplate>
                  </controls:AppSelectionList>
                  <Border Grid.Row="1"
                          Classes="stage-plan-footer-divider" />
                  <Border Grid.Row="2"
                          Classes="stage-plan-actions">
                    <Button Classes="grouped-card-footer-action"
                            Content="{Binding AddStageText}"
                            Click="OnAddStagePlanEntryClick" />
                  </Border>
                </Grid>
              </Border>
            </controls:SettingsInlineRow>
          </controls:AdaptiveSpacingStackPanel>
        </Border>

        <Border Classes="app-surface app-card fight-settings-card">
          <controls:AdaptiveSpacingStackPanel Classes="task-settings-card-content">
            <controls:SettingsInlineRow controls:SettingsLabelWidthCoordinator.GroupKey="TaskQueue.Fields">
              <controls:NullableCheckBox Classes="fight-compact"
                                         Text="{Binding Texts[Fight.UseMedicine]}"
                                         IsChecked="{Binding UseMedicine}"
                                         IsEnabled="{Binding IsMedicineToggleEnabled}" />
              <controls:AppNumberInput Grid.Column="2"
                                       Classes="fight-settings-count-input"
                                       Minimum="0"
                                       Maximum="999"
                                       Value="{Binding Medicine}"
                                       IsEnabled="{Binding IsMedicineInputEnabled}" />
            </controls:SettingsInlineRow>

            <controls:SettingsInlineRow controls:SettingsLabelWidthCoordinator.GroupKey="TaskQueue.Fields">
              <controls:NullableCheckBox Classes="fight-compact"
                                         Text="{Binding UseStoneDisplayName}"
                                         IsChecked="{Binding UseStone}" />
              <controls:AppNumberInput Grid.Column="2"
                                       Classes="fight-settings-count-input"
                                       Minimum="0"
                                       Maximum="999"
                                       Value="{Binding Stone}" />
            </controls:SettingsInlineRow>

            <controls:SettingsInlineRow controls:SettingsLabelWidthCoordinator.GroupKey="TaskQueue.Fields">
              <controls:NullableCheckBox Classes="fight-compact"
                                         Text="{Binding Texts[Fight.PerformBattles]}"
                                         IsChecked="{Binding EnableTimesLimit}" />
              <controls:AppNumberInput Grid.Column="2"
                                       Classes="fight-settings-count-input"
                                       Minimum="0"
                                       Maximum="999999"
                                       Value="{Binding Times}" />
            </controls:SettingsInlineRow>
          </controls:AdaptiveSpacingStackPanel>
        </Border>

        <Border Classes="app-surface app-card fight-settings-card"
                IsVisible="{Binding ShowSeriesSetting}">
          <controls:SettingsInlineRow Classes="task-settings-card-content"
                                      controls:SettingsLabelWidthCoordinator.GroupKey="TaskQueue.Fields">
            <controls:SettingsLabel Text="{Binding Texts[Fight.Series]}"
                                    Tip="{Binding Texts[Fight.SeriesTip]}" />
            <controls:AppSelect Grid.Column="2"
                                Classes="fight-settings-inline-select"
                                ItemsSource="{Binding SeriesOptions}"
                                SelectedValueBinding="{Binding Value}"
                                SelectedValue="{Binding Series}">
              <controls:AppSelect.ItemTemplate>
                <DataTemplate x:DataType="vm:FightTaskModuleViewModel+IntOption">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </controls:AppSelect.ItemTemplate>
            </controls:AppSelect>
          </controls:SettingsInlineRow>
        </Border>

        <Border Classes="app-surface app-card fight-settings-card">
          <controls:SettingsInlineRow Classes="task-settings-card-content"
                                      FieldWidth="{DynamicResource MAA.Size.Settings.FieldWideWidth}"
                                      RowDefinitions="Auto,Auto,Auto"
                                      controls:SettingsLabelWidthCoordinator.GroupKey="TaskQueue.Fields">
            <controls:NullableCheckBox Classes="fight-compact"
                                       Text="{Binding Texts[Fight.AssignedMaterial]}"
                                       Tip="{Binding Texts[Fight.SpecifiedDropsTip]}"
                                       IsChecked="{Binding EnableTargetDrop}" />
            <controls:AppSelect Grid.Column="2"
                                Classes="fight-settings-inline-select"
                                IsEnabled="{Binding IsDropControlsEnabled}"
                                ItemsSource="{Binding DropOptions}"
                                SelectedValueBinding="{Binding Value}"
                                SelectedValue="{Binding DropId}">
              <controls:AppSelect.ItemTemplate>
                <DataTemplate x:DataType="vm:FightTaskModuleViewModel+DropOption">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </controls:AppSelect.ItemTemplate>
            </controls:AppSelect>
            <TextBlock Grid.Row="1"
                       Margin="0,8,0,0"
                       Classes="fight-settings-field-label"
                       Text="{Binding Texts[Fight.DropTargetMode]}" />
            <controls:AppSelect Grid.Row="1"
                                Grid.Column="2"
                                Margin="0,8,0,0"
                                Classes="fight-settings-inline-select"
                                IsEnabled="{Binding IsDropControlsEnabled}"
                                ItemsSource="{Binding DropTargetModeOptions}"
                                SelectedValueBinding="{Binding Value}"
                                SelectedValue="{Binding DropTargetMode}">
              <controls:AppSelect.ItemTemplate>
                <DataTemplate x:DataType="vm:FightTaskModuleViewModel+StringOption">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </controls:AppSelect.ItemTemplate>
            </controls:AppSelect>
            <TextBlock Grid.Row="2"
                       Margin="0,8,0,0"
                       Classes="fight-settings-field-label"
                       Text="{Binding DropCountLabelText}" />
            <controls:AppNumberInput Grid.Row="2"
                                     Grid.Column="2"
                                     Margin="0,8,0,0"
                                     Classes="fight-settings-count-input"
                                     Minimum="1"
                                     Maximum="999999"
                                     Value="{Binding DropCount}"
                                     IsEnabled="{Binding IsDropControlsEnabled}" />
          </controls:SettingsInlineRow>
        </Border>
      </controls:AdaptiveSpacingStackPanel>

      <controls:AdaptiveSpacingStackPanel IsVisible="{Binding IsAdvancedMode}" Classes="fight-settings-group task-settings-section">
        <Border Classes="app-surface app-card fight-settings-card">
          <controls:AdaptiveSpacingStackPanel Classes="fight-settings-card-content task-settings-card-content">
            <CheckBox Classes="app-checkbox"
                      Content="{Binding Texts[Fight.UseCustomAnnihilation]}"
                      IsChecked="{Binding UseCustomAnnihilation}" />
            <controls:SettingsInlineRow FieldWidth="{DynamicResource MAA.Size.Settings.FieldWideWidth}"
                                        controls:SettingsLabelWidthCoordinator.GroupKey="TaskQueue.Fields">
              <controls:SettingsLabel Text="{Binding Texts[Fight.AnnihilationStage]}" />
              <controls:AppSelect Grid.Column="2"
                                  Classes="fight-settings-inline-select"
                                  IsEnabled="{Binding UseCustomAnnihilation}"
                                  ItemsSource="{Binding AnnihilationStageOptions}"
                                  SelectedValueBinding="{Binding Value}"
                                  SelectedValue="{Binding SelectedAnnihilationStageValue, Mode=TwoWay}">
                <controls:AppSelect.ItemTemplate>
                  <DataTemplate x:DataType="vm:FightTaskModuleViewModel+StringOption">
                    <TextBlock Text="{Binding DisplayName}" />
                  </DataTemplate>
                </controls:AppSelect.ItemTemplate>
              </controls:AppSelect>
            </controls:SettingsInlineRow>
          </controls:AdaptiveSpacingStackPanel>
        </Border>

        <Border Classes="app-surface app-card fight-settings-card">
          <controls:AdaptiveSpacingStackPanel Classes="fight-settings-card-content task-settings-card-content">
            <controls:AppHintedCheckBox Text="{Binding Texts[Fight.DrGrandet]}"
                                         Tip="{Binding Texts[Fight.DrGrandetTip]}"
                                         IsChecked="{Binding IsDrGrandet}" />
            <controls:SettingsDependentRow>
              <CheckBox Classes="app-checkbox"
                        HorizontalAlignment="Stretch"
                        IsChecked="{Binding UseExpiringMedicine}">
                <TextBlock Text="{Binding Texts[Fight.UseExpiringMedicine]}"
                           TextWrapping="Wrap" />
              </CheckBox>
            </controls:SettingsDependentRow>
            <controls:SettingsDependentRow>
              <CheckBox Classes="app-checkbox"
                        HorizontalAlignment="Stretch"
                        IsChecked="{Binding UseExpireMedicineForActivity}">
                <TextBlock Text="{Binding Texts[Fight.UseExpireMedicineForActivity]}"
                           TextWrapping="Wrap" />
              </CheckBox>
            </controls:SettingsDependentRow>
            <CheckBox Classes="app-checkbox"
                      Content="{Binding Texts[Fight.HideSeries]}"
                      IsChecked="{Binding HideSeries}" />
            <controls:AppHintedCheckBox Text="{Binding CustomStageCodeText}"
                                         Tip="{Binding CustomStageCodeTipText}"
                                         IsChecked="{Binding IsStageManually}" />
            <controls:AppHintedCheckBox Text="{Binding Texts[Fight.AllowUseStoneSave]}"
                                         Tip="{Binding Texts[Fight.AllowUseStoneSaveWarning]}"
                                         IsChecked="{Binding AllowUseStoneSave}" />
            <controls:SettingsInlineRow controls:SettingsLabelWidthCoordinator.GroupKey="TaskQueue.Fields">
              <controls:SettingsLabel Text="{Binding Texts[Fight.StageResetMode]}" />
              <controls:AppSelect Grid.Column="2"
                                  Classes="fight-settings-inline-select"
                                  ItemsSource="{Binding StageResetModeOptions}"
                                  SelectedValueBinding="{Binding Value}"
                                  SelectedValue="{Binding StageResetMode}">
                <controls:AppSelect.ItemTemplate>
                  <DataTemplate x:DataType="vm:FightTaskModuleViewModel+StringOption">
                    <TextBlock Text="{Binding DisplayName}" />
                  </DataTemplate>
                </controls:AppSelect.ItemTemplate>
              </controls:AppSelect>
            </controls:SettingsInlineRow>
            <CheckBox Classes="app-checkbox"
                      Content="{Binding Texts[Fight.UseAlternateStage]}"
                      IsChecked="{Binding UseAlternateStage}" />
            <CheckBox Classes="app-checkbox"
                      Content="{Binding Texts[Fight.HideUnavailableStage]}"
                      IsChecked="{Binding HideUnavailableStage}"
                      IsEnabled="{Binding IsHideUnavailableStageEnabled}" />
            <controls:AppHintedCheckBox Text="{Binding UseWeeklyScheduleText}"
                                         Tip="{Binding UseWeeklyScheduleTip}"
                                         IsChecked="{Binding UseWeeklySchedule}" />
            <WrapPanel IsVisible="{Binding UseWeeklySchedule}">
              <CheckBox Classes="app-checkbox"
                        Margin="0,0,12,8"
                        Content="{Binding WeeklyScheduleSundayText}"
                        IsChecked="{Binding WeeklyScheduleSunday}" />
              <CheckBox Classes="app-checkbox"
                        Margin="0,0,12,8"
                        Content="{Binding WeeklyScheduleMondayText}"
                        IsChecked="{Binding WeeklyScheduleMonday}" />
              <CheckBox Classes="app-checkbox"
                        Margin="0,0,12,8"
                        Content="{Binding WeeklyScheduleTuesdayText}"
                        IsChecked="{Binding WeeklyScheduleTuesday}" />
              <CheckBox Classes="app-checkbox"
                        Margin="0,0,12,8"
                        Content="{Binding WeeklyScheduleWednesdayText}"
                        IsChecked="{Binding WeeklyScheduleWednesday}" />
              <CheckBox Classes="app-checkbox"
                        Margin="0,0,12,8"
                        Content="{Binding WeeklyScheduleThursdayText}"
                        IsChecked="{Binding WeeklyScheduleThursday}" />
              <CheckBox Classes="app-checkbox"
                        Margin="0,0,12,8"
                        Content="{Binding WeeklyScheduleFridayText}"
                        IsChecked="{Binding WeeklyScheduleFriday}" />
              <CheckBox Classes="app-checkbox"
                        Margin="0,0,12,8"
                        Content="{Binding WeeklyScheduleSaturdayText}"
                        IsChecked="{Binding WeeklyScheduleSaturday}" />
            </WrapPanel>
          </controls:AdaptiveSpacingStackPanel>
        </Border>

        <Border Classes="app-surface app-card fight-settings-card">
          <controls:AdaptiveSpacingStackPanel Classes="fight-settings-card-content task-settings-card-content">
            <TextBlock Classes="app-caption"
                       Text="{Binding MultiTasksShareTipText}"
                       TextWrapping="Wrap" />
            <CheckBox Classes="app-checkbox"
                      Content="{Binding AutoRestartOnDropText}"
                      IsChecked="{Binding AutoRestartOnDrop}" />
          </controls:AdaptiveSpacingStackPanel>
        </Border>
      </controls:AdaptiveSpacingStackPanel>

      <Border Classes="app-surface app-card fight-settings-card"
              IsVisible="{Binding HasValidationIssues}">
        <controls:AdaptiveSpacingStackPanel Classes="fight-settings-card-content task-settings-card-content">
          <controls:AdaptiveSpacingStackPanel IsVisible="{Binding HasValidationIssues}"
                      Classes="task-settings-card-content">
            <TextBlock Classes="app-caption"
                       Text="{Binding Texts[Common.ValidationIssues]}" />
            <ListBox MaxHeight="96"
                     ItemsSource="{Binding ValidationMessages}">
              <ListBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Classes="long-wrap"
                             Text="{Binding .}"
                             TextWrapping="Wrap" />
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </controls:AdaptiveSpacingStackPanel>
        </controls:AdaptiveSpacingStackPanel>
      </Border>
    </controls:AdaptiveSpacingStackPanel>
  </controls:AdaptiveSpacingStackPanel>
</UserControl>
