<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             xmlns:vm="clr-namespace:MAAUnified.App.ViewModels.TaskQueue"
             x:Class="MAAUnified.App.Features.TaskQueue.ReclamationSettingsView">
  <UserControl.Styles>
    <Style Selector="StackPanel.reclamation-settings-section-stack">
      <Setter Property="Spacing" Value="{DynamicResource MAA.App.Settings.PageCompactFlowSpacing}" />
    </Style>
    <Style Selector="controls|AdaptiveSpacingStackPanel.reclamation-settings-section-stack">
      <Setter Property="Spacing" Value="{DynamicResource MAA.App.Settings.PageCompactFlowSpacing}" />
    </Style>
    <Style Selector="StackPanel.reclamation-settings-status-stack">
      <Setter Property="Spacing" Value="{DynamicResource MAA.App.Settings.PageToggleStackSpacing}" />
    </Style>
    <Style Selector="controls|AdaptiveSpacingStackPanel.reclamation-settings-status-stack">
      <Setter Property="Spacing" Value="{DynamicResource MAA.App.Settings.PageToggleStackSpacing}" />
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,Auto" Margin="4">
    <TextBlock Classes="section-title" Text="{Binding Texts[Reclamation.Title]}" />

    <controls:AdaptiveSpacingStackPanel Grid.Row="1"
                Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}"
                Spacing="{DynamicResource MAA.Spacing.Medium}">
      <controls:AdaptiveSpacingStackPanel Classes="reclamation-settings-section-stack"
                  IsVisible="{Binding IsGeneralMode}">
          <Border Classes="app-surface app-card">
            <controls:SettingsInlineRow>
              <TextBlock Classes="settings-field-caption"
                         Text="{Binding Texts[Reclamation.Theme]}" />
              <controls:AppSelect ItemsSource="{Binding ThemeOptions}"
                                  SelectedValueBinding="{Binding Type}"
                                  SelectedValue="{Binding Theme}">
                <controls:AppSelect.ItemTemplate>
                  <DataTemplate x:DataType="vm:TaskModuleOption">
                    <TextBlock Text="{Binding DisplayName}" />
                  </DataTemplate>
                </controls:AppSelect.ItemTemplate>
              </controls:AppSelect>
            </controls:SettingsInlineRow>
          </Border>

          <Border Classes="app-surface app-card">
            <controls:AdaptiveSpacingStackPanel Spacing="6">
              <controls:SettingsInlineRow FieldWidth="{DynamicResource MAA.Size.Settings.FieldWideWidth}">
                <TextBlock Classes="settings-field-caption"
                           Text="{Binding Texts[Reclamation.Mode]}" />
                <controls:AppSelect ItemsSource="{Binding ModeOptions}"
                                    SelectedValueBinding="{Binding Value}"
                                    SelectedValue="{Binding Mode}">
                  <controls:AppSelect.ItemTemplate>
                    <DataTemplate x:DataType="vm:ReclamationModuleViewModel+IntOption">
                      <TextBlock Text="{Binding DisplayName}" TextWrapping="Wrap" />
                    </DataTemplate>
                  </controls:AppSelect.ItemTemplate>
                </controls:AppSelect>
              </controls:SettingsInlineRow>
              <TextBlock Classes="settings-note settings-centered-text long-wrap"
                         Text="{Binding Texts[Reclamation.EarlyTip]}" />
            </controls:AdaptiveSpacingStackPanel>
          </Border>
      </controls:AdaptiveSpacingStackPanel>

      <controls:AdaptiveSpacingStackPanel Classes="reclamation-settings-section-stack"
                  IsVisible="{Binding IsAdvancedMode}">
          <Border Classes="app-surface app-card">
            <controls:AdaptiveSpacingStackPanel Spacing="{DynamicResource MAA.App.Settings.PageToggleStackSpacing}">
              <TextBlock Classes="settings-note settings-centered-text long-wrap"
                         Text="{Binding Texts[Reclamation.ToolToCraftTip]}" />
              <controls:AppTextInput MaxWidth="{DynamicResource MAA.Size.Settings.FieldPathWideWidth}"
                                     HorizontalAlignment="Stretch"
                                     Watermark="{Binding Texts[Reclamation.ToolToCraftPlaceholder]}"
                                     IsEnabled="{Binding IsArchiveSettingsEnabled}"
                                     Text="{Binding ToolsToCraftText, UpdateSourceTrigger=LostFocus}" />
            </controls:AdaptiveSpacingStackPanel>
          </Border>

          <Border Classes="app-surface app-card">
            <controls:AdaptiveSpacingStackPanel Spacing="{DynamicResource MAA.App.Settings.PageToggleStackSpacing}">
              <controls:SettingsInlineRow FieldWidth="{DynamicResource MAA.Size.Settings.FieldWideWidth}">
                <TextBlock Classes="settings-field-caption"
                           Text="{Binding Texts[Reclamation.IncrementMode]}" />
                <controls:AppSelect IsEnabled="{Binding IsArchiveSettingsEnabled}"
                                    ItemsSource="{Binding IncrementModeOptions}"
                                    SelectedValueBinding="{Binding Value}"
                                    SelectedValue="{Binding IncrementMode}">
                  <controls:AppSelect.ItemTemplate>
                    <DataTemplate x:DataType="vm:ReclamationModuleViewModel+IntOption">
                      <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                  </controls:AppSelect.ItemTemplate>
                </controls:AppSelect>
              </controls:SettingsInlineRow>
              <controls:SettingsInlineRow>
                <TextBlock Classes="settings-field-caption"
                           Text="{Binding Texts[Reclamation.NumCraftBatches]}" />
                <controls:AppNumberInput Minimum="0"
                                         Maximum="99999"
                                         IsEnabled="{Binding IsArchiveSettingsEnabled}"
                                         Value="{Binding NumCraftBatches}" />
              </controls:SettingsInlineRow>
            </controls:AdaptiveSpacingStackPanel>
          </Border>

          <Border Classes="app-surface app-card"
                  IsVisible="{Binding ShowClearStore}">
            <controls:AdaptiveSpacingStackPanel>
              <CheckBox Classes="app-checkbox"
                        Content="{Binding Texts[Reclamation.ClearStore]}"
                        IsChecked="{Binding ClearStore}"
                        IsVisible="{Binding ShowClearStore}" />
            </controls:AdaptiveSpacingStackPanel>
          </Border>
      </controls:AdaptiveSpacingStackPanel>

      <controls:AdaptiveSpacingStackPanel Classes="reclamation-settings-status-stack">
          <Border Classes="app-surface app-card"
                  IsVisible="{Binding HasValidationIssues}">
            <controls:AdaptiveSpacingStackPanel Spacing="{DynamicResource MAA.App.Settings.PageToggleStackSpacing}">
              <TextBlock Classes="settings-centered-text subtle"
                         Text="{Binding Texts[Common.ValidationIssues]}" />
              <ListBox MaxHeight="96"
                       ItemsSource="{Binding ValidationMessages}">
                <ListBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Classes="long-wrap"
                               Text="{Binding .}"
                               TextWrapping="Wrap" />
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </controls:AdaptiveSpacingStackPanel>
          </Border>
          <TextBlock Classes="settings-note settings-centered-text long-wrap"
                     Text="{Binding StatusMessage}" />
      </controls:AdaptiveSpacingStackPanel>
    </controls:AdaptiveSpacingStackPanel>
  </Grid>
</UserControl>
