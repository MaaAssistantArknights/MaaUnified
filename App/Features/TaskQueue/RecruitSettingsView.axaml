<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             xmlns:vm="clr-namespace:MAAUnified.App.ViewModels.TaskQueue"
             x:Class="MAAUnified.App.Features.TaskQueue.RecruitSettingsView">
  <UserControl.Styles>
    <Style Selector="Border.recruit-time-card">
      <Setter Property="Padding" Value="10" />
    </Style>
    <Style Selector="controls|AppNumberInput.recruit-time-picker">
      <Setter Property="Width" Value="{DynamicResource MAA.Size.Toolbox.RecruitTimePickerWidth}" />
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
  </UserControl.Styles>

  <controls:AdaptiveSpacingStackPanel Margin="2"
              Classes="recruit-layout">
    <Border
            IsVisible="{Binding IsGeneralMode}">
      <controls:AdaptiveSpacingStackPanel Classes="recruit-section-content">
        <CheckBox Classes="app-checkbox"
                  Content="{Binding Texts[Recruit.UseExpedited]}"
                  IsChecked="{Binding UseExpedited}" />

        <Border Classes="app-surface app-card">
          <controls:SettingsInlineRow Classes="recruit-card-content">
            <TextBlock Classes="subtle"
                       Text="{Binding Texts[Recruit.Times]}"
                       TextWrapping="Wrap" />
            <controls:AppNumberInput Minimum="0"
                                     Maximum="99"
                                     Value="{Binding Times}" />
          </controls:SettingsInlineRow>
        </Border>
      </controls:AdaptiveSpacingStackPanel>
    </Border>

    <controls:AdaptiveSpacingStackPanel IsVisible="{Binding IsAdvancedMode}"
                Classes="recruit-section-content">
      <Border>
        <controls:AdaptiveSpacingStackPanel Classes="recruit-section-content">
          <Border Classes="app-surface app-card">
            <controls:SettingsInlineRow Classes="recruit-card-content"
                                        FieldWidth="{DynamicResource MAA.Size.Settings.FieldWideWidth}">
              <TextBlock Classes="subtle"
                         Text="{Binding Texts[Recruit.SelectStrategy]}"
                         TextWrapping="Wrap" />
              <controls:AppSelect ItemsSource="{Binding ExtraTagsModeOptions}"
                                  SelectedValueBinding="{Binding Value}"
                                  SelectedValue="{Binding ExtraTagsMode}">
                <controls:AppSelect.ItemTemplate>
                  <DataTemplate x:DataType="vm:RecruitTaskModuleViewModel+ExtraTagsModeOption">
                    <TextBlock Text="{Binding DisplayName}" />
                  </DataTemplate>
                </controls:AppSelect.ItemTemplate>
              </controls:AppSelect>
            </controls:SettingsInlineRow>
          </Border>

          <Border Classes="app-surface app-card">
            <controls:SettingsInlineRow Classes="recruit-card-content"
                                        FieldWidth="{DynamicResource MAA.Size.Settings.FieldWideWidth}">
              <TextBlock Classes="subtle"
                         Text="{Binding Texts[Recruit.FirstTags]}"
                         TextWrapping="Wrap" />
              <controls:AppMultiSelect HeaderText="{Binding FirstTagsSummary}">
                <controls:AppMultiSelect.DropDownContent>
                  <ItemsControl ItemsSource="{Binding FirstTagOptions}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Spacing="4" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate x:DataType="vm:RecruitTaskModuleViewModel+RecruitTagOption">
                        <ToggleButton Classes="app-multi-select-option"
                                      IsChecked="{Binding IsSelected}">
                          <TextBlock Text="{Binding DisplayName}" />
                        </ToggleButton>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </controls:AppMultiSelect.DropDownContent>
              </controls:AppMultiSelect>
            </controls:SettingsInlineRow>
          </Border>
        </controls:AdaptiveSpacingStackPanel>
      </Border>

      <Border>
        <controls:AdaptiveSpacingStackPanel Classes="recruit-section-content">
          <CheckBox Classes="app-checkbox"
                    Content="{Binding Texts[Recruit.Refresh]}"
                    IsChecked="{Binding Refresh}" />
          <CheckBox Classes="app-checkbox"
                    Content="{Binding Texts[Recruit.ForceRefresh]}"
                    IsChecked="{Binding ForceRefresh}"
                    IsEnabled="{Binding Refresh}" />

          <Border Classes="app-surface app-card">
            <controls:AdaptiveSpacingStackPanel Classes="recruit-card-content">
              <CheckBox Classes="app-checkbox"
                        Content="{Binding Texts[Recruit.PreserveTags]}"
                        IsChecked="{Binding PreserveTagsEnabled}" />
              <TextBlock Classes="subtle"
                         Text="{Binding Texts[Recruit.PreserveTagsTip]}"
                         TextWrapping="Wrap" />
              <controls:SettingsInlineRow FieldWidth="{DynamicResource MAA.Size.Settings.FieldWideWidth}"
                                          IsEnabled="{Binding PreserveTagsEnabled}">
                <TextBlock Classes="subtle"
                           Text="{Binding Texts[Recruit.PreserveTags]}"
                           TextWrapping="Wrap" />
                <controls:AppMultiSelect HeaderText="{Binding PreserveTagsSummary}">
                  <controls:AppMultiSelect.DropDownContent>
                    <ItemsControl ItemsSource="{Binding PreserveTagOptions}">
                      <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                          <StackPanel Spacing="4" />
                        </ItemsPanelTemplate>
                      </ItemsControl.ItemsPanel>
                      <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:RecruitTaskModuleViewModel+RecruitTagOption">
                          <ToggleButton Classes="app-multi-select-option"
                                        IsChecked="{Binding IsSelected}">
                            <TextBlock Text="{Binding DisplayName}" />
                          </ToggleButton>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </controls:AppMultiSelect.DropDownContent>
                </controls:AppMultiSelect>
              </controls:SettingsInlineRow>
            </controls:AdaptiveSpacingStackPanel>
          </Border>

          <Border Classes="app-surface app-card">
            <controls:AppHintedCheckBox Text="{Binding Texts[Recruit.NotChooseLevel1]}"
                                         Tip="{Binding Texts[Recruit.NotChooseLevel1Tip]}"
                                         IsChecked="{Binding NotChooseLevel1}" />
          </Border>
        </controls:AdaptiveSpacingStackPanel>
      </Border>

      <Border>
        <controls:AdaptiveSpacingStackPanel Classes="recruit-section-content">
          <Border Classes="app-surface app-card recruit-time-card">
            <controls:AdaptiveSpacingStackPanel Classes="recruit-card-content">
              <Grid ColumnDefinitions="Auto,12,Auto">
                <CheckBox Classes="app-checkbox"
                          Content="{Binding Texts[Recruit.ChooseLevel3]}"
                          IsChecked="{Binding ChooseLevel3}" />
                <Grid Grid.Column="2"
                      IsEnabled="{Binding ChooseLevel3}"
                      ColumnDefinitions="Auto,Auto,Auto">
                  <controls:AppNumberInput Classes="recruit-time-picker"
                                           Minimum="1"
                                           Maximum="9"
                                           WrapAroundStep="True"
                                           Value="{Binding Level3Hour}" />
                  <TextBlock Grid.Column="1"
                             Margin="{DynamicResource MAA.Thickness.MarginLeftSmall}"
                             VerticalAlignment="Center"
                             Text=":" />
                  <controls:AppNumberInput Grid.Column="2"
                                           Classes="recruit-time-picker"
                                           Margin="{DynamicResource MAA.Thickness.MarginLeftSmall}"
                                           Minimum="0"
                                           Maximum="50"
                                           Increment="10"
                                           WrapAroundStep="True"
                                           Value="{Binding Level3Minute}" />
                </Grid>
              </Grid>
            </controls:AdaptiveSpacingStackPanel>
          </Border>

          <Border Classes="app-surface app-card recruit-time-card">
            <controls:AdaptiveSpacingStackPanel Classes="recruit-card-content">
              <Grid ColumnDefinitions="Auto,12,Auto">
                <CheckBox Classes="app-checkbox"
                          Content="{Binding Texts[Recruit.ChooseLevel4]}"
                          IsChecked="{Binding ChooseLevel4}" />
                <Grid Grid.Column="2"
                      IsEnabled="{Binding ChooseLevel4}"
                      ColumnDefinitions="Auto,Auto,Auto">
                  <controls:AppNumberInput Classes="recruit-time-picker"
                                           Minimum="1"
                                           Maximum="9"
                                           WrapAroundStep="True"
                                           Value="{Binding Level4Hour}" />
                  <TextBlock Grid.Column="1"
                             Margin="{DynamicResource MAA.Thickness.MarginLeftSmall}"
                             VerticalAlignment="Center"
                             Text=":" />
                  <controls:AppNumberInput Grid.Column="2"
                                           Classes="recruit-time-picker"
                                           Margin="{DynamicResource MAA.Thickness.MarginLeftSmall}"
                                           Minimum="0"
                                           Maximum="50"
                                           Increment="10"
                                           WrapAroundStep="True"
                                           Value="{Binding Level4Minute}" />
                </Grid>
              </Grid>
            </controls:AdaptiveSpacingStackPanel>
          </Border>

          <Border Classes="app-surface app-card recruit-time-card">
            <controls:AdaptiveSpacingStackPanel Classes="recruit-card-content">
              <Grid ColumnDefinitions="Auto,12,Auto">
                <CheckBox Classes="app-checkbox"
                          Content="{Binding Texts[Recruit.ChooseLevel5]}"
                          IsChecked="{Binding ChooseLevel5}" />
                <Grid Grid.Column="2"
                      IsEnabled="{Binding ChooseLevel5}"
                      ColumnDefinitions="Auto,Auto,Auto">
                  <controls:AppNumberInput Classes="recruit-time-picker"
                                           Minimum="1"
                                           Maximum="9"
                                           WrapAroundStep="True"
                                           Value="{Binding Level5Hour}" />
                  <TextBlock Grid.Column="1"
                             Margin="{DynamicResource MAA.Thickness.MarginLeftSmall}"
                             VerticalAlignment="Center"
                             Text=":" />
                  <controls:AppNumberInput Grid.Column="2"
                                           Classes="recruit-time-picker"
                                           Margin="{DynamicResource MAA.Thickness.MarginLeftSmall}"
                                           Minimum="0"
                                           Maximum="50"
                                           Increment="10"
                                           WrapAroundStep="True"
                                           Value="{Binding Level5Minute}" />
                </Grid>
              </Grid>
            </controls:AdaptiveSpacingStackPanel>
          </Border>

          <Border Classes="app-surface app-card">
            <controls:AdaptiveSpacingStackPanel Classes="recruit-card-content">
              <StackPanel Orientation="Horizontal">
                <CheckBox Classes="app-checkbox"
                          Content="{Binding Texts[Recruit.AutoSelectLevel6]}"
                          IsChecked="{Binding ChooseLevel6}" />
                <TextBlock Classes="subtle"
                           Margin="{DynamicResource MAA.Thickness.MarginLeftSmall}"
                           VerticalAlignment="Center"
                           IsVisible="{Binding ChooseLevel6}"
                           Text="{Binding Texts[Recruit.AutoSelectLevel6FixedTime]}"
                           TextWrapping="Wrap" />
              </StackPanel>
            </controls:AdaptiveSpacingStackPanel>
          </Border>
        </controls:AdaptiveSpacingStackPanel>
      </Border>
    </controls:AdaptiveSpacingStackPanel>

    <Border IsVisible="{Binding HasValidationIssues}">
      <controls:AdaptiveSpacingStackPanel Classes="recruit-card-content">
        <Border Classes="app-surface app-card"
                IsVisible="{Binding HasValidationIssues}">
          <controls:AdaptiveSpacingStackPanel Classes="recruit-card-content">
            <TextBlock Classes="subtle"
                       Text="{Binding Texts[Common.ValidationIssues]}"
                       TextWrapping="Wrap" />
            <ListBox MaxHeight="96"
                     ItemsSource="{Binding ValidationMessages}" />
          </controls:AdaptiveSpacingStackPanel>
        </Border>
      </controls:AdaptiveSpacingStackPanel>
    </Border>
  </controls:AdaptiveSpacingStackPanel>
</UserControl>
