<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             xmlns:vm="clr-namespace:MAAUnified.App.ViewModels.TaskQueue"
             x:Class="MAAUnified.App.Features.TaskQueue.StartUpTaskView">
  <UserControl.Styles>
    <Style Selector="StackPanel.startup-layout">
      <Setter Property="Spacing" Value="{DynamicResource MAA.Spacing.Small}" />
    </Style>

    <Style Selector="StackPanel.startup-section-content">
      <Setter Property="Spacing" Value="{DynamicResource MAA.Spacing.Small}" />
    </Style>

    <Style Selector="StackPanel.startup-card-content">
      <Setter Property="Spacing" Value="{DynamicResource MAA.Spacing.Small}" />
    </Style>

    <Style Selector="TextBlock.startup-field-label">
      <Setter Property="FontWeight" Value="Normal" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Secondary}" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style Selector="ListBox.startup-validation-list">
      <Setter Property="MaxHeight" Value="96" />
    </Style>

  </UserControl.Styles>

  <controls:AdaptiveSpacingStackPanel Margin="2" Classes="startup-layout">
    <controls:AdaptiveSpacingStackPanel Classes="startup-section-content">
        <Border Classes="app-surface app-card"
                IsVisible="{Binding ShowAccountSwitch}">
          <controls:SettingsInlineRow Classes="startup-card-content"
                                      FieldWidth="{DynamicResource MAA.Size.Settings.FieldWidth}"
                                      controls:SettingsLabelWidthCoordinator.GroupKey="TaskQueue.Fields">
            <controls:SettingsLabel Text="{Binding Texts[StartUp.AccountSwitch]}"
                                    Tip="{Binding Texts[StartUp.AccountSwitchTip]}" />

            <controls:AppActionInput HorizontalAlignment="Left"
                                     Text="{Binding AccountName, UpdateSourceTrigger=LostFocus}"
                                     ActionContent="{Binding Texts[StartUp.AccountSwitchManualRun]}"
                                     ActionClick="OnAccountSwitchManualRunClick" />
          </controls:SettingsInlineRow>
        </Border>

        <Border Classes="app-surface app-card">
          <CheckBox Classes="app-checkbox"
                    Content="{Binding Texts[StartUp.StartGameEnabled]}"
                    IsChecked="{Binding StartGameEnabled}"
                    IsEnabled="{Binding CanEditStartGameEnabled}" />
        </Border>
      </controls:AdaptiveSpacingStackPanel>

    <controls:AdaptiveSpacingStackPanel Classes="startup-section-content">
        <Border Classes="app-surface app-card">
          <controls:SettingsInlineRow Classes="startup-card-content"
                                      controls:SettingsLabelWidthCoordinator.GroupKey="TaskQueue.Fields">
            <controls:SettingsLabel Text="{Binding Texts[StartUp.ClientType]}" />
            <controls:AppSelect ItemsSource="{Binding ClientTypeOptions}"
                                SelectedValueBinding="{Binding Type}"
                                SelectedValue="{Binding SelectedClientTypeValue}">
              <controls:AppSelect.ItemTemplate>
                <DataTemplate x:DataType="vm:TaskModuleOption">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </controls:AppSelect.ItemTemplate>
            </controls:AppSelect>
          </controls:SettingsInlineRow>
        </Border>

        <Border Classes="app-surface app-card">
          <controls:SettingsInlineRow Classes="startup-card-content"
                                      controls:SettingsLabelWidthCoordinator.GroupKey="TaskQueue.Fields">
            <controls:SettingsLabel Text="{Binding Texts[StartUp.ConnectConfig]}" />
            <controls:AppSelect ItemsSource="{Binding ConnectConfigOptions}"
                                SelectedValueBinding="{Binding Type}"
                                SelectedValue="{Binding SelectedConnectConfigValue}">
              <controls:AppSelect.ItemTemplate>
                <DataTemplate x:DataType="vm:TaskModuleOption">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </controls:AppSelect.ItemTemplate>
            </controls:AppSelect>
          </controls:SettingsInlineRow>
        </Border>

        <Border Classes="app-surface app-card">
          <controls:SettingsInlineRow Classes="startup-card-content"
                                      FieldWidth="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
                                      controls:SettingsLabelWidthCoordinator.GroupKey="TaskQueue.Fields">
            <controls:SettingsLabel Text="{Binding Texts[StartUp.ConnectAddress]}"
                                    Tip="{Binding Texts[StartUp.ConnectionAddressTip]}" />

            <controls:AppHistoryInput ItemsSource="{Binding ConnectAddressHistory}"
                                      Text="{Binding ConnectAddress, Mode=TwoWay}"
                                      ItemDeleted="OnConnectAddressItemDeleted"
                                      EditorCommitted="OnConnectAddressEditorCommitted"
                                      SelectionCommitted="OnConnectAddressSelectionCommitted" />
          </controls:SettingsInlineRow>
        </Border>
      </controls:AdaptiveSpacingStackPanel>

    <controls:AdaptiveSpacingStackPanel Classes="startup-section-content">
        <Border Classes="app-surface app-card">
          <controls:SettingsInlineRow Classes="startup-card-content"
                                      FieldWidth="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
                                      controls:SettingsLabelWidthCoordinator.GroupKey="TaskQueue.Fields">
            <controls:SettingsLabel Text="{Binding Texts[StartUp.AdbPath]}" />

            <controls:AppActionInput Text="{Binding AdbPath, UpdateSourceTrigger=LostFocus}"
                                     ActionContent="{Binding Texts[StartUp.Select]}"
                                     ActionClick="OnSelectAdbPathClick" />
          </controls:SettingsInlineRow>
        </Border>

        <Border Classes="app-surface app-card">
          <controls:SettingsInlineRow Classes="startup-card-content"
                                      controls:SettingsLabelWidthCoordinator.GroupKey="TaskQueue.Fields">
            <controls:SettingsLabel Text="{Binding Texts[StartUp.TouchMode]}" />
            <controls:AppSelect ItemsSource="{Binding TouchModeOptions}"
                                SelectedValueBinding="{Binding Type}"
                                SelectedValue="{Binding SelectedTouchModeValue}">
              <controls:AppSelect.ItemTemplate>
                <DataTemplate x:DataType="vm:TaskModuleOption">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </controls:AppSelect.ItemTemplate>
            </controls:AppSelect>
          </controls:SettingsInlineRow>
        </Border>

        <Border Classes="app-surface app-card">
          <controls:AppHintedCheckBox Text="{Binding Texts[StartUp.AutoDetect]}"
                                       Tip="{Binding Texts[StartUp.AutoDetectConnectionTip]}"
                                       IsChecked="{Binding AutoDetectConnection}" />
        </Border>
      </controls:AdaptiveSpacingStackPanel>

    <controls:AdaptiveSpacingStackPanel Classes="startup-section-content">
        <Border Classes="app-surface app-card"
                IsVisible="{Binding HasValidationIssues}">
          <controls:AdaptiveSpacingStackPanel Classes="startup-card-content">
            <TextBlock Classes="startup-field-label"
                       Text="{Binding Texts[Common.ValidationIssues]}" />
            <ListBox Classes="startup-validation-list"
                     ItemsSource="{Binding ValidationMessages}" />
          </controls:AdaptiveSpacingStackPanel>
        </Border>
      </controls:AdaptiveSpacingStackPanel>
  </controls:AdaptiveSpacingStackPanel>
</UserControl>
