<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             xmlns:vm="clr-namespace:MAAUnified.App.ViewModels.TaskQueue"
             x:Class="MAAUnified.App.Features.TaskQueue.StartUpTaskView">
  <UserControl.Styles>
    <Style Selector="StackPanel.startup-layout">
      <Setter Property="Spacing" Value="{DynamicResource MAA.Spacing.Small}" />
    </Style>

    <Style Selector="StackPanel.startup-section-content">
      <Setter Property="Spacing" Value="{DynamicResource MAA.Spacing.Small}" />
    </Style>

    <Style Selector="StackPanel.startup-card-content">
      <Setter Property="Spacing" Value="{DynamicResource MAA.Spacing.Small}" />
    </Style>

    <Style Selector="TextBlock.startup-field-label">
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Text.Primary}" />
      <Setter Property="TextWrapping" Value="Wrap" />
    </Style>

    <Style Selector="ListBox.startup-validation-list">
      <Setter Property="MaxHeight" Value="96" />
    </Style>
  </UserControl.Styles>

  <StackPanel Margin="2" Classes="startup-layout">
    <TextBlock Classes="section-title" Text="{Binding Texts[StartUp.Title]}" />

    <Border Classes="app-surface app-section">
      <StackPanel Classes="startup-section-content">
        <Border Classes="app-surface app-card"
                IsVisible="{Binding ShowAccountSwitch}">
          <StackPanel Classes="startup-card-content">
            <Grid ColumnDefinitions="Auto,Auto,*">
              <TextBlock Classes="startup-field-label"
                         Text="{Binding Texts[StartUp.AccountSwitch]}" />
              <controls:TooltipHint Grid.Column="1"
                                    Margin="6,0,0,0"
                                    Tip="{Binding Texts[StartUp.AccountSwitchTip]}" />
            </Grid>

            <TextBox Classes="app-input app-input-block"
                     Text="{Binding AccountName, UpdateSourceTrigger=LostFocus}" />

            <Button Classes="app-button app-secondary"
                    HorizontalAlignment="Left"
                    Content="{Binding Texts[StartUp.AccountSwitchManualRun]}"
                    IsEnabled="{Binding CanRunAccountSwitchNow}"
                    Click="OnAccountSwitchManualRunClick" />
          </StackPanel>
        </Border>

        <Border Classes="app-surface app-card">
          <CheckBox Classes="app-checkbox"
                    Content="{Binding Texts[StartUp.StartGameEnabled]}"
                    IsChecked="{Binding StartGameEnabled}"
                    IsEnabled="{Binding CanEditStartGameEnabled}" />
        </Border>
      </StackPanel>
    </Border>

    <Border Classes="app-surface app-section">
      <StackPanel Classes="startup-section-content">
        <Border Classes="app-surface app-card">
          <StackPanel Classes="startup-card-content">
            <TextBlock Classes="startup-field-label"
                       Text="{Binding Texts[StartUp.ClientType]}" />
            <ComboBox ItemsSource="{Binding ClientTypeOptions}"
                      SelectedValueBinding="{Binding Type}"
                      SelectedValue="{Binding SelectedClientTypeValue}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:TaskModuleOption">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>
        </Border>

        <Border Classes="app-surface app-card">
          <StackPanel Classes="startup-card-content">
            <TextBlock Classes="startup-field-label"
                       Text="{Binding Texts[StartUp.ConnectConfig]}" />
            <ComboBox ItemsSource="{Binding ConnectConfigOptions}"
                      SelectedValueBinding="{Binding Type}"
                      SelectedValue="{Binding SelectedConnectConfigValue}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:TaskModuleOption">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>
        </Border>

        <Border Classes="app-surface app-card">
          <StackPanel Classes="startup-card-content">
            <Grid ColumnDefinitions="Auto,Auto,*">
              <TextBlock Classes="startup-field-label"
                         Text="{Binding Texts[StartUp.ConnectAddress]}" />
              <controls:TooltipHint Grid.Column="1"
                                    Margin="6,0,0,0"
                                    Tip="{Binding Texts[StartUp.ConnectionAddressTip]}" />
            </Grid>

            <AutoCompleteBox ItemsSource="{Binding ConnectAddressHistory}"
                             Text="{Binding ConnectAddress, UpdateSourceTrigger=LostFocus}" />
          </StackPanel>
        </Border>
      </StackPanel>
    </Border>

    <Border Classes="app-surface app-section">
      <StackPanel Classes="startup-section-content">
        <Border Classes="app-surface app-card">
          <StackPanel Classes="startup-card-content">
            <TextBlock Classes="startup-field-label"
                       Text="{Binding Texts[StartUp.AdbPath]}" />

            <TextBox Classes="app-input app-input-block"
                     Text="{Binding AdbPath, UpdateSourceTrigger=LostFocus}" />

            <Button Classes="app-button app-secondary"
                    HorizontalAlignment="Left"
                    Content="{Binding Texts[StartUp.Select]}"
                    Click="OnSelectAdbPathClick" />
          </StackPanel>
        </Border>

        <Border Classes="app-surface app-card">
          <StackPanel Classes="startup-card-content">
            <TextBlock Classes="startup-field-label"
                       Text="{Binding Texts[StartUp.TouchMode]}" />
            <ComboBox ItemsSource="{Binding TouchModeOptions}"
                      SelectedValueBinding="{Binding Type}"
                      SelectedValue="{Binding SelectedTouchModeValue}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:TaskModuleOption">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>
        </Border>

        <Border Classes="app-surface app-card">
          <Grid ColumnDefinitions="Auto,Auto,*">
            <CheckBox Classes="app-checkbox"
                      Content="{Binding Texts[StartUp.AutoDetect]}"
                      IsChecked="{Binding AutoDetectConnection}" />
            <controls:TooltipHint Grid.Column="1"
                                  Margin="6,0,0,0"
                                  VerticalAlignment="Center"
                                  Tip="{Binding Texts[StartUp.AutoDetectConnectionTip]}" />
          </Grid>
        </Border>
      </StackPanel>
    </Border>

    <Border Classes="app-surface app-section">
      <StackPanel Classes="startup-section-content">
        <Border Classes="app-surface app-card">
          <StackPanel Classes="startup-card-content">
            <TextBlock Classes="long-wrap"
                       Text="{Binding StatusMessage}" />
            <TextBlock Classes="long-wrap state-error"
                       Text="{Binding LastErrorMessage}" />
          </StackPanel>
        </Border>

        <Border Classes="app-surface app-card"
                IsVisible="{Binding HasValidationIssues}">
          <StackPanel Classes="startup-card-content">
            <TextBlock Classes="startup-field-label"
                       Text="{Binding Texts[Common.ValidationIssues]}" />
            <ListBox Classes="startup-validation-list"
                     ItemsSource="{Binding ValidationMessages}" />
          </StackPanel>
        </Border>
      </StackPanel>
    </Border>
  </StackPanel>
</UserControl>
