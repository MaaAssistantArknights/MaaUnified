<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MAAUnified.App.Controls"
        x:Class="MAAUnified.App.Features.Dialogs.ProcessPickerDialogView"
        Width="620"
        Height="460"
        MinWidth="520"
        MinHeight="360"
        CanResize="False"
        Background="Transparent"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        WindowStartupLocation="CenterOwner">
  <controls:AppWindowFrame x:Name="DialogShell"
                           Mode="CompactModal"
                           CloseRequested="OnShellCloseRequested">
    <controls:AppWindowFrame.HeaderContent>
      <TextBlock x:Name="SelectionSummaryText"
                 Classes="app-window-subtitle long-wrap"
                 Text="No running process found" />
    </controls:AppWindowFrame.HeaderContent>
    <controls:AppWindowFrame.Content>
      <Grid RowDefinitions="Auto,*">
        <Border Classes="app-surface app-section">
          <StackPanel Classes="app-compact-selection-intro">
            <TextBlock Classes="section-title"
                       Text="Running processes" />
            <TextBlock x:Name="HintText"
                       Classes="app-window-subtitle subtle long-wrap"
                       Text="Choose the process that should receive the connection." />
          </StackPanel>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,14,0,0">
          <Border Classes="app-surface app-card">
            <controls:AppSelectionList x:Name="ProcessList"
                                       Classes="app-compact-selection-list"
                                       VisualMode="Surface"
                                       SelectionMode="Single"
                                       SelectionChanged="OnProcessSelectionChanged"
                                       DoubleTapped="OnProcessListDoubleTapped"
                                       KeyDown="OnProcessListKeyDown">
              <controls:AppSelectionList.ItemTemplate>
                <DataTemplate>
                  <Border Classes="app-selection-list-item-shell">
                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto">
                      <TextBlock Classes="section-title long-wrap"
                                 Text="{Binding DisplayName}" />
                      <Border Grid.Column="1"
                              Classes="app-badge"
                              IsVisible="{Binding IsPrimary}">
                        <TextBlock Classes="app-badge-text"
                                   Text="Primary" />
                      </Border>
                      <TextBlock Grid.Row="1"
                                 Grid.ColumnSpan="2"
                                 Margin="0,8,0,0"
                                 Classes="app-caption long-ellipsis"
                                 Text="{Binding Id}" />
                    </Grid>
                  </Border>
                </DataTemplate>
              </controls:AppSelectionList.ItemTemplate>
            </controls:AppSelectionList>
          </Border>

          <Border x:Name="EmptyStatePanel"
                  Classes="app-surface app-section"
                  IsVisible="False">
            <StackPanel Classes="app-compact-empty-state-content">
              <TextBlock Classes="app-window-title app-compact-empty-title"
                         Text="No running process found" />
              <TextBlock Classes="app-window-subtitle app-compact-empty-body"
                         Text="Refresh to scan again, or check whether the target app is already open." />
            </StackPanel>
          </Border>
        </Grid>
      </Grid>
    </controls:AppWindowFrame.Content>
    <controls:AppWindowFrame.ActionsContent>
      <StackPanel Orientation="Horizontal"
                  Spacing="10">
        <Button x:Name="RefreshButton"
                Classes="app-button app-secondary"
                Content="Refresh"
                Click="OnRefreshClick" />
        <Button x:Name="CancelButton"
                Classes="app-button app-secondary"
                Content="Cancel"
                Click="OnCancelClick" />
        <Button x:Name="ConfirmButton"
                Classes="app-button app-primary"
                Content="Select"
                Click="OnConfirmClick" />
      </StackPanel>
    </controls:AppWindowFrame.ActionsContent>
  </controls:AppWindowFrame>
</Window>
