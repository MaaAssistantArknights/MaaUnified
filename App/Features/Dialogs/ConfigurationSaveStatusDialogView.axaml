<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MAAUnified.App.Controls"
        x:Class="MAAUnified.App.Features.Dialogs.ConfigurationSaveStatusDialogView"
        Width="560"
        MinWidth="460"
        SizeToContent="Height"
        CanResize="False"
        Background="Transparent"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        WindowStartupLocation="CenterOwner">
  <controls:AppWindowFrame x:Name="DialogShell"
                           Mode="CompactModal"
                           ShowCloseButton="False"
                           CloseRequested="OnShellCloseRequested">
    <controls:AppWindowFrame.Content>
      <TextBlock x:Name="MessageTextBlock"
                 Classes="app-lead long-wrap"
                 Text="" />
    </controls:AppWindowFrame.Content>
    <controls:AppWindowFrame.ActionsContent>
      <Button x:Name="ConfirmButton"
              Classes="app-button app-primary"
              Content="确定"
              IsDefault="True"
              Click="OnConfirmClick" />
    </controls:AppWindowFrame.ActionsContent>
  </controls:AppWindowFrame>
</Window>
