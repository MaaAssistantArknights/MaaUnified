<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MAAUnified.App.Features.Dialogs.EmulatorPathSelectionDialogView"
        Width="720"
        Height="480"
        MinWidth="620"
        MinHeight="380"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="10" RowDefinitions="Auto,*,Auto,Auto">
    <TextBlock x:Name="DialogTitleText"
               Classes="section-title dialog-window-title"
               Text="Emulator Path Selection" />
    <ListBox x:Name="PathList"
             Grid.Row="1"
             Margin="0,8,0,0"
             SelectionMode="Single" />
    <TextBox x:Name="PathInput"
             Grid.Row="2"
             Margin="0,8,0,0"
             Watermark="/path/to/emulator" />
    <StackPanel Grid.Row="3"
                Orientation="Horizontal"
                Spacing="8"
                HorizontalAlignment="Right"
                Margin="0,12,0,0">
      <Button Classes="wpf-button wpf-button-secondary" x:Name="CancelButton" Content="Cancel" Click="OnCancelClick" />
      <Button x:Name="ConfirmButton" Classes="wpf-button" Content="Confirm" Click="OnConfirmClick" />
    </StackPanel>
  </Grid>
</Window>
