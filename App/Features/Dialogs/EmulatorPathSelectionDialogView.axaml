<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MAAUnified.App.Controls"
        x:Class="MAAUnified.App.Features.Dialogs.EmulatorPathSelectionDialogView"
        Width="720"
        Height="480"
        MinWidth="620"
        MinHeight="380"
        CanResize="False"
        Background="Transparent"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        WindowStartupLocation="CenterOwner">
  <controls:AppWindowFrame x:Name="DialogShell"
                           Mode="CompactModal"
                           CloseRequested="OnShellCloseRequested">
    <controls:AppWindowFrame.HeaderContent>
      <TextBlock x:Name="SelectionSummaryText"
                 Classes="app-window-subtitle long-wrap"
                 Text="No detected paths" />
    </controls:AppWindowFrame.HeaderContent>
    <controls:AppWindowFrame.Content>
      <Grid RowDefinitions="Auto,*,Auto">
        <Border Classes="app-surface app-section">
          <StackPanel Classes="app-compact-selection-intro">
            <TextBlock Classes="section-title"
                       Text="Detected paths" />
            <TextBlock x:Name="DialogIntroText"
                       Classes="app-window-subtitle subtle long-wrap"
                       Text="Pick a detected emulator executable or paste a custom path below." />
          </StackPanel>
        </Border>

        <Grid Grid.Row="1"
              Margin="0,14,0,0">
          <Border Classes="app-surface app-card">
            <controls:AppSelectionList x:Name="PathList"
                                       Classes="app-compact-selection-list"
                                       VisualMode="Surface"
                                       SelectionMode="Single"
                                       DoubleTapped="OnPathListDoubleTapped"
                                       KeyDown="OnPathListKeyDown">
              <controls:AppSelectionList.ItemTemplate>
                <DataTemplate>
                  <Border Classes="app-selection-list-item-shell">
                    <TextBlock Classes="app-body long-wrap"
                               Text="{Binding .}" />
                  </Border>
                </DataTemplate>
              </controls:AppSelectionList.ItemTemplate>
            </controls:AppSelectionList>
          </Border>

          <Border x:Name="EmptyStatePanel"
                  Classes="app-surface app-section"
                  IsVisible="False">
            <StackPanel Classes="app-compact-empty-state-content">
              <TextBlock Classes="app-window-title app-compact-empty-title"
                         Text="No detected paths" />
              <TextBlock Classes="app-window-subtitle app-compact-empty-body"
                         Text="Paste the emulator executable path below if auto-detection did not find one." />
            </StackPanel>
          </Border>
        </Grid>

        <Border Grid.Row="2"
                Margin="0,14,0,0"
                Classes="app-surface app-section">
          <Grid RowDefinitions="Auto,Auto">
            <TextBlock Classes="section-title"
                       Text="Custom path" />
            <controls:AppTextInput x:Name="PathInput"
                                   Grid.Row="1"
                                   Margin="0,10,0,0"
                                   Watermark="/path/to/emulator"
                                   TextChanged="OnPathInputTextChanged"
                                   KeyDown="OnPathInputKeyDown" />
          </Grid>
        </Border>
      </Grid>
    </controls:AppWindowFrame.Content>
    <controls:AppWindowFrame.ActionsContent>
      <StackPanel Orientation="Horizontal"
                  Spacing="10">
        <Button x:Name="CancelButton"
                Classes="app-button app-secondary"
                Content="Cancel"
                Click="OnCancelClick" />
        <Button x:Name="ConfirmButton"
                Classes="app-button app-primary"
                Content="Confirm"
                Click="OnConfirmClick" />
      </StackPanel>
    </controls:AppWindowFrame.ActionsContent>
  </controls:AppWindowFrame>
</Window>
