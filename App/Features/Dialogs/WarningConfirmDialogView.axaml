<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MAAUnified.App.Controls"
        x:Class="MAAUnified.App.Features.Dialogs.WarningConfirmDialogView"
        Width="620"
        MinWidth="520"
        SizeToContent="Height"
        CanResize="False"
        Background="Transparent"
        SystemDecorations="None"
        WindowStartupLocation="CenterOwner">
  <controls:AppWindowFrame x:Name="DialogShell"
                           Mode="CompactModal"
                           ShowCloseButton="False"
                           CloseRequested="OnShellCloseRequested">
    <controls:AppWindowFrame.Content>
      <Border Classes="warning-dialog-content">
        <Grid ColumnDefinitions="Auto,*">
          <Border Classes="app-hero app-warning-hero"
                  VerticalAlignment="Top">
            <TextBlock Classes="app-hero-glyph app-warning-hero-glyph"
                       Text="!" />
          </Border>

          <StackPanel Grid.Column="1"
                      Margin="18,2,0,0"
                      Spacing="12">
            <TextBlock x:Name="LeadTextBlock"
                       Classes="app-lead long-wrap"
                       IsVisible="False"
                       Text="" />
            <Border x:Name="EmphasisPanel"
                    Classes="app-highlight app-warning-highlight"
                    IsVisible="False">
              <TextBlock x:Name="EmphasisTextBlock"
                         Classes="app-emphasis app-warning-emphasis long-wrap"
                         Text="" />
            </Border>
            <TextBlock x:Name="DetailTextBlock"
                       Classes="app-body long-wrap"
                       Text="" />
          </StackPanel>
        </Grid>
      </Border>
    </controls:AppWindowFrame.Content>
    <controls:AppWindowFrame.ActionsContent>
      <StackPanel Orientation="Horizontal"
                  Spacing="10">
        <Button x:Name="CancelButton"
                Classes="app-button app-secondary"
                Content=""
                Click="OnCancelClick" />
        <Button x:Name="ConfirmButton"
                Classes="app-button app-primary"
                Content=""
                Click="OnConfirmClick" />
      </StackPanel>
    </controls:AppWindowFrame.ActionsContent>
  </controls:AppWindowFrame>
</Window>
