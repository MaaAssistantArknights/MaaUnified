<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MAAUnified.App.Features.Dialogs.VersionUpdateDialogView"
        Width="680"
        Height="520"
        MinWidth="580"
        MinHeight="420"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="10" RowDefinitions="Auto,Auto,Auto,*,Auto">
    <TextBlock x:Name="DialogTitleText"
               Classes="section-title dialog-window-title"
               Text="Version Update" />
    <TextBlock x:Name="VersionLine"
               Grid.Row="1"
               Margin="0,8,0,0"
               Classes="long-wrap"
               Text="Current -> Target" />
    <TextBlock x:Name="SummaryLine"
               Grid.Row="2"
               Margin="0,6,0,0"
               Classes="long-wrap"
               Text="Summary" />
    <TextBox x:Name="BodyBox"
             Grid.Row="3"
             Margin="0,10,0,0"
             IsReadOnly="True"
             TextWrapping="Wrap"
             AcceptsReturn="True" />
    <StackPanel Grid.Row="4"
                Orientation="Horizontal"
                Spacing="8"
                HorizontalAlignment="Right"
                Margin="0,12,0,0">
      <Button Classes="wpf-button wpf-button-secondary" x:Name="CancelButton" Content="Later" Click="OnCancelClick" />
      <Button x:Name="ConfirmButton" Classes="wpf-button" Content="Confirm" Click="OnConfirmClick" />
    </StackPanel>
  </Grid>
</Window>
