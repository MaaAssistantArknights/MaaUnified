<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialogs="clr-namespace:MAAUnified.App.Features.Dialogs"
        x:Class="MAAUnified.App.Features.Dialogs.VersionUpdateDialogView"
        Width="680"
        Height="520"
        MinWidth="580"
        MinHeight="420"
        CanResize="False"
        Background="Transparent"
        SystemDecorations="None"
        WindowStartupLocation="CenterOwner">
  <dialogs:ModernDialogShell x:Name="DialogShell"
                             CloseRequested="OnShellCloseRequested">
    <dialogs:ModernDialogShell.Content>
      <Grid RowDefinitions="Auto,*">
        <StackPanel Spacing="8">
          <TextBlock x:Name="VersionLine"
                     Classes="modern-dialog-lead"
                     Text="Current -> Target" />
          <TextBlock x:Name="SummaryLine"
                     Classes="modern-dialog-body"
                     Text="Summary" />
        </StackPanel>
        <Border Grid.Row="1"
                Margin="0,12,0,0"
                Classes="modern-dialog-section">
          <TextBox x:Name="BodyBox"
                   AcceptsReturn="True"
                   IsReadOnly="True"
                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                   TextWrapping="Wrap"
                   />
        </Border>
      </Grid>
    </dialogs:ModernDialogShell.Content>
    <dialogs:ModernDialogShell.ActionsContent>
      <StackPanel Orientation="Horizontal"
                  Spacing="10">
        <Button x:Name="CancelButton"
                Classes="modern-dialog-button modern-dialog-button-secondary"
                Content="Later"
                IsCancel="True"
                Click="OnCancelClick" />
        <Button x:Name="ConfirmButton"
                Classes="modern-dialog-button modern-dialog-button-primary"
                Content="Confirm"
                IsDefault="True"
                Click="OnConfirmClick" />
      </StackPanel>
    </dialogs:ModernDialogShell.ActionsContent>
  </dialogs:ModernDialogShell>
</Window>
