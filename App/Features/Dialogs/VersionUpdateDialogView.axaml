<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MAAUnified.App.Controls"
        x:Class="MAAUnified.App.Features.Dialogs.VersionUpdateDialogView"
        Width="680"
        Height="520"
        MinWidth="580"
        MinHeight="420"
        CanResize="False"
        Background="Transparent"
        SystemDecorations="None"
        WindowStartupLocation="CenterOwner">
  <controls:AppWindowFrame x:Name="DialogShell"
                           Mode="CompactModal"
                           CloseRequested="OnShellCloseRequested">
    <controls:AppWindowFrame.Content>
      <Grid RowDefinitions="Auto,*">
        <StackPanel Spacing="8">
          <TextBlock x:Name="VersionLine"
                     Classes="section-title"
                     Text="Current -> Target" />
          <TextBlock x:Name="SummaryLine"
                     Classes="app-body"
                     Text="Summary" />
        </StackPanel>
        <Border Grid.Row="1"
                Margin="0,12,0,0"
                Classes="app-surface app-section">
          <TextBox x:Name="BodyBox"
                   Classes="app-input app-input-block"
                   AcceptsReturn="True"
                   IsReadOnly="True"
                   ScrollViewer.VerticalScrollBarVisibility="Auto"
                   TextWrapping="Wrap" />
        </Border>
      </Grid>
    </controls:AppWindowFrame.Content>
    <controls:AppWindowFrame.ActionsContent>
      <StackPanel Orientation="Horizontal"
                  Spacing="10">
        <Button x:Name="CancelButton"
                Classes="app-button app-secondary"
                Content="Later"
                IsCancel="True"
                Click="OnCancelClick" />
        <Button x:Name="ConfirmButton"
                Classes="app-button app-primary"
                Content="Confirm"
                IsDefault="True"
                Click="OnConfirmClick" />
      </StackPanel>
    </controls:AppWindowFrame.ActionsContent>
  </controls:AppWindowFrame>
</Window>
