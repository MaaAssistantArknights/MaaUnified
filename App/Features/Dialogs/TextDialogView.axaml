<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MAAUnified.App.Features.Dialogs.TextDialogView"
        Width="620"
        Height="320"
        MinWidth="480"
        MinHeight="260"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="10" RowDefinitions="Auto,Auto,*,Auto">
    <TextBlock x:Name="DialogTitleText"
               Classes="section-title dialog-window-title"
               Text="Text Dialog" />
    <TextBlock x:Name="PromptText"
               Grid.Row="1"
               Margin="0,8,0,0"
               Classes="long-wrap"
               Text="Prompt" />
    <TextBox x:Name="InputBox"
             Grid.Row="2"
             Margin="0,8,0,0"
             TextWrapping="Wrap"
             AcceptsReturn="False" />
    <StackPanel Grid.Row="3"
                Orientation="Horizontal"
                Spacing="8"
                HorizontalAlignment="Right"
                Margin="0,12,0,0">
      <Button Classes="wpf-button wpf-button-secondary" x:Name="CancelButton" Content="Cancel" Click="OnCancelClick" />
      <Button x:Name="ConfirmButton" Classes="wpf-button" Content="Confirm" Click="OnConfirmClick" />
    </StackPanel>
  </Grid>
</Window>
