<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MAAUnified.App.Controls"
        x:Class="MAAUnified.App.Features.Dialogs.ErrorDialogView"
        Width="760"
        Height="540"
        MinWidth="640"
        MinHeight="420"
        CanResize="False"
        Background="Transparent"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        WindowStartupLocation="CenterOwner">
  <controls:AppWindowFrame x:Name="DialogShell"
                           Mode="CompactModal"
                           CloseRequested="OnShellCloseRequested">
    <controls:AppWindowFrame.HeaderContent>
      <TextBlock x:Name="ContextLine"
                 Classes="app-window-subtitle subtle long-wrap"
                 Text="Context" />
    </controls:AppWindowFrame.HeaderContent>
    <controls:AppWindowFrame.Content>
      <Grid RowDefinitions="Auto,*">
        <Border Classes="error-dialog-summary-panel">
          <Grid ColumnDefinitions="Auto,*">
            <Border x:Name="SummaryHero"
                    Classes="app-hero error-dialog-hero"
                    VerticalAlignment="Top">
              <TextBlock Classes="app-hero-glyph error-dialog-hero-glyph"
                         Text="!" />
            </Border>

            <StackPanel x:Name="SummaryContentPanel"
                        Grid.Column="1"
                        Margin="18,2,0,0"
                        Spacing="12">
              <TextBlock x:Name="FriendlyMessageText"
                         Classes="app-lead long-wrap"
                         Text="" />
              <Border x:Name="SuggestionPanel"
                      Classes="error-dialog-suggestion-panel"
                      IsVisible="False">
                <TextBlock x:Name="SuggestionText"
                           Classes="app-body long-wrap"
                           Text="" />
              </Border>
            </StackPanel>
          </Grid>
        </Border>

        <Grid x:Name="DetailHost"
              Grid.Row="1"
              Margin="0,18,0,0"
              RowDefinitions="Auto,*">
          <TextBlock x:Name="DetailSectionTitle"
                     Classes="section-title"
                     Text="Error details" />
          <Border Grid.Row="1"
                  Margin="0,8,0,0"
                  Classes="error-dialog-detail-panel">
            <TextBox x:Name="ErrorDetailBox"
                     Classes="settings-input settings-input-block error-dialog-detail-box"
                     AcceptsReturn="True"
                     IsReadOnly="True"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     TextWrapping="Wrap" />
          </Border>
        </Grid>
      </Grid>
    </controls:AppWindowFrame.Content>
    <controls:AppWindowFrame.ActionsContent>
      <StackPanel Orientation="Horizontal"
                  Spacing="10">
        <Button x:Name="CopyButton"
                Classes="app-button app-secondary"
                Content="Copy"
                Click="OnCopyClick" />
        <Button x:Name="IssueReportButton"
                Classes="app-button app-secondary"
                Content="IssueReport"
                Click="OnOpenIssueReportClick" />
        <Button x:Name="CancelButton"
                Classes="app-button app-secondary"
                Content="Ignore"
                IsCancel="True"
                Click="OnCancelClick" />
        <Button x:Name="ConfirmButton"
                Classes="app-button app-primary"
                Content="Close"
                IsDefault="True"
                Click="OnConfirmClick" />
      </StackPanel>
    </controls:AppWindowFrame.ActionsContent>
  </controls:AppWindowFrame>
</Window>
