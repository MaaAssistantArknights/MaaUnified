<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="MAAUnified.App.Features.Dialogs.ErrorDialogView"
        Width="760"
        Height="540"
        MinWidth="640"
        MinHeight="420"
        WindowStartupLocation="CenterOwner">
  <Grid Margin="10" RowDefinitions="Auto,Auto,*,Auto">
    <TextBlock x:Name="DialogTitleText"
               Classes="section-title dialog-window-title"
               Foreground="{DynamicResource MAA.ErrorBrush}"
               Text="Error" />
    <TextBlock x:Name="ContextLine"
               Grid.Row="1"
               Margin="0,8,0,0"
               Classes="long-wrap"
               Text="Context" />
    <TextBox x:Name="ErrorDetailBox"
             Grid.Row="2"
             Margin="0,8,0,0"
             IsReadOnly="True"
             AcceptsReturn="True"
             TextWrapping="Wrap" />
    <StackPanel Grid.Row="3"
                Orientation="Horizontal"
                Spacing="8"
                HorizontalAlignment="Right"
                Margin="0,12,0,0">
      <Button x:Name="CopyButton" Classes="wpf-button wpf-button-secondary" Content="Copy" Click="OnCopyClick" />
      <Button x:Name="IssueReportButton" Classes="wpf-button wpf-button-secondary" Content="IssueReport" Click="OnOpenIssueReportClick" />
      <Button Classes="wpf-button wpf-button-secondary" x:Name="CancelButton" Content="Ignore" Click="OnCancelClick" />
      <Button x:Name="ConfirmButton" Classes="wpf-button" Content="Close" Click="OnConfirmClick" />
    </StackPanel>
  </Grid>
</Window>
