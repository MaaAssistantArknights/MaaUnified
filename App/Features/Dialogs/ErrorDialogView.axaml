<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:dialogs="clr-namespace:MAAUnified.App.Features.Dialogs"
        x:Class="MAAUnified.App.Features.Dialogs.ErrorDialogView"
        Width="760"
        Height="540"
        MinWidth="640"
        MinHeight="420"
        CanResize="False"
        Background="Transparent"
        SystemDecorations="None"
        WindowStartupLocation="CenterOwner">
  <dialogs:ModernDialogShell x:Name="DialogShell"
                             CloseRequested="OnShellCloseRequested">
    <dialogs:ModernDialogShell.HeaderContent>
      <TextBlock x:Name="ContextLine"
                 Margin="8,0,0,0"
                 Classes="long-wrap subtle"
                 Text="Context" />
    </dialogs:ModernDialogShell.HeaderContent>
    <dialogs:ModernDialogShell.Content>
      <Border Classes="modern-dialog-section">
        <TextBox x:Name="ErrorDetailBox"
                 AcceptsReturn="True"
                 IsReadOnly="True"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap"
                 />
      </Border>
    </dialogs:ModernDialogShell.Content>
    <dialogs:ModernDialogShell.ActionsContent>
      <StackPanel Orientation="Horizontal"
                  Spacing="10">
        <Button x:Name="CopyButton"
                Classes="modern-dialog-button modern-dialog-button-secondary"
                Content="Copy"
                Click="OnCopyClick" />
        <Button x:Name="IssueReportButton"
                Classes="modern-dialog-button modern-dialog-button-secondary"
                Content="IssueReport"
                Click="OnOpenIssueReportClick" />
        <Button x:Name="CancelButton"
                Classes="modern-dialog-button modern-dialog-button-secondary"
                Content="Ignore"
                IsCancel="True"
                Click="OnCancelClick" />
        <Button x:Name="ConfirmButton"
                Classes="modern-dialog-button modern-dialog-button-primary"
                Content="Close"
                IsDefault="True"
                Click="OnConfirmClick" />
      </StackPanel>
    </dialogs:ModernDialogShell.ActionsContent>
  </dialogs:ModernDialogShell>
</Window>
