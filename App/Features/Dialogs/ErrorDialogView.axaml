<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MAAUnified.App.Controls"
        x:Class="MAAUnified.App.Features.Dialogs.ErrorDialogView"
        Width="760"
        Height="540"
        MinWidth="640"
        MinHeight="420"
        CanResize="False"
        Background="Transparent"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        WindowStartupLocation="CenterOwner">
  <controls:AppWindowFrame x:Name="DialogShell"
                           Mode="CompactModal"
                           CloseRequested="OnShellCloseRequested">
    <controls:AppWindowFrame.HeaderContent>
      <TextBlock x:Name="ContextLine"
                 Classes="app-window-subtitle subtle long-wrap"
                 Text="Context" />
    </controls:AppWindowFrame.HeaderContent>
    <controls:AppWindowFrame.Content>
      <Border Classes="app-surface app-section">
        <TextBox x:Name="ErrorDetailBox"
                 Classes="app-input app-input-block"
                 AcceptsReturn="True"
                 IsReadOnly="True"
                 ScrollViewer.VerticalScrollBarVisibility="Auto"
                 TextWrapping="Wrap" />
      </Border>
    </controls:AppWindowFrame.Content>
    <controls:AppWindowFrame.ActionsContent>
      <StackPanel Orientation="Horizontal"
                  Spacing="10">
        <Button x:Name="CopyButton"
                Classes="app-button app-secondary"
                Content="Copy"
                Click="OnCopyClick" />
        <Button x:Name="IssueReportButton"
                Classes="app-button app-secondary"
                Content="IssueReport"
                Click="OnOpenIssueReportClick" />
        <Button x:Name="CancelButton"
                Classes="app-button app-secondary"
                Content="Ignore"
                IsCancel="True"
                Click="OnCancelClick" />
        <Button x:Name="ConfirmButton"
                Classes="app-button app-primary"
                Content="Close"
                IsDefault="True"
                Click="OnConfirmClick" />
      </StackPanel>
    </controls:AppWindowFrame.ActionsContent>
  </controls:AppWindowFrame>
</Window>
