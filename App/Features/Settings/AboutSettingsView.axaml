<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Classes="settings-page"
             x:Class="MAAUnified.App.Features.Settings.AboutSettingsView">
  <UserControl.Styles>
    <Style Selector="StackPanel.about-settings-column">
      <Setter Property="Spacing" Value="10" />
    </Style>

    <Style Selector="Button.about-settings-action">
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>
  </UserControl.Styles>

  <Grid Margin="4"
        RowDefinitions="Auto,Auto">
    <TextBlock Classes="settings-page-title"
               Text="{Binding RootTexts[Settings.Section.About]}" />

    <StackPanel Grid.Row="1"
                Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}"
                HorizontalAlignment="Left"
                Classes="settings-page-flow">
      <Grid Classes="settings-page-two-column"
            HorizontalAlignment="Left"
            ColumnDefinitions="Auto,24,Auto">
        <StackPanel Classes="about-settings-column settings-page-column-stack">
          <Button Classes="app-button app-secondary about-settings-action"
                  Content="{Binding RootTexts[Settings.Action.OpenOfficial]}"
                  Click="OnOpenOfficialWebsiteClick" />
          <Button Classes="app-button app-secondary about-settings-action"
                  Content="bilibili"
                  Click="OnOpenBilibiliClick" />
          <Button Classes="app-button app-secondary about-settings-action"
                  Content="GitHub"
                  Click="OnOpenGithubClick" />
          <Button Classes="app-button app-primary about-settings-action"
                  Content="{Binding RootTexts[Settings.Action.CheckAnnouncement]}"
                  Click="OnCheckAnnouncementClick" />
        </StackPanel>

        <StackPanel Grid.Column="2"
                    Classes="about-settings-column settings-page-column-stack">
          <Button Classes="app-button app-primary about-settings-action"
                  Content="{Binding RootTexts[Settings.Action.OpenCommunity]}"
                  Click="OnOpenCommunityClick" />
          <Button Classes="app-button app-secondary about-settings-action"
                  Content="{Binding RootTexts[Settings.Action.OpenDownload]}"
                  Click="OnOpenDownloadClick" />
          <Button Classes="app-button app-secondary about-settings-action"
                  Content="QQ Group"
                  Click="OnOpenQqGroupClick" />
          <Button Classes="app-button app-secondary about-settings-action"
                  Content="QQ Channel"
                  Click="OnOpenQqChannelClick" />
          <Button Classes="app-button app-secondary about-settings-action"
                  Content="Telegram"
                  Click="OnOpenTelegramClick" />
          <Button Classes="app-button app-secondary about-settings-action"
                  Content="Discord"
                  Click="OnOpenDiscordClick" />
        </StackPanel>
      </Grid>

      <Border Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
              Classes="app-surface app-card settings-page-meta-block">
        <TextBlock MaxWidth="{DynamicResource MAA.Size.Settings.ContentMaxWidth}"
                   HorizontalAlignment="Left"
                   TextAlignment="Left"
                   TextWrapping="Wrap"
                   Classes="app-body"
                   Text="{Binding AboutVersionInfo}" />
      </Border>

      <Border Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
              Classes="settings-page-status-block">
        <StackPanel Classes="settings-page-status-list">
          <TextBlock Classes="app-body"
                     Text="{Binding AboutStatusMessage}"
                     TextWrapping="Wrap" />
          <TextBlock Classes="state-error app-body"
                     Text="{Binding AboutErrorMessage}"
                     IsVisible="{Binding HasAboutErrorMessage}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </Border>
    </StackPanel>
  </Grid>
</UserControl>
