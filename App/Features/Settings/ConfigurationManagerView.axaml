<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             Classes="settings-page"
             x:Class="MAAUnified.App.Features.Settings.ConfigurationManagerView">
  <UserControl.Styles>
    <Style Selector="UserControl.settings-page Grid.configuration-manager-action-grid">
      <Setter Property="HorizontalAlignment" Value="Left" />
    </Style>

    <Style Selector="UserControl.settings-page Button.configuration-manager-action-button">
      <Setter Property="MinWidth" Value="144" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>
  </UserControl.Styles>

  <Grid Margin="4"
        RowDefinitions="Auto,Auto">
    <TextBlock Classes="settings-page-title"
               Text="{Binding RootTexts[Settings.Section.ConfigurationManager]}" />

    <controls:AdaptiveSpacingStackPanel Grid.Row="1"
                Classes="settings-page-flow"
                Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}">
      <Grid Classes="settings-page-labeled-row"
            ColumnDefinitions="132,*">
        <TextBlock Classes="settings-label"
                   Text="{Binding RootTexts[Settings.ConfigurationManager.ProfileName]}" />
        <ComboBox Grid.Column="1"
                  Classes="settings-select configuration-manager-profile-picker"
                  Width="{DynamicResource MAA.Size.Settings.ColumnWidth}"
                  HorizontalAlignment="Left"
                  ItemsSource="{Binding ConfigurationProfiles}"
                  SelectedValueBinding="{Binding .}"
                  SelectedValue="{Binding ConfigurationManagerSelectedProfile}"
                  SelectionChanged="OnConfigurationProfileSelectionChanged">
          <ComboBox.ItemTemplate>
            <DataTemplate>
              <Border Classes="settings-dropdown-item-shell">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Grid.Column="0"
                             Classes="settings-dropdown-item-text"
                             Margin="0,0,10,0"
                             Text="{Binding .}" />
                  <Button Grid.Column="1"
                          Classes="settings-dropdown-delete-button"
                          Tag="{Binding .}"
                          Content="×"
                          PointerPressed="OnDropdownDeleteButtonPointerPressed"
                          PointerReleased="OnDropdownDeleteButtonPointerReleased"
                          Click="OnDeleteProfileEntryClick" />
                </Grid>
              </Border>
            </DataTemplate>
          </ComboBox.ItemTemplate>
          <ComboBox.SelectionBoxItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding .}" />
            </DataTemplate>
          </ComboBox.SelectionBoxItemTemplate>
        </ComboBox>
      </Grid>

      <Grid Classes="settings-page-labeled-action-row"
            ColumnDefinitions="132,*">
        <TextBlock Classes="settings-label"
                   Text="{Binding RootTexts[Settings.ConfigurationManager.SaveAsNew]}" />
        <Grid Grid.Column="1"
              HorizontalAlignment="Left"
              ColumnDefinitions="Auto,Auto">
          <controls:AppActionInput Width="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
                                   HorizontalAlignment="Left"
                                   Text="{Binding ConfigurationManagerNewProfileName, UpdateSourceTrigger=LostFocus}"
                                   Watermark="{Binding RootTexts[Settings.ConfigurationManager.NewProfileWatermark]}"
                                   ActionContent="{Binding RootTexts[Settings.ConfigurationManager.SaveAsNew]}"
                                   ActionClick="OnCreateProfileClick" />
          <TextBlock Grid.Column="1"
                     Margin="8,0,0,0"
                     VerticalAlignment="Center"
                     Classes="app-caption state-success"
                     Text="{Binding ConfigurationManagerSaveAsNewSucceededText}"
                     IsVisible="{Binding HasConfigurationManagerSaveAsNewSucceeded}"
                     TextWrapping="NoWrap" />
          <TextBlock Grid.Column="1"
                     Margin="8,0,0,0"
                     VerticalAlignment="Center"
                     Classes="app-caption state-error"
                     Text="{Binding ConfigurationManagerSaveAsNewFailedText}"
                     IsVisible="{Binding HasConfigurationManagerSaveAsNewFailed}"
                     TextWrapping="NoWrap" />
        </Grid>
      </Grid>

      <Border Classes="settings-page-subtle-divider" />

      <Grid Classes="configuration-manager-action-grid"
            RowDefinitions="Auto,10,Auto"
            ColumnDefinitions="Auto,12,Auto">
        <Button Classes="app-button app-secondary configuration-manager-action-button"
                Content="{Binding RootTexts[Settings.ConfigurationManager.ExportCurrent]}"
                Click="OnExportCurrentProfileClick" />
        <Button Grid.Row="2"
                Classes="app-button app-secondary configuration-manager-action-button"
                Content="{Binding RootTexts[Settings.ConfigurationManager.ExportAll]}"
                Click="OnExportAllProfilesClick" />
        <Button Grid.Column="2"
                Classes="app-button app-secondary configuration-manager-action-button"
                Content="{Binding RootTexts[Settings.ConfigurationManager.Import]}"
                Click="OnImportProfilesClick" />
      </Grid>
    </controls:AdaptiveSpacingStackPanel>
  </Grid>
</UserControl>
