<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Settings.ConfigurationManagerView">
  <UserControl.Styles>
    <Style Selector="StackPanel.configuration-manager-section-content">
      <Setter Property="Spacing" Value="14" />
    </Style>

    <Style Selector="TextBlock.configuration-manager-section-title">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
    </Style>

    <Style Selector="TextBlock.configuration-manager-section-description">
      <Setter Property="MaxWidth" Value="420" />
    </Style>

    <Style Selector="StackPanel.configuration-manager-button-group">
      <Setter Property="Orientation" Value="Horizontal" />
      <Setter Property="Spacing" Value="10" />
    </Style>

    <Style Selector="StackPanel.configuration-manager-status-stack">
      <Setter Property="Spacing" Value="8" />
    </Style>

    <Style Selector="Border.configuration-manager-action-card">
      <Setter Property="Padding" Value="16" />
    </Style>
  </UserControl.Styles>

  <Grid Margin="4"
        RowDefinitions="Auto,Auto">
    <TextBlock Classes="section-title"
               Text="{Binding RootTexts[Settings.Section.ConfigurationManager]}" />

    <StackPanel Grid.Row="1"
                Classes="settings-form"
                Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}">
      <WrapPanel Classes="settings-wrap">
        <Border Classes="app-surface app-section configuration-manager-action-card">
          <StackPanel Classes="configuration-manager-section-content">
            <StackPanel Spacing="6">
              <TextBlock Classes="configuration-manager-section-title"
                         Text="{Binding RootTexts[Settings.ConfigurationManager.ProfileName]}" />
              <TextBlock Classes="app-caption configuration-manager-section-description"
                         Text="{Binding RootTexts[Settings.Section.ConfigurationManager]}" />
            </StackPanel>

            <ComboBox Classes="app-input"
                      Width="{DynamicResource MAA.Size.Settings.ColumnWidth}"
                      HorizontalAlignment="Left"
                      ItemsSource="{Binding ConfigurationProfiles}"
                      SelectedValueBinding="{Binding .}"
                      SelectedValue="{Binding ConfigurationManagerSelectedProfile}"
                      SelectionChanged="OnConfigurationProfileSelectionChanged" />
          </StackPanel>
        </Border>

        <Border Classes="app-surface app-section configuration-manager-action-card">
          <StackPanel Classes="configuration-manager-section-content">
            <StackPanel Spacing="6">
              <TextBlock Classes="configuration-manager-section-title"
                         Text="{Binding RootTexts[Settings.ConfigurationManager.SaveAsNew]}" />
              <TextBlock Classes="app-caption configuration-manager-section-description"
                         Text="{Binding RootTexts[Settings.ConfigurationManager.NewProfileWatermark]}" />
            </StackPanel>

            <StackPanel Spacing="10">
              <TextBox Classes="app-input"
                       Text="{Binding ConfigurationManagerNewProfileName, UpdateSourceTrigger=LostFocus}"
                       Watermark="{Binding RootTexts[Settings.ConfigurationManager.NewProfileWatermark]}" />
              <StackPanel Classes="configuration-manager-button-group">
                <Button Classes="app-button app-primary"
                        Content="{Binding RootTexts[Settings.ConfigurationManager.SaveAsNew]}"
                        Click="OnCreateProfileClick" />
              </StackPanel>
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Classes="app-surface app-section configuration-manager-action-card">
          <StackPanel Classes="configuration-manager-section-content">
            <StackPanel Spacing="6">
              <TextBlock Classes="configuration-manager-section-title state-error"
                         Text="{Binding RootTexts[Settings.ConfigurationManager.DeleteCurrent]}" />
              <TextBlock Classes="app-caption configuration-manager-section-description"
                         Text="{Binding RootTexts[Settings.ConfigurationManager.AutoSavedCurrent]}" />
            </StackPanel>

            <StackPanel Classes="configuration-manager-button-group">
              <Button Classes="app-button app-secondary"
                      Content="{Binding RootTexts[Settings.ConfigurationManager.DeleteCurrent]}"
                      Click="OnDeleteCurrentProfileClick" />
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Classes="app-surface app-section configuration-manager-action-card">
          <StackPanel Classes="configuration-manager-section-content">
            <StackPanel Spacing="6">
              <TextBlock Classes="configuration-manager-section-title"
                         Text="{Binding RootTexts[Settings.ConfigurationManager.Import]}" />
              <TextBlock Classes="app-caption configuration-manager-section-description"
                         Text="{Binding RootTexts[Settings.ConfigurationManager.ExportAll]}" />
            </StackPanel>

            <StackPanel Classes="configuration-manager-button-group">
              <Button Classes="app-button app-secondary"
                      Content="{Binding RootTexts[Settings.ConfigurationManager.ExportAll]}"
                      Click="OnExportAllProfilesClick" />
              <Button Classes="app-button app-secondary"
                      Content="{Binding RootTexts[Settings.ConfigurationManager.ExportCurrent]}"
                      Click="OnExportCurrentProfileClick" />
              <Button Classes="app-button app-primary"
                      Content="{Binding RootTexts[Settings.ConfigurationManager.Import]}"
                      Click="OnImportProfilesClick" />
            </StackPanel>
          </StackPanel>
        </Border>
      </WrapPanel>

      <Border Classes="app-surface app-section configuration-manager-action-card">
        <StackPanel Classes="configuration-manager-status-stack">
          <TextBlock Classes="configuration-manager-section-title"
                     Text="{Binding RootTexts[Settings.ConfigurationManager.AutoSavedCurrent]}" />
          <TextBlock Classes="app-body"
                     Text="{Binding ConfigurationManagerStatusMessage}" />
          <TextBlock Classes="state-error app-body"
                     Text="{Binding ConfigurationManagerErrorMessage}"
                     IsVisible="{Binding HasConfigurationManagerErrorMessage}" />
        </StackPanel>
      </Border>
    </StackPanel>
  </Grid>
</UserControl>
