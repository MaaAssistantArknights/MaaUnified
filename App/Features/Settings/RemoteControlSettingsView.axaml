<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             x:Class="MAAUnified.App.Features.Settings.RemoteControlSettingsView">
  <Grid Margin="4" RowDefinitions="Auto,Auto,Auto">
    <TextBlock Classes="section-title" Text="{Binding RootTexts[Settings.Section.RemoteControl]}" />
    <StackPanel Grid.Row="1"
                Classes="settings-form"
                Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}"
                Spacing="{DynamicResource MAA.Spacing.Medium}">
      <TextBlock MaxWidth="{DynamicResource MAA.Size.Settings.ContentMaxWidth}"
                 Classes="settings-centered-text"
                 Text="{Binding RootTexts[Settings.RemoteControl.Warning]}" />

      <Grid ColumnDefinitions="132,*">
        <TextBlock Classes="settings-label" Text="{Binding RootTexts[Settings.RemoteControl.GetTaskEndpoint]}" />
        <TextBox Grid.Column="1"
                 Text="{Binding RemoteGetTaskEndpoint, UpdateSourceTrigger=LostFocus}"
                 Watermark="{Binding RootTexts[Settings.RemoteControl.GetTaskEndpointWatermark]}" />
      </Grid>

      <Grid ColumnDefinitions="132,*">
        <TextBlock Classes="settings-label" Text="{Binding RootTexts[Settings.RemoteControl.ReportTaskEndpoint]}" />
        <TextBox Grid.Column="1"
                 Text="{Binding RemoteReportEndpoint, UpdateSourceTrigger=LostFocus}"
                 Watermark="{Binding RootTexts[Settings.RemoteControl.ReportTaskEndpointWatermark]}" />
      </Grid>

      <Grid ColumnDefinitions="132,120">
        <TextBlock Classes="settings-label" Text="{Binding RootTexts[Settings.RemoteControl.PollIntervalMs]}" />
        <controls:VerticalSpinNumberBox Grid.Column="1"
                                        Minimum="500"
                                        Maximum="60000"
                                        Value="{Binding RemotePollInterval}" />
      </Grid>

      <Grid ColumnDefinitions="132,220,Auto">
        <TextBlock Classes="settings-label" Text="{Binding RootTexts[Settings.RemoteControl.UserIdentity]}" />
        <TextBox Grid.Column="1"
                 Text="{Binding RemoteUserIdentity, UpdateSourceTrigger=LostFocus}"
                 Watermark="{Binding RootTexts[Settings.RemoteControl.UserIdentityWatermark]}" />
        <Button Grid.Column="2"
                Classes="wpf-button wpf-button-secondary"
                Margin="{DynamicResource MAA.Thickness.MarginActionButtonLeft}"
                Content="{Binding RootTexts[Settings.Action.TestRemote]}"
                Click="OnTestRemoteConnectivityClick" />
      </Grid>

      <Grid ColumnDefinitions="132,220,Auto">
        <TextBlock Classes="settings-label" Text="{Binding RootTexts[Settings.RemoteControl.DeviceIdentity]}" />
        <TextBox Grid.Column="1"
                 IsReadOnly="True"
                 Text="{Binding RemoteDeviceIdentity, Mode=OneWay}"
                 Watermark="{Binding RootTexts[Settings.RemoteControl.DeviceIdentityWatermark]}" />
        <Button Grid.Column="2"
                Classes="wpf-button wpf-button-secondary"
                Margin="{DynamicResource MAA.Thickness.MarginActionButtonLeft}"
                Content="{Binding RootTexts[RemoteControlRegenerateDeviceIdentity]}"
                Click="OnRegenerateRemoteDeviceIdentityClick" />
      </Grid>
    </StackPanel>

    <StackPanel Grid.Row="2"
                Classes="settings-form settings-form-narrow"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
                Spacing="4">
      <TextBlock Classes="settings-centered-text" Text="{Binding RemoteControlStatusMessage}" />
      <TextBlock Classes="state-warning settings-centered-text"
                 Text="{Binding RemoteControlWarningMessage}"
                 IsVisible="{Binding HasRemoteControlWarningMessage}" />
      <TextBlock Classes="state-error settings-centered-text"
                 Text="{Binding RemoteControlErrorMessage}"
                 IsVisible="{Binding HasRemoteControlErrorMessage}" />
    </StackPanel>
  </Grid>
</UserControl>
