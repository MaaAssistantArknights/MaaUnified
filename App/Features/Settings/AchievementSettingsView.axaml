<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Classes="settings-page"
             x:Class="MAAUnified.App.Features.Settings.AchievementSettingsView">
  <UserControl.Styles>
    <Style Selector="Border.achievement-settings-medal-shell">
      <Setter Property="Width" Value="108" />
      <Setter Property="Height" Value="108" />
      <Setter Property="Padding" Value="8" />
      <Setter Property="CornerRadius" Value="54" />
      <Setter Property="HorizontalAlignment" Value="Left" />
      <Setter Property="Background" Value="#1AFFFFFF" />
      <Setter Property="BorderThickness" Value="2" />
    </Style>

  </UserControl.Styles>

  <Grid Margin="4"
        RowDefinitions="Auto,Auto,Auto">
    <TextBlock Classes="settings-page-title"
               Text="{Binding RootTexts[Settings.Section.Achievement]}" />

    <StackPanel Grid.Row="1"
                Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}"
                HorizontalAlignment="Left"
                Classes="settings-page-flow">
      <Border Classes="settings-page-meta-block">
        <StackPanel Classes="settings-page-compact-flow"
                    HorizontalAlignment="Left">
          <TextBlock HorizontalAlignment="Left"
                     TextAlignment="Left"
                     Classes="app-window-title"
                     Text="{Binding AchievementLevelText}" />
          <Button Classes="app-button app-primary"
                  HorizontalAlignment="Left"
                  Content="{Binding RootTexts[Settings.Action.ShowAchievement]}"
                  Click="OnShowAchievementListClick" />

          <StackPanel Classes="settings-page-compact-flow"
                      HorizontalAlignment="Left"
                      IsVisible="{Binding CanUseAchievementDebugEntry}">
            <Border Classes="achievement-settings-medal-shell"
                    BorderBrush="{Binding AchievementDebugMedalColor}"
                    PointerPressed="OnAchievementDebugPointerPressed">
              <ToolTip.Tip>
                <ToolTip Content="{Binding AchievementDebugTip}" />
              </ToolTip.Tip>
              <TextBlock HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         FontSize="24"
                         FontWeight="Bold"
                         Foreground="{Binding AchievementDebugMedalColor}"
                         Text="MAA" />
            </Border>
            <TextBlock HorizontalAlignment="Left"
                       TextAlignment="Left"
                       TextWrapping="Wrap"
                       Classes="app-caption"
                       Text="{Binding AchievementDebugTip}" />
          </StackPanel>
        </StackPanel>
      </Border>

      <Grid Classes="settings-page-two-column"
            HorizontalAlignment="Left"
            ColumnDefinitions="Auto,12,Auto">
        <Button Classes="app-button app-secondary"
                HorizontalAlignment="Left"
                Content="{Binding RootTexts[Settings.Achievement.Backup]}"
                Click="OnBackupAchievementClick" />
        <Button Grid.Column="2"
                Classes="app-button app-secondary"
                HorizontalAlignment="Left"
                Content="{Binding RootTexts[Settings.Achievement.Restore]}"
                Click="OnRestoreAchievementClick" />
      </Grid>

      <Grid Classes="settings-page-two-column"
            HorizontalAlignment="Left"
            ColumnDefinitions="Auto,12,Auto"
            IsVisible="{Binding CanUseAchievementDebugActions}">
        <Button Classes="app-button app-secondary"
                HorizontalAlignment="Left"
                Content="{Binding RootTexts[Settings.Achievement.UnlockAll]}"
                Click="OnUnlockAllAchievementClick" />
        <Button Grid.Column="2"
                Classes="app-button app-secondary"
                HorizontalAlignment="Left"
                Content="{Binding RootTexts[Settings.Achievement.LockAll]}"
                Click="OnLockAllAchievementClick" />
      </Grid>

      <StackPanel Classes="settings-page-compact-flow">
        <CheckBox Classes="app-checkbox"
                  Content="{Binding RootTexts[Settings.Achievement.PopupDisabled]}"
                  IsChecked="{Binding AchievementPopupDisabled}" />
        <CheckBox Classes="app-checkbox"
                  Content="{Binding RootTexts[Settings.Achievement.PopupAutoClose]}"
                  IsChecked="{Binding AchievementPopupAutoClose}"
                  IsVisible="{Binding CanEditAchievementPopupAutoClose}" />
      </StackPanel>
    </StackPanel>

    <Border Grid.Row="2"
            Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
            Classes="settings-page-status-block">
      <StackPanel Classes="settings-page-status-list">
        <TextBlock TextWrapping="Wrap"
                   Classes="app-body"
                   Text="{Binding AchievementStatusMessage}" />
        <TextBlock TextWrapping="Wrap"
                   Classes="state-error"
                   Text="{Binding AchievementErrorMessage}"
                   IsVisible="{Binding HasAchievementErrorMessage}" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
