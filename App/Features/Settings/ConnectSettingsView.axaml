<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             xmlns:vm="clr-namespace:MAAUnified.App.ViewModels.Settings"
             x:Class="MAAUnified.App.Features.Settings.ConnectSettingsView">
  <Grid Margin="4" RowDefinitions="Auto,*">
    <TextBlock Classes="section-title" Text="{Binding RootTexts[Settings.Section.Connect]}" />

    <ScrollViewer Grid.Row="1"
                  Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel Classes="settings-form">
        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="{DynamicResource MAA.Spacing.Large}"
                    IsVisible="{Binding IsAdbConnectionMode}">
          <Grid ColumnDefinitions="Auto,Auto">
            <CheckBox Content="{Binding RootTexts[Settings.Connect.AutoDetect]}"
                      IsChecked="{Binding AutoDetect}" />
            <controls:TooltipHint Grid.Column="1"
                                  Margin="{DynamicResource MAA.Thickness.MarginLeftSmall}"
                                  Tip="{Binding RootTexts[Settings.Connect.AutoDetectTip]}" />
          </Grid>
          <CheckBox Content="{Binding RootTexts[Settings.Connect.AlwaysAutoDetect]}"
                    IsChecked="{Binding AlwaysAutoDetect}"
                    IsVisible="{Binding AutoDetect}" />
        </StackPanel>

        <StackPanel Classes="settings-centered-column">
          <TextBlock Classes="settings-field-caption" Text="{Binding RootTexts[Settings.Connect.Configuration]}" />
          <controls:CheckComboBox Width="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
                                  HeaderText="{Binding SelectedConnectConfigOption.DisplayName}"
                                  ItemsSource="{Binding ConnectConfigOptions}"
                                  SelectedItem="{Binding SelectedConnectConfigOption, Mode=TwoWay}">
            <controls:CheckComboBox.ItemTemplate>
              <DataTemplate x:DataType="vm:ConnectionGameOptionItem">
                <TextBlock Text="{Binding DisplayName}" />
              </DataTemplate>
            </controls:CheckComboBox.ItemTemplate>
          </controls:CheckComboBox>
        </StackPanel>

        <TextBlock Classes="state-warning settings-centered-text"
                   HorizontalAlignment="Center"
                   MaxWidth="{DynamicResource MAA.Size.Settings.FormNarrowMaxWidth}"
                   Text="{Binding RootTexts[Settings.Connect.AttachWindowWarning]}"
                   IsVisible="{Binding IsAttachWindowMode}" />

        <StackPanel Classes="settings-centered-column"
                    Spacing="{DynamicResource MAA.Spacing.Medium}"
                    IsVisible="{Binding IsAdbConnectionMode}">
          <StackPanel Classes="settings-centered-column">
            <Grid HorizontalAlignment="Center"
                  ColumnDefinitions="Auto,Auto">
              <TextBlock Grid.Column="0"
                         Classes="settings-field-caption"
                         Margin="0"
                         Text="{Binding RootTexts[Settings.Connect.Address]}" />
              <controls:TooltipHint Grid.Column="1" Tip="{Binding RootTexts[Settings.Connect.AddressTip]}" />
            </Grid>
            <AutoCompleteBox Width="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
                             IsEnabled="{Binding CanEditAdbConnectionFields}"
                             ItemsSource="{Binding ConnectAddressHistory}"
                             Text="{Binding ConnectAddress, UpdateSourceTrigger=LostFocus}" />
            <ItemsControl Width="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
                          Margin="0,6,0,0"
                          ItemsSource="{Binding ConnectAddressHistory}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid Margin="0,2,0,0"
                        ColumnDefinitions="*,Auto">
                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="{Binding .}" />
                    <Button Grid.Column="1"
                            Classes="wpf-button wpf-button-secondary"
                            MinWidth="28"
                            Padding="6,0"
                            Tag="{Binding .}"
                            Content="×"
                            Click="OnRemoveAddressHistoryClick" />
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>

          <StackPanel Classes="settings-centered-column">
            <TextBlock Classes="settings-field-caption" Text="{Binding RootTexts[Settings.Connect.AdbPath]}" />
            <Grid Width="{DynamicResource MAA.Size.Settings.FieldPathWideWidth}"
                  ColumnDefinitions="*,Auto">
              <TextBox IsEnabled="{Binding CanEditAdbConnectionFields}"
                       Text="{Binding AdbPath, UpdateSourceTrigger=LostFocus}" />
              <Button Grid.Column="1"
                      Classes="wpf-button wpf-button-secondary"
                      Margin="{DynamicResource MAA.Thickness.MarginActionButtonLeft}"
                      Content="{Binding RootTexts[Settings.Start.SelectButton]}"
                      IsEnabled="{Binding CanEditAdbConnectionFields}"
                      Click="OnSelectAdbPathClick" />
            </Grid>
          </StackPanel>
        </StackPanel>

        <StackPanel Classes="settings-centered-column"
                    Spacing="{DynamicResource MAA.Spacing.Medium}"
                    IsVisible="{Binding ShowMuMuExtrasSection}">
          <CheckBox HorizontalAlignment="Center"
                    Content="{Binding RootTexts[Settings.Connect.MuMu.EnableExtras]}"
                    IsChecked="{Binding MuMu12ExtrasEnabled}"
                    Checked="OnMuMuExtrasChecked" />
          <StackPanel Classes="settings-centered-column"
                      Spacing="{DynamicResource MAA.Spacing.Small}"
                      IsVisible="{Binding MuMu12ExtrasEnabled}">
            <TextBlock Classes="settings-field-caption" Text="{Binding RootTexts[Settings.Connect.MuMu.EmulatorPath]}" />
            <TextBox Width="{DynamicResource MAA.Size.Settings.FieldPathWideWidth}"
                     Text="{Binding MuMu12EmulatorPath, UpdateSourceTrigger=LostFocus}"
                     LostFocus="OnMuMuEmulatorPathLostFocus" />
            <CheckBox HorizontalAlignment="Center"
                      Content="{Binding RootTexts[Settings.Connect.MuMu.BridgeConnection]}"
                      IsChecked="{Binding MuMuBridgeConnection}" />
            <StackPanel Classes="settings-centered-column"
                        IsVisible="{Binding MuMuBridgeConnection}">
              <TextBlock Classes="settings-field-caption" Text="{Binding RootTexts[Settings.Connect.InstanceId]}" />
              <TextBox Width="{DynamicResource MAA.Size.Settings.FieldSlimWidth}"
                       Text="{Binding MuMu12Index, UpdateSourceTrigger=LostFocus}" />
            </StackPanel>
          </StackPanel>
        </StackPanel>

        <StackPanel Classes="settings-centered-column"
                    Spacing="{DynamicResource MAA.Spacing.Medium}"
                    IsVisible="{Binding ShowLdPlayerExtrasSection}">
          <CheckBox HorizontalAlignment="Center"
                    Content="{Binding RootTexts[Settings.Connect.LdPlayer.EnableExtras]}"
                    IsChecked="{Binding LdPlayerExtrasEnabled}"
                    Checked="OnLdPlayerExtrasChecked" />
          <StackPanel Classes="settings-centered-column"
                      Spacing="{DynamicResource MAA.Spacing.Small}"
                      IsVisible="{Binding LdPlayerExtrasEnabled}">
            <TextBlock Classes="settings-field-caption" Text="{Binding RootTexts[Settings.Connect.LdPlayer.EmulatorPath]}" />
            <TextBox Width="{DynamicResource MAA.Size.Settings.FieldPathWideWidth}"
                     Text="{Binding LdPlayerEmulatorPath, UpdateSourceTrigger=LostFocus}"
                     LostFocus="OnLdPlayerEmulatorPathLostFocus" />
            <CheckBox HorizontalAlignment="Center"
                      Content="{Binding RootTexts[Settings.Connect.LdPlayer.ManualSetIndex]}"
                      IsChecked="{Binding LdPlayerManualSetIndex}" />
            <StackPanel Classes="settings-centered-column"
                        IsVisible="{Binding LdPlayerManualSetIndex}">
              <TextBlock Classes="settings-field-caption" Text="{Binding RootTexts[Settings.Connect.InstanceId]}" />
              <TextBox Width="{DynamicResource MAA.Size.Settings.FieldSlimWidth}"
                       Text="{Binding LdPlayerIndex, UpdateSourceTrigger=LostFocus}" />
            </StackPanel>
          </StackPanel>
        </StackPanel>

        <StackPanel Classes="settings-centered-column"
                    Spacing="{DynamicResource MAA.Spacing.Medium}"
                    IsVisible="{Binding IsAttachWindowMode}">
          <StackPanel Classes="settings-centered-column">
            <TextBlock Classes="settings-field-caption" Text="{Binding RootTexts[Settings.Connect.ScreencapMethod]}" />
            <ComboBox Width="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
                      ItemsSource="{Binding AttachWindowScreencapOptions}"
                      SelectedItem="{Binding SelectedAttachWindowScreencapOption, Mode=TwoWay}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:ConnectionGameOptionItem">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>

          <StackPanel Classes="settings-centered-column">
            <TextBlock Classes="settings-field-caption" Text="{Binding RootTexts[Settings.Connect.MouseInput]}" />
            <ComboBox Width="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
                      ItemsSource="{Binding AttachWindowInputOptions}"
                      SelectedItem="{Binding SelectedAttachWindowMouseOption, Mode=TwoWay}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:ConnectionGameOptionItem">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>

          <StackPanel Classes="settings-centered-column">
            <TextBlock Classes="settings-field-caption" Text="{Binding RootTexts[Settings.Connect.KeyboardInput]}" />
            <ComboBox Width="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
                      ItemsSource="{Binding AttachWindowInputOptions}"
                      SelectedItem="{Binding SelectedAttachWindowKeyboardOption, Mode=TwoWay}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:ConnectionGameOptionItem">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </StackPanel>
        </StackPanel>

        <Button Classes="wpf-button wpf-button-secondary"
                HorizontalAlignment="Center"
                Content="{Binding RootTexts[Settings.Connect.ScreenshotTest]}"
                Click="OnScreenshotTestClick" />

        <TextBlock Classes="settings-centered-text subtle"
                   Text="{Binding TestLinkInfo}"
                   IsVisible="{Binding HasTestLinkInfo}" />
        <TextBlock Classes="settings-centered-text subtle"
                   Text="{Binding ScreencapCost}" />

        <StackPanel Classes="settings-centered-column"
                    Spacing="{DynamicResource MAA.Spacing.Small}"
                    IsVisible="{Binding IsAdbConnectionMode}">
          <Grid HorizontalAlignment="Center"
                ColumnDefinitions="Auto,Auto">
            <CheckBox Content="{Binding RootTexts[Settings.Start.RetryOnDisconnected]}"
                      IsChecked="{Binding RetryOnDisconnected}" />
            <controls:TooltipHint Grid.Column="1"
                                  Margin="{DynamicResource MAA.Thickness.MarginLeftTooltip}"
                                  Tip="{Binding RootTexts[Settings.Start.RetryOnDisconnectedTip]}" />
          </Grid>
          <CheckBox HorizontalAlignment="Center"
                    Content="{Binding RootTexts[Settings.Connect.AllowAdbRestart]}"
                    IsChecked="{Binding AllowAdbRestart}" />
          <CheckBox HorizontalAlignment="Center"
                    Content="{Binding RootTexts[Settings.Connect.AllowAdbHardRestart]}"
                    IsChecked="{Binding AllowAdbHardRestart}" />
        </StackPanel>

        <StackPanel Classes="settings-centered-column"
                    Spacing="{DynamicResource MAA.Spacing.Small}"
                    IsVisible="{Binding IsAdbConnectionMode}">
          <TextBlock Classes="settings-field-caption" Text="{Binding RootTexts[Settings.Connect.TouchMode]}" />
          <StackPanel Orientation="Horizontal"
                      HorizontalAlignment="Center"
                      Spacing="{DynamicResource MAA.Spacing.Small}">
            <ComboBox Width="{DynamicResource MAA.Size.Settings.FieldCenteredWidth}"
                      IsEnabled="{Binding CanEditAdbConnectionFields}"
                      ItemsSource="{Binding TouchModeOptions}"
                      SelectedItem="{Binding SelectedTouchModeOption, Mode=TwoWay}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:ConnectionGameOptionItem">
                  <TextBlock Text="{Binding DisplayName}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
            <Button Classes="wpf-button wpf-button-secondary"
                    Content="{Binding RootTexts[Settings.Connect.ReplaceAdb]}"
                    Click="OnReplaceAdbClick" />
          </StackPanel>
        </StackPanel>

        <StackPanel Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Spacing="{DynamicResource MAA.Spacing.Large}"
                    IsVisible="{Binding IsAdbConnectionMode}">
          <CheckBox Content="{Binding RootTexts[Settings.Connect.KillAdbOnExit]}"
                    IsChecked="{Binding KillAdbOnExit}" />
          <CheckBox Content="{Binding RootTexts[Settings.Connect.AdbLiteEnabled]}"
                    IsChecked="{Binding AdbLiteEnabled}" />
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
