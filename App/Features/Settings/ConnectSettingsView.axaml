<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             xmlns:vm="clr-namespace:MAAUnified.App.ViewModels.Settings"
             x:Class="MAAUnified.App.Features.Settings.ConnectSettingsView">
  <UserControl.Styles>
    <Style Selector="Border.connect-settings-section">
      <Setter Property="Padding" Value="22" />
    </Style>

    <Style Selector="StackPanel.connect-settings-section-stack">
      <Setter Property="Spacing" Value="16" />
    </Style>

    <Style Selector="Border.connect-settings-card">
      <Setter Property="Padding" Value="16" />
    </Style>

    <Style Selector="StackPanel.connect-settings-card-stack">
      <Setter Property="Spacing" Value="10" />
    </Style>

    <Style Selector="TextBlock.connect-settings-card-title">
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="StackPanel.connect-settings-toggle-list">
      <Setter Property="Spacing" Value="8" />
    </Style>

    <Style Selector="TextBlock.connect-settings-status-text">
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="TextAlignment" Value="Center" />
    </Style>
  </UserControl.Styles>

  <Grid Margin="4"
        RowDefinitions="Auto,*">
    <TextBlock Classes="section-title"
               Text="{Binding RootTexts[Settings.Section.Connect]}" />

    <ScrollViewer Grid.Row="1"
                  Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel Classes="settings-form">
        <WrapPanel Classes="settings-wrap">
          <Border Classes="app-surface app-section connect-settings-section">
            <StackPanel Classes="connect-settings-section-stack">
              <TextBlock Classes="section-title"
                         Text="{Binding RootTexts[Settings.Connect.Configuration]}" />

              <Border Classes="app-surface app-card connect-settings-card">
                <StackPanel Classes="connect-settings-card-stack">
                  <TextBlock Classes="app-body connect-settings-card-title"
                             Text="{Binding RootTexts[Settings.Connect.Configuration]}" />
                  <controls:CheckComboBox Width="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
                                          HorizontalAlignment="Left"
                                          HeaderText="{Binding SelectedConnectConfigOption.DisplayName}"
                                          ItemsSource="{Binding ConnectConfigOptions}"
                                          SelectedItem="{Binding SelectedConnectConfigOption, Mode=TwoWay}">
                    <controls:CheckComboBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:ConnectionGameOptionItem">
                        <TextBlock Text="{Binding DisplayName}" />
                      </DataTemplate>
                    </controls:CheckComboBox.ItemTemplate>
                  </controls:CheckComboBox>
                </StackPanel>
              </Border>

              <Border Classes="app-surface app-card connect-settings-card"
                      IsVisible="{Binding IsAdbConnectionMode}">
                <StackPanel Classes="connect-settings-card-stack">
                  <TextBlock Classes="app-body connect-settings-card-title"
                             Text="{Binding RootTexts[Settings.Connect.AutoDetect]}" />
                  <StackPanel Classes="connect-settings-toggle-list">
                    <StackPanel Orientation="Horizontal"
                                Spacing="6">
                      <CheckBox Classes="app-checkbox"
                                Content="{Binding RootTexts[Settings.Connect.AutoDetect]}"
                                IsChecked="{Binding AutoDetect}" />
                      <controls:TooltipHint VerticalAlignment="Center"
                                            Tip="{Binding RootTexts[Settings.Connect.AutoDetectTip]}" />
                    </StackPanel>
                    <CheckBox Classes="app-checkbox"
                              Content="{Binding RootTexts[Settings.Connect.AlwaysAutoDetect]}"
                              IsChecked="{Binding AlwaysAutoDetect}"
                              IsVisible="{Binding AutoDetect}" />
                  </StackPanel>
                </StackPanel>
              </Border>

              <Border Classes="app-highlight app-warning-highlight"
                      IsVisible="{Binding IsAttachWindowMode}">
                <TextBlock Classes="state-warning app-caption long-wrap"
                           Text="{Binding RootTexts[Settings.Connect.AttachWindowWarning]}" />
              </Border>
            </StackPanel>
          </Border>

          <Border Classes="app-surface app-section connect-settings-section"
                  IsVisible="{Binding IsAdbConnectionMode}">
            <StackPanel Classes="connect-settings-section-stack">
              <StackPanel Spacing="6">
                <TextBlock Classes="section-title"
                           Text="{Binding RootTexts[Settings.Connect.Address]}" />
                <TextBlock Classes="app-caption"
                           Text="{Binding RootTexts[Settings.Connect.AddressTip]}" />
              </StackPanel>

              <Border Classes="app-surface app-card connect-settings-card">
                <StackPanel Classes="connect-settings-card-stack">
                  <StackPanel Orientation="Horizontal"
                              Spacing="6">
                    <TextBlock Classes="app-body connect-settings-card-title"
                               VerticalAlignment="Center"
                               Text="{Binding RootTexts[Settings.Connect.Address]}" />
                    <controls:TooltipHint VerticalAlignment="Center"
                                          Tip="{Binding RootTexts[Settings.Connect.AddressTip]}" />
                  </StackPanel>
                  <controls:CheckComboBox Width="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
                                          HorizontalAlignment="Left"
                                          IsEditable="True"
                                          IsEnabled="{Binding CanEditAdbConnectionFields}"
                                          ItemsSource="{Binding ConnectAddressHistory}"
                                          Text="{Binding ConnectAddress}"
                                          SelectionCommitted="OnConnectAddressSelectionCommitted">
                    <controls:CheckComboBox.ItemTemplate>
                      <DataTemplate>
                        <Grid ColumnDefinitions="*,Auto">
                          <TextBlock Grid.Column="0"
                                     VerticalAlignment="Center"
                                     Margin="0,0,8,0"
                                     Text="{Binding .}" />
                          <Button Grid.Column="1"
                                  Classes="app-button app-subtle app-icon-only"
                                  MinWidth="32"
                                  Padding="0"
                                  Tag="{Binding .}"
                                  Content="×"
                                  Click="OnRemoveAddressHistoryClick" />
                        </Grid>
                      </DataTemplate>
                    </controls:CheckComboBox.ItemTemplate>
                  </controls:CheckComboBox>
                </StackPanel>
              </Border>

              <Border Classes="app-surface app-card connect-settings-card">
                <StackPanel Classes="connect-settings-card-stack">
                  <TextBlock Classes="app-body connect-settings-card-title"
                             Text="{Binding RootTexts[Settings.Connect.AdbPath]}" />
                  <StackPanel Width="{DynamicResource MAA.Size.Settings.FieldPathWideWidth}"
                              HorizontalAlignment="Left"
                              Orientation="Horizontal"
                              Spacing="10">
                    <TextBox Classes="app-input"
                             Width="420"
                             IsEnabled="{Binding CanEditAdbConnectionFields}"
                             Text="{Binding AdbPath, UpdateSourceTrigger=LostFocus}" />
                    <Button Classes="app-button app-secondary"
                            Content="{Binding RootTexts[Settings.Start.SelectButton]}"
                            IsEnabled="{Binding CanEditAdbConnectionFields}"
                            Click="OnSelectAdbPathClick" />
                  </StackPanel>
                </StackPanel>
              </Border>

              <Border Classes="app-surface app-card connect-settings-card">
                <StackPanel Classes="connect-settings-card-stack">
                  <TextBlock Classes="app-body connect-settings-card-title"
                             Text="{Binding RootTexts[Settings.Connect.TouchMode]}" />
                  <StackPanel Width="{DynamicResource MAA.Size.Settings.FieldPathWideWidth}"
                              HorizontalAlignment="Left"
                              Orientation="Horizontal"
                              Spacing="10">
                    <ComboBox Classes="app-input"
                              Width="{DynamicResource MAA.Size.Settings.FieldCenteredWidth}"
                              IsEnabled="{Binding CanEditAdbConnectionFields}"
                              ItemsSource="{Binding TouchModeOptions}"
                              SelectedItem="{Binding SelectedTouchModeOption, Mode=TwoWay}">
                      <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:ConnectionGameOptionItem">
                          <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Classes="app-button app-secondary"
                            Content="{Binding RootTexts[Settings.Connect.ReplaceAdb]}"
                            Click="OnReplaceAdbClick" />
                  </StackPanel>
                </StackPanel>
              </Border>

              <Border Classes="app-surface app-card connect-settings-card"
                      IsVisible="{Binding ShowMuMuExtrasSection}">
                <StackPanel Classes="connect-settings-card-stack">
                  <CheckBox Classes="app-checkbox"
                            Content="{Binding RootTexts[Settings.Connect.MuMu.EnableExtras]}"
                            IsChecked="{Binding MuMu12ExtrasEnabled}"
                            Checked="OnMuMuExtrasChecked" />
                  <StackPanel Classes="connect-settings-card-stack"
                              IsVisible="{Binding MuMu12ExtrasEnabled}">
                    <TextBlock Classes="app-body connect-settings-card-title"
                               Text="{Binding RootTexts[Settings.Connect.MuMu.EmulatorPath]}" />
                    <TextBox Classes="app-input"
                             Width="{DynamicResource MAA.Size.Settings.FieldPathWideWidth}"
                             HorizontalAlignment="Left"
                             Text="{Binding MuMu12EmulatorPath, UpdateSourceTrigger=LostFocus}"
                             LostFocus="OnMuMuEmulatorPathLostFocus" />
                    <CheckBox Classes="app-checkbox"
                              Content="{Binding RootTexts[Settings.Connect.MuMu.BridgeConnection]}"
                              IsChecked="{Binding MuMuBridgeConnection}" />
                    <StackPanel Classes="connect-settings-card-stack"
                                IsVisible="{Binding MuMuBridgeConnection}">
                      <TextBlock Classes="app-caption"
                                 Text="{Binding RootTexts[Settings.Connect.InstanceId]}" />
                      <TextBox Classes="app-input"
                               Width="{DynamicResource MAA.Size.Settings.FieldSlimWidth}"
                               HorizontalAlignment="Left"
                               Text="{Binding MuMu12Index, UpdateSourceTrigger=LostFocus}" />
                    </StackPanel>
                  </StackPanel>
                </StackPanel>
              </Border>

              <Border Classes="app-surface app-card connect-settings-card"
                      IsVisible="{Binding ShowLdPlayerExtrasSection}">
                <StackPanel Classes="connect-settings-card-stack">
                  <CheckBox Classes="app-checkbox"
                            Content="{Binding RootTexts[Settings.Connect.LdPlayer.EnableExtras]}"
                            IsChecked="{Binding LdPlayerExtrasEnabled}"
                            Checked="OnLdPlayerExtrasChecked" />
                  <StackPanel Classes="connect-settings-card-stack"
                              IsVisible="{Binding LdPlayerExtrasEnabled}">
                    <TextBlock Classes="app-body connect-settings-card-title"
                               Text="{Binding RootTexts[Settings.Connect.LdPlayer.EmulatorPath]}" />
                    <TextBox Classes="app-input"
                             Width="{DynamicResource MAA.Size.Settings.FieldPathWideWidth}"
                             HorizontalAlignment="Left"
                             Text="{Binding LdPlayerEmulatorPath, UpdateSourceTrigger=LostFocus}"
                             LostFocus="OnLdPlayerEmulatorPathLostFocus" />
                    <CheckBox Classes="app-checkbox"
                              Content="{Binding RootTexts[Settings.Connect.LdPlayer.ManualSetIndex]}"
                              IsChecked="{Binding LdPlayerManualSetIndex}" />
                    <StackPanel Classes="connect-settings-card-stack"
                                IsVisible="{Binding LdPlayerManualSetIndex}">
                      <TextBlock Classes="app-caption"
                                 Text="{Binding RootTexts[Settings.Connect.InstanceId]}" />
                      <TextBox Classes="app-input"
                               Width="{DynamicResource MAA.Size.Settings.FieldSlimWidth}"
                               HorizontalAlignment="Left"
                               Text="{Binding LdPlayerIndex, UpdateSourceTrigger=LostFocus}" />
                    </StackPanel>
                  </StackPanel>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <Border Classes="app-surface app-section connect-settings-section"
                  IsVisible="{Binding IsAttachWindowMode}">
            <StackPanel Classes="connect-settings-section-stack">
              <TextBlock Classes="section-title"
                         Text="{Binding RootTexts[Settings.Connect.AttachWindowWarning]}" />

              <Border Classes="app-surface app-card connect-settings-card">
                <StackPanel Classes="connect-settings-card-stack">
                  <TextBlock Classes="app-body connect-settings-card-title"
                             Text="{Binding RootTexts[Settings.Connect.ScreencapMethod]}" />
                  <ComboBox Classes="app-input"
                            Width="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
                            HorizontalAlignment="Left"
                            ItemsSource="{Binding AttachWindowScreencapOptions}"
                            SelectedItem="{Binding SelectedAttachWindowScreencapOption, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:ConnectionGameOptionItem">
                        <TextBlock Text="{Binding DisplayName}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>
              </Border>

              <Border Classes="app-surface app-card connect-settings-card">
                <StackPanel Classes="connect-settings-card-stack">
                  <TextBlock Classes="app-body connect-settings-card-title"
                             Text="{Binding RootTexts[Settings.Connect.MouseInput]}" />
                  <ComboBox Classes="app-input"
                            Width="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
                            HorizontalAlignment="Left"
                            ItemsSource="{Binding AttachWindowInputOptions}"
                            SelectedItem="{Binding SelectedAttachWindowMouseOption, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:ConnectionGameOptionItem">
                        <TextBlock Text="{Binding DisplayName}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>
              </Border>

              <Border Classes="app-surface app-card connect-settings-card">
                <StackPanel Classes="connect-settings-card-stack">
                  <TextBlock Classes="app-body connect-settings-card-title"
                             Text="{Binding RootTexts[Settings.Connect.KeyboardInput]}" />
                  <ComboBox Classes="app-input"
                            Width="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
                            HorizontalAlignment="Left"
                            ItemsSource="{Binding AttachWindowInputOptions}"
                            SelectedItem="{Binding SelectedAttachWindowKeyboardOption, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:ConnectionGameOptionItem">
                        <TextBlock Text="{Binding DisplayName}" />
                      </DataTemplate>
                    </ComboBox.ItemTemplate>
                  </ComboBox>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <Border Classes="app-surface app-section connect-settings-section">
            <StackPanel Classes="connect-settings-section-stack">
              <TextBlock Classes="section-title"
                         Text="{Binding RootTexts[Settings.Connect.ScreenshotTest]}" />

              <Border Classes="app-surface app-card connect-settings-card">
                <StackPanel Classes="connect-settings-card-stack">
                  <Button Classes="app-button app-secondary"
                          HorizontalAlignment="Left"
                          Content="{Binding RootTexts[Settings.Connect.ScreenshotTest]}"
                          Click="OnScreenshotTestClick" />
                  <TextBlock Classes="app-caption connect-settings-status-text"
                             Text="{Binding TestLinkInfo}"
                             IsVisible="{Binding HasTestLinkInfo}" />
                  <TextBlock Classes="app-caption connect-settings-status-text"
                             Text="{Binding ScreencapCost}" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

          <Border Classes="app-surface app-section connect-settings-section"
                  IsVisible="{Binding IsAdbConnectionMode}">
            <StackPanel Classes="connect-settings-section-stack">
              <TextBlock Classes="section-title"
                         Text="{Binding RootTexts[Settings.Start.RetryOnDisconnected]}" />

              <Border Classes="app-surface app-card connect-settings-card">
                <StackPanel Classes="connect-settings-toggle-list">
                  <StackPanel Orientation="Horizontal"
                              Spacing="6">
                    <CheckBox Classes="app-checkbox"
                              Content="{Binding RootTexts[Settings.Start.RetryOnDisconnected]}"
                              IsChecked="{Binding RetryOnDisconnected}" />
                    <controls:TooltipHint VerticalAlignment="Center"
                                          Tip="{Binding RootTexts[Settings.Start.RetryOnDisconnectedTip]}" />
                  </StackPanel>
                  <CheckBox Classes="app-checkbox"
                            Content="{Binding RootTexts[Settings.Connect.AllowAdbRestart]}"
                            IsChecked="{Binding AllowAdbRestart}" />
                  <CheckBox Classes="app-checkbox"
                            Content="{Binding RootTexts[Settings.Connect.AllowAdbHardRestart]}"
                            IsChecked="{Binding AllowAdbHardRestart}" />
                  <CheckBox Classes="app-checkbox"
                            Content="{Binding RootTexts[Settings.Connect.KillAdbOnExit]}"
                            IsChecked="{Binding KillAdbOnExit}" />
                  <CheckBox Classes="app-checkbox"
                            Content="{Binding RootTexts[Settings.Connect.AdbLiteEnabled]}"
                            IsChecked="{Binding AdbLiteEnabled}" />
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>
        </WrapPanel>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
