<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MAAUnified.App.ViewModels.Settings"
             x:Class="MAAUnified.App.Features.Settings.VersionUpdateSettingsView">
  <Grid Margin="4" RowDefinitions="Auto,*">
    <TextBlock Classes="section-title" Text="{Binding RootTexts[Settings.Section.VersionUpdate]}" />

    <Grid Grid.Row="1"
          Margin="0,8,0,0"
          ColumnDefinitions="260,*">
      <StackPanel Grid.Column="0"
                  Classes="settings-centered-column"
                  Spacing="8">
        <CheckBox Content="{Binding RootTexts[Settings.VersionUpdate.StartupCheck]}"
                  IsChecked="{Binding VersionUpdateStartupCheck}" />
        <CheckBox Content="{Binding RootTexts[Settings.VersionUpdate.ScheduledCheck]}"
                  IsChecked="{Binding VersionUpdateScheduledCheck}" />
        <CheckBox Content="{Binding RootTexts[Settings.VersionUpdate.AutoDownload]}"
                  IsChecked="{Binding VersionUpdateAutoDownload}" />
        <CheckBox Content="{Binding RootTexts[Settings.VersionUpdate.AutoInstall]}"
                  IsChecked="{Binding VersionUpdateAutoInstall}" />

        <StackPanel Classes="settings-centered-column" Spacing="4">
          <TextBlock Classes="settings-field-caption" Text="{Binding RootTexts[Settings.VersionUpdate.Channel]}" />
          <ComboBox Width="{DynamicResource MAA.Size.Settings.FieldSlimWidth}"
                    ItemsSource="{Binding VersionUpdateVersionTypeOptions}"
                    SelectedItem="{Binding SelectedVersionUpdateVersionTypeOption, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="vm:DisplayValueOption">
                <TextBlock Text="{Binding Display}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>

        <StackPanel Classes="settings-centered-column" Spacing="4">
          <TextBlock Classes="settings-field-caption" Text="{Binding RootTexts[Settings.VersionUpdate.Source]}" />
          <ComboBox Width="{DynamicResource MAA.Size.Settings.FieldSlimWidth}"
                    ItemsSource="{Binding VersionUpdateResourceSourceOptions}"
                    SelectedItem="{Binding SelectedVersionUpdateResourceSourceOption, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="vm:DisplayValueOption">
                <TextBlock Text="{Binding Display}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </StackPanel>

        <CheckBox Content="{Binding RootTexts[Settings.VersionUpdate.ForceGithub]}"
                  IsChecked="{Binding VersionUpdateForceGithubSource}"
                  IsVisible="{Binding IsVersionUpdateGithubSource}" />

        <StackPanel Classes="settings-centered-column"
                    Spacing="4"
                    IsVisible="{Binding IsVersionUpdateMirrorChyanSource}">
          <TextBlock Classes="settings-field-caption" Text="{Binding RootTexts[Settings.VersionUpdate.MirrorCdk]}" />
          <Grid Width="{DynamicResource MAA.Size.Settings.FieldSlimWidth}"
                ColumnDefinitions="*,Auto">
            <TextBox Text="{Binding VersionUpdateMirrorChyanCdk, UpdateSourceTrigger=LostFocus}" />
            <Button Grid.Column="1"
                    Classes="wpf-button wpf-button-secondary"
                    Margin="8,0,0,0"
                    Content="{Binding RootTexts[Settings.VersionUpdate.Copy]}"
                    Click="OnCopyMirrorChyanCdkClick" />
          </Grid>
          <TextBlock Classes="state-warning"
                     Text="{Binding VersionUpdateMirrorChyanCdkExpiryText}"
                     TextWrapping="Wrap" />
          <Button Classes="wpf-button wpf-button-secondary"
                  HorizontalAlignment="Center"
                  Content="{Binding RootTexts[Settings.VersionUpdate.MirrorSite]}"
                  Click="OnOpenMirrorChyanClick" />
        </StackPanel>
      </StackPanel>

      <StackPanel Grid.Column="1" Spacing="8" Margin="16,0,0,0">
        <Grid ColumnDefinitions="Auto,140,Auto,*"
              RowDefinitions="Auto,Auto">
          <TextBlock VerticalAlignment="Center" Text="{Binding RootTexts[Settings.VersionUpdate.ProxyType]}" />
          <ComboBox Grid.Column="1"
                    ItemsSource="{Binding VersionUpdateProxyTypeOptions}"
                    SelectedItem="{Binding SelectedVersionUpdateProxyTypeOption, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
              <DataTemplate x:DataType="vm:DisplayValueOption">
                <TextBlock Text="{Binding Display}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>

          <TextBlock Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center" Text="{Binding RootTexts[Settings.VersionUpdate.ProxyAddress]}" />
          <TextBox Grid.Column="3"
                   Margin="8,0,0,0"
                   Watermark="{Binding RootTexts[Settings.VersionUpdate.ProxyAddressWatermark]}"
                   Text="{Binding VersionUpdateProxy, UpdateSourceTrigger=LostFocus}" />

          <TextBlock Grid.Row="1" Margin="0,8,0,0" VerticalAlignment="Center" Text="{Binding RootTexts[Settings.VersionUpdate.ResourceApi]}" />
          <TextBox Grid.Row="1"
                   Grid.Column="1"
                   Grid.ColumnSpan="3"
                   Margin="0,8,0,0"
                   Text="{Binding VersionUpdateResourceApi, UpdateSourceTrigger=LostFocus}" />
        </Grid>

        <WrapPanel Margin="0,4,0,0" ItemWidth="220">
          <Border Classes="wpf-card">
            <StackPanel Spacing="2">
              <TextBlock Opacity="0.7" Text="{Binding RootTexts[Settings.VersionUpdate.PanelUiVersion]}" />
              <TextBlock Text="{Binding UpdatePanelUiVersion}" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
          <Border Classes="wpf-card">
            <StackPanel Spacing="2">
              <TextBlock Opacity="0.7" Text="{Binding RootTexts[Settings.VersionUpdate.PanelCoreVersion]}" />
              <TextBlock Text="{Binding UpdatePanelCoreVersion}" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
          <Border Classes="wpf-card">
            <StackPanel Spacing="2">
              <TextBlock Opacity="0.7" Text="{Binding RootTexts[Settings.VersionUpdate.PanelBuildTime]}" />
              <TextBlock Text="{Binding UpdatePanelBuildTime}" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
          <Border Classes="wpf-card">
            <StackPanel Spacing="2">
              <TextBlock Opacity="0.7" Text="{Binding RootTexts[Settings.VersionUpdate.PanelResourceVersion]}" />
              <TextBlock Text="{Binding UpdatePanelResourceVersion}" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
          <Border Classes="wpf-card">
            <StackPanel Spacing="2">
              <TextBlock Opacity="0.7" Text="{Binding RootTexts[Settings.VersionUpdate.PanelResourceTime]}" />
              <TextBlock Text="{Binding UpdatePanelResourceTime}" TextWrapping="Wrap" />
            </StackPanel>
          </Border>
        </WrapPanel>

        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
          <Button Classes="wpf-button wpf-button-primary"
                  Content="{Binding RootTexts[Settings.VersionUpdate.SoftwareUpdate]}"
                  IsEnabled="{Binding CanRunVersionUpdateActions}"
                  Click="OnCheckUpdateClick" />
          <Button Classes="wpf-button wpf-button-secondary"
                  Content="{Binding RootTexts[Settings.VersionUpdate.Changelog]}"
                  IsEnabled="{Binding CanRunVersionUpdateActions}"
                  Click="OnOpenChangelogClick" />
          <Button Classes="wpf-button wpf-button-secondary"
                  Content="{Binding RootTexts[Settings.VersionUpdate.ResourceUpdate]}"
                  IsEnabled="{Binding CanRunVersionUpdateActions}"
                  Click="OnUpdateResourceClick" />
        </StackPanel>

        <Button Classes="wpf-button wpf-button-secondary"
                HorizontalAlignment="Left"
                Content="{Binding RootTexts[Settings.VersionUpdate.ResourceRepository]}"
                Click="OnOpenResourceRepositoryClick" />

        <StackPanel MaxWidth="{DynamicResource MAA.Size.Settings.ContentMaxWidth}"
                    Spacing="4"
                    Margin="0,6,0,0">
          <TextBlock Classes="settings-centered-text subtle long-wrap"
                     Text="{Binding VersionUpdateActivityMessage}"
                     IsVisible="{Binding HasVersionUpdateActivityMessage}"
                     TextWrapping="Wrap" />
          <TextBlock Classes="settings-centered-text long-wrap"
                     Text="{Binding VersionUpdateStatusMessage}"
                     TextWrapping="Wrap" />
          <TextBlock Classes="state-error"
                     Text="{Binding VersionUpdateErrorMessage}"
                     IsVisible="{Binding HasVersionUpdateErrorMessage}"
                     TextWrapping="Wrap" />
        </StackPanel>
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
