<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             xmlns:vm="clr-namespace:MAAUnified.App.ViewModels.Settings"
             Classes="settings-page"
             x:Class="MAAUnified.App.Features.Settings.VersionUpdateSettingsView">
  <UserControl.Styles>
    <Style Selector="controls|AdaptiveSpacingStackPanel.version-update-section-stack">
      <Setter Property="Spacing" Value="16" />
    </Style>

    <Style Selector="controls|AdaptiveSpacingStackPanel.version-update-card-stack">
      <Setter Property="Spacing" Value="10" />
    </Style>
  </UserControl.Styles>

  <Grid Margin="4"
        RowDefinitions="Auto,Auto,Auto">
    <TextBlock Classes="settings-page-title"
               Text="{Binding RootTexts[Settings.Section.VersionUpdate]}" />

    <Grid Grid.Row="1"
          Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}"
          Classes="settings-page-two-column"
          HorizontalAlignment="Left"
          ColumnDefinitions="Auto,24,*">
      <controls:AdaptiveSpacingStackPanel Classes="version-update-section-stack settings-page-column-stack">
        <controls:AdaptiveSpacingStackPanel Classes="version-update-card-stack settings-page-toggle-stack">
          <CheckBox Classes="app-checkbox"
                    Content="{Binding RootTexts[Settings.VersionUpdate.StartupCheck]}"
                    IsChecked="{Binding VersionUpdateStartupCheck}" />
          <controls:AdaptiveSpacingStackPanel Classes="settings-page-inline-field-group">
            <controls:AppHintedCheckBox Text="{Binding RootTexts[Settings.VersionUpdate.ScheduledCheck]}"
                                         Tip="{DynamicResource UpdateAutoCheckTip}"
                                         IsChecked="{Binding VersionUpdateScheduledCheck}" />
          </controls:AdaptiveSpacingStackPanel>
          <CheckBox Classes="app-checkbox"
                    Content="{Binding RootTexts[Settings.VersionUpdate.AutoDownload]}"
                    IsChecked="{Binding VersionUpdateAutoDownload}" />
          <CheckBox Classes="app-checkbox"
                    Content="{Binding RootTexts[Settings.VersionUpdate.AutoInstall]}"
                    IsChecked="{Binding VersionUpdateAutoInstall}" />
        </controls:AdaptiveSpacingStackPanel>

        <controls:AdaptiveSpacingStackPanel Classes="version-update-card-stack settings-page-column-stack">
          <Grid Classes="settings-page-labeled-row"
                controls:SettingsLabelWidthCoordinator.GroupKey="VersionUpdate.Main"
                ColumnDefinitions="Auto,*">
            <controls:SettingsLabel Text="{Binding RootTexts[Settings.VersionUpdate.Channel]}"
                                    Tip="{DynamicResource UpdateCheckTip}" />
            <ComboBox Grid.Column="1"
                      Classes="settings-select"
                      Width="{DynamicResource MAA.Size.Settings.FieldSlimWidth}"
                      HorizontalAlignment="Left"
                      ItemsSource="{Binding VersionUpdateVersionTypeOptions}"
                      SelectedItem="{Binding SelectedVersionUpdateVersionTypeOption, Mode=TwoWay}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:DisplayValueOption">
                  <TextBlock Text="{Binding Display}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>

          <Grid Classes="settings-page-labeled-row"
                controls:SettingsLabelWidthCoordinator.GroupKey="VersionUpdate.Main"
                ColumnDefinitions="Auto,*">
            <controls:SettingsLabel Text="{Binding RootTexts[Settings.VersionUpdate.Source]}"
                                    Tip="{DynamicResource UpdateSourceTip}" />
            <ComboBox Grid.Column="1"
                      Classes="settings-select"
                      Width="{DynamicResource MAA.Size.Settings.FieldSlimWidth}"
                      HorizontalAlignment="Left"
                      ItemsSource="{Binding VersionUpdateResourceSourceOptions}"
                      SelectedItem="{Binding SelectedVersionUpdateResourceSourceOption, Mode=TwoWay}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:DisplayValueOption">
                  <TextBlock Text="{Binding Display}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>

          <controls:AdaptiveSpacingStackPanel Classes="settings-page-inline-field-group"
                      IsVisible="{Binding IsVersionUpdateGithubSource}">
            <controls:AppHintedCheckBox Text="{Binding RootTexts[Settings.VersionUpdate.ForceGithub]}"
                                         Tip="{DynamicResource ForceGithubGlobalSourceTip}"
                                         IsChecked="{Binding VersionUpdateForceGithubSource}" />
          </controls:AdaptiveSpacingStackPanel>

          <controls:AdaptiveSpacingStackPanel Classes="settings-page-column-stack settings-page-meta-block"
                      Spacing="8"
                      IsVisible="{Binding IsVersionUpdateMirrorChyanSource}">
            <Grid Classes="settings-page-labeled-action-row"
                  controls:SettingsLabelWidthCoordinator.GroupKey="VersionUpdate.Main"
                  ColumnDefinitions="Auto,*">
              <controls:SettingsLabel Text="{Binding RootTexts[Settings.VersionUpdate.MirrorCdk]}" />
              <controls:AppActionInput Grid.Column="1"
                                       Width="{DynamicResource MAA.Size.Settings.FieldSlimWidth}"
                                       HorizontalAlignment="Left"
                                       Text="{Binding VersionUpdateMirrorChyanCdk, UpdateSourceTrigger=LostFocus}"
                                       ActionContent="{Binding RootTexts[Settings.VersionUpdate.Copy]}"
                                       ActionClick="OnCopyMirrorChyanCdkClick" />
            </Grid>

            <TextBlock Classes="app-caption state-warning"
                       Text="{Binding VersionUpdateMirrorChyanCdkExpiryText}"
                       TextWrapping="Wrap" />

            <Button HorizontalAlignment="Left"
                    Classes="app-button app-secondary"
                    Content="{Binding RootTexts[Settings.VersionUpdate.MirrorSite]}"
                    Click="OnOpenMirrorChyanClick" />
          </controls:AdaptiveSpacingStackPanel>

          <Grid Classes="settings-page-labeled-row"
                controls:SettingsLabelWidthCoordinator.GroupKey="VersionUpdate.Main"
                ColumnDefinitions="Auto,*">
            <controls:SettingsLabel Text="{Binding RootTexts[Settings.VersionUpdate.ProxyType]}" />
            <ComboBox Grid.Column="1"
                      Classes="settings-select"
                      Width="{DynamicResource MAA.Size.Settings.FieldNarrowWidth}"
                      HorizontalAlignment="Left"
                      ItemsSource="{Binding VersionUpdateProxyTypeOptions}"
                      SelectedItem="{Binding SelectedVersionUpdateProxyTypeOption, Mode=TwoWay}">
              <ComboBox.ItemTemplate>
                <DataTemplate x:DataType="vm:DisplayValueOption">
                  <TextBlock Text="{Binding Display}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Grid>

          <Grid Classes="settings-page-labeled-row"
                controls:SettingsLabelWidthCoordinator.GroupKey="VersionUpdate.Main"
                ColumnDefinitions="Auto,*">
            <controls:SettingsLabel Text="{Binding RootTexts[Settings.VersionUpdate.ProxyAddress]}" />
            <TextBox Grid.Column="1"
                     Classes="settings-input"
                     Width="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
                     HorizontalAlignment="Left"
                     Watermark="{Binding RootTexts[Settings.VersionUpdate.ProxyAddressWatermark]}"
                     Text="{Binding VersionUpdateProxy, UpdateSourceTrigger=LostFocus}" />
          </Grid>

          <Grid Classes="settings-page-labeled-row"
                controls:SettingsLabelWidthCoordinator.GroupKey="VersionUpdate.Main"
                ColumnDefinitions="Auto,*">
            <controls:SettingsLabel Text="{Binding RootTexts[Settings.VersionUpdate.ResourceApi]}" />
            <TextBox Grid.Column="1"
                     Classes="settings-input"
                     Width="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
                     HorizontalAlignment="Left"
                     Text="{Binding VersionUpdateResourceApi, UpdateSourceTrigger=LostFocus}" />
          </Grid>
        </controls:AdaptiveSpacingStackPanel>

      </controls:AdaptiveSpacingStackPanel>

      <controls:AdaptiveSpacingStackPanel Grid.Column="2"
                  Classes="version-update-section-stack settings-page-column-stack">

        <Border Classes="grouped-card-frame"
                Padding="18">
          <controls:AdaptiveSpacingStackPanel Classes="version-update-card-stack settings-page-column-stack">
            <Grid Classes="settings-page-labeled-row"
                  controls:SettingsLabelWidthCoordinator.GroupKey="VersionUpdate.Panel"
                  ColumnDefinitions="Auto,*">
              <controls:SettingsLabel Text="{Binding RootTexts[Settings.VersionUpdate.PanelUiVersion]}" />
              <TextBlock Grid.Column="1"
                         Classes="app-body"
                         Text="{Binding UpdatePanelUiVersion}"
                         TextWrapping="Wrap" />
            </Grid>

            <Grid Classes="settings-page-labeled-row"
                  controls:SettingsLabelWidthCoordinator.GroupKey="VersionUpdate.Panel"
                  ColumnDefinitions="Auto,*">
              <controls:SettingsLabel Text="{Binding RootTexts[Settings.VersionUpdate.PanelCoreVersion]}" />
              <TextBlock Grid.Column="1"
                         Classes="app-body"
                         Text="{Binding UpdatePanelCoreVersion}"
                         TextWrapping="Wrap" />
            </Grid>

            <Grid Classes="settings-page-labeled-row"
                  controls:SettingsLabelWidthCoordinator.GroupKey="VersionUpdate.Panel"
                  ColumnDefinitions="Auto,*">
              <controls:SettingsLabel Text="{Binding RootTexts[Settings.VersionUpdate.PanelResourceVersion]}" />
              <TextBlock Grid.Column="1"
                         Classes="app-body"
                         Text="{Binding UpdatePanelResourceVersion}"
                         TextWrapping="Wrap" />
            </Grid>

            <Grid Classes="settings-page-labeled-row"
                  controls:SettingsLabelWidthCoordinator.GroupKey="VersionUpdate.Panel"
                  ColumnDefinitions="Auto,*">
              <controls:SettingsLabel Text="{Binding RootTexts[Settings.VersionUpdate.PanelBuildTime]}" />
              <TextBlock Grid.Column="1"
                         Classes="app-body"
                         Text="{Binding UpdatePanelBuildTime}"
                         TextWrapping="Wrap" />
            </Grid>

            <Grid Classes="settings-page-labeled-row"
                  controls:SettingsLabelWidthCoordinator.GroupKey="VersionUpdate.Panel"
                  ColumnDefinitions="Auto,*">
              <controls:SettingsLabel Text="{Binding RootTexts[Settings.VersionUpdate.PanelResourceTime]}" />
              <TextBlock Grid.Column="1"
                         Classes="app-body"
                         Text="{Binding UpdatePanelResourceTime}"
                         TextWrapping="Wrap" />
            </Grid>
          </controls:AdaptiveSpacingStackPanel>
        </Border>

        <Grid Margin="0,8,0,0"
              HorizontalAlignment="Left"
              RowDefinitions="Auto,10,Auto"
              ColumnDefinitions="Auto,12,Auto,24,Auto">
          <Button Grid.Row="0"
                  Grid.Column="0"
                  HorizontalAlignment="Left"
                  Classes="app-button app-primary"
                  Content="{Binding RootTexts[Settings.VersionUpdate.SoftwareUpdate]}"
                  IsEnabled="{Binding CanRunVersionUpdateActions}"
                  Click="OnCheckUpdateClick" />
          <Button Grid.Row="0"
                  Grid.Column="4"
                  HorizontalAlignment="Left"
                  Classes="app-button app-secondary"
                  Content="{Binding RootTexts[Settings.VersionUpdate.Changelog]}"
                  IsEnabled="{Binding CanRunVersionUpdateActions}"
                  Click="OnOpenChangelogClick" />

          <Button Grid.Row="2"
                  Grid.Column="0"
                  HorizontalAlignment="Left"
                  Classes="app-button app-primary"
                  Content="{Binding RootTexts[Settings.VersionUpdate.ResourceUpdate]}"
                  IsEnabled="{Binding CanRunVersionUpdateActions}"
                  Click="OnUpdateResourceClick" />
          <controls:TooltipHint Grid.Row="2"
                                Grid.Column="2"
                                VerticalAlignment="Center"
                                Tip="{DynamicResource ResourceUpdateTip}" />
          <Button Grid.Row="2"
                  Grid.Column="4"
                  HorizontalAlignment="Left"
                  Classes="app-button app-secondary"
                  Content="{Binding RootTexts[Settings.VersionUpdate.ResourceRepository]}"
                  Click="OnOpenResourceRepositoryClick" />
        </Grid>
      </controls:AdaptiveSpacingStackPanel>
    </Grid>

    <Border Grid.Row="2"
            Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
            Classes="settings-page-status-block">
      <controls:AdaptiveSpacingStackPanel MaxWidth="{DynamicResource MAA.Size.Settings.ContentMaxWidth}"
                  Classes="settings-page-status-list">
        <TextBlock Classes="app-window-subtitle subtle long-wrap"
                   Text="{Binding VersionUpdateActivityMessage}"
                   IsVisible="{Binding HasVersionUpdateActivityMessage}"
                   TextWrapping="Wrap" />
      </controls:AdaptiveSpacingStackPanel>
    </Border>
  </Grid>
</UserControl>
