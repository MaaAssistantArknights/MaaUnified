<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:MAAUnified.App.ViewModels.Settings"
             Classes="settings-page"
             x:Class="MAAUnified.App.Features.Settings.VersionUpdateSettingsView">
  <UserControl.Styles>
    <Style Selector="Border.version-update-card">
      <Setter Property="Padding" Value="16" />
    </Style>

    <Style Selector="StackPanel.version-update-section-stack">
      <Setter Property="Spacing" Value="16" />
    </Style>

    <Style Selector="StackPanel.version-update-card-stack">
      <Setter Property="Spacing" Value="10" />
    </Style>

    <Style Selector="StackPanel.version-update-status-list">
      <Setter Property="Spacing" Value="8" />
    </Style>
  </UserControl.Styles>

  <Grid Margin="4"
        RowDefinitions="Auto,Auto,Auto">
    <TextBlock Classes="settings-page-title"
               Text="{Binding RootTexts[Settings.Section.VersionUpdate]}" />

    <Grid Grid.Row="1"
          Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}"
          Classes="settings-page-two-column"
          HorizontalAlignment="Left"
          ColumnDefinitions="300,24,*">
      <StackPanel Classes="version-update-section-stack settings-page-column-stack">
        <Border Classes="app-surface app-card version-update-card">
          <StackPanel Classes="version-update-card-stack settings-page-toggle-stack">
            <CheckBox Classes="app-checkbox"
                      Content="{Binding RootTexts[Settings.VersionUpdate.StartupCheck]}"
                      IsChecked="{Binding VersionUpdateStartupCheck}" />
            <CheckBox Classes="app-checkbox"
                      Content="{Binding RootTexts[Settings.VersionUpdate.ScheduledCheck]}"
                      IsChecked="{Binding VersionUpdateScheduledCheck}" />
            <CheckBox Classes="app-checkbox"
                      Content="{Binding RootTexts[Settings.VersionUpdate.AutoDownload]}"
                      IsChecked="{Binding VersionUpdateAutoDownload}" />
            <CheckBox Classes="app-checkbox"
                      Content="{Binding RootTexts[Settings.VersionUpdate.AutoInstall]}"
                      IsChecked="{Binding VersionUpdateAutoInstall}" />
          </StackPanel>
        </Border>

        <Border Classes="app-surface app-card version-update-card">
          <StackPanel Classes="version-update-card-stack settings-page-column-stack">
            <Grid Classes="settings-page-labeled-row"
                  ColumnDefinitions="132,*">
              <TextBlock Classes="settings-label"
                         Text="{Binding RootTexts[Settings.VersionUpdate.Channel]}" />
              <ComboBox Grid.Column="1"
                        Classes="app-input settings-input"
                        Width="{DynamicResource MAA.Size.Settings.FieldSlimWidth}"
                        HorizontalAlignment="Left"
                        ItemsSource="{Binding VersionUpdateVersionTypeOptions}"
                        SelectedItem="{Binding SelectedVersionUpdateVersionTypeOption, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:DisplayValueOption">
                    <TextBlock Text="{Binding Display}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </Grid>

            <Grid Classes="settings-page-labeled-row"
                  ColumnDefinitions="132,*">
              <TextBlock Classes="settings-label"
                         Text="{Binding RootTexts[Settings.VersionUpdate.Source]}" />
              <ComboBox Grid.Column="1"
                        Classes="app-input settings-input"
                        Width="{DynamicResource MAA.Size.Settings.FieldSlimWidth}"
                        HorizontalAlignment="Left"
                        ItemsSource="{Binding VersionUpdateResourceSourceOptions}"
                        SelectedItem="{Binding SelectedVersionUpdateResourceSourceOption, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:DisplayValueOption">
                    <TextBlock Text="{Binding Display}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </Grid>

            <CheckBox Classes="app-checkbox"
                      Content="{Binding RootTexts[Settings.VersionUpdate.ForceGithub]}"
                      IsChecked="{Binding VersionUpdateForceGithubSource}"
                      IsVisible="{Binding IsVersionUpdateGithubSource}" />

            <StackPanel Classes="settings-page-column-stack settings-page-meta-block"
                        Spacing="8"
                        IsVisible="{Binding IsVersionUpdateMirrorChyanSource}">
              <Grid Classes="settings-page-labeled-action-row"
                    ColumnDefinitions="132,*,Auto">
                <TextBlock Classes="settings-label"
                           Text="{Binding RootTexts[Settings.VersionUpdate.MirrorCdk]}" />
                <TextBox Grid.Column="1"
                         Classes="app-input"
                         Margin="0,0,8,0"
                         Width="{DynamicResource MAA.Size.Settings.FieldSlimWidth}"
                         HorizontalAlignment="Left"
                         Text="{Binding VersionUpdateMirrorChyanCdk, UpdateSourceTrigger=LostFocus}" />
                <Button Grid.Column="2"
                        Classes="app-button app-secondary"
                        Content="{Binding RootTexts[Settings.VersionUpdate.Copy]}"
                        Click="OnCopyMirrorChyanCdkClick" />
              </Grid>

              <TextBlock Classes="app-caption state-warning"
                         Text="{Binding VersionUpdateMirrorChyanCdkExpiryText}"
                         TextWrapping="Wrap" />

              <Button HorizontalAlignment="Left"
                      Classes="app-button app-secondary"
                      Content="{Binding RootTexts[Settings.VersionUpdate.MirrorSite]}"
                      Click="OnOpenMirrorChyanClick" />
            </StackPanel>
          </StackPanel>
        </Border>
      </StackPanel>

      <StackPanel Grid.Column="2"
                  Classes="version-update-section-stack settings-page-column-stack">
        <Border Classes="app-surface app-card version-update-card">
          <StackPanel Classes="version-update-card-stack settings-page-column-stack">
            <Grid Classes="settings-page-labeled-row"
                  ColumnDefinitions="132,*">
              <TextBlock Classes="settings-label"
                         Text="{Binding RootTexts[Settings.VersionUpdate.ProxyType]}" />
              <ComboBox Grid.Column="1"
                        Classes="app-input settings-input"
                        Width="160"
                        HorizontalAlignment="Left"
                        ItemsSource="{Binding VersionUpdateProxyTypeOptions}"
                        SelectedItem="{Binding SelectedVersionUpdateProxyTypeOption, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:DisplayValueOption">
                    <TextBlock Text="{Binding Display}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </Grid>

            <Grid Classes="settings-page-labeled-row"
                  ColumnDefinitions="132,*">
              <TextBlock Classes="settings-label"
                         Text="{Binding RootTexts[Settings.VersionUpdate.ProxyAddress]}" />
              <TextBox Grid.Column="1"
                       Classes="app-input"
                       Width="{DynamicResource MAA.Size.Settings.FieldSlimWidth}"
                       HorizontalAlignment="Left"
                       Watermark="{Binding RootTexts[Settings.VersionUpdate.ProxyAddressWatermark]}"
                       Text="{Binding VersionUpdateProxy, UpdateSourceTrigger=LostFocus}" />
            </Grid>

            <Grid Classes="settings-page-labeled-row"
                  ColumnDefinitions="132,*">
              <TextBlock Classes="settings-label"
                         Text="{Binding RootTexts[Settings.VersionUpdate.ResourceApi]}" />
              <TextBox Grid.Column="1"
                       Classes="app-input"
                       MinWidth="260"
                       MaxWidth="{DynamicResource MAA.Size.Settings.FieldPathWideWidth}"
                       HorizontalAlignment="Left"
                       Text="{Binding VersionUpdateResourceApi, UpdateSourceTrigger=LostFocus}" />
            </Grid>
          </StackPanel>
        </Border>

        <Border Classes="app-surface app-card version-update-card settings-page-meta-block">
          <StackPanel Classes="version-update-card-stack settings-page-column-stack">
            <Grid Classes="settings-page-labeled-row"
                  ColumnDefinitions="180,*">
              <TextBlock Classes="settings-label"
                         Text="{Binding RootTexts[Settings.VersionUpdate.PanelUiVersion]}" />
              <TextBlock Grid.Column="1"
                         Classes="app-body"
                         Text="{Binding UpdatePanelUiVersion}"
                         TextWrapping="Wrap" />
            </Grid>

            <Grid Classes="settings-page-labeled-row"
                  ColumnDefinitions="180,*">
              <TextBlock Classes="settings-label"
                         Text="{Binding RootTexts[Settings.VersionUpdate.PanelCoreVersion]}" />
              <TextBlock Grid.Column="1"
                         Classes="app-body"
                         Text="{Binding UpdatePanelCoreVersion}"
                         TextWrapping="Wrap" />
            </Grid>

            <Grid Classes="settings-page-labeled-row"
                  ColumnDefinitions="180,*">
              <TextBlock Classes="settings-label"
                         Text="{Binding RootTexts[Settings.VersionUpdate.PanelResourceVersion]}" />
              <TextBlock Grid.Column="1"
                         Classes="app-body"
                         Text="{Binding UpdatePanelResourceVersion}"
                         TextWrapping="Wrap" />
            </Grid>

            <Grid Classes="settings-page-labeled-row"
                  ColumnDefinitions="180,*">
              <TextBlock Classes="settings-label"
                         Text="{Binding RootTexts[Settings.VersionUpdate.PanelBuildTime]}" />
              <TextBlock Grid.Column="1"
                         Classes="app-body"
                         Text="{Binding UpdatePanelBuildTime}"
                         TextWrapping="Wrap" />
            </Grid>

            <Grid Classes="settings-page-labeled-row"
                  ColumnDefinitions="180,*">
              <TextBlock Classes="settings-label"
                         Text="{Binding RootTexts[Settings.VersionUpdate.PanelResourceTime]}" />
              <TextBlock Grid.Column="1"
                         Classes="app-body"
                         Text="{Binding UpdatePanelResourceTime}"
                         TextWrapping="Wrap" />
            </Grid>
          </StackPanel>
        </Border>

        <Border Classes="app-surface app-card version-update-card">
          <StackPanel Classes="version-update-card-stack settings-page-column-stack">
            <Button HorizontalAlignment="Left"
                    Classes="app-button app-primary"
                    Content="{Binding RootTexts[Settings.VersionUpdate.SoftwareUpdate]}"
                    IsEnabled="{Binding CanRunVersionUpdateActions}"
                    Click="OnCheckUpdateClick" />
            <Button HorizontalAlignment="Left"
                    Classes="app-button app-secondary"
                    Content="{Binding RootTexts[Settings.VersionUpdate.Changelog]}"
                    IsEnabled="{Binding CanRunVersionUpdateActions}"
                    Click="OnOpenChangelogClick" />
            <Button HorizontalAlignment="Left"
                    Classes="app-button app-secondary"
                    Content="{Binding RootTexts[Settings.VersionUpdate.ResourceUpdate]}"
                    IsEnabled="{Binding CanRunVersionUpdateActions}"
                    Click="OnUpdateResourceClick" />
            <Button HorizontalAlignment="Left"
                    Classes="app-button app-secondary"
                    Content="{Binding RootTexts[Settings.VersionUpdate.ResourceRepository]}"
                    Click="OnOpenResourceRepositoryClick" />
          </StackPanel>
        </Border>
      </StackPanel>
    </Grid>

    <Border Grid.Row="2"
            Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
            Classes="settings-page-status-block">
      <StackPanel MaxWidth="{DynamicResource MAA.Size.Settings.ContentMaxWidth}"
                  Classes="settings-page-status-list version-update-status-list">
        <TextBlock Classes="app-window-subtitle subtle long-wrap"
                   Text="{Binding VersionUpdateActivityMessage}"
                   IsVisible="{Binding HasVersionUpdateActivityMessage}"
                   TextWrapping="Wrap" />
        <TextBlock Classes="app-body long-wrap"
                   Text="{Binding VersionUpdateStatusMessage}"
                   TextWrapping="Wrap" />
        <TextBlock Classes="app-body state-error"
                   Text="{Binding VersionUpdateErrorMessage}"
                   IsVisible="{Binding HasVersionUpdateErrorMessage}"
                   TextWrapping="Wrap" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
