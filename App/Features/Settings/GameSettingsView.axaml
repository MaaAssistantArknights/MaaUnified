<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             xmlns:vm="clr-namespace:MAAUnified.App.ViewModels.Settings"
             x:Class="MAAUnified.App.Features.Settings.GameSettingsView">
  <UserControl.Styles>
    <Style Selector="Border.game-settings-section">
      <Setter Property="Padding" Value="22" />
    </Style>

    <Style Selector="StackPanel.game-settings-stack">
      <Setter Property="Spacing" Value="12" />
    </Style>

    <Style Selector="Border.game-settings-card">
      <Setter Property="Padding" Value="16" />
    </Style>

    <Style Selector="TextBlock.game-settings-card-title">
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="WrapPanel.game-settings-toggle-group">
      <Setter Property="ItemWidth" Value="260" />
      <Setter Property="Orientation" Value="Horizontal" />
    </Style>
  </UserControl.Styles>

  <Grid Margin="4"
        RowDefinitions="Auto,Auto,Auto">
    <TextBlock Classes="section-title"
               Text="{Binding RootTexts[Settings.Section.Game]}" />

    <WrapPanel Grid.Row="1"
               Classes="settings-form settings-wrap"
               Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}">
      <Border Classes="app-surface app-section game-settings-section">
        <StackPanel Classes="game-settings-stack">
          <TextBlock Classes="app-body"
                     FontSize="16"
                     FontWeight="SemiBold"
                     Text="{Binding RootTexts[Settings.Game.ClientType]}" />

          <Border Classes="app-surface app-card game-settings-card">
            <StackPanel Classes="game-settings-stack">
              <TextBlock Classes="app-caption"
                         Text="{Binding RootTexts[Settings.Game.ClientType]}" />
              <ComboBox Classes="app-input"
                        MinWidth="260"
                        MaxWidth="420"
                        HorizontalAlignment="Left"
                        ItemsSource="{Binding ConnectionGameSharedState.ClientTypeOptions}"
                        SelectedItem="{Binding ConnectionGameSharedState.SelectedClientTypeOption, Mode=TwoWay}">
                <ComboBox.ItemTemplate>
                  <DataTemplate x:DataType="vm:ConnectionGameOptionItem">
                    <TextBlock Text="{Binding DisplayName}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>
            </StackPanel>
          </Border>

          <Border Classes="app-surface app-card game-settings-card"
                  IsVisible="{Binding ConnectionGameSharedState.IsYoStarEnClientType}">
            <StackPanel Classes="game-settings-stack">
              <TextBlock Classes="app-body game-settings-card-title"
                         Text="YoStar EN resolution guide is available." />
              <Button Classes="app-button app-secondary"
                      HorizontalAlignment="Left"
                      Content="Open YoStar EN Resolution Guide"
                      Click="OnOpenYoStarResolutionGuideClick" />
            </StackPanel>
          </Border>

          <Border Classes="app-surface app-card game-settings-card"
                  IsVisible="{Binding ConnectionGameSharedState.ShowOverseasClientHint}">
            <StackPanel Classes="game-settings-stack">
              <TextBlock Classes="app-body"
                         Text="Using an overseas client? See adaptation help." />
              <Button Classes="app-button app-secondary"
                      HorizontalAlignment="Left"
                      Content="Open Overseas Adaptation Guide"
                      Click="OnOpenOverseasAdaptationGuideClick" />
            </StackPanel>
          </Border>

          <Border Classes="app-surface app-card game-settings-card">
            <StackPanel Classes="game-settings-stack">
              <CheckBox Classes="app-checkbox"
                        Content="{Binding RootTexts[Settings.Game.DeploymentWithPause]}"
                        IsChecked="{Binding DeploymentWithPause}" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <Border Classes="app-surface app-section game-settings-section">
        <StackPanel Classes="game-settings-stack">
          <TextBlock Classes="app-body"
                     FontSize="16"
                     FontWeight="SemiBold"
                     Text="{Binding RootTexts[Settings.Game.StartsWithScript]}" />

          <Border Classes="app-surface app-card game-settings-card">
            <StackPanel Classes="game-settings-stack">
              <StackPanel Orientation="Horizontal"
                          Spacing="8">
                <TextBlock Classes="app-body game-settings-card-title"
                           VerticalAlignment="Center"
                           Text="{Binding RootTexts[Settings.Game.StartsWithScript]}" />
                <controls:TooltipHint Tip="{Binding RootTexts[Settings.Game.StartsWithScriptTip]}" />
              </StackPanel>
              <TextBox Classes="app-input"
                       Text="{Binding StartsWithScript, UpdateSourceTrigger=LostFocus}"
                       DragDrop.AllowDrop="True"
                       DragDrop.DragOver="OnScriptPathDragOver"
                       DragDrop.Drop="OnStartsWithScriptDrop" />
            </StackPanel>
          </Border>

          <Border Classes="app-surface app-card game-settings-card">
            <StackPanel Classes="game-settings-stack">
              <StackPanel Orientation="Horizontal"
                          Spacing="8">
                <TextBlock Classes="app-body game-settings-card-title"
                           VerticalAlignment="Center"
                           Text="{Binding RootTexts[Settings.Game.EndsWithScript]}" />
                <controls:TooltipHint Tip="{Binding RootTexts[Settings.Game.EndsWithScriptTip]}" />
              </StackPanel>
              <TextBox Classes="app-input"
                       Text="{Binding EndsWithScript, UpdateSourceTrigger=LostFocus}"
                       DragDrop.AllowDrop="True"
                       DragDrop.DragOver="OnScriptPathDragOver"
                       DragDrop.Drop="OnEndsWithScriptDrop" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>

      <Border Classes="app-surface app-section game-settings-section">
        <StackPanel Classes="game-settings-stack">
          <TextBlock Classes="app-body"
                     FontSize="16"
                     FontWeight="SemiBold"
                     Text="{Binding RootTexts[Settings.Section.Game]}" />

          <WrapPanel Classes="game-settings-toggle-group"
                     ItemHeight="88"
                     ItemWidth="280">
            <Border Classes="app-surface app-card game-settings-card">
              <CheckBox Classes="app-checkbox"
                        Content="{Binding RootTexts[Settings.Game.UseScriptOnCopilot]}"
                        IsChecked="{Binding CopilotWithScript}" />
            </Border>

            <Border Classes="app-surface app-card game-settings-card">
              <CheckBox Classes="app-checkbox"
                        Content="{Binding RootTexts[Settings.Game.UseScriptOnManualStop]}"
                        IsChecked="{Binding ManualStopWithScript}" />
            </Border>

            <Border Classes="app-surface app-card game-settings-card">
              <CheckBox Classes="app-checkbox"
                        Content="{Binding RootTexts[Settings.Game.BlockSleep]}"
                        IsChecked="{Binding BlockSleep}" />
            </Border>

            <Border Classes="app-surface app-card game-settings-card"
                    IsVisible="{Binding ShowBlockSleepWithScreenOnOption}">
              <CheckBox Classes="app-checkbox"
                        Content="{Binding RootTexts[Settings.Game.BlockSleepWithScreenOn]}"
                        IsChecked="{Binding BlockSleepWithScreenOn}" />
            </Border>

            <Border Classes="app-surface app-card game-settings-card">
              <CheckBox Classes="app-checkbox"
                        Content="{Binding RootTexts[Settings.Game.EnablePenguin]}"
                        IsChecked="{Binding EnablePenguin}" />
            </Border>

            <Border Classes="app-surface app-card game-settings-card">
              <CheckBox Classes="app-checkbox"
                        Content="{Binding RootTexts[Settings.Game.EnableYituliu]}"
                        IsChecked="{Binding EnableYituliu}" />
            </Border>
          </WrapPanel>

          <Border Classes="app-surface app-card game-settings-card"
                  IsVisible="{Binding ShowPenguinIdField}">
            <StackPanel Classes="game-settings-stack">
              <TextBlock Classes="app-caption"
                         Text="{Binding RootTexts[Settings.Game.PenguinId]}" />
              <TextBox Classes="app-input"
                       MinWidth="240"
                       MaxWidth="360"
                       HorizontalAlignment="Left"
                       Text="{Binding PenguinId, UpdateSourceTrigger=LostFocus}" />
            </StackPanel>
          </Border>
        </StackPanel>
      </Border>
    </WrapPanel>

    <WrapPanel Grid.Row="2"
               Classes="settings-wrap"
               Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}">
      <Border Classes="app-surface app-section game-settings-section">
        <Border Classes="app-surface app-card game-settings-card">
          <StackPanel Classes="game-settings-stack">
            <TextBlock Classes="app-caption"
                       Text="{Binding RootTexts[Settings.Game.TaskTimeoutMinutes]}" />
            <controls:VerticalSpinNumberBox Width="{DynamicResource MAA.Size.Settings.FieldNarrowWidth}"
                                            HorizontalAlignment="Left"
                                            Minimum="0"
                                            Maximum="1440"
                                            Value="{Binding TaskTimeoutMinutes}" />
          </StackPanel>
        </Border>
      </Border>

      <Border Classes="app-surface app-section game-settings-section">
        <Border Classes="app-surface app-card game-settings-card">
          <StackPanel Classes="game-settings-stack">
            <TextBlock Classes="app-caption"
                       Text="{Binding RootTexts[Settings.Game.ReminderIntervalMinutes]}" />
            <controls:VerticalSpinNumberBox Width="{DynamicResource MAA.Size.Settings.FieldNarrowWidth}"
                                            HorizontalAlignment="Left"
                                            Minimum="1"
                                            Maximum="1440"
                                            Value="{Binding ReminderIntervalMinutes}" />
          </StackPanel>
        </Border>
      </Border>
    </WrapPanel>
  </Grid>
</UserControl>
