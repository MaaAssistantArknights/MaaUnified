<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             xmlns:vm="clr-namespace:MAAUnified.App.ViewModels.Settings"
             x:Class="MAAUnified.App.Features.Settings.GameSettingsView">
  <Grid Margin="4" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto">
    <TextBlock Classes="section-title" Text="{Binding RootTexts[Settings.Section.Game]}" />

    <StackPanel Grid.Row="1"
                Classes="settings-centered-column"
                Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}">
      <TextBlock Classes="settings-field-caption" Text="{Binding RootTexts[Settings.Game.ClientType]}" />
      <ComboBox Width="{DynamicResource MAA.Size.Settings.FieldCenteredWidth}"
                ItemsSource="{Binding ConnectionGameSharedState.ClientTypeOptions}"
                SelectedItem="{Binding ConnectionGameSharedState.SelectedClientTypeOption, Mode=TwoWay}">
        <ComboBox.ItemTemplate>
          <DataTemplate x:DataType="vm:ConnectionGameOptionItem">
            <TextBlock Text="{Binding DisplayName}" />
          </DataTemplate>
        </ComboBox.ItemTemplate>
      </ComboBox>
      <StackPanel Classes="settings-centered-column"
                  Margin="0,8,0,0"
                  IsVisible="{Binding ConnectionGameSharedState.IsYoStarEnClientType}">
        <TextBlock Classes="settings-centered-text"
                   Foreground="OrangeRed"
                   Text="YoStar EN resolution guide is available." />
        <Button Classes="wpf-button wpf-button-secondary"
                HorizontalAlignment="Center"
                Content="Open YoStar EN Resolution Guide"
                Click="OnOpenYoStarResolutionGuideClick" />
      </StackPanel>
      <StackPanel Classes="settings-centered-column"
                  Margin="0,8,0,0"
                  IsVisible="{Binding ConnectionGameSharedState.ShowOverseasClientHint}">
        <TextBlock Classes="settings-centered-text subtle"
                   Text="Using an overseas client? See adaptation help." />
        <Button Classes="wpf-button wpf-button-secondary"
                HorizontalAlignment="Center"
                Content="Open Overseas Adaptation Guide"
                Click="OnOpenOverseasAdaptationGuideClick" />
      </StackPanel>
    </StackPanel>

    <StackPanel Grid.Row="2"
                Classes="settings-centered-column"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}">
      <CheckBox Content="{Binding RootTexts[Settings.Game.DeploymentWithPause]}"
                HorizontalAlignment="Center"
                IsChecked="{Binding DeploymentWithPause}" />
    </StackPanel>

    <StackPanel Grid.Row="3"
                Classes="settings-centered-column"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}">
      <Grid HorizontalAlignment="Center"
            ColumnDefinitions="Auto,Auto">
        <TextBlock Grid.Column="0"
                   Classes="settings-field-caption"
                   Margin="0"
                   Text="{Binding RootTexts[Settings.Game.StartsWithScript]}" />
        <controls:TooltipHint Grid.Column="1" Tip="{Binding RootTexts[Settings.Game.StartsWithScriptTip]}" />
      </Grid>
      <TextBox Width="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
               Text="{Binding StartsWithScript, UpdateSourceTrigger=LostFocus}"
               DragDrop.AllowDrop="True"
               DragDrop.DragOver="OnScriptPathDragOver"
               DragDrop.Drop="OnStartsWithScriptDrop" />
    </StackPanel>

    <StackPanel Grid.Row="4"
                Classes="settings-centered-column"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}">
      <Grid HorizontalAlignment="Center"
            ColumnDefinitions="Auto,Auto">
        <TextBlock Grid.Column="0"
                   Classes="settings-field-caption"
                   Margin="0"
                   Text="{Binding RootTexts[Settings.Game.EndsWithScript]}" />
        <controls:TooltipHint Grid.Column="1" Tip="{Binding RootTexts[Settings.Game.EndsWithScriptTip]}" />
      </Grid>
      <TextBox Width="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
               Text="{Binding EndsWithScript, UpdateSourceTrigger=LostFocus}"
               DragDrop.AllowDrop="True"
               DragDrop.DragOver="OnScriptPathDragOver"
               DragDrop.Drop="OnEndsWithScriptDrop" />
    </StackPanel>

    <StackPanel Grid.Row="5"
                Classes="settings-centered-column"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}">
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Center"
                  Spacing="{DynamicResource MAA.Spacing.Large}">
        <CheckBox Content="{Binding RootTexts[Settings.Game.UseScriptOnCopilot]}" IsChecked="{Binding CopilotWithScript}" />
        <CheckBox Content="{Binding RootTexts[Settings.Game.UseScriptOnManualStop]}" IsChecked="{Binding ManualStopWithScript}" />
      </StackPanel>
    </StackPanel>

    <StackPanel Grid.Row="6"
                Classes="settings-centered-column"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}">
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Center"
                  Spacing="{DynamicResource MAA.Spacing.Large}">
        <CheckBox Content="{Binding RootTexts[Settings.Game.BlockSleep]}" IsChecked="{Binding BlockSleep}" />
        <CheckBox Content="{Binding RootTexts[Settings.Game.BlockSleepWithScreenOn]}"
                  IsChecked="{Binding BlockSleepWithScreenOn}"
                  IsVisible="{Binding ShowBlockSleepWithScreenOnOption}" />
      </StackPanel>
    </StackPanel>

    <StackPanel Grid.Row="7"
                Classes="settings-centered-column"
                Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}">
      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Center"
                  Spacing="{DynamicResource MAA.Spacing.Large}">
        <CheckBox Content="{Binding RootTexts[Settings.Game.EnablePenguin]}" IsChecked="{Binding EnablePenguin}" />
        <CheckBox Content="{Binding RootTexts[Settings.Game.EnableYituliu]}" IsChecked="{Binding EnableYituliu}" />
      </StackPanel>
      <StackPanel Classes="settings-centered-column"
                  Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
                  IsVisible="{Binding ShowPenguinIdField}">
        <TextBlock Classes="settings-field-caption" Text="{Binding RootTexts[Settings.Game.PenguinId]}" />
        <TextBox Width="{DynamicResource MAA.Size.Settings.FieldInputWidth}"
                 Text="{Binding PenguinId, UpdateSourceTrigger=LostFocus}" />
      </StackPanel>
    </StackPanel>

    <Grid Grid.Row="8"
          Classes="settings-form"
          Margin="{DynamicResource MAA.Thickness.Settings.RowMargin}"
          ColumnDefinitions="250,250">
      <StackPanel Grid.Column="0" Classes="settings-centered-column">
        <TextBlock Classes="settings-field-caption" Text="{Binding RootTexts[Settings.Game.TaskTimeoutMinutes]}" />
        <controls:VerticalSpinNumberBox Width="{DynamicResource MAA.Size.Settings.FieldNarrowWidth}"
                                        Minimum="0"
                                        Maximum="1440"
                                        Value="{Binding TaskTimeoutMinutes}" />
      </StackPanel>

      <StackPanel Grid.Column="1" Classes="settings-centered-column">
        <TextBlock Classes="settings-field-caption" Text="{Binding RootTexts[Settings.Game.ReminderIntervalMinutes]}" />
        <controls:VerticalSpinNumberBox Width="{DynamicResource MAA.Size.Settings.FieldNarrowWidth}"
                                        Minimum="1"
                                        Maximum="1440"
                                        Value="{Binding ReminderIntervalMinutes}" />
      </StackPanel>
    </Grid>
  </Grid>
</UserControl>
