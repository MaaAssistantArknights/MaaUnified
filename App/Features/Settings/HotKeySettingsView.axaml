<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="MAAUnified.App.Features.Settings.HotKeySettingsView">
  <UserControl.Styles>
    <Style Selector="Border.hotkey-settings-block">
      <Setter Property="Padding" Value="22" />
    </Style>

    <Style Selector="Border.hotkey-settings-section">
      <Setter Property="Margin" Value="0,14,0,0" />
    </Style>

    <Style Selector="Border.hotkey-settings-card">
      <Setter Property="Padding" Value="18" />
    </Style>

    <Style Selector="StackPanel.hotkey-settings-stack">
      <Setter Property="Spacing" Value="14" />
    </Style>

    <Style Selector="StackPanel.hotkey-settings-card-content">
      <Setter Property="Spacing" Value="12" />
    </Style>

    <Style Selector="TextBlock.hotkey-settings-card-title">
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style Selector="StackPanel.hotkey-settings-actions">
      <Setter Property="Orientation" Value="Horizontal" />
      <Setter Property="Spacing" Value="10" />
    </Style>

    <Style Selector="StackPanel.hotkey-settings-status-list">
      <Setter Property="Spacing" Value="8" />
    </Style>
  </UserControl.Styles>

  <Grid Margin="4"
        Classes="settings-form"
        RowDefinitions="Auto,Auto,Auto,Auto">
    <Border Classes="app-surface app-section hotkey-settings-block">
      <StackPanel Classes="hotkey-settings-stack">
        <TextBlock Classes="app-window-title"
                   Text="{Binding RootTexts[Settings.Section.HotKey]}" />
        <TextBlock Classes="app-window-subtitle"
                   Text="{Binding HotkeyCaptureGuideText}"
                   TextWrapping="Wrap" />
      </StackPanel>
    </Border>

    <Border Grid.Row="1"
            Classes="app-surface app-section hotkey-settings-block hotkey-settings-section">
      <StackPanel Classes="hotkey-settings-stack">
        <Border Classes="app-surface app-card hotkey-settings-card">
          <StackPanel Classes="hotkey-settings-card-content">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Classes="app-body hotkey-settings-card-title"
                         Text="{Binding ShowGuiHotkeyState.Title}" />
              <TextBlock Grid.Column="1"
                         Margin="12,0,0,0"
                         VerticalAlignment="Center"
                         Classes="app-caption"
                         Text="{Binding ShowGuiHotkeyState.ScopeLabel}" />
            </Grid>

            <TextBox x:Name="ShowGuiCaptureBox"
                     Classes="app-input"
                     IsReadOnly="True"
                     Tag="ShowGui"
                     Text="{Binding ShowGuiHotkeyState.InputText}"
                     KeyDown="OnHotkeyCaptureKeyDown" />

            <StackPanel Classes="hotkey-settings-actions">
              <Button Classes="app-button app-secondary"
                      Tag="ShowGui"
                      Content="{Binding ShowGuiHotkeyState.CaptureButtonText}"
                      Click="OnBeginCaptureClick" />
              <Button Classes="app-button app-secondary"
                      Tag="ShowGui"
                      Content="{Binding ShowGuiHotkeyState.ClearButtonText}"
                      Click="OnClearHotkeyClick" />
            </StackPanel>

            <TextBlock Classes="state-warning app-caption"
                       IsVisible="{Binding ShowGuiHotkeyState.HasWarningMessage}"
                       Text="{Binding ShowGuiHotkeyState.WarningMessage}"
                       TextWrapping="Wrap" />
            <TextBlock Classes="state-error app-caption"
                       IsVisible="{Binding ShowGuiHotkeyState.HasErrorMessage}"
                       Text="{Binding ShowGuiHotkeyState.ErrorMessage}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Classes="app-surface app-card hotkey-settings-card">
          <StackPanel Classes="hotkey-settings-card-content">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Classes="app-body hotkey-settings-card-title"
                         Text="{Binding LinkStartHotkeyState.Title}" />
              <TextBlock Grid.Column="1"
                         Margin="12,0,0,0"
                         VerticalAlignment="Center"
                         Classes="app-caption"
                         Text="{Binding LinkStartHotkeyState.ScopeLabel}" />
            </Grid>

            <TextBox x:Name="LinkStartCaptureBox"
                     Classes="app-input"
                     IsReadOnly="True"
                     Tag="LinkStart"
                     Text="{Binding LinkStartHotkeyState.InputText}"
                     KeyDown="OnHotkeyCaptureKeyDown" />

            <StackPanel Classes="hotkey-settings-actions">
              <Button Classes="app-button app-secondary"
                      Tag="LinkStart"
                      Content="{Binding LinkStartHotkeyState.CaptureButtonText}"
                      Click="OnBeginCaptureClick" />
              <Button Classes="app-button app-secondary"
                      Tag="LinkStart"
                      Content="{Binding LinkStartHotkeyState.ClearButtonText}"
                      Click="OnClearHotkeyClick" />
            </StackPanel>

            <TextBlock Classes="state-warning app-caption"
                       IsVisible="{Binding LinkStartHotkeyState.HasWarningMessage}"
                       Text="{Binding LinkStartHotkeyState.WarningMessage}"
                       TextWrapping="Wrap" />
            <TextBlock Classes="state-error app-caption"
                       IsVisible="{Binding LinkStartHotkeyState.HasErrorMessage}"
                       Text="{Binding LinkStartHotkeyState.ErrorMessage}"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </StackPanel>
    </Border>

    <Border Grid.Row="2"
            Classes="app-surface app-section hotkey-settings-block hotkey-settings-section">
      <StackPanel HorizontalAlignment="Center">
        <Button Classes="app-button app-primary"
                Content="{Binding RootTexts[Settings.Action.RegisterHotkeys]}"
                Click="OnApplyHotkeysClick" />
      </StackPanel>
    </Border>

    <Border Grid.Row="3"
            Classes="app-surface app-section hotkey-settings-block hotkey-settings-section">
      <StackPanel Classes="hotkey-settings-status-list">
        <TextBlock Classes="app-body"
                   Text="{Binding HotkeyStatusMessage}"
                   TextWrapping="Wrap" />
        <TextBlock Classes="state-warning app-caption"
                   Text="{Binding HotkeyWarningMessage}"
                   TextWrapping="Wrap"
                   IsVisible="{Binding HasHotkeyWarningMessage}" />
        <TextBlock Classes="state-error app-caption"
                   Text="{Binding HotkeyErrorMessage}"
                   TextWrapping="Wrap"
                   IsVisible="{Binding HasHotkeyErrorMessage}" />
      </StackPanel>
    </Border>
  </Grid>
</UserControl>
