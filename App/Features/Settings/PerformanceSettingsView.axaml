<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             xmlns:vm="clr-namespace:MAAUnified.App.ViewModels.Settings"
             Classes="settings-page"
             x:Class="MAAUnified.App.Features.Settings.PerformanceSettingsView">
  <Grid Margin="4"
        RowDefinitions="Auto,Auto">
    <TextBlock Classes="settings-page-title"
               Text="{Binding RootTexts[Settings.Section.Performance]}" />

    <controls:AdaptiveSpacingStackPanel Grid.Row="1"
                Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}"
                Classes="settings-page-flow">
      <Grid Classes="settings-page-labeled-row"
            ColumnDefinitions="132,*">
        <TextBlock Classes="settings-label"
                   TextWrapping="Wrap">
          <Run Text="{Binding RootTexts[Settings.Performance.Gpu.Select]}" />
          <Run Text="&#160;" />
          <InlineUIContainer BaselineAlignment="Center">
            <controls:TooltipHint Tip="{DynamicResource UseGpuForInferenceTip}" />
          </InlineUIContainer>
        </TextBlock>
        <ComboBox Grid.Column="1"
                  Classes="settings-select"
                  Width="{DynamicResource MAA.Size.Settings.FieldPathWidth}"
                  HorizontalAlignment="Left"
                  ItemsSource="{Binding AvailableGpuOptions}"
                  SelectedValueBinding="{Binding Descriptor.Id}"
                  SelectedValue="{Binding SelectedGpuOptionId}"
                  IsEnabled="{Binding IsGpuSelectionEnabled}">
          <ComboBox.ItemTemplate>
            <DataTemplate x:DataType="vm:GpuOptionDisplayItem">
              <TextBlock Text="{Binding Display}" />
            </DataTemplate>
          </ComboBox.ItemTemplate>
        </ComboBox>
      </Grid>

      <controls:AdaptiveSpacingStackPanel Classes="settings-page-branch-block settings-page-compact-flow"
                  IsVisible="{Binding IsGpuCustomSelectionFieldsVisible}">
        <Grid Classes="settings-page-labeled-row"
              ColumnDefinitions="132,*">
          <TextBlock Classes="settings-label"
                     Text="{Binding RootTexts[Settings.Performance.Gpu.CustomDescription]}" />
          <TextBox Grid.Column="1"
                   Classes="settings-input"
                   Width="{DynamicResource MAA.Size.Settings.FieldPathWidth}"
                   HorizontalAlignment="Left"
                   Text="{Binding GpuCustomDescription, UpdateSourceTrigger=LostFocus}"
                   IsEnabled="{Binding IsGpuSelectionEnabled}" />
        </Grid>

        <Grid Classes="settings-page-labeled-row"
              ColumnDefinitions="132,*">
          <TextBlock Classes="settings-label"
                     Text="{Binding RootTexts[Settings.Performance.Gpu.CustomInstancePath]}" />
          <TextBox Grid.Column="1"
                   Classes="settings-input"
                   Width="{DynamicResource MAA.Size.Settings.FieldPathWidth}"
                   HorizontalAlignment="Left"
                   Text="{Binding GpuCustomInstancePath, UpdateSourceTrigger=LostFocus}"
                   IsEnabled="{Binding IsGpuSelectionEnabled}" />
        </Grid>
      </controls:AdaptiveSpacingStackPanel>

      <Border Classes="settings-page-status-block">
        <controls:AdaptiveSpacingStackPanel Classes="settings-page-status-list">
          <TextBlock Classes="app-body"
                     Text="{Binding GpuSupportMessage}"
                     IsVisible="{Binding HasGpuSupportMessage}" />
          <TextBlock Classes="app-body"
                     Text="{Binding RootTexts[Settings.Performance.Gpu.RestartRequired]}"
                     IsVisible="{Binding ShowGpuRestartRequiredHint}" />
          <TextBlock Classes="state-warning"
                     Text="{Binding GpuWarningMessage}"
                     IsVisible="{Binding HasGpuWarningMessage}" />
          <TextBlock Classes="state-warning"
                     Text="{Binding StartPerformanceValidationMessage}"
                     IsVisible="{Binding HasStartPerformanceValidationMessage}" />
        </controls:AdaptiveSpacingStackPanel>
      </Border>
    </controls:AdaptiveSpacingStackPanel>
  </Grid>
</UserControl>
