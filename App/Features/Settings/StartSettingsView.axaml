<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             Classes="settings-page"
             x:Class="MAAUnified.App.Features.Settings.StartSettingsView">
  <UserControl.Styles>
    <Style Selector="StackPanel.start-settings-stack">
      <Setter Property="Spacing" Value="14" />
    </Style>

    <Style Selector="StackPanel.start-settings-note-pair">
      <Setter Property="Spacing" Value="0" />
    </Style>

    <Style Selector="TextBlock.start-settings-note">
      <Setter Property="Margin" Value="28,-3,0,0" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Action.DisabledForeground}" />
    </Style>

    <Style Selector="controls|AdaptiveSpacingStackPanel.start-settings-toggle-stack">
      <Setter Property="AfterSupplementaryTextGap" Value="-2" />
    </Style>
  </UserControl.Styles>

  <Grid Margin="4"
        RowDefinitions="Auto,*">
    <TextBlock Classes="settings-page-title"
               Text="{Binding RootTexts[Settings.Section.Start]}" />

    <controls:AdaptiveSpacingStackPanel Grid.Row="1"
                Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}"
                HorizontalAlignment="Left"
                Classes="settings-page-flow">
      <Grid Classes="settings-page-two-column"
            HorizontalAlignment="Left"
            ColumnDefinitions="Auto,24,Auto">
        <controls:AdaptiveSpacingStackPanel Classes="start-settings-stack start-settings-toggle-stack settings-page-column-stack settings-page-toggle-stack">
          <controls:AdaptiveSpacingStackPanel Classes="settings-page-inline-field-group">
            <controls:AppHintedCheckBox Text="{Binding RootTexts[Settings.Start.AutoStartMaa]}"
                                         Tip="{Binding RootTexts[Settings.Start.AutoStartMaaTip]}"
                                         IsChecked="{Binding StartSelf}" />
          </controls:AdaptiveSpacingStackPanel>

          <StackPanel Classes="start-settings-note-pair">
            <CheckBox Classes="app-checkbox"
                      Content="{Binding RootTexts[Settings.Start.MinimizeDirectly]}"
                      IsChecked="{Binding MinimizeDirectly}" />
            <TextBlock Classes="app-caption settings-note start-settings-note"
                       Text="{Binding RootTexts[Settings.Start.ApplyOnNextLaunch]}" />
          </StackPanel>

          <StackPanel Classes="start-settings-note-pair">
            <CheckBox Classes="app-checkbox"
                      Content="{Binding RootTexts[Settings.Start.RunDirectly]}"
                      IsChecked="{Binding RunDirectly}" />
            <TextBlock Classes="app-caption settings-note start-settings-note"
                       Text="{Binding RootTexts[Settings.Start.ApplyOnNextLaunch]}" />
          </StackPanel>

          <StackPanel Classes="start-settings-note-pair">
            <CheckBox Classes="app-checkbox"
                      Content="{Binding RootTexts[Settings.Start.AutoOpenEmulator]}"
                      IsChecked="{Binding OpenEmulatorAfterLaunch}" />
            <TextBlock Classes="app-caption settings-note start-settings-note"
                       Text="{Binding RootTexts[Settings.Start.ApplyOnNextExecution]}" />
          </StackPanel>

          <controls:AdaptiveSpacingStackPanel Classes="settings-page-inline-field-group">
            <controls:AppHintedCheckBox Text="{Binding RootTexts[Settings.Start.RetryOnDisconnected]}"
                                         Tip="{Binding RootTexts[Settings.Start.RetryOnDisconnectedTip]}"
                                         IsChecked="{Binding ConnectionGameSharedState.RetryOnDisconnected}" />
          </controls:AdaptiveSpacingStackPanel>
        </controls:AdaptiveSpacingStackPanel>

        <controls:AdaptiveSpacingStackPanel Grid.Column="2"
                    Classes="start-settings-stack settings-page-column-stack"
                    IsVisible="{Binding CanEditEmulatorLaunchSettings}">
          <Grid Classes="settings-page-labeled-action-row"
                controls:SettingsLabelWidthCoordinator.GroupKey="Start.Emulator"
                ColumnDefinitions="Auto,*">
            <controls:SettingsLabel Text="{Binding RootTexts[Settings.Start.EmulatorPath]}"
                                    Tip="{Binding RootTexts[Settings.Start.EmulatorPathTip]}" />
            <controls:AppActionInput Grid.Column="1"
                                     Width="{DynamicResource MAA.Size.Settings.FieldPathWideWidth}"
                                     HorizontalAlignment="Left"
                                     Text="{Binding EmulatorPath, UpdateSourceTrigger=LostFocus}"
                                     ActionContent="{Binding RootTexts[Settings.Start.SelectButton]}"
                                     ActionClick="OnSelectEmulatorPathClick" />
          </Grid>

          <Grid Classes="settings-page-labeled-row"
                controls:SettingsLabelWidthCoordinator.GroupKey="Start.Emulator"
                ColumnDefinitions="Auto,*">
            <controls:SettingsLabel Text="{Binding RootTexts[Settings.Start.EmulatorExtraArgs]}"
                                    Tip="{Binding RootTexts[Settings.Start.EmulatorExtraArgsTip]}" />
            <TextBox Grid.Column="1"
                     Classes="settings-input"
                     IsEnabled="{Binding CanEditEmulatorLaunchSettings}"
                     Text="{Binding EmulatorAddCommand, UpdateSourceTrigger=LostFocus}" />
          </Grid>

          <Grid Classes="settings-page-labeled-row"
                controls:SettingsLabelWidthCoordinator.GroupKey="Start.Emulator"
                ColumnDefinitions="Auto,*">
            <controls:SettingsLabel Text="{Binding RootTexts[Settings.Start.EmulatorWaitSeconds]}" />
            <controls:AdaptiveSpacingStackPanel Grid.Column="1"
                        Spacing="6">
              <controls:AppNumberInput
                                              Width="80"
                                              Minimum="0"
                                              Maximum="600"
                                              Value="{Binding EmulatorWaitSeconds}" />
              <TextBlock Classes="app-caption"
                         Text="{Binding RootTexts[Settings.Start.EmulatorWaitSecondsNote]}" />
            </controls:AdaptiveSpacingStackPanel>
          </Grid>
        </controls:AdaptiveSpacingStackPanel>
      </Grid>

      <Border Classes="settings-page-status-block">
        <controls:AdaptiveSpacingStackPanel Classes="settings-page-status-list"
                    MaxWidth="{DynamicResource MAA.Size.Settings.FormMaxWidth}">
          <TextBlock Classes="state-warning"
                     Text="{Binding StartPerformanceValidationMessage}"
                     IsVisible="{Binding HasStartPerformanceValidationMessage}" />
          <TextBlock Classes="state-warning"
                     Text="{Binding AutostartWarningMessage}"
                     IsVisible="{Binding HasAutostartWarningMessage}" />
        </controls:AdaptiveSpacingStackPanel>
      </Border>
    </controls:AdaptiveSpacingStackPanel>
  </Grid>
</UserControl>
