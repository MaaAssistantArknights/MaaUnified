<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:MAAUnified.App.Controls"
             xmlns:vm="clr-namespace:MAAUnified.App.ViewModels.Settings"
             Classes="settings-page"
             x:Class="MAAUnified.App.Features.Settings.GuiSettingsView">
  <UserControl.Styles>
    <Style Selector="Grid.gui-settings-preview-row controls|SettingsLabel">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="Margin" Value="0,0,8,0" />
    </Style>

    <Style Selector="Grid.gui-settings-preview-row controls|SettingsLabel Grid">
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style Selector="Grid.gui-settings-preview-row controls|SettingsLabel TextBlock.settings-label-text">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Muted}" />
      <Setter Property="LineHeight" Value="18" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
      <Setter Property="TextAlignment" Value="Right" />
      <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>

    <Style Selector="Grid.gui-settings-preview-row > TextBlock.gui-settings-preview-text">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Muted}" />
      <Setter Property="LineHeight" Value="18" />
    </Style>
  </UserControl.Styles>

  <Grid Margin="4"
        RowDefinitions="Auto,Auto">
    <TextBlock Classes="settings-page-title"
               Text="{Binding RootTexts[Settings.Section.GUI]}" />

    <controls:AdaptiveSpacingStackPanel Grid.Row="1"
                Margin="{DynamicResource MAA.Thickness.Settings.SectionTopMargin}"
                HorizontalAlignment="Left"
                Classes="settings-page-flow">
      <Grid Classes="settings-page-two-column"
            HorizontalAlignment="Left"
            ColumnDefinitions="Auto,24,Auto">
        <controls:AdaptiveSpacingStackPanel Classes="settings-page-column-stack settings-page-toggle-stack">
          <CheckBox Classes="app-checkbox"
                    Content="{Binding RootTexts[Settings.GUI.UseTray]}"
                    IsChecked="{Binding UseTray}" />
          <CheckBox Classes="app-checkbox"
                    Content="{Binding RootTexts[Settings.GUI.MinimizeToTray]}"
                    IsChecked="{Binding MinimizeToTray}"
                    IsVisible="{Binding CanMinimizeToTray}" />
          <controls:AdaptiveSpacingStackPanel Classes="settings-page-inline-field-group">
            <controls:AppHintedCheckBox Text="{Binding RootTexts[Settings.GUI.UseNotify]}"
                                         Tip="{DynamicResource SystemNotificationInfo}"
                                         IsChecked="{Binding UseNotify}" />
          </controls:AdaptiveSpacingStackPanel>
          <CheckBox Classes="app-checkbox"
                    Content="{Binding RootTexts[Settings.GUI.WindowTitleScrollable]}"
                    IsChecked="{Binding WindowTitleScrollable}" />
          <controls:AdaptiveSpacingStackPanel Classes="settings-page-inline-field-group">
            <controls:AppHintedCheckBox Text="{Binding RootTexts[Settings.GUI.UseSoftwareRendering]}"
                                         Tip="{DynamicResource BadModules.UseSoftwareRenderingTip}"
                                         IsChecked="{Binding UseSoftwareRendering}" />
          </controls:AdaptiveSpacingStackPanel>

          <controls:AdaptiveSpacingStackPanel Classes="settings-page-column-stack settings-page-meta-block">
            <Grid Classes="settings-page-labeled-row"
                  controls:SettingsLabelWidthCoordinator.GroupKey="Gui.Log"
                  ColumnDefinitions="Auto,*">
              <controls:SettingsLabel Text="{Binding RootTexts[Settings.GUI.LogItemDateFormat]}" />
              <controls:AppSelect Grid.Column="1"
                        Classes="settings-select"
                        Width="{DynamicResource MAA.Size.Settings.FieldCenteredWidth}"
                        HorizontalAlignment="Left"
                        ItemsSource="{Binding LogItemDateFormatOptions}"
                        SelectedValue="{Binding LogItemDateFormatString}" />
            </Grid>

            <Grid Classes="settings-page-labeled-row gui-settings-preview-row"
                  controls:SettingsLabelWidthCoordinator.GroupKey="Gui.Log"
                  ColumnDefinitions="Auto,*">
              <controls:SettingsLabel Text="{Binding RootTexts[Settings.GUI.LogItemDateFormat.PreviewCaption]}" />
              <TextBlock Grid.Column="1"
                         Classes="app-caption gui-settings-preview-text"
                         Text="{Binding GuiLogItemDateFormatPreview}"
                         TextWrapping="Wrap" />
            </Grid>
          </controls:AdaptiveSpacingStackPanel>
        </controls:AdaptiveSpacingStackPanel>

        <controls:AdaptiveSpacingStackPanel Grid.Column="2"
                    Classes="settings-page-column-stack">
          <Grid Classes="settings-page-labeled-row"
                controls:SettingsLabelWidthCoordinator.GroupKey="Gui.Main"
                ColumnDefinitions="Auto,*">
            <controls:SettingsLabel Text="{Binding RootTexts[Settings.GUI.Language]}" />
            <controls:AppSelect Grid.Column="1"
                      Classes="settings-select"
                      Width="{DynamicResource MAA.Size.Settings.FieldNarrowWidth}"
                      HorizontalAlignment="Left"
                      ItemsSource="{Binding SupportedLanguages}"
                      SelectedItem="{Binding SelectedLanguageOption, Mode=TwoWay}">
              <controls:AppSelect.ItemTemplate>
                <DataTemplate x:DataType="vm:DisplayValueOption">
                  <TextBlock Text="{Binding Display}" />
                </DataTemplate>
              </controls:AppSelect.ItemTemplate>
            </controls:AppSelect>
          </Grid>

          <Grid Classes="settings-page-labeled-row"
                controls:SettingsLabelWidthCoordinator.GroupKey="Gui.Main"
                ColumnDefinitions="Auto,*">
            <controls:SettingsLabel Text="{Binding RootTexts[Settings.GUI.OperNameLanguage]}" />
            <controls:AppSelect Grid.Column="1"
                      Classes="settings-select"
                      Width="{DynamicResource MAA.Size.Settings.FieldCenteredWidth}"
                      HorizontalAlignment="Left"
                      ItemsSource="{Binding OperNameLanguageOptions}"
                      SelectedItem="{Binding SelectedOperNameLanguageOption, Mode=TwoWay}">
              <controls:AppSelect.ItemTemplate>
                <DataTemplate x:DataType="vm:DisplayValueOption">
                  <TextBlock Text="{Binding Display}" />
                </DataTemplate>
              </controls:AppSelect.ItemTemplate>
            </controls:AppSelect>
          </Grid>

          <Grid Classes="settings-page-labeled-row"
                controls:SettingsLabelWidthCoordinator.GroupKey="Gui.Main"
                ColumnDefinitions="Auto,*">
            <controls:SettingsLabel Text="{Binding RootTexts[Settings.GUI.Theme]}" />
            <controls:AppSelect Grid.Column="1"
                      Classes="settings-select"
                      Width="{DynamicResource MAA.Size.Settings.FieldNarrowWidth}"
                      HorizontalAlignment="Left"
                      ItemsSource="{Binding ThemeOptions}"
                      SelectedItem="{Binding SelectedThemeOption, Mode=TwoWay}">
              <controls:AppSelect.ItemTemplate>
                <DataTemplate x:DataType="vm:DisplayValueOption">
                  <TextBlock Text="{Binding Display}" />
                </DataTemplate>
              </controls:AppSelect.ItemTemplate>
            </controls:AppSelect>
          </Grid>

          <Grid Classes="settings-page-labeled-row"
                controls:SettingsLabelWidthCoordinator.GroupKey="Gui.Main"
                ColumnDefinitions="Auto,*">
            <controls:SettingsLabel Text="{Binding RootTexts[Settings.GUI.UiScalePercent]}"
                                    Tip="{Binding RootTexts[Settings.GUI.UiScalePercentTip]}" />
            <controls:AppNumberInput Grid.Column="1"
                                     Width="{DynamicResource MAA.Size.Settings.FieldNarrowWidth}"
                                     HorizontalAlignment="Left"
                                     Minimum="70"
                                     Maximum="140"
                                     CommitValueOnLostFocus="True"
                                     Value="{Binding UiScalePercent}" />
          </Grid>

          <Grid Classes="settings-page-labeled-row"
                controls:SettingsLabelWidthCoordinator.GroupKey="Gui.Main"
                ColumnDefinitions="Auto,*">
            <controls:SettingsLabel Text="{Binding RootTexts[Settings.GUI.InverseClearMode]}" />
            <controls:AppSelect Grid.Column="1"
                      Classes="settings-select"
                      Width="{DynamicResource MAA.Size.Settings.FieldCenteredWidth}"
                      HorizontalAlignment="Left"
                      ItemsSource="{Binding InverseClearModeOptions}"
                      SelectedItem="{Binding SelectedInverseClearModeOption, Mode=TwoWay}">
              <controls:AppSelect.ItemTemplate>
                <DataTemplate x:DataType="vm:DisplayValueOption">
                  <TextBlock Text="{Binding Display}" />
                </DataTemplate>
              </controls:AppSelect.ItemTemplate>
            </controls:AppSelect>
          </Grid>
        </controls:AdaptiveSpacingStackPanel>
      </Grid>

      <Border Classes="settings-page-status-block">
        <controls:AdaptiveSpacingStackPanel Classes="settings-page-status-list">
          <TextBlock Classes="state-warning app-body"
                     Text="{Binding GuiSectionValidationMessage}"
                     IsVisible="{Binding HasGuiSectionValidationMessage}"
                     TextWrapping="Wrap" />
        </controls:AdaptiveSpacingStackPanel>
      </Border>
    </controls:AdaptiveSpacingStackPanel>
  </Grid>
</UserControl>
