<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MAAUnified.App.Controls">
  <Styles.Resources>
    <Thickness x:Key="MAA.App.SelectionList.ShellPadding">14</Thickness>
    <Thickness x:Key="MAA.App.SelectionList.RailPadding">22,0,22,0</Thickness>
    <Thickness x:Key="MAA.App.SelectionList.RailShellPadding">0,9,0,9</Thickness>
    <Thickness x:Key="MAA.App.SelectionList.RailShellTrailingAccessoryPadding">0,9,15,9</Thickness>
    <Thickness x:Key="MAA.App.SelectionList.SurfaceShellPadding">14</Thickness>
    <Thickness x:Key="MAA.App.SelectionList.NoneShellPadding">14</Thickness>
  </Styles.Resources>

  <Style Selector="controls|AppSelectionList">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
    <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}"
                ClipToBounds="True">
          <Grid ClipToBounds="True">
            <ScrollViewer x:Name="PART_ScrollViewer"
                          Padding="{TemplateBinding Padding}"
                          HorizontalScrollBarVisibility="{Binding (ScrollViewer.HorizontalScrollBarVisibility), RelativeSource={RelativeSource TemplatedParent}}"
                          VerticalScrollBarVisibility="{Binding (ScrollViewer.VerticalScrollBarVisibility), RelativeSource={RelativeSource TemplatedParent}}">
              <ItemsPresenter ItemsPanel="{TemplateBinding ItemsPanel}" />
            </ScrollViewer>

            <Border x:Name="PART_AccentHost"
                    Width="18"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    ClipToBounds="True"
                    IsHitTestVisible="False"
                    IsVisible="False">
              <Grid>
                <Border x:Name="PART_FollowAccentGlow"
                        Classes="app-selection-list-follow-accent-glow"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        IsVisible="False" />
                <Border x:Name="PART_FollowAccent"
                        Classes="app-selection-list-follow-accent"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"
                        IsVisible="False" />
              </Grid>
            </Border>
          </Grid>
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="controls|AppSelectionList.selection-list-rail /template/ Border#PART_AccentHost">
    <Setter Property="Width" Value="22" />
    <Setter Property="IsVisible" Value="True" />
  </Style>

  <Style Selector="controls|AppSelectionList ListBoxItem">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    <Setter Property="VerticalContentAlignment" Value="Stretch" />
    <Setter Property="Focusable" Value="False" />
    <Setter Property="FocusAdorner" Value="{x:Null}" />
    <Setter Property="Template">
      <ControlTemplate>
        <ContentPresenter x:Name="PART_ContentPresenter"
                          Background="Transparent"
                          BorderBrush="Transparent"
                          BorderThickness="0"
                          HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                          VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                          Content="{TemplateBinding Content}"
                          ContentTemplate="{TemplateBinding ContentTemplate}" />
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="controls|AppSelectionList ListBoxItem:pointerover">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="controls|AppSelectionList ListBoxItem:selected">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="controls|AppSelectionList ListBoxItem:selected:pointerover">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="controls|AppSelectionList ListBoxItem:pressed">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="controls|AppSelectionList ListBoxItem:selected:pressed">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="controls|AppSelectionList ListBoxItem:focus">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="controls|AppSelectionList ListBoxItem:focus-visible">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="controls|AppSelectionList ListBoxItem /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="controls|AppSelectionList ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="controls|AppSelectionList ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="controls|AppSelectionList ListBoxItem:selected:pointerover /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="controls|AppSelectionList ListBoxItem:selected:pressed /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="controls|AppSelectionList ListBoxItem:focus /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="controls|AppSelectionList ListBoxItem:focus-visible /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="controls|AppSelectionList /template/ ScrollViewer#PART_ScrollViewer">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Border.app-selection-list-item-shell">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Surface.Card}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Border.Card}" />
    <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
    <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.Card}" />
    <Setter Property="Padding" Value="{DynamicResource MAA.App.SelectionList.ShellPadding}" />
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background"
                         Duration="0:0:0.18" />
        <BrushTransition Property="BorderBrush"
                         Duration="0:0:0.18" />
      </Transitions>
    </Setter>
  </Style>

  <Style Selector="controls|AppSelectionList.selection-list-rail ListBoxItem">
    <Setter Property="Margin" Value="0,0,0,6" />
  </Style>

  <Style Selector="controls|AppSelectionList.selection-list-rail">
    <Setter Property="Padding" Value="{DynamicResource MAA.App.SelectionList.RailPadding}" />
  </Style>

  <Style Selector="controls|AppSelectionList.selection-list-rail Border.app-selection-list-item-shell">
    <Setter Property="Background" Value="#00FFFFFF" />
    <Setter Property="BorderBrush" Value="#00FFFFFF" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="{DynamicResource MAA.App.SelectionList.RailShellPadding}" />
    <Setter Property="MinHeight" Value="46" />
    <Setter Property="CornerRadius" Value="20" />
  </Style>

  <Style Selector="controls|AppSelectionList.selection-list-rail.selection-list-rail-trailing-accessory-space Border.app-selection-list-item-shell">
    <Setter Property="Padding" Value="{DynamicResource MAA.App.SelectionList.RailShellTrailingAccessoryPadding}" />
  </Style>

  <Style Selector="controls|AppSelectionList.selection-list-surface ListBoxItem">
    <Setter Property="Margin" Value="0,0,0,10" />
  </Style>

  <Style Selector="controls|AppSelectionList.selection-list-surface Border.app-selection-list-item-shell">
    <Setter Property="Padding" Value="{DynamicResource MAA.App.SelectionList.SurfaceShellPadding}" />
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Surface.Card}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Border.Card}" />
  </Style>

  <Style Selector="controls|AppSelectionList.selection-list-none ListBoxItem">
    <Setter Property="Margin" Value="0,0,0,12" />
    <Setter Property="IsHitTestVisible" Value="False" />
  </Style>

  <Style Selector="controls|AppSelectionList.selection-list-none Border.app-selection-list-item-shell">
    <Setter Property="Padding" Value="{DynamicResource MAA.App.SelectionList.NoneShellPadding}" />
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Surface.Section}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Border.Section}" />
  </Style>

  <Style Selector="controls|AppSelectionList.selection-list-none ListBoxItem:pointerover Border.app-selection-list-item-shell">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Surface.Section}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Border.Section}" />
  </Style>

  <Style Selector="controls|AppSelectionList.selection-list-none ListBoxItem:selected Border.app-selection-list-item-shell">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Surface.Section}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Border.Section}" />
  </Style>

  <Style Selector="controls|AppSelectionList.selection-list-none ListBoxItem:selected:pointerover Border.app-selection-list-item-shell">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Surface.Section}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Border.Section}" />
  </Style>

  <Style Selector="Border.app-selection-list-follow-accent-glow">
    <Setter Property="Width" Value="14" />
    <Setter Property="Height" Value="24" />
    <Setter Property="Margin" Value="2,0,0,0" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="Opacity" Value="0.96" />
    <Setter Property="ZIndex" Value="1" />
    <Setter Property="Background">
      <LinearGradientBrush StartPoint="0,0"
                           EndPoint="0,1">
        <GradientStop Offset="0"
                      Color="#D883B3E6" />
        <GradientStop Offset="1"
                      Color="#1483B3E6" />
      </LinearGradientBrush>
    </Setter>
    <Setter Property="Transitions">
      <Transitions>
        <ThicknessTransition Property="Margin"
                             Duration="0:0:0.24" />
        <DoubleTransition Property="Height"
                          Duration="0:0:0.2" />
      </Transitions>
    </Setter>
  </Style>

  <Style Selector="Border.app-selection-list-follow-accent">
    <Setter Property="Width" Value="6" />
    <Setter Property="Height" Value="24" />
    <Setter Property="Margin" Value="6,0,0,0" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="ZIndex" Value="2" />
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Action.PrimaryBackground}" />
    <Setter Property="Transitions">
      <Transitions>
        <ThicknessTransition Property="Margin"
                             Duration="0:0:0.22" />
        <DoubleTransition Property="Height"
                          Duration="0:0:0.18" />
      </Transitions>
    </Setter>
  </Style>
</Styles>
