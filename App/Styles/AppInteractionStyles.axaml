<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:MAAUnified.App.Controls">
  <Styles.Resources>
    <Thickness x:Key="MAA.App.Interaction.FloatingCardPadding">16</Thickness>
    <Thickness x:Key="MAA.App.Interaction.ToastPadding">14,12</Thickness>
    <Thickness x:Key="MAA.App.Interaction.SplitButtonHostPadding">0</Thickness>
    <Thickness x:Key="MAA.App.Interaction.ListEditorPreviewPadding">12</Thickness>
    <Thickness x:Key="MAA.App.Interaction.SplitButtonPopupPadding">10</Thickness>
    <Thickness x:Key="MAA.App.Interaction.FloatingMenuPadding">6</Thickness>
    <Thickness x:Key="MAA.App.Interaction.FloatingMenuItemPadding">12,7</Thickness>
    <CornerRadius x:Key="MAA.App.Interaction.FloatingMenuCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="MAA.App.Interaction.FloatingMenuItemCornerRadius">5</CornerRadius>
    <x:Double x:Key="MAA.App.Interaction.ReorderButtonWidth">88</x:Double>
    <x:Double x:Key="MAA.App.Interaction.FloatingMenuMinWidth">148</x:Double>
    <x:Double x:Key="MAA.App.Interaction.FloatingMenuItemMinHeight">32</x:Double>
  </Styles.Resources>

  <Style Selector="Border.app-floating-card">
    <Setter Property="Padding" Value="{DynamicResource MAA.App.Interaction.FloatingCardPadding}" />
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Surface.Card}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Border.Card}" />
    <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
    <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.Card}" />
    <Setter Property="BoxShadow" Value="{DynamicResource MAA.App.BoxShadow.Card}" />
    <Setter Property="ClipToBounds" Value="False" />
  </Style>

  <Style Selector="Border.app-toast">
    <Setter Property="MinWidth" Value="240" />
    <Setter Property="MaxWidth" Value="420" />
    <Setter Property="Padding" Value="{DynamicResource MAA.App.Interaction.ToastPadding}" />
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Surface.Card}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Border.Card}" />
    <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
    <Setter Property="CornerRadius" Value="16" />
    <Setter Property="BoxShadow" Value="{DynamicResource MAA.App.BoxShadow.Card}" />
    <Setter Property="ClipToBounds" Value="False" />
  </Style>

  <Style Selector="Border.app-toast.status-warning">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Surface.Warning}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.State.Warning}" />
  </Style>

  <Style Selector="Grid.app-split-button-host">
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <Style Selector="Border.app-split-button-host">
    <Setter Property="Padding" Value="{DynamicResource MAA.App.Interaction.SplitButtonHostPadding}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.Button}" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <Style Selector="controls|ReorderableList">
    <Setter Property="MinWidth" Value="320" />
    <Setter Property="MinHeight" Value="180" />
  </Style>

  <Style Selector="controls|ReorderableList Border.app-reorderable-list-surface">
    <Setter Property="MinHeight" Value="152" />
  </Style>

  <Style Selector="controls|ReorderableList Button.reorder-button">
    <Setter Property="MinWidth" Value="{DynamicResource MAA.App.Interaction.ReorderButtonWidth}" />
  </Style>

  <Style Selector="controls|AppSplitButton">
    <Setter Property="MinWidth" Value="180" />
  </Style>

  <Style Selector="controls|AppSplitButton Button.app-split-button-trigger">
    <Setter Property="CornerRadius" Value="0" />
  </Style>

  <Style Selector="controls|AppSplitButton Button.app-split-button-primary">
    <Setter Property="HorizontalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="controls|AppSplitButton Button.app-split-button-secondary">
    <Setter Property="MinWidth" Value="40" />
    <Setter Property="Padding" Value="12,0" />
  </Style>

  <Style Selector="controls|AppSplitButton Border.app-split-button-popup">
    <Setter Property="Padding" Value="{DynamicResource MAA.App.Interaction.SplitButtonPopupPadding}" />
    <Setter Property="MinWidth" Value="180" />
  </Style>
</Styles>
