<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MAAUnified.App.Controls">
  <Styles.Resources>
    <Thickness x:Key="MAA.App.Settings.RailPadding">12,12,4,8</Thickness>
    <Thickness x:Key="MAA.App.Settings.RailItemPadding">0,9,0,9</Thickness>
    <Thickness x:Key="MAA.App.Settings.SectionIntroPadding">0,0,0,4</Thickness>
    <Thickness x:Key="MAA.App.Settings.ActionBarPadding">0</Thickness>
    <Thickness x:Key="MAA.App.Settings.StatusPanelPadding">0</Thickness>
    <Thickness x:Key="MAA.App.Settings.RowSpacing">0,8,0,0</Thickness>
    <Thickness x:Key="MAA.App.Settings.SubtleDividerMargin">0,2,0,2</Thickness>

    <x:Double x:Key="MAA.App.Settings.PageFlowSpacing">14</x:Double>
    <x:Double x:Key="MAA.App.Settings.PageCompactFlowSpacing">10</x:Double>
    <x:Double x:Key="MAA.App.Settings.PageColumnStackSpacing">16</x:Double>
    <x:Double x:Key="MAA.App.Settings.PageToggleStackSpacing">8</x:Double>
    <x:Double x:Key="MAA.App.Settings.PageMetaBlockSpacing">4</x:Double>
    <x:Double x:Key="MAA.App.Settings.SectionSpacing">16</x:Double>
    <x:Double x:Key="MAA.App.Settings.RailItemMinHeight">46</x:Double>
  </Styles.Resources>

  <Style Selector="Border.settings-rail">
    <Setter Property="Width" Value="{DynamicResource MAA.Size.Settings.SectionListWidth}" />
    <Setter Property="Padding" Value="{DynamicResource MAA.App.Settings.RailPadding}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="24" />
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="Background">
      <LinearGradientBrush StartPoint="0,0"
                           EndPoint="0,1">
        <GradientStop Offset="0"
                      Color="#FFF1F6FD" />
        <GradientStop Offset="1"
                      Color="#FFE7EEF9" />
      </LinearGradientBrush>
    </Setter>
  </Style>

  <Style Selector="controls|AppSelectionList.settings-rail">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="controls|AppSelectionList.settings-rail Border.settings-rail-item">
    <Setter Property="MinHeight" Value="{DynamicResource MAA.App.Settings.RailItemMinHeight}" />
    <Setter Property="Padding" Value="{DynamicResource MAA.App.Settings.RailItemPadding}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="18" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background" Duration="0:0:0.18" />
        <BrushTransition Property="BorderBrush" Duration="0:0:0.18" />
      </Transitions>
    </Setter>
  </Style>

  <Style Selector="TextBlock.settings-rail-item-text">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Secondary}" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="TextWrapping" Value="WrapWithOverflow" />
    <Setter Property="MaxLines" Value="2" />
    <Setter Property="LineHeight" Value="17" />
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Foreground" Duration="0:0:0.18" />
      </Transitions>
    </Setter>
  </Style>

  <Style Selector="controls|AppSelectionList.settings-rail ListBoxItem:pointerover Border.settings-rail-item">
    <Setter Property="Background" Value="#80E6EBF2" />
  </Style>

  <Style Selector="controls|AppSelectionList.settings-rail ListBoxItem:pointerover TextBlock.settings-rail-item-text">
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
  </Style>

  <Style Selector="controls|AppSelectionList.settings-rail ListBoxItem:selected Border.settings-rail-item">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="controls|AppSelectionList.settings-rail ListBoxItem:selected:pointerover Border.settings-rail-item">
    <Setter Property="Background" Value="#80E6EBF2" />
  </Style>

  <Style Selector="controls|AppSelectionList.settings-rail ListBoxItem:selected TextBlock.settings-rail-item-text">
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
  </Style>

  <Style Selector="controls|AppSelectionList.settings-rail:disabled TextBlock.settings-rail-item-text">
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Action.DisabledForeground}" />
  </Style>

  <Style Selector="StackPanel.settings-section-shell">
    <Setter Property="Spacing" Value="{DynamicResource MAA.App.Settings.SectionSpacing}" />
  </Style>

  <Style Selector="ScrollViewer.settings-content-scroll">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0,0,12,0" />
  </Style>

  <Style Selector="StackPanel.settings-content-panel">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Border.settings-section-anchor">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0" />
  </Style>

  <Style Selector="Border.settings-sticky-title">
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Border.settings-sticky-title-viewport">
    <Setter Property="Padding" Value="0" />
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="Grid.settings-sticky-title-track">
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="RenderTransform">
      <TranslateTransform Y="0" />
    </Setter>
    <Setter Property="Transitions">
      <Transitions>
        <TransformOperationsTransition Property="RenderTransform"
                                       Duration="0:0:0.22" />
      </Transitions>
    </Setter>
  </Style>

  <Style Selector="TextBlock.settings-sticky-title-text">
    <Setter Property="Margin" Value="0" />
    <Setter Property="Transitions">
      <Transitions>
        <ThicknessTransition Property="Margin"
                             Duration="0:0:0.16" />
        <TransformOperationsTransition Property="RenderTransform"
                                       Duration="0:0:0.18" />
      </Transitions>
    </Setter>
  </Style>

  <Style Selector="Border.settings-sticky-transition-shell">
    <Setter Property="ClipToBounds" Value="True" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="Padding" Value="0,6,0,4" />
    <Setter Property="Background" Value="#F7FFFFFF" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="RenderTransform">
      <TranslateTransform Y="0" />
    </Setter>
    <Setter Property="Transitions">
      <Transitions>
        <DoubleTransition Property="Height"
                          Duration="0:0:0.14" />
        <TransformOperationsTransition Property="RenderTransform"
                                       Duration="0:0:0.14" />
      </Transitions>
    </Setter>
  </Style>

  <Style Selector="TextBlock.settings-sticky-title-previous">
    <Setter Property="Opacity" Value="0.72" />
    <Setter Property="RenderTransform">
      <TranslateTransform Y="0" />
    </Setter>
  </Style>

  <Style Selector="Border.settings-sticky-title-current-shell">
    <Setter Property="Padding" Value="0,6,0,4" />
    <Setter Property="Background" Value="#F7FFFFFF" />
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>

  <Style Selector="UserControl.settings-page StackPanel.settings-page-flow">
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="Margin" Value="{DynamicResource MAA.Thickness.Settings.PageContentIndent}" />
    <Setter Property="MaxWidth" Value="{DynamicResource MAA.Size.Settings.FormMaxWidth}" />
    <Setter Property="Spacing" Value="{DynamicResource MAA.App.Settings.PageFlowSpacing}" />
  </Style>

  <Style Selector="UserControl.settings-page StackPanel.settings-page-compact-flow">
    <Setter Property="Spacing" Value="{DynamicResource MAA.App.Settings.PageCompactFlowSpacing}" />
  </Style>

  <Style Selector="UserControl.settings-page Grid.settings-page-two-column">
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="Margin" Value="{DynamicResource MAA.Thickness.Settings.PageContentIndent}" />
    <Setter Property="MaxWidth" Value="{DynamicResource MAA.Size.Settings.FormMaxWidth}" />
  </Style>

  <Style Selector="UserControl.settings-page Grid.settings-page-labeled-row">
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>

  <Style Selector="UserControl.settings-page Grid.settings-page-labeled-action-row">
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>

  <Style Selector="UserControl.settings-page Grid.settings-page-paired-row">
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>

  <Style Selector="UserControl.settings-page Grid.settings-page-action-pair">
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>

  <Style Selector="UserControl.settings-page StackPanel.settings-page-column-stack">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Top" />
    <Setter Property="Spacing" Value="{DynamicResource MAA.App.Settings.PageColumnStackSpacing}" />
  </Style>

  <Style Selector="UserControl.settings-page StackPanel.settings-page-branch-block">
    <Setter Property="Margin" Value="{DynamicResource MAA.Thickness.Settings.BranchIndent}" />
    <Setter Property="Spacing" Value="{DynamicResource MAA.App.Settings.PageCompactFlowSpacing}" />
  </Style>

  <Style Selector="UserControl.settings-page Grid.settings-page-branch-block">
    <Setter Property="Margin" Value="{DynamicResource MAA.Thickness.Settings.BranchIndent}" />
  </Style>

  <Style Selector="UserControl.settings-page Border.settings-page-branch-block">
    <Setter Property="Margin" Value="{DynamicResource MAA.Thickness.Settings.BranchIndent}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="UserControl.settings-page StackPanel.settings-page-toggle-stack">
    <Setter Property="Spacing" Value="{DynamicResource MAA.App.Settings.PageToggleStackSpacing}" />
  </Style>

  <Style Selector="UserControl.settings-page WrapPanel.settings-page-matrix">
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="Orientation" Value="Horizontal" />
    <Setter Property="ItemWidth" Value="{DynamicResource MAA.Size.Settings.WrapItemWidth}" />
  </Style>

  <Style Selector="UserControl.settings-page Grid.settings-page-matrix">
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="MaxWidth" Value="{DynamicResource MAA.Size.Settings.FormMaxWidth}" />
  </Style>

  <Style Selector="UserControl.settings-page StackPanel.settings-page-matrix">
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="MaxWidth" Value="{DynamicResource MAA.Size.Settings.FormMaxWidth}" />
    <Setter Property="Spacing" Value="12" />
  </Style>

  <Style Selector="UserControl.settings-page Border.settings-page-matrix-item">
    <Setter Property="MinWidth" Value="{DynamicResource MAA.Size.Settings.WrapItemWidth}" />
    <Setter Property="Margin" Value="0,0,12,12" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="UserControl.settings-page StackPanel.settings-page-matrix-item">
    <Setter Property="MinWidth" Value="{DynamicResource MAA.Size.Settings.WrapItemWidth}" />
    <Setter Property="Margin" Value="0,0,12,12" />
    <Setter Property="Spacing" Value="{DynamicResource MAA.App.Settings.PageToggleStackSpacing}" />
  </Style>

  <Style Selector="UserControl.settings-page Grid.settings-page-matrix-item">
    <Setter Property="MinWidth" Value="{DynamicResource MAA.Size.Settings.WrapItemWidth}" />
    <Setter Property="Margin" Value="0,0,12,12" />
  </Style>

  <Style Selector="UserControl.settings-page StackPanel.settings-page-meta-block">
    <Setter Property="MaxWidth" Value="{DynamicResource MAA.Size.Settings.ContentMaxWidth}" />
    <Setter Property="Spacing" Value="{DynamicResource MAA.App.Settings.PageMetaBlockSpacing}" />
  </Style>

  <Style Selector="UserControl.settings-page Border.settings-page-meta-block">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="UserControl.settings-page StackPanel.settings-page-status-list">
    <Setter Property="Spacing" Value="8" />
  </Style>

  <Style Selector="UserControl.settings-page Border.settings-page-status-block">
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
  </Style>

  <Style Selector="UserControl.settings-page Border.settings-page-subtle-divider">
    <Setter Property="Margin" Value="{DynamicResource MAA.App.Settings.SubtleDividerMargin}" />
    <Setter Property="Height" Value="1" />
    <Setter Property="Background" Value="#66D8E2ED" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="TextBlock.settings-root-intro">
    <Setter Property="Margin" Value="{DynamicResource MAA.App.Settings.SectionIntroPadding}" />
    <Setter Property="MaxWidth" Value="780" />
  </Style>

  <Style Selector="WrapPanel.settings-section-action-bar">
    <Setter Property="ItemHeight" Value="{DynamicResource MAA.App.Size.ButtonHeight}" />
    <Setter Property="Margin" Value="{DynamicResource MAA.App.Settings.ActionBarPadding}" />
    <Setter Property="Orientation" Value="Horizontal" />
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>

  <Style Selector="StackPanel.settings-section-actions">
    <Setter Property="Orientation" Value="Horizontal" />
    <Setter Property="Spacing" Value="10" />
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>

  <Style Selector="StackPanel.settings-section-action-bar">
    <Setter Property="Orientation" Value="Horizontal" />
    <Setter Property="Spacing" Value="10" />
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>

  <Style Selector="DockPanel.settings-section-actions">
    <Setter Property="LastChildFill" Value="False" />
  </Style>

  <Style Selector="DockPanel.settings-section-action-bar">
    <Setter Property="LastChildFill" Value="False" />
  </Style>

  <Style Selector="Border.settings-status-panel">
    <Setter Property="Padding" Value="{DynamicResource MAA.App.Settings.StatusPanelPadding}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
  </Style>

  <Style Selector="Border.settings-status-panel.status-warning">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="UserControl.settings-page Border.app-surface.app-section">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
  </Style>

  <Style Selector="UserControl.settings-page Border.app-surface.app-card">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
  </Style>

  <Style Selector="UserControl.settings-page Button">
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>

  <Style Selector="UserControl.settings-page TextBox.app-input">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.Background}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.Border}" />
    <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.SettingsInput}" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.Foreground}" />
    <Setter Property="Padding" Value="{DynamicResource MAA.App.Thickness.SettingsInputPadding}" />
    <Setter Property="Height" Value="{DynamicResource MAA.App.Size.InputHeight}" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="UserControl.settings-page TextBox.app-input:pointerover">
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.BorderHover}" />
  </Style>

  <Style Selector="UserControl.settings-page TextBox.app-input:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.BorderFocus}" />
  </Style>

  <Style Selector="UserControl.settings-page TextBox.app-input:focus-visible">
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.BorderFocus}" />
  </Style>

  <Style Selector="UserControl.settings-page TextBox.app-input:disabled">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.BackgroundDisabled}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Action.DisabledBorder}" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ForegroundDisabled}" />
  </Style>

  <Style Selector="ComboBox.app-input.settings-input, UserControl.settings-page ComboBox.app-input">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.Background}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.Border}" />
    <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.SettingsInput}" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.Foreground}" />
    <Setter Property="Padding" Value="{DynamicResource MAA.App.Thickness.SettingsInputPadding}" />
    <Setter Property="MaxDropDownHeight" Value="{DynamicResource MAA.App.Size.InputPopupMaxHeight}" />
  </Style>

  <Style Selector="ComboBox.app-input.settings-input:pointerover, UserControl.settings-page ComboBox.app-input:pointerover">
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.BorderHover}" />
  </Style>

  <Style Selector="ComboBox.app-input.settings-input:focus, UserControl.settings-page ComboBox.app-input:focus">
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.BorderFocus}" />
  </Style>

  <Style Selector="ComboBox.app-input.settings-input:focus-visible, UserControl.settings-page ComboBox.app-input:focus-visible">
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.BorderFocus}" />
  </Style>

  <Style Selector="ComboBox.app-input.settings-input:disabled, UserControl.settings-page ComboBox.app-input:disabled">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.BackgroundDisabled}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Action.DisabledBorder}" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ForegroundDisabled}" />
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="ComboBox.app-input.settings-input /template/ ContentPresenter#PART_ContentPresenter, UserControl.settings-page ComboBox.app-input /template/ ContentPresenter#PART_ContentPresenter">
    <Setter Property="Margin" Value="0" />
    <Setter Property="HorizontalAlignment" Value="Stretch" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.Foreground}" />
  </Style>

  <Style Selector="ComboBox.app-input.settings-input /template/ ToggleButton#PART_DropDownButton, UserControl.settings-page ComboBox.app-input /template/ ToggleButton#PART_DropDownButton">
    <Setter Property="Width" Value="{DynamicResource MAA.App.Size.SettingsInputDropDownButtonWidth}" />
    <Setter Property="MinWidth" Value="{DynamicResource MAA.App.Size.SettingsInputDropDownButtonWidth}" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="CornerRadius" Value="0,8,8,0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.Chevron}" />
  </Style>

  <Style Selector="ComboBox.app-input.settings-input /template/ Border#DropDownOverlay, UserControl.settings-page ComboBox.app-input /template/ Border#DropDownOverlay">
    <Setter Property="Width" Value="{DynamicResource MAA.App.Size.SettingsInputDropDownButtonWidth}" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="CornerRadius" Value="0,8,8,0" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="ComboBox.app-input.settings-input:pointerover /template/ ToggleButton#PART_DropDownButton, UserControl.settings-page ComboBox.app-input:pointerover /template/ ToggleButton#PART_DropDownButton">
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronHover}" />
  </Style>

  <Style Selector="ComboBox.app-input.settings-input:disabled /template/ ToggleButton#PART_DropDownButton, UserControl.settings-page ComboBox.app-input:disabled /template/ ToggleButton#PART_DropDownButton">
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronDisabled}" />
  </Style>

  <Style Selector="ComboBox.app-input.settings-input /template/ PathIcon#DropDownGlyph, UserControl.settings-page ComboBox.app-input /template/ PathIcon#DropDownGlyph">
    <Setter Property="Width" Value="{DynamicResource MAA.App.Size.SettingsInputChevronWidth}" />
    <Setter Property="Height" Value="{DynamicResource MAA.App.Size.SettingsInputChevronHeight}" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.Chevron}" />
  </Style>

  <Style Selector="ComboBox.app-input.settings-input:pointerover /template/ PathIcon#DropDownGlyph, UserControl.settings-page ComboBox.app-input:pointerover /template/ PathIcon#DropDownGlyph">
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronHover}" />
  </Style>

  <Style Selector="ComboBox.app-input.settings-input:disabled /template/ PathIcon#DropDownGlyph, UserControl.settings-page ComboBox.app-input:disabled /template/ PathIcon#DropDownGlyph">
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronDisabled}" />
  </Style>

  <Style Selector="ComboBox.app-input.settings-input /template/ Path#DropDownGlyph, UserControl.settings-page ComboBox.app-input /template/ Path#DropDownGlyph">
    <Setter Property="Width" Value="{DynamicResource MAA.App.Size.SettingsInputChevronWidth}" />
    <Setter Property="Height" Value="{DynamicResource MAA.App.Size.SettingsInputChevronHeight}" />
    <Setter Property="Margin" Value="0" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Stroke" Value="{DynamicResource MAA.Brush.App.SettingsInput.Chevron}" />
    <Setter Property="Fill" Value="Transparent" />
    <Setter Property="Stretch" Value="Uniform" />
    <Setter Property="StrokeThickness" Value="1.4" />
    <Setter Property="StrokeLineCap" Value="Round" />
  </Style>

  <Style Selector="ComboBox.app-input.settings-input:pointerover /template/ Path#DropDownGlyph, UserControl.settings-page ComboBox.app-input:pointerover /template/ Path#DropDownGlyph">
    <Setter Property="Stroke" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronHover}" />
  </Style>

  <Style Selector="ComboBox.app-input.settings-input:disabled /template/ Path#DropDownGlyph, UserControl.settings-page ComboBox.app-input:disabled /template/ Path#DropDownGlyph">
    <Setter Property="Stroke" Value="{DynamicResource MAA.Brush.App.SettingsInput.ChevronDisabled}" />
  </Style>

  <Style Selector="ComboBox.app-input.settings-input /template/ Popup#PART_Popup, UserControl.settings-page ComboBox.app-input /template/ Popup#PART_Popup">
    <Setter Property="WindowManagerAddShadowHint" Value="False" />
    <Setter Property="VerticalOffset" Value="4" />
  </Style>

  <Style Selector="ComboBox.app-input.settings-input /template/ Border#PopupBorder, UserControl.settings-page ComboBox.app-input /template/ Border#PopupBorder">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.PopupBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.SettingsInput.PopupBorder}" />
