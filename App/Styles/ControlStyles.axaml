    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Wpf.TaskStatus.Running}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.Wpf.TaskStatus.Running}" />
  </Style>

  <Style Selector="Border.wpf-card.status-success">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Wpf.TaskStatus.Success}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.Wpf.TaskStatus.Success}" />
  </Style>

  <Style Selector="Border.wpf-card.status-error">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Wpf.TaskStatus.Error}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.Wpf.TaskStatus.Error}" />
  </Style>

  <Style Selector="Border.wpf-card.status-skipped">
    <Setter Property="Opacity" Value="0.55" />
  </Style>

  <Style Selector="Border.wpf-card.status-idle">
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="TextBlock.section-title">
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="{DynamicResource MAA.FontSize.SectionTitle}" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Text.Primary}" />
    <Setter Property="Margin" Value="{DynamicResource MAA.Thickness.SectionTitleMargin}" />
  </Style>

  <Style Selector="TextBlock.dialog-window-title">
