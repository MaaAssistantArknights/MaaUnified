  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Surface.Window}" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Text.Primary}" />
    <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI, sans-serif" />
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Text.Primary}" />
  </Style>

  <Style Selector="TextBlock.subtle">
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Text.Secondary}" />
  </Style>

  <Style Selector="TextBlock.muted">
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Text.Muted}" />
  </Style>

  <Style Selector="Border.wpf-panel">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Wpf.Region25}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
    <Setter Property="CornerRadius" Value="{DynamicResource MAA.CornerRadius.Section}" />
    <Setter Property="Padding" Value="{DynamicResource MAA.Thickness.SectionPadding}" />
  </Style>

  <Style Selector="Border.wpf-panel.wpf-panel-plain">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="Padding" Value="8,0" />
  </Style>

  <Style Selector="Border.wpf-panel.wpf-panel-strong">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Wpf.Region75}" />
    <Setter Property="CornerRadius" Value="{DynamicResource MAA.CornerRadius.SectionStrong}" />
    <Setter Property="Padding" Value="{DynamicResource MAA.Thickness.SectionPaddingStrong}" />
  </Style>

  <Style Selector="Border.wpf-panel.wpf-panel-warning">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Surface.Warning}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.State.Warning}" />
  </Style>

  <Style Selector="Border.wpf-card">
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
    <Setter Property="CornerRadius" Value="{DynamicResource MAA.CornerRadius.Item}" />
    <Setter Property="Padding" Value="{DynamicResource MAA.Thickness.ItemPadding}" />
    <Setter Property="Margin" Value="{DynamicResource MAA.Thickness.MarginItemVertical}" />
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Wpf.Region25}" />
  </Style>

  <Style Selector="Border.wpf-card.wpf-card-compact">
    <Setter Property="Padding" Value="{DynamicResource MAA.Thickness.ItemCompactPadding}" />
    <Setter Property="MinHeight" Value="{DynamicResource MAA.Size.TaskQueue.RowHeight}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.wpf-card.task-row-card">
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="BorderBrush" Value="Transparent" />
  </Style>

  <Style Selector="Border.wpf-card.status-running">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Wpf.TaskStatus.Running}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.Wpf.TaskStatus.Running}" />
  </Style>

  <Style Selector="Border.wpf-card.status-success">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Wpf.TaskStatus.Success}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.Wpf.TaskStatus.Success}" />
  </Style>

  <Style Selector="Border.wpf-card.status-error">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Wpf.TaskStatus.Error}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.Wpf.TaskStatus.Error}" />
  </Style>

  <Style Selector="Border.wpf-card.status-skipped">
    <Setter Property="Opacity" Value="0.55" />
  </Style>

  <Style Selector="Border.wpf-card.status-idle">
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="TextBlock.section-title">
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="FontSize" Value="{DynamicResource MAA.FontSize.SectionTitle}" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Text.Primary}" />
    <Setter Property="Margin" Value="{DynamicResource MAA.Thickness.SectionTitleMargin}" />
  </Style>

  <Style Selector="TextBlock.long-wrap">
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="TextBlock.long-ellipsis">
    <Setter Property="TextWrapping" Value="NoWrap" />
    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
  </Style>

  <Style Selector="TextBlock.state-warning">
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.State.Warning}" />
  </Style>

  <Style Selector="TextBlock.state-error">
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.State.Error}" />
  </Style>

  <Style Selector="TextBlock.state-success">
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.State.Success}" />
  </Style>

  <Style Selector="Border.achievement-toast">
    <Setter Property="Width" Value="360" />
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Toast.AchievementBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.Toast.AchievementBorder}" />
    <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
    <Setter Property="CornerRadius" Value="18" />
    <Setter Property="ClipToBounds" Value="True" />
  </Style>

  <Style Selector="Border.achievement-toast-badge">
    <Setter Property="Padding" Value="10,4" />
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Toast.AchievementBadgeBackground}" />
    <Setter Property="CornerRadius" Value="999" />
    <Setter Property="HorizontalAlignment" Value="Left" />
  </Style>

  <Style Selector="TextBlock.achievement-toast-badge-text">
    <Setter Property="FontSize" Value="11" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Toast.AchievementBadgeForeground}" />
  </Style>

  <Style Selector="Border.achievement-toast-medal-shell">
    <Setter Property="Width" Value="44" />
    <Setter Property="Height" Value="44" />
    <Setter Property="CornerRadius" Value="22" />
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Toast.AchievementMedalSurface}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.Toast.AchievementMedalBorder}" />
    <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="HorizontalAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.achievement-toast-medal-core">
    <Setter Property="Width" Value="28" />
    <Setter Property="Height" Value="28" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.achievement-toast-medal-glyph">
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="Foreground" Value="#FFFFFFFF" />
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="TextAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.achievement-toast-title">
    <Setter Property="FontSize" Value="15.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Text.Primary}" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TextBlock.achievement-toast-description">
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Text.Secondary}" />
    <Setter Property="TextWrapping" Value="Wrap" />
    <Setter Property="LineHeight" Value="20" />
    <Setter Property="TextAlignment" Value="Left" />
  </Style>

  <Style Selector="Button.achievement-toast-close">
    <Setter Property="Width" Value="28" />
    <Setter Property="Height" Value="28" />
    <Setter Property="MinWidth" Value="28" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="CornerRadius" Value="14" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Toast.AchievementCloseForeground}" />
    <Setter Property="FontSize" Value="14" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
  </Style>

  <Style Selector="Button.achievement-toast-close:pointerover">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Toast.AchievementCloseHoverBackground}" />
  </Style>

  <Style Selector="Button.achievement-toast-close:pressed">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Toast.AchievementClosePressedBackground}" />
  </Style>

  <Style Selector="Border.modern-dialog-shell">
