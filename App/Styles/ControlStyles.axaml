    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
    <Setter Property="CornerRadius" Value="{DynamicResource MAA.CornerRadius.Section}" />
