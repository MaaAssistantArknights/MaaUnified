    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.Wpf.TaskStatus.Running}" />
  </Style>

  <Style Selector="Border.item-card.status-success">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Wpf.TaskStatus.Success}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.Wpf.TaskStatus.Success}" />
  </Style>

  <Style Selector="Border.item-card.status-error">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Wpf.TaskStatus.Error}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.Wpf.TaskStatus.Error}" />
  </Style>

  <Style Selector="Border.item-card.status-skipped">
    <Setter Property="Opacity" Value="0.55" />
  </Style>

  <Style Selector="Border.item-card.status-idle">
    <Setter Property="Opacity" Value="1" />
  </Style>

  <Style Selector="Button.action">
    <Setter Property="MinWidth" Value="{DynamicResource MAA.Size.Action.MinWidth}" />
    <Setter Property="Height" Value="{DynamicResource MAA.Size.Action.Height}" />
    <Setter Property="Padding" Value="{DynamicResource MAA.Thickness.ActionPadding}" />
    <Setter Property="CornerRadius" Value="{DynamicResource MAA.CornerRadius.Action}" />
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Action.SecondaryBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.Action.SecondaryBorder}" />
    <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Action.SecondaryForeground}" />
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="Button.action.action-primary">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Action.PrimaryBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.Action.PrimaryBorder}" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Action.PrimaryForeground}" />
  </Style>

  <Style Selector="Button.action.action-secondary">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Action.SecondaryBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.Action.SecondaryBorder}" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Action.SecondaryForeground}" />
  </Style>

  <Style Selector="Button.action.action-subtle">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Action.SubtleBackground}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.Action.SubtleBorder}" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Action.SubtleForeground}" />
  </Style>

  <Style Selector="Button.action.compact">
    <Setter Property="MinWidth" Value="{DynamicResource MAA.Size.Action.CompactMinWidth}" />
    <Setter Property="Height" Value="{DynamicResource MAA.Size.Action.Height}" />
    <Setter Property="Padding" Value="{DynamicResource MAA.Thickness.ActionCompactPadding}" />
    <Setter Property="FontSize" Value="{DynamicResource MAA.FontSize.ActionCompact}" />
  </Style>

  <Style Selector="Button.action.icon-only">
    <Setter Property="MinWidth" Value="{DynamicResource MAA.Size.Action.IconMinWidth}" />
    <Setter Property="Padding" Value="{DynamicResource MAA.Thickness.ActionIconPadding}" />
  </Style>

  <Style Selector="ListBox.task-queue-list ListBoxItem:selected Border.item-card">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Wpf.TaskRowSelected}" />
  </Style>

  <Style Selector="TabControl.root-nav TabItem">
    <Setter Property="Padding" Value="{DynamicResource MAA.Thickness.RootNavTabPadding}" />
    <Setter Property="MinHeight" Value="{DynamicResource MAA.Size.Tab.MinHeight}" />
    <Setter Property="FontSize" Value="{DynamicResource MAA.FontSize.SectionTitle}" />
  </Style>

  <Style Selector="TabControl.root-nav TabItem:selected">
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TabStrip.root-nav TabStripItem">
    <Setter Property="Padding" Value="{DynamicResource MAA.Thickness.RootNavTabPadding}" />
    <Setter Property="MinHeight" Value="{DynamicResource MAA.Size.Tab.MinHeight}" />
    <Setter Property="FontSize" Value="{DynamicResource MAA.FontSize.SectionTitle}" />
  </Style>

  <Style Selector="TabStrip.root-nav TabStripItem:selected">
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TabControl.copilot-nav TabItem">
    <Setter Property="Padding" Value="{DynamicResource MAA.Thickness.CopilotNavTabPadding}" />
    <Setter Property="MinHeight" Value="{DynamicResource MAA.Size.Tab.MinHeight}" />
    <Setter Property="FontSize" Value="{DynamicResource MAA.FontSize.CopilotNavTab}" />
  </Style>

  <Style Selector="TabControl.copilot-nav TabItem:selected">
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>

  <Style Selector="TabControl.toolbox-nav TabItem">
    <Setter Property="Padding" Value="{DynamicResource MAA.Thickness.ToolboxNavTabPadding}" />
    <Setter Property="MinHeight" Value="{DynamicResource MAA.Size.Tab.MinHeight}" />
    <Setter Property="FontSize" Value="{DynamicResource MAA.FontSize.SectionTitle}" />
  </Style>

  <Style Selector="TabControl.toolbox-nav TabItem:selected">
    <Setter Property="FontWeight" Value="SemiBold" />
  </Style>
</Styles>
