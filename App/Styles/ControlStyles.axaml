    <!-- OperBox card width calculation:
         padding 24 + rarity strip 4 + left content margin 12 + profession 48
         + column gap 12 + status row max width (elite 30 + gap 3 + ~28 for Lv.90 + gap 3 + potential 25)
         ~= 189. Keep the card at 206 and the slot at 214 so AdaptiveWrapPanel
         can preserve 16px gaps without letting neighboring cards visually collide. -->
    <x:Double x:Key="MAA.Size.Toolbox.OperBoxCardMinWidth">206</x:Double>
    <x:Double x:Key="MAA.Size.Toolbox.OperBoxCardMinHeight">108</x:Double>
    <x:Double x:Key="MAA.Size.Toolbox.OperBoxBadgeIcon">24</x:Double>
