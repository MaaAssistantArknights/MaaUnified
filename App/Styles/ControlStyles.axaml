  <Style Selector="TabStrip.root-nav">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Template">
      <ControlTemplate>
        <Grid ClipToBounds="True">
          <ItemsPresenter Name="PART_ItemsPresenter"
                          ItemsPanel="{TemplateBinding ItemsPanel}" />
          <controls:AppSelectionIndicatorPresenter Classes="selection-indicator-nav"
                                                  Target="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                  Orientation="Horizontal"
                                                  LeadingInset="10"
                                                  TrailingInset="10"
                                                  MinimumLength="{DynamicResource MAA.Size.NavIndicator.MinLength}" />
        </Grid>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="TabStrip.copilot-nav">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Template">
      <ControlTemplate>
        <Grid ClipToBounds="True">
          <ItemsPresenter Name="PART_ItemsPresenter"
                          ItemsPanel="{TemplateBinding ItemsPanel}" />
          <controls:AppSelectionIndicatorPresenter Classes="selection-indicator-nav"
                                                  Target="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                  Orientation="Horizontal"
                                                  LeadingInset="10"
                                                  TrailingInset="10"
                                                  MinimumLength="{DynamicResource MAA.Size.NavIndicator.MinLength}" />
        </Grid>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="TabControl.toolbox-nav">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Template">
      <ControlTemplate>
        <Grid RowDefinitions="Auto,*"
              ClipToBounds="True">
          <Grid Grid.Row="0"
                ClipToBounds="True">
            <ItemsPresenter Name="PART_ItemsPresenter"
                            ItemsPanel="{TemplateBinding ItemsPanel}" />
            <controls:AppSelectionIndicatorPresenter Classes="selection-indicator-nav"
                                                    Target="{Binding RelativeSource={RelativeSource TemplatedParent}}"
                                                    Orientation="Horizontal"
                                                    LeadingInset="10"
                                                    TrailingInset="10"
                                                    MinimumLength="{DynamicResource MAA.Size.NavIndicator.MinLength}" />
          </Grid>

          <ScrollViewer Grid.Row="1"
                        Classes="toolbox-nav-content-scroll"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Auto">
            <ContentPresenter x:Name="PART_SelectedContentHost"
                              Margin="{DynamicResource MAA.Thickness.ToolboxNavContentMargin}"
                              Content="{TemplateBinding SelectedContent}"
                              ContentTemplate="{TemplateBinding SelectedContentTemplate}"
                              HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                              VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}" />
          </ScrollViewer>
        </Grid>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="ScrollViewer.toolbox-nav-content-scroll">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="controls|AppSelectionIndicatorPresenter.selection-indicator-nav.indicator-horizontal /template/ Border#PART_IndicatorGlow">
    <Setter Property="Width" Value="{DynamicResource MAA.Size.NavIndicator.MinLength}" />
    <Setter Property="Height" Value="{DynamicResource MAA.Size.NavIndicator.Thickness}" />
    <Setter Property="Margin" Value="0,0,0,3" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="VerticalAlignment" Value="Top" />
    <Setter Property="Opacity" Value="0" />
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Action.PrimaryBackground}" />
    <Setter Property="Transitions">
      <Transitions>
        <ThicknessTransition Property="Margin"
                             Duration="0:0:0.14"
                             Easing="CubicEaseOut" />
        <DoubleTransition Property="Width"
                          Duration="0:0:0.12"
                          Easing="CubicEaseOut" />
        <DoubleTransition Property="Height"
                          Duration="0:0:0.12"
                          Easing="CubicEaseOut" />
      </Transitions>
    </Setter>
  </Style>

  <Style Selector="controls|AppSelectionIndicatorPresenter.selection-indicator-nav.indicator-horizontal /template/ Border#PART_Indicator">
    <Setter Property="Width" Value="{DynamicResource MAA.Size.NavIndicator.MinLength}" />
    <Setter Property="Height" Value="{DynamicResource MAA.Size.NavIndicator.Thickness}" />
    <Setter Property="Margin" Value="0,0,0,3" />
    <Setter Property="HorizontalAlignment" Value="Left" />
    <Setter Property="VerticalAlignment" Value="Top" />
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Action.PrimaryBackground}" />
    <Setter Property="Transitions">
      <Transitions>
        <ThicknessTransition Property="Margin"
                             Duration="0:0:0.13"
                             Easing="CubicEaseOut" />
        <DoubleTransition Property="Width"
                          Duration="0:0:0.11"
                          Easing="CubicEaseOut" />
        <DoubleTransition Property="Height"
                          Duration="0:0:0.11"
                          Easing="CubicEaseOut" />
      </Transitions>
    </Setter>
  </Style>

  <Style Selector="TabStrip.root-nav TabStripItem">
    <Setter Property="Padding" Value="{DynamicResource MAA.Thickness.RootNavTabPadding}" />
    <Setter Property="Height" Value="{DynamicResource MAA.Size.RootNavTab.Height}" />
    <Setter Property="MinHeight" Value="{DynamicResource MAA.Size.Tab.MinHeight}" />
    <Setter Property="FontSize" Value="{DynamicResource MAA.FontSize.RootNavTab}" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Secondary}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border x:Name="PART_NavChrome"
                Background="Transparent"
                CornerRadius="10"
                Height="{DynamicResource MAA.Size.RootNavTab.Height}">
          <TextBlock Margin="{TemplateBinding Padding}"
                     Height="{DynamicResource MAA.LineHeight.RootNavTab}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"
                     FontSize="{DynamicResource MAA.FontSize.RootNavTab}"
                     FontWeight="{TemplateBinding FontWeight}"
                     Foreground="{TemplateBinding Foreground}"
                     LineHeight="{DynamicResource MAA.LineHeight.RootNavTab}"
                     MaxLines="1"
                     Text="{TemplateBinding Content}"
                     TextWrapping="NoWrap" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="TabStrip.root-nav TabStripItem TextBlock">
    <Setter Property="LineHeight" Value="{DynamicResource MAA.LineHeight.RootNavTab}" />
    <Setter Property="TextWrapping" Value="NoWrap" />
    <Setter Property="MaxLines" Value="1" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="TabStrip.root-nav TabStripItem:selected">
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
  </Style>

  <Style Selector="TabStrip.root-nav TabStripItem:pointerover">
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
  </Style>

  <Style Selector="TabStrip.root-nav TabStripItem:pointerover /template/ Border#PART_NavChrome">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="TabStrip.root-nav TabStripItem:pressed /template/ Border#PART_NavChrome">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="TabStrip.root-nav TabStripItem:selected /template/ Border#PART_NavChrome">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="TabStrip.root-nav TabStripItem /template/ Border#PART_NavChrome">
    <!-- Navigation underline motion is a design contract. Keep these hover/press transitions aligned with it. -->
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background"
                         Duration="0:0:0.11" />
      </Transitions>
    </Setter>
  </Style>

  <Style Selector="TabStrip.copilot-nav TabStripItem">
    <Setter Property="Padding" Value="{DynamicResource MAA.Thickness.CopilotNavTabPadding}" />
    <Setter Property="MinHeight" Value="{DynamicResource MAA.Size.Tab.MinHeight}" />
    <Setter Property="FontSize" Value="{DynamicResource MAA.FontSize.CopilotNavTab}" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Secondary}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border x:Name="PART_NavChrome"
                Background="Transparent"
                CornerRadius="10">
          <ContentPresenter Margin="{TemplateBinding Padding}"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="TabStrip.copilot-nav TabStripItem:selected">
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
  </Style>

  <Style Selector="TabStrip.copilot-nav TabStripItem:pointerover">
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
  </Style>

  <Style Selector="TabStrip.copilot-nav TabStripItem:pointerover /template/ Border#PART_NavChrome">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="TabStrip.copilot-nav TabStripItem:pressed /template/ Border#PART_NavChrome">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="TabStrip.copilot-nav TabStripItem:selected /template/ Border#PART_NavChrome">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="TabStrip.copilot-nav TabStripItem /template/ Border#PART_NavChrome">
    <!-- Navigation underline motion is a design contract. Keep these hover/press transitions aligned with it. -->
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background"
                         Duration="0:0:0.11" />
      </Transitions>
    </Setter>
  </Style>

  <Style Selector="TabControl.toolbox-nav TabItem">
    <Setter Property="Padding" Value="{DynamicResource MAA.Thickness.ToolboxNavTabPadding}" />
    <Setter Property="MinHeight" Value="{DynamicResource MAA.Size.Tab.MinHeight}" />
    <Setter Property="FontSize" Value="{DynamicResource MAA.FontSize.SectionTitle}" />
    <Setter Property="FontWeight" Value="Medium" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Secondary}" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Template">
      <ControlTemplate>
        <Border x:Name="PART_NavChrome"
                Background="Transparent"
                CornerRadius="10">
          <ContentPresenter Margin="{TemplateBinding Padding}"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Content="{TemplateBinding Header}"
                            ContentTemplate="{TemplateBinding HeaderTemplate}" />
        </Border>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="TabControl.toolbox-nav TabItem:selected">
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
  </Style>

  <Style Selector="TabControl.toolbox-nav TabItem:pointerover">
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Primary}" />
  </Style>

  <Style Selector="TabControl.toolbox-nav TabItem:pointerover /template/ Border#PART_NavChrome">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="TabControl.toolbox-nav TabItem:pressed /template/ Border#PART_NavChrome">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="TabControl.toolbox-nav TabItem:selected /template/ Border#PART_NavChrome">
    <Setter Property="Background" Value="Transparent" />
  </Style>

  <Style Selector="TabControl.toolbox-nav TabItem /template/ Border#PART_NavChrome">
    <!-- Navigation underline motion is a design contract. Keep these hover/press transitions aligned with it. -->
    <Setter Property="Transitions">
      <Transitions>
        <BrushTransition Property="Background"
                         Duration="0:0:0.11" />
      </Transitions>
    </Setter>
  </Style>
</Styles>
