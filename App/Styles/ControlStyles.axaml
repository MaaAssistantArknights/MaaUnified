  <Style Selector="Border.wpf-card">
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.Border.Default}" />
    <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
    <Setter Property="CornerRadius" Value="{DynamicResource MAA.CornerRadius.Item}" />
    <Setter Property="Padding" Value="{DynamicResource MAA.Thickness.ItemPadding}" />
    <Setter Property="Margin" Value="{DynamicResource MAA.Thickness.MarginItemVertical}" />
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Wpf.Region25}" />
  </Style>

  <Style Selector="Border.wpf-card.wpf-card-compact">
    <Setter Property="Padding" Value="{DynamicResource MAA.Thickness.ItemCompactPadding}" />
    <Setter Property="MinHeight" Value="{DynamicResource MAA.Size.TaskQueue.RowHeight}" />
    <Setter Property="VerticalAlignment" Value="Center" />
  </Style>

  <Style Selector="Border.wpf-card.task-row-card">
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="BorderBrush" Value="Transparent" />
