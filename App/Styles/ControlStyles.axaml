  <Style Selector="Window">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Surface.Window}" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Text.Primary}" />
    <Setter Property="FontFamily" Value="{DynamicResource MAA.FontFamily.UI}" />
  </Style>

  <Style Selector="TextBlock">
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Text.Primary}" />
    <Setter Property="FontFamily" Value="{DynamicResource MAA.FontFamily.UI}" />
  </Style>

  <Style Selector="TemplatedControl">
    <Setter Property="FontFamily" Value="{DynamicResource MAA.FontFamily.UI}" />
  </Style>

  <Style Selector="ContentPresenter">
    <Setter Property="FontFamily" Value="{DynamicResource MAA.FontFamily.UI}" />
  </Style>

  <Style Selector="TextPresenter">
    <Setter Property="documents:TextElement.FontFamily" Value="{DynamicResource MAA.FontFamily.UI}" />
  </Style>

  <Style Selector="ToolTip TemplatedControl">
    <Setter Property="FontFamily" Value="{DynamicResource MAA.FontFamily.UI}" />
  </Style>

  <Style Selector="ToolTip">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="ClipToBounds" Value="False" />
    <Setter Property="Transitions">
      <Transitions>
        <DoubleTransition Property="Opacity"
                          Duration="0:0:0.12" />
      </Transitions>
    </Setter>
  </Style>

  <Style Selector="ToolTip ContentPresenter">
    <Setter Property="FontFamily" Value="{DynamicResource MAA.FontFamily.UI}" />
    <Setter Property="ClipToBounds" Value="False" />
  </Style>

  <Style Selector="ToolTip TextPresenter">
    <Setter Property="documents:TextElement.FontFamily" Value="{DynamicResource MAA.FontFamily.UI}" />
  </Style>

  <Style Selector="ToolTip TextBlock">
    <Setter Property="FontFamily" Value="{DynamicResource MAA.FontFamily.UI}" />
  </Style>

  <Style Selector="Border.app-tooltip-card">
    <Setter Property="MaxWidth" Value="340" />
    <Setter Property="Padding" Value="12,9" />
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.Dialog.CardSurface}" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.Badge}" />
    <Setter Property="BoxShadow" Value="{DynamicResource MAA.App.BoxShadow.Card}" />
    <Setter Property="ClipToBounds" Value="False" />
  </Style>

  <Style Selector="TextBlock.app-tooltip-card-text">
    <Setter Property="MaxWidth" Value="316" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Text.Primary}" />
    <Setter Property="TextWrapping" Value="Wrap" />
  </Style>

  <Style Selector="Popup TemplatedControl">
    <Setter Property="FontFamily" Value="{DynamicResource MAA.FontFamily.UI}" />
  </Style>

  <Style Selector="Popup ContentPresenter">
    <Setter Property="FontFamily" Value="{DynamicResource MAA.FontFamily.UI}" />
  </Style>

  <Style Selector="Popup TextPresenter">
    <Setter Property="documents:TextElement.FontFamily" Value="{DynamicResource MAA.FontFamily.UI}" />
  </Style>

  <Style Selector="Popup TextBlock">
    <Setter Property="FontFamily" Value="{DynamicResource MAA.FontFamily.UI}" />
  </Style>

  <Style Selector="Popup">
    <Setter Property="controls:PopupUiScale.UseTopLevelUiScale" Value="True" />
  </Style>

  <Style Selector="TextBlock.subtle">
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.Text.Secondary}" />
