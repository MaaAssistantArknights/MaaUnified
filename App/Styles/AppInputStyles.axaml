    <Setter Property="Width" Value="{DynamicResource MAA.App.Size.SettingsDropdownDeleteButtonSize}" />
    <Setter Property="MinWidth" Value="{DynamicResource MAA.App.Size.SettingsDropdownDeleteButtonSize}" />
