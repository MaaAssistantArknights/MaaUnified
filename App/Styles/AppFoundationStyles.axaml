  <Style Selector="Button.app-button.app-slider-chip">
    <Setter Property="Height" Value="36" />
    <Setter Property="MinWidth" Value="{DynamicResource MAA.App.Size.ChipMinWidth}" />
    <Setter Property="Padding" Value="16,0" />
    <Setter Property="CornerRadius" Value="18" />
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Secondary}" />
    <Setter Property="FontSize" Value="12.5" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="HorizontalContentAlignment" Value="Center" />
    <Setter Property="VerticalContentAlignment" Value="Center" />
    <Setter Property="Template">
      <ControlTemplate>
        <Panel Background="Transparent">
          <TextBlock x:Name="PART_SliderChipText"
                     Margin="{TemplateBinding Padding}"
                     HorizontalAlignment="Stretch"
                     VerticalAlignment="Center"
                     FontSize="{TemplateBinding FontSize}"
                     FontWeight="{TemplateBinding FontWeight}"
                     Text="{TemplateBinding Content}"
                     TextAlignment="Center"
                     TextWrapping="NoWrap" />
        </Panel>
      </ControlTemplate>
    </Setter>
  </Style>

