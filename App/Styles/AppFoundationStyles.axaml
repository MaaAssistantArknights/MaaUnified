<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MAAUnified.App.Controls">
  <Styles.Resources>
    <CornerRadius x:Key="MAA.App.CornerRadius.Window">24</CornerRadius>
    <CornerRadius x:Key="MAA.App.CornerRadius.Section">18</CornerRadius>
    <CornerRadius x:Key="MAA.App.CornerRadius.Card">18</CornerRadius>
    <CornerRadius x:Key="MAA.App.CornerRadius.Button">21</CornerRadius>
    <CornerRadius x:Key="MAA.App.CornerRadius.Chip">17</CornerRadius>
    <CornerRadius x:Key="MAA.App.CornerRadius.IconButton">19</CornerRadius>
    <CornerRadius x:Key="MAA.App.CornerRadius.Input">14</CornerRadius>
    <CornerRadius x:Key="MAA.App.CornerRadius.SearchInput">19</CornerRadius>
    <CornerRadius x:Key="MAA.App.CornerRadius.Badge">14</CornerRadius>
    <CornerRadius x:Key="MAA.App.CornerRadius.Checkbox">7</CornerRadius>
    <CornerRadius x:Key="MAA.App.CornerRadius.SettingsInput">8</CornerRadius>

    <BoxShadows x:Key="MAA.App.BoxShadow.Card">0 3 8 0 #0C000000, 0 2 4 -3 #12000000, 0 6 16 4 #08000000</BoxShadows>

    <Thickness x:Key="MAA.App.Thickness.FramePadding">20</Thickness>
    <Thickness x:Key="MAA.App.Thickness.SectionPadding">16</Thickness>
    <Thickness x:Key="MAA.App.Thickness.CardPadding">16</Thickness>
    <Thickness x:Key="MAA.App.Thickness.ButtonPadding">18,0</Thickness>
    <Thickness x:Key="MAA.App.Thickness.ChipPadding">14,0</Thickness>
    <Thickness x:Key="MAA.App.Thickness.InputPadding">14,0</Thickness>
    <Thickness x:Key="MAA.App.Thickness.InputBlockPadding">14,12</Thickness>
    <Thickness x:Key="MAA.App.Thickness.BadgePadding">10,4</Thickness>

    <x:Double x:Key="MAA.App.Size.ButtonMinWidth">104</x:Double>
    <x:Double x:Key="MAA.App.Size.ButtonHeight">42</x:Double>
    <x:Double x:Key="MAA.App.Size.ChipMinWidth">72</x:Double>
    <x:Double x:Key="MAA.App.Size.ChipHeight">34</x:Double>
    <x:Double x:Key="MAA.App.Size.IconButton">38</x:Double>
    <x:Double x:Key="MAA.App.Size.InputHeight">38</x:Double>
    <x:Double x:Key="MAA.App.Size.InputBlockMinHeight">120</x:Double>
    <x:Double x:Key="MAA.App.Size.SearchInputMinWidth">220</x:Double>
    <x:Double x:Key="MAA.App.Size.CompactEmptyTextMaxWidth">340</x:Double>

    <SolidColorBrush x:Key="MAA.Brush.App.Surface.Window" Color="{DynamicResource MAA.Color.Dialog.Surface}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Surface.Section" Color="{DynamicResource MAA.Color.Dialog.Section}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Surface.Card" Color="{DynamicResource MAA.Color.Dialog.CardSurface}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Border.Window" Color="{DynamicResource MAA.Color.Dialog.Border}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Border.Section" Color="{DynamicResource MAA.Color.Dialog.SectionBorder}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Border.Card" Color="{DynamicResource MAA.Color.Dialog.CardBorder}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Text.Primary" Color="{DynamicResource MAA.Color.Text.Primary}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Text.Secondary" Color="{DynamicResource MAA.Color.Text.Secondary}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Text.Muted" Color="{DynamicResource MAA.Color.Text.Muted}" />
    <SolidColorBrush x:Key="MAA.Brush.App.State.Warning" Color="{DynamicResource MAA.Color.State.Warning}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Surface.Warning" Color="{DynamicResource MAA.Color.Surface.Warning}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Action.PrimaryBackground" Color="{DynamicResource MAA.Color.Action.PrimaryBackground}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Action.PrimaryBackgroundHover" Color="{DynamicResource MAA.Color.Action.PrimaryBackgroundHover}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Action.PrimaryBackgroundPressed" Color="{DynamicResource MAA.Color.Action.PrimaryBackgroundPressed}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Action.PrimaryBackgroundDisabled" Color="{DynamicResource MAA.Color.Action.PrimaryBackgroundDisabled}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Action.PrimaryBorder" Color="{DynamicResource MAA.Color.Action.PrimaryBorder}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Action.PrimaryForeground" Color="{DynamicResource MAA.Color.Action.PrimaryForeground}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Action.ButtonPrimaryBackground" Color="{DynamicResource MAA.Color.Action.ButtonPrimaryBackground}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Action.ButtonPrimaryBackgroundHover" Color="{DynamicResource MAA.Color.Action.ButtonPrimaryBackgroundHover}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Action.ButtonPrimaryBackgroundPressed" Color="{DynamicResource MAA.Color.Action.ButtonPrimaryBackgroundPressed}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Action.ButtonPrimaryBorder" Color="{DynamicResource MAA.Color.Action.ButtonPrimaryBorder}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Action.SecondaryBackground" Color="{DynamicResource MAA.Color.Dialog.Section}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Action.SecondaryBackgroundHover" Color="{DynamicResource MAA.Color.Action.SecondaryBackgroundHover}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Action.SecondaryBackgroundPressed" Color="{DynamicResource MAA.Color.Action.SecondaryBackgroundPressed}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Action.SecondaryBorder" Color="{DynamicResource MAA.Color.Dialog.SectionBorder}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Action.SecondaryForeground" Color="{DynamicResource MAA.Color.Text.Secondary}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Action.SubtleBackground" Color="{DynamicResource MAA.Color.Action.SubtleBackground}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Action.SubtleBackgroundHover" Color="{DynamicResource MAA.Color.Action.SubtleBackgroundHover}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Action.SubtleBackgroundPressed" Color="{DynamicResource MAA.Color.Action.SubtleBackgroundPressed}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Action.SubtleForeground" Color="{DynamicResource MAA.Color.Action.SubtleForeground}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Action.DisabledBackground" Color="{DynamicResource MAA.Color.Action.BackgroundDisabled}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Action.DisabledBorder" Color="{DynamicResource MAA.Color.Action.Border}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Action.DisabledForeground" Color="{DynamicResource MAA.Color.Action.ForegroundDisabled}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Selection.Background" Color="{DynamicResource MAA.Color.Dialog.FilterChipSelectedBackground}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Selection.Border" Color="{DynamicResource MAA.Color.Dialog.FilterChipSelectedBorder}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Selection.Foreground" Color="{DynamicResource MAA.Color.Dialog.FilterChipSelectedForeground}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Chip.Background" Color="{DynamicResource MAA.Color.Dialog.FilterChipBackground}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Chip.Border" Color="{DynamicResource MAA.Color.Dialog.FilterChipBorder}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Chip.Foreground" Color="{DynamicResource MAA.Color.Dialog.FilterChipForeground}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Close.Foreground" Color="{DynamicResource MAA.Color.Dialog.CloseForeground}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Close.HoverBackground" Color="{DynamicResource MAA.Color.Dialog.CloseHoverBackground}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Close.PressedBackground" Color="{DynamicResource MAA.Color.Dialog.ClosePressedBackground}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Input.Background" Color="{DynamicResource MAA.Color.Dialog.CardSurface}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Input.Border" Color="{DynamicResource MAA.Color.Dialog.FilterChipBorder}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Input.BorderHover" Color="{DynamicResource MAA.Color.Action.SecondaryBorder}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Input.BorderFocus" Color="{DynamicResource MAA.Color.Action.PrimaryBorder}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Input.BackgroundDisabled" Color="{DynamicResource MAA.Color.Action.BackgroundDisabled}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Input.ForegroundDisabled" Color="{DynamicResource MAA.Color.Action.ForegroundDisabled}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Input.PopupBackground" Color="{DynamicResource MAA.Color.Dialog.Section}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Input.PopupBorder" Color="{DynamicResource MAA.Color.Dialog.SectionBorder}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Input.ItemBackgroundHover" Color="{DynamicResource MAA.Color.Action.SecondaryBackgroundHover}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Input.ItemBackgroundSelected" Color="{DynamicResource MAA.Color.Dialog.FilterChipSelectedBackground}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Input.ItemBorderSelected" Color="{DynamicResource MAA.Color.Dialog.FilterChipSelectedBorder}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Input.ItemForegroundSelected" Color="{DynamicResource MAA.Color.Dialog.FilterChipSelectedForeground}" />
    <Thickness x:Key="MAA.App.Thickness.InputPopupPadding">8</Thickness>
    <Thickness x:Key="MAA.App.Thickness.InputItemPadding">12,9</Thickness>
    <x:Double x:Key="MAA.App.Size.InputPopupMaxHeight">280</x:Double>
    <CornerRadius x:Key="MAA.App.CornerRadius.SettingsInputPopup">8</CornerRadius>
    <Thickness x:Key="MAA.App.Thickness.SettingsInputPadding">14,0</Thickness>
    <Thickness x:Key="MAA.App.Thickness.SettingsInputShellPadding">14,0,0,0</Thickness>
    <Thickness x:Key="MAA.App.Thickness.SettingsInputPopupPadding">6</Thickness>
    <Thickness x:Key="MAA.App.Thickness.SettingsInputItemPadding">11,7</Thickness>
    <x:Double x:Key="MAA.App.Size.SettingsInputDropDownButtonWidth">26</x:Double>
    <x:Double x:Key="MAA.App.Size.SettingsSpinStepperWidth">26</x:Double>
    <x:Double x:Key="MAA.App.Size.SettingsInputChevronWidth">10</x:Double>
    <x:Double x:Key="MAA.App.Size.SettingsInputChevronHeight">5</x:Double>
    <GridLength x:Key="MAA.App.Layout.SettingsInputDropDownButtonColumnWidth">26</GridLength>
    <SolidColorBrush x:Key="MAA.Brush.App.SettingsInput.Background" Color="{DynamicResource MAA.Color.Dialog.Surface}" />
    <SolidColorBrush x:Key="MAA.Brush.App.SettingsInput.Border" Color="{DynamicResource MAA.Color.Dialog.SectionBorder}" />
    <SolidColorBrush x:Key="MAA.Brush.App.SettingsInput.BorderHover" Color="{DynamicResource MAA.Color.Action.SecondaryBorder}" />
    <SolidColorBrush x:Key="MAA.Brush.App.SettingsInput.BorderFocus" Color="{DynamicResource MAA.Color.Action.PrimaryBorder}" />
    <SolidColorBrush x:Key="MAA.Brush.App.SettingsInput.BackgroundDisabled" Color="{DynamicResource MAA.Color.Action.BackgroundDisabled}" />
    <SolidColorBrush x:Key="MAA.Brush.App.SettingsInput.Foreground" Color="{DynamicResource MAA.Color.Text.Primary}" />
    <SolidColorBrush x:Key="MAA.Brush.App.SettingsInput.ForegroundDisabled" Color="{DynamicResource MAA.Color.Action.ForegroundDisabled}" />
    <SolidColorBrush x:Key="MAA.Brush.App.SettingsInput.Chevron" Color="{DynamicResource MAA.Color.Text.Muted}" />
    <SolidColorBrush x:Key="MAA.Brush.App.SettingsInput.ChevronHover" Color="{DynamicResource MAA.Color.Text.Secondary}" />
    <SolidColorBrush x:Key="MAA.Brush.App.SettingsInput.ChevronDisabled" Color="{DynamicResource MAA.Color.Action.ForegroundDisabled}" />
    <SolidColorBrush x:Key="MAA.Brush.App.SettingsInput.PopupBackground" Color="{DynamicResource MAA.Color.Dialog.Surface}" />
    <SolidColorBrush x:Key="MAA.Brush.App.SettingsInput.PopupBorder" Color="{DynamicResource MAA.Color.Dialog.SectionBorder}" />
    <SolidColorBrush x:Key="MAA.Brush.App.SettingsInput.PopupScrollViewerBackground" Color="{DynamicResource MAA.Color.Dialog.Surface}" />
    <SolidColorBrush x:Key="MAA.Brush.App.SettingsInput.ItemForeground" Color="{DynamicResource MAA.Color.Text.Secondary}" />
    <SolidColorBrush x:Key="MAA.Brush.App.SettingsInput.ItemForegroundHover" Color="{DynamicResource MAA.Color.Text.Primary}" />
    <SolidColorBrush x:Key="MAA.Brush.App.SettingsInput.ItemForegroundSelected" Color="{DynamicResource MAA.Color.Dialog.FilterChipSelectedForeground}" />
    <SolidColorBrush x:Key="MAA.Brush.App.SettingsInput.ItemForegroundDisabled" Color="{DynamicResource MAA.Color.Action.ForegroundDisabled}" />
    <SolidColorBrush x:Key="MAA.Brush.App.SettingsInput.ItemBackgroundHover" Color="{DynamicResource MAA.Color.Action.SecondaryBackgroundHover}" />
    <SolidColorBrush x:Key="MAA.Brush.App.SettingsInput.ItemBackgroundSelected" Color="{DynamicResource MAA.Color.Dialog.FilterChipSelectedBackground}" />
    <SolidColorBrush x:Key="MAA.Brush.App.SettingsInput.ItemBorderSelected" Color="{DynamicResource MAA.Color.Dialog.FilterChipSelectedBorder}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Badge.Background" Color="{DynamicResource MAA.Color.Dialog.FilterChipSelectedBackground}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Badge.Border" Color="{DynamicResource MAA.Color.Dialog.FilterChipSelectedBorder}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Badge.Foreground" Color="{DynamicResource MAA.Color.Dialog.FilterChipSelectedForeground}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Checkbox.Background" Color="{DynamicResource MAA.Color.Dialog.CardSurface}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Checkbox.Border" Color="{DynamicResource MAA.Color.Dialog.FilterChipBorder}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Checkbox.BackgroundHover" Color="{DynamicResource MAA.Color.Action.SecondaryBackgroundHover}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Checkbox.BackgroundPressed" Color="{DynamicResource MAA.Color.Action.SecondaryBackgroundPressed}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Checkbox.BackgroundChecked" Color="{DynamicResource MAA.Color.Action.PrimaryBackground}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Checkbox.BackgroundCheckedHover" Color="{DynamicResource MAA.Color.Action.PrimaryBackgroundHover}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Checkbox.BorderChecked" Color="{DynamicResource MAA.Color.Action.PrimaryBorder}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Checkbox.Glyph" Color="{DynamicResource MAA.Color.Action.PrimaryForeground}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Checkbox.Focus" Color="{DynamicResource MAA.Color.Action.PrimaryBorder}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Checkbox.DisabledBackground" Color="{DynamicResource MAA.Color.Action.BackgroundDisabled}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Checkbox.DisabledBorder" Color="{DynamicResource MAA.Color.Action.Border}" />
    <SolidColorBrush x:Key="MAA.Brush.App.Checkbox.DisabledForeground" Color="{DynamicResource MAA.Color.Action.ForegroundDisabled}" />
  </Styles.Resources>

  <Style Selector="controls|AppWindowFrame">
    <Setter Property="UseLayoutRounding" Value="True" />
    <Setter Property="Template">
      <ControlTemplate>
        <Grid UseLayoutRounding="True">
          <Border x:Name="PART_FrameSurface"
                  Margin="{TemplateBinding ShellMargin}"
                  UseLayoutRounding="True"
                  Classes="app-surface app-window">
            <Grid RowDefinitions="Auto,Auto,*,Auto">
              <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel x:Name="PART_LeftWindowControls"
                            Orientation="Horizontal"
                            Spacing="6"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Top">
                  <Button x:Name="PART_LeftCloseButton"
                          Classes="app-button app-subtle app-icon-only app-window-control app-window-close"
                          VerticalAlignment="Top"
                          IsVisible="{TemplateBinding ShowCloseButton}">
                    <Button.Content>
                      <Path Width="8.5"
                            Height="8.5"
                            Data="M1 1 L7.5 7.5 M7.5 1 L1 7.5"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Stretch="Fill"
                            Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            StrokeThickness="1.35"
                            StrokeLineCap="Round" />
                    </Button.Content>
                  </Button>
                  <Button x:Name="PART_LeftMinimizeButton"
                          Classes="app-button app-subtle app-icon-only app-window-control app-window-minimize"
                          VerticalAlignment="Top"
                          IsVisible="{TemplateBinding ShowMinimizeButton}">
                    <Button.Content>
                      <Border Width="9"
                              Height="1.35"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              CornerRadius="999" />
                    </Button.Content>
                  </Button>
                  <Button x:Name="PART_LeftMaximizeButton"
                          Classes="app-button app-subtle app-icon-only app-window-control app-window-maximize"
                          VerticalAlignment="Top"
                          IsVisible="{TemplateBinding ShowMaximizeButton}">
                    <Button.Content>
                      <Grid Width="8.5"
                            Height="8.5">
                        <Path Classes="app-window-maximize-icon-normal"
                              Data="M2 2 H8 V8 H2 Z"
                              Stretch="Fill"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.1" />
                        <Path Classes="app-window-maximize-icon-restore"
                              Data="M2 4 H6 V8 H2 Z M4 2 H8 V6"
                              Stretch="Fill"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.1" />
                      </Grid>
                    </Button.Content>
                  </Button>
                </StackPanel>

                <Border x:Name="PART_HeaderDragArea"
                        Grid.Column="1"
                        IsHitTestVisible="{TemplateBinding AllowsHeaderDrag}"
                        Background="Transparent">
                  <TextBlock Classes="app-window-title dialog-window-title"
                             Text="{TemplateBinding Title}" />
                </Border>

                <StackPanel x:Name="PART_RightWindowControls"
                            Grid.Column="2"
                            Orientation="Horizontal"
                            Spacing="6"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Top">
                  <Button x:Name="PART_RightMinimizeButton"
                          Classes="app-button app-subtle app-icon-only app-window-control app-window-minimize"
                          VerticalAlignment="Top"
                          IsVisible="{TemplateBinding ShowMinimizeButton}">
                    <Button.Content>
                      <Border Width="9"
                              Height="1.35"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              Background="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              CornerRadius="999" />
                    </Button.Content>
                  </Button>
                  <Button x:Name="PART_RightMaximizeButton"
                          Classes="app-button app-subtle app-icon-only app-window-control app-window-maximize"
                          VerticalAlignment="Top"
                          IsVisible="{TemplateBinding ShowMaximizeButton}">
                    <Button.Content>
                      <Grid Width="8.5"
                            Height="8.5">
                        <Path Classes="app-window-maximize-icon-normal"
                              Data="M2 2 H8 V8 H2 Z"
                              Stretch="Fill"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.1" />
                        <Path Classes="app-window-maximize-icon-restore"
                              Data="M2 4 H6 V8 H2 Z M4 2 H8 V6"
                              Stretch="Fill"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="1.1" />
                      </Grid>
                    </Button.Content>
                  </Button>
                  <Button x:Name="PART_RightCloseButton"
                          Classes="app-button app-subtle app-icon-only app-window-control app-window-close"
                          VerticalAlignment="Top"
                          IsVisible="{TemplateBinding ShowCloseButton}">
                    <Button.Content>
                      <Path Width="8.5"
                            Height="8.5"
                            Data="M1 1 L7.5 7.5 M7.5 1 L1 7.5"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Stretch="Fill"
                            Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                            StrokeThickness="1.35"
                            StrokeLineCap="Round" />
                    </Button.Content>
                  </Button>
                </StackPanel>
              </Grid>

              <ContentPresenter Grid.Row="1"
                                Margin="0,6,0,0"
                                IsVisible="{TemplateBinding HasHeaderContent}"
                                Content="{TemplateBinding HeaderContent}" />

              <ContentPresenter Grid.Row="2"
                                Margin="0,16,0,0"
                                Content="{TemplateBinding Content}" />

              <ContentPresenter Grid.Row="3"
                                Margin="0,20,0,0"
                                IsVisible="{TemplateBinding HasActions}"
                                HorizontalAlignment="Right"
                                Content="{TemplateBinding ActionsContent}" />
            </Grid>
          </Border>

          <Grid Margin="{TemplateBinding ShellMargin}"
                UseLayoutRounding="True"
                IsVisible="{TemplateBinding ShowsResizeGrips}"
                ZIndex="10">
            <Border x:Name="PART_ResizeNorth"
                    Height="14"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Top"
                    Background="Transparent" />
            <Border x:Name="PART_ResizeSouth"
                    Height="14"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Bottom"
                    Background="Transparent" />
            <Border x:Name="PART_ResizeWest"
                    Width="14"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Stretch"
                    Background="Transparent" />
            <Border x:Name="PART_ResizeEast"
                    Width="14"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Background="Transparent" />
            <Border x:Name="PART_ResizeNorthWest"
                    Width="24"
                    Height="24"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="Transparent"
                    ZIndex="1" />
            <Border x:Name="PART_ResizeNorthEast"
                    Width="24"
                    Height="24"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="Transparent"
                    ZIndex="1" />
            <Border x:Name="PART_ResizeSouthWest"
                    Width="24"
                    Height="24"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Background="Transparent"
                    ZIndex="1" />
            <Border x:Name="PART_ResizeSouthEast"
                    Width="24"
                    Height="24"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Background="Transparent"
                    ZIndex="1" />
          </Grid>
        </Grid>
      </ControlTemplate>
    </Setter>
  </Style>

  <Style Selector="controls|AppWindowFrame /template/ StackPanel#PART_LeftWindowControls">
    <Setter Property="IsVisible" Value="False" />
  </Style>

  <Style Selector="controls|AppWindowFrame /template/ StackPanel#PART_RightWindowControls">
    <Setter Property="IsVisible" Value="True" />
  </Style>

  <Style Selector="controls|AppWindowFrame:controls-left /template/ StackPanel#PART_LeftWindowControls">
    <Setter Property="IsVisible" Value="True" />
  </Style>

  <Style Selector="controls|AppWindowFrame:controls-left /template/ StackPanel#PART_RightWindowControls">
    <Setter Property="IsVisible" Value="False" />
  </Style>

  <Style Selector="controls|AppWindowFrame /template/ Path.app-window-maximize-icon-restore">
    <Setter Property="IsVisible" Value="False" />
  </Style>

  <Style Selector="controls|AppWindowFrame /template/ Border#PART_FrameSurface">
    <Setter Property="BoxShadow" Value="0 0 24 0 #29000000" />
  </Style>

  <Style Selector="controls|AppWindowFrame:window-maximized /template/ Path.app-window-maximize-icon-normal">
    <Setter Property="IsVisible" Value="False" />
  </Style>

  <Style Selector="controls|AppWindowFrame:window-maximized /template/ Path.app-window-maximize-icon-restore">
    <Setter Property="IsVisible" Value="True" />
  </Style>

  <Style Selector="controls|AppWindowFrame:window-maximized">
    <Setter Property="ShellMargin" Value="0" />
  </Style>

  <Style Selector="controls|AppWindowFrame:window-maximized /template/ Border#PART_FrameSurface">
    <Setter Property="CornerRadius" Value="0" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="BoxShadow" Value="0 0 0 0 #00000000" />
  </Style>

  <Style Selector="Border.app-surface.app-window">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Surface.Window}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Border.Window}" />
    <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
    <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.Window}" />
    <Setter Property="Padding" Value="{DynamicResource MAA.App.Thickness.FramePadding}" />
  </Style>

  <Style Selector="Border.app-surface.app-section">
    <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Surface.Section}" />
    <Setter Property="BorderBrush" Value="{DynamicResource MAA.Brush.App.Border.Section}" />
    <Setter Property="BorderThickness" Value="{DynamicResource MAA.BorderThickness.Thin}" />
    <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.Section}" />
    <Setter Property="Padding" Value="{DynamicResource MAA.App.Thickness.SectionPadding}" />
  </Style>

  <Style Selector="UserControl.task-queue-page Border.app-surface.app-section">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderBrush" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="CornerRadius" Value="0" />
  </Style>

  <Style Selector="UserControl.copilot-page Border.app-surface.app-section">
