<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:MAAUnified.App.Views"
        x:Class="MAAUnified.App.Views.TrayContextMenuWindow"
        Background="Transparent"
        CanResize="False"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ShowInTaskbar="False"
        SystemDecorations="None"
        WindowStartupLocation="Manual"
        Topmost="True">
  <Window.Styles>
    <Style Selector="Border.tray-context-menu-panel">
      <Setter Property="MinWidth" Value="{DynamicResource MAA.App.Interaction.FloatingMenuMinWidth}" />
      <Setter Property="Padding" Value="{DynamicResource MAA.App.Interaction.FloatingMenuPadding}" />
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Surface.Card}" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.Interaction.FloatingMenuCornerRadius}" />
      <Setter Property="BoxShadow" Value="{DynamicResource MAA.App.BoxShadow.Card}" />
      <Setter Property="ClipToBounds" Value="False" />
    </Style>
    <Style Selector="ItemsControl.tray-context-menu-list">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ItemsControl.tray-context-menu-list ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="ItemsControl.tray-context-menu-list ContentPresenter /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Padding" Value="0" />
    </Style>
    <Style Selector="ItemsControl.tray-context-menu-list ContentPresenter:pointerover">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ItemsControl.tray-context-menu-list ContentPresenter:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="Border.tray-context-menu-item-shell">
      <Setter Property="MinHeight" Value="{DynamicResource MAA.App.Interaction.FloatingMenuItemMinHeight}" />
      <Setter Property="Padding" Value="{DynamicResource MAA.App.Interaction.FloatingMenuItemPadding}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.Interaction.FloatingMenuItemCornerRadius}" />
      <Setter Property="Cursor" Value="Hand" />
    </Style>
    <Style Selector="Border.tray-context-menu-item-shell:pointerover">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.SettingsInput.ItemBackgroundHover}" />
      <Setter Property="BorderBrush" Value="Transparent" />
    </Style>
    <Style Selector="Border.tray-context-menu-item-shell:disabled">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="Cursor" Value="Arrow" />
      <Setter Property="Opacity" Value="0.64" />
    </Style>
    <Style Selector="TextBlock.tray-context-menu-item-text">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Secondary}" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="LineHeight" Value="18" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.tray-context-menu-item-shell:pointerover TextBlock.tray-context-menu-item-text">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.SettingsInput.ItemForegroundHover}" />
    </Style>
    <Style Selector="Border.tray-context-menu-item-shell:disabled TextBlock.tray-context-menu-item-text">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Action.DisabledForeground}" />
    </Style>
    <Style Selector="Border.tray-context-menu-separator">
      <Setter Property="Height" Value="1" />
      <Setter Property="Margin" Value="8,6" />
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.App.Border.Section}" />
      <Setter Property="Opacity" Value="0.72" />
    </Style>
  </Window.Styles>

  <Window.DataTemplates>
    <DataTemplate DataType="local:TrayContextMenuItemEntry">
      <Border Classes="tray-context-menu-item-shell"
              IsEnabled="{Binding IsEnabled}"
              Tag="{Binding}"
              PointerPressed="OnMenuItemPointerPressed">
        <TextBlock Classes="tray-context-menu-item-text"
                   Text="{Binding Header}" />
      </Border>
    </DataTemplate>
    <DataTemplate DataType="local:TrayContextMenuSeparatorEntry">
      <Border Classes="tray-context-menu-separator" />
    </DataTemplate>
  </Window.DataTemplates>

  <Border Classes="tray-context-menu-panel">
    <ItemsControl x:Name="MenuItemsHost"
                  Classes="tray-context-menu-list" />
  </Border>
</Window>
