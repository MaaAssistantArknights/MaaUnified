<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MAAUnified.App.ViewModels.Infrastructure"
        xmlns:taskVm="clr-namespace:MAAUnified.App.ViewModels.TaskQueue"
        x:Class="MAAUnified.App.Views.OverlayHostWindow"
        x:DataType="vm:OverlayPresentationViewModel">
  <Window.Styles>
    <Style Selector="Border#OverlayPanel">
      <Setter Property="CornerRadius" Value="{DynamicResource MAA.App.CornerRadius.Card}" />
      <Setter Property="Background">
        <Setter.Value>
          <SolidColorBrush Color="{DynamicResource MAA.Color.Dialog.CardSurface}"
                           Opacity="0.68" />
        </Setter.Value>
      </Setter>
      <Setter Property="BorderBrush">
        <Setter.Value>
          <SolidColorBrush Color="{DynamicResource MAA.Color.Dialog.CardBorder}"
                           Opacity="0.58" />
        </Setter.Value>
      </Setter>
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="14,12" />
      <Setter Property="ClipToBounds" Value="True" />
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowDirectionEffect BlurRadius="24"
                                     ShadowDepth="4"
                                     Opacity="0.22"
                                     Color="Black" />
        </Setter.Value>
      </Setter>
    </Style>
    <Style Selector="TextBlock.overlay-log-time">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Muted}" />
      <Setter Property="LineHeight" Value="20" />
      <Setter Property="VerticalAlignment" Value="Top" />
      <Setter Property="TextWrapping" Value="NoWrap" />
    </Style>
    <Style Selector="TextBlock.overlay-log-content">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.App.Text.Secondary}" />
      <Setter Property="TextWrapping" Value="Wrap" />
      <Setter Property="LineHeight" Value="20" />
      <Setter Property="VerticalAlignment" Value="Top" />
    </Style>
    <Style Selector="TextBlock.overlay-log-content.state-warning">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.State.Warning}" />
    </Style>
    <Style Selector="TextBlock.overlay-log-content.state-error">
      <Setter Property="Foreground" Value="{DynamicResource MAA.Brush.State.Error}" />
    </Style>
  </Window.Styles>

  <Window.DataTemplates>
    <DataTemplate DataType="taskVm:TaskQueueLogEntryViewModel">
      <Grid Classes="overlay-log-entry"
            ColumnDefinitions="Auto,*">
        <TextBlock Classes="overlay-log-time"
                   IsVisible="{Binding HasTime}"
                   Text="{Binding Time}" />
        <TextBlock Grid.Column="1"
                   Classes="overlay-log-content"
                   Classes.state-error="{Binding IsError}"
                   Classes.state-warning="{Binding IsWarning}"
                   Margin="10,0,0,0"
                   Text="{Binding Content}" />
      </Grid>
    </DataTemplate>
  </Window.DataTemplates>

  <Grid IsHitTestVisible="False">
    <Border x:Name="OverlayPanel"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Margin="8"
            MaxWidth="440">
      <ScrollViewer x:Name="OverlayScroller"
                    HorizontalScrollBarVisibility="Disabled"
                    VerticalScrollBarVisibility="Hidden">
        <ItemsControl ItemsSource="{Binding CurrentLogs}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Spacing="4" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
        </ItemsControl>
      </ScrollViewer>
    </Border>
  </Grid>
</Window>
