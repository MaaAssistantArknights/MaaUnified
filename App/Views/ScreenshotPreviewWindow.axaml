<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:MAAUnified.App.Controls"
        x:Class="MAAUnified.App.Views.ScreenshotPreviewWindow"
        Width="800"
        Height="480"
        MinWidth="480"
        MinHeight="320"
        CanResize="True"
        Background="Transparent"
        SystemDecorations="None"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        WindowStartupLocation="CenterOwner"
        Title="Screenshot Preview">
  <controls:AppWindowFrame x:Name="DialogShell"
                           Title="Screenshot Preview"
                           Mode="ResizableDialog"
                           CapWindowHeightToOwner="True"
                           CloseRequested="OnShellCloseRequested">
    <controls:AppWindowFrame.HeaderContent>
      <TextBlock x:Name="PreviewHeaderText"
                 Classes="app-window-subtitle dialog-window-subtitle long-wrap"
                 IsVisible="False"
                 Text="" />
    </controls:AppWindowFrame.HeaderContent>
    <controls:AppWindowFrame.Content>
      <Grid RowDefinitions="Auto,*">
        <Border Classes="app-surface app-section">
          <StackPanel Spacing="6">
            <TextBlock x:Name="PreviewSectionTitleText"
                       Classes="section-title"
                       Text="Screenshot Preview" />
            <TextBlock x:Name="PreviewStatusText"
                       Classes="long-wrap subtle"
                       IsVisible="False"
                       Text="" />
          </StackPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="{DynamicResource MAA.Thickness.MarginTopSection}"
                Classes="app-surface app-card">
          <Border Background="#10151D"
                  Padding="16">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
              <Image x:Name="PreviewImage"
                     Stretch="Uniform" />
            </ScrollViewer>
          </Border>
        </Border>
      </Grid>
    </controls:AppWindowFrame.Content>
    <controls:AppWindowFrame.ActionsContent>
      <Button x:Name="CloseActionButton"
              Classes="app-button app-primary"
              Content="Close"
              Click="OnCloseClick" />
    </controls:AppWindowFrame.ActionsContent>
  </controls:AppWindowFrame>
</Window>
