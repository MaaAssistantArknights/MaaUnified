<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:viewModels="clr-namespace:MAAUnified.App.ViewModels"
        xmlns:rootViews="clr-namespace:MAAUnified.App.Features.Root"
        xmlns:advancedViews="clr-namespace:MAAUnified.App.Features.Advanced"
        xmlns:taskVm="clr-namespace:MAAUnified.App.ViewModels.TaskQueue"
        xmlns:copilotVm="clr-namespace:MAAUnified.App.ViewModels.Copilot"
        xmlns:toolboxVm="clr-namespace:MAAUnified.App.ViewModels.Toolbox"
        xmlns:settingsVm="clr-namespace:MAAUnified.App.ViewModels.Settings"
        mc:Ignorable="d"
        x:Class="MAAUnified.App.Views.MainWindow"
        Width="{DynamicResource MAA.Size.MainWindow.Width}"
        Height="{DynamicResource MAA.Size.MainWindow.Height}"
        MinWidth="{DynamicResource MAA.Size.MainWindow.MinWidth}"
        MinHeight="{DynamicResource MAA.Size.MainWindow.MinHeight}"
        Title="{Binding WindowTitle}"
        Topmost="{Binding IsWindowTopMost}">
  <Window.DataTemplates>
    <DataTemplate DataType="viewModels:RootPageHostViewModel">
      <Border Classes="wpf-panel">
        <Grid RowDefinitions="Auto,Auto,Auto,*">
          <TextBlock Classes="section-title"
                     HorizontalAlignment="Center"
                     Text="{Binding StatusTitle}" />
          <ProgressBar Grid.Row="1"
                       Width="{DynamicResource MAA.Size.TaskQueue.PostActionSummaryWidth}"
                       Margin="{DynamicResource MAA.Thickness.MarginTopSection}"
                       HorizontalAlignment="Center"
                       IsIndeterminate="True"
                       IsVisible="{Binding IsLoading}" />
          <TextBlock Grid.Row="2"
                     Width="{DynamicResource MAA.Size.TaskQueue.PostActionSummaryWidth}"
                     Margin="{DynamicResource MAA.Thickness.MarginTopSection}"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"
                     Classes="long-wrap subtle"
                     Text="{Binding StatusMessage}" />
          <TextBlock Grid.Row="3"
                     Width="{DynamicResource MAA.Size.TaskQueue.ConfigPanelWidth}"
                     Margin="{DynamicResource MAA.Thickness.MarginTopSection}"
                     HorizontalAlignment="Center"
                     TextAlignment="Center"
                     Classes="long-wrap state-error"
                     Text="{Binding ErrorMessage}"
                     IsVisible="{Binding HasErrorMessage}" />
        </Grid>
      </Border>
    </DataTemplate>
    <DataTemplate DataType="taskVm:TaskQueuePageViewModel">
      <rootViews:TaskQueueView />
    </DataTemplate>
    <DataTemplate DataType="copilotVm:CopilotPageViewModel">
      <advancedViews:CopilotView />
    </DataTemplate>
    <DataTemplate DataType="toolboxVm:ToolboxPageViewModel">
      <advancedViews:ToolboxView />
    </DataTemplate>
    <DataTemplate DataType="settingsVm:SettingsPageViewModel">
      <rootViews:SettingsView />
    </DataTemplate>
    <DataTemplate DataType="viewModels:AchievementToastItemViewModel">
      <Border Classes="achievement-toast"
              Margin="0,0,0,10">
        <Border.Effect>
          <DropShadowDirectionEffect BlurRadius="18"
                                     ShadowDepth="4"
                                     Opacity="0.16"
                                     Color="Black" />
        </Border.Effect>
        <Grid ColumnDefinitions="6,*">
          <Border Background="{Binding MedalColor}" />
          <Border Grid.Column="1"
                  Padding="14,12,12,12">
            <Grid ColumnDefinitions="Auto,*"
                  RowDefinitions="Auto,Auto">
              <Border Grid.RowSpan="2"
                      Margin="0,0,14,0"
                      Classes="achievement-toast-medal-shell">
                <Border Classes="achievement-toast-medal-core"
                        Background="{Binding MedalColor}">
                  <TextBlock Classes="achievement-toast-medal-glyph"
                             Text="★" />
                </Border>
              </Border>
              <Grid Grid.Column="1"
                    ColumnDefinitions="*,Auto"
                    VerticalAlignment="Top">
                <Border VerticalAlignment="Center"
                        Classes="achievement-toast-badge">
                  <TextBlock Classes="achievement-toast-badge-text"
                             Text="{Binding CelebrateText}" />
                </Border>
                <Button Grid.Column="1"
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        Classes="achievement-toast-close"
                        Content="✕"
                        Tag="{Binding Id}"
                        Click="OnDismissAchievementToastClick" />
              </Grid>
              <StackPanel Grid.Row="1"
                          Grid.Column="1"
                          Margin="0,10,0,0"
                          Spacing="6">
                <TextBlock Classes="achievement-toast-title"
                           Text="{Binding Title}" />
                <TextBlock Classes="achievement-toast-description"
                           Text="{Binding Description}" />
              </StackPanel>
            </Grid>
          </Border>
        </Grid>
      </Border>
    </DataTemplate>
  </Window.DataTemplates>
  <Window.Styles>
    <Style Selector="Button.wpf-button.window-overlay-toggle">
      <Setter Property="MinWidth" Value="96" />
      <Setter Property="Height" Value="32" />
      <Setter Property="Padding" Value="10,0" />
    </Style>
    <Style Selector="Border.overlay-indicator">
      <Setter Property="Width" Value="10" />
      <Setter Property="Height" Value="10" />
      <Setter Property="CornerRadius" Value="999" />
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.Text.Secondary}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style Selector="Border.overlay-indicator.mode-preview">
      <Setter Property="Background" Value="#D9A441" />
    </Style>
    <Style Selector="Border.overlay-indicator.mode-native">
      <Setter Property="Background" Value="#4FA86C" />
    </Style>
    <Style Selector="Border.overlay-indicator.mode-hidden">
      <Setter Property="Background" Value="{DynamicResource MAA.Brush.Text.Secondary}" />
    </Style>
  </Window.Styles>
  <Grid x:Name="ShellRoot"
        Margin="{DynamicResource MAA.Thickness.PageMargin}">
    <Image
           Source="{Binding ShellBackgroundImage}"
           Opacity="{Binding ShellBackgroundOpacity}"
           Stretch="{Binding ShellBackgroundStretch}"
           IsVisible="{Binding HasShellBackgroundImage}"
           IsHitTestVisible="False">
      <Image.Effect>
        <BlurEffect Radius="{Binding ShellBackgroundBlur}" />
      </Image.Effect>
    </Image>

    <Grid RowDefinitions="Auto,*"
          Width="{DynamicResource MAA.Size.MainWindow.LayoutWidth}"
          MaxWidth="{DynamicResource MAA.Size.MainWindow.ContentMaxWidth}"
          HorizontalAlignment="Center">
      <TabStrip Classes="root-nav"
                SelectedIndex="{Binding SelectedRootTabIndex}">
        <TabStripItem Content="{Binding TaskQueueTabTitle}" />
        <TabStripItem Content="{Binding CopilotTabTitle}" />
        <TabStripItem Content="{Binding ToolboxTabTitle}" />
        <TabStripItem Content="{Binding SettingsTabTitle}" />
      </TabStrip>

      <Grid Grid.Row="1">
        <ContentControl Content="{Binding TaskQueueRootPage.PageContent}"
                        IsVisible="{Binding IsTaskQueueRootTabSelected}" />
        <ContentControl Content="{Binding CopilotRootPage.PageContent}"
                        IsVisible="{Binding IsCopilotRootTabSelected}" />
        <ContentControl Content="{Binding ToolboxRootPage.PageContent}"
                        IsVisible="{Binding IsToolboxRootTabSelected}" />
        <ContentControl Content="{Binding SettingsRootPage.PageContent}"
                        IsVisible="{Binding IsSettingsRootTabSelected}" />
      </Grid>
    </Grid>

    <StackPanel HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Margin="0,5,5,0"
                Spacing="8">
      <Button Classes="wpf-button wpf-button-secondary window-overlay-toggle"
              HorizontalAlignment="Right"
              IsVisible="{Binding ShowWindowOverlayButton}"
              ToolTip.Tip="{Binding TaskQueuePage.OverlayButtonToolTip}"
              Click="OnWindowOverlayToggleClick"
              PointerPressed="OnWindowOverlayButtonPointerPressed">
        <StackPanel Orientation="Horizontal"
                    Spacing="{DynamicResource MAA.Spacing.Tight}">
          <Border Classes="overlay-indicator"
                  Classes.mode-hidden="{Binding TaskQueuePage.IsOverlayHiddenMode}"
                  Classes.mode-preview="{Binding TaskQueuePage.IsOverlayPreviewMode}"
                  Classes.mode-native="{Binding TaskQueuePage.IsOverlayNativeMode}" />
          <TextBlock Text="{Binding TaskQueuePage.OverlayButtonText}" />
        </StackPanel>
      </Button>
      <ItemsControl ItemsSource="{Binding AchievementToasts}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <StackPanel Spacing="0" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
      </ItemsControl>
    </StackPanel>
  </Grid>
</Window>
